---
---

<footer class="bg-surface-footer border-t border-border-dark pt-16 pb-8">
  <div class="mx-auto max-w-7xl px-4 lg:px-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <div class="flex flex-col gap-4">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/logo.svg" alt="FlySky Guitar Logo" class="flysky-global-logo h-8 w-auto" />
          <h2 class="text-white text-lg font-bold" data-setting="flysky_storeName">FlySky Guitar</h2>
        </a>
        <p class="text-text-muted text-sm leading-relaxed flex items-start gap-2 mt-2">
          <span class="material-symbols-outlined text-[18px] shrink-0 mt-0.5">location_on</span>
          <span data-setting="flysky_storeAddress">37 Lê Thiện Trị, Phường Ngũ Hành Sơn, Thành phố Đà Nẵng, Da Nang, Vietnam</span>
        </p>
      </div>
      <div>
        <h4 class="text-white font-bold mb-4">Cửa hàng</h4>
        <ul class="flex flex-col gap-2 text-text-muted text-sm">
          <li><a class="hover:text-primary transition-colors" href="/search?q=Guitar%20%C4%90i%E1%BB%87n">Guitar Điện</a></li>
          <li><a class="hover:text-primary transition-colors" href="/search?q=Guitar%20Acoustic">Guitar Acoustic</a></li>
          <li><a class="hover:text-primary transition-colors" href="/search?q=Guitar%20Bass">Guitar Bass</a></li>
          <li><a class="hover:text-primary transition-colors" href="/search?q=Ph%E1%BB%A5%20ki%E1%BB%87n">Phụ kiện</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold mb-4">Hỗ trợ</h4>
        <ul class="flex flex-col gap-2 text-text-muted text-sm">
          <li><a class="hover:text-primary transition-colors" href="/blog" data-setting="flysky_supportWarrantyUrl">Thông tin bảo hành</a></li>
          <li><a class="hover:text-primary transition-colors" href="/payment" data-setting="flysky_supportShippingReturnUrl">Giao hàng &amp; Trả hàng</a></li>
          <li><a class="hover:text-primary transition-colors" href="/blog" data-setting="flysky_supportCareGuideUrl">Hướng dẫn bảo quản</a></li>
          <li><a class="hover:text-primary transition-colors" href="/contact">Liên hệ chúng tôi</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold mb-4">Đăng ký nhận tin</h4>
        <p class="text-text-muted text-sm mb-4">Đăng ký để nhận thông tin về các mẫu mới nhất và tiêu điểm nghệ sĩ.</p>
        <form class="flex gap-2" id="footer-newsletter-form">
          <input required type="email" name="email" class="bg-card-dark border border-border-dark text-white text-sm rounded-lg px-4 py-2 w-full focus:ring-1 focus:ring-primary focus:border-primary outline-none" placeholder="Email của bạn" />
          <button type="submit" class="bg-primary hover:bg-primary/90 text-background-dark font-bold rounded-lg px-4 transition-colors cursor-pointer">
            <span class="material-symbols-outlined">send</span>
          </button>
        </form>
        <div id="footer-newsletter-notice" class="hidden mt-2 rounded-lg px-3 py-2 text-xs"></div>
      </div>
    </div>
    <div class="border-t border-border-dark pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-text-muted text-sm text-center md:text-left">© 2026 <span data-setting="flysky_storeName">FlySky Guitar</span>. Bảo lưu mọi quyền.</p>
      <div class="flex gap-4">
        <a class="text-text-muted hover:text-white transition-colors" href="#" data-setting="flysky_facebookUrl"><span class="sr-only">Facebook</span>FB</a>
        <a class="text-text-muted hover:text-white transition-colors" href="#" data-setting="flysky_instagramUrl"><span class="sr-only">Instagram</span>IG</a>
        <a class="text-text-muted hover:text-white transition-colors" href="#" data-setting="flysky_tiktokUrl"><span class="sr-only">TikTok</span>TT</a>
        <a class="text-text-muted hover:text-white transition-colors" href="#" data-setting="flysky_youtubeUrl"><span class="sr-only">YouTube</span>YT</a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('footer-newsletter-form');
    if (!form) return;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const emailInput = form.querySelector('input[name="email"]');
      const submitBtn = form.querySelector('button[type="submit"]');
      const notice = document.getElementById('footer-newsletter-notice');
      if (!emailInput || !submitBtn) return;

      const email = emailInput.value.trim();
      if (!email) return;

      function showNotice(msg, ok) {
        if (!notice) return;
        notice.textContent = msg;
        notice.className = 'mt-2 rounded-lg px-3 py-2 text-xs ' + (ok
          ? 'bg-green-500/10 border border-green-500/30 text-green-400'
          : 'bg-red-500/10 border border-red-500/30 text-red-400');
        notice.classList.remove('hidden');
        setTimeout(() => notice.classList.add('hidden'), 4000);
      }

      const oldHtml = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="material-symbols-outlined">sync</span>';

      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();

        if (!res.ok || !data?.success) {
          showNotice(data?.error || 'Không thể đăng ký bản tin. Vui lòng thử lại.', false);
        } else if (data.state === 'already_active') {
          showNotice('Email này đã đăng ký bản tin trước đó rồi.', false);
        } else {
          showNotice('Cảm ơn bạn đã đăng ký nhận bản tin!', true);
          form.reset();
        }
      } catch {
        showNotice('Không thể kết nối máy chủ. Vui lòng thử lại sau.', false);
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = oldHtml;
      }
    });
  });
</script>
