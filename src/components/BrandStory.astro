---
import { supabase } from '../lib/supabase';

interface Props {
  isAdmin?: boolean;
}

const { isAdmin = false } = Astro.props;

const { data: rows } = await supabase.from('site_settings').select('key, value')
  .in('key', [
    'flysky_brand_section_tag','flysky_brand_title1','flysky_brand_title2','flysky_brand_desc',
    'flysky_brand_feat1_title','flysky_brand_feat1_desc',
    'flysky_brand_feat2_title','flysky_brand_feat2_desc',
    'flysky_brand_image','flysky_brand_images',
  ]);
const s: Record<string,string> = {};
(rows || []).forEach((r: any) => { s[r.key] = r.value ?? ''; });
const g = (k: string, d: string) => s[k] || d;

const sectionTag  = g('flysky_brand_section_tag', 'Quy trình của chúng tôi');
const title1      = g('flysky_brand_title1', 'Sinh ra từ gỗ.');
const title2      = g('flysky_brand_title2', 'Chế tác cho âm sắc.');
const desc        = g('flysky_brand_desc', 'Mỗi cây đàn FlySky đều bắt đầu từ một mảnh gỗ âm sắc được tuyển chọn kỹ lưỡng. Các nghệ nhân bậc thầy của chúng tôi kết hợp kỹ thuật truyền thống hàng thế kỷ với độ chính xác hiện đại để tạo ra những nhạc cụ không chỉ chơi nhạc mà còn truyền cảm hứng.');
const feat1Title  = g('flysky_brand_feat1_title', 'Cần đàn chạm khắc thủ công');
const feat1Desc   = g('flysky_brand_feat1_desc', 'Được tạo hình để mang lại sự thoải mái và khả năng chơi tối ưu.');
const feat2Title  = g('flysky_brand_feat2_title', 'Hệ thống điện tử chính xác');
const feat2Desc   = g('flysky_brand_feat2_desc', 'Bộ thu âm (pickups) được quấn thủ công cho độ trong trẻo nguyên bản.');
const brandImage  = g('flysky_brand_image', '/images/brand-story.jpg');
const brandImagesRaw = g('flysky_brand_images', '');
const brandImages = String(brandImagesRaw)
  .split(/\r?\n|,/)
  .map((x: string) => x.trim())
  .filter(Boolean);
const brandImageList = brandImages.length > 0 ? brandImages : [brandImage];
---

<section class="py-24 bg-background-dark relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 lg:px-10">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      <div class="w-full lg:w-1/2 relative">
        <div class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-primary rounded-tl-3xl z-10"></div>
        <div class={`relative rounded-2xl overflow-hidden aspect-[4/3] shadow-2xl ${isAdmin ? 'quick-image-editable' : ''}`} data-image-setting={isAdmin ? 'flysky_brand_image' : undefined}>
          <div class="brand-slide-layer" id="brand-slide-a" style={`background-image:url('${brandImageList[0]}');opacity:1;`}></div>
          <div class="brand-slide-layer" id="brand-slide-b" style={`background-image:url('${brandImageList[0]}');opacity:0;`}></div>
          <div class="absolute inset-0 bg-primary/10 mix-blend-overlay"></div>
          {isAdmin && (
            <div class="quick-image-overlay">
              <span class="material-symbols-outlined text-[18px]">upload</span>
              Kéo ảnh vào hoặc bấm để đổi
            </div>
          )}
        </div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 border-b-2 border-r-2 border-primary rounded-br-3xl z-10"></div>
      </div>
      <div class="w-full lg:w-1/2 flex flex-col gap-6">
        <div class="flex items-center gap-3 mb-2">
          <span class="h-px w-12 bg-primary"></span>
          <span class={`text-primary font-bold uppercase tracking-widest text-sm ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_brand_section_tag' : undefined}>{sectionTag}</span>
        </div>
        <h2 class="text-white type-display-section">
          <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_brand_title1' : undefined}>{title1}</span><br />
          <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_brand_title2' : undefined}>{title2}</span>
        </h2>
        <p class={`text-text-muted type-body-lead ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_brand_desc' : undefined}>
          {desc}
        </p>
        <div class="flex flex-col gap-4 mt-4">
          <div class="flex items-start gap-4">
            <div class="p-2 rounded-lg bg-card-dark text-primary">
              <span class="material-symbols-outlined">carpenter</span>
            </div>
            <div>
              <h4 class={`text-white type-title-card ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_brand_feat1_title' : undefined}>{feat1Title}</h4>
              <p class={`text-text-muted text-sm ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_brand_feat1_desc' : undefined}>{feat1Desc}</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="p-2 rounded-lg bg-card-dark text-primary">
              <span class="material-symbols-outlined">graphic_eq</span>
            </div>
            <div>
              <h4 class={`text-white type-title-card ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_brand_feat2_title' : undefined}>{feat2Title}</h4>
              <p class={`text-text-muted text-sm ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_brand_feat2_desc' : undefined}>{feat2Desc}</p>
            </div>
          </div>
        </div>
        <div class="mt-6">
          <a class="inline-flex items-center gap-2 text-white font-bold border-b-2 border-primary hover:text-primary transition-colors pb-1" href="/about">
            Đọc câu chuyện thương hiệu của chúng tôi
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ brandImageList }}>
  const slides = Array.isArray(brandImageList) ? brandImageList.filter(Boolean) : [];
  const layerA = document.getElementById('brand-slide-a');
  const layerB = document.getElementById('brand-slide-b');

  if (layerA && layerB && slides.length > 1) {
    let currentIndex = 0;
    let showingA = true;

    window.setInterval(() => {
      const nextIndex = (currentIndex + 1) % slides.length;
      const outgoing = showingA ? layerA : layerB;
      const incoming = showingA ? layerB : layerA;

      incoming.style.backgroundImage = `url('${slides[nextIndex]}')`;
      incoming.style.opacity = '0';
      incoming.style.transition = 'opacity 900ms ease';

      requestAnimationFrame(() => {
        incoming.style.opacity = '1';
        outgoing.style.opacity = '0';
      });

      currentIndex = nextIndex;
      showingA = !showingA;
    }, 4500);
  }
</script>

<style>
  .brand-slide-layer {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    will-change: opacity;
  }
</style>
