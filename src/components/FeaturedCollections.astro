---
---

<section class="py-16 bg-background-dark relative">
  <div class="mx-auto max-w-7xl px-4 lg:px-10">
    <div class="flex items-end justify-between mb-8">
      <div>
        <span class="text-primary font-bold tracking-widest uppercase text-sm">Khám phá</span>
        <h2 class="text-white text-3xl font-bold mt-2">Bộ sưu tập nổi bật</h2>
      </div>
      <a class="hidden md:flex items-center gap-1 text-primary font-medium hover:text-white transition-colors" href="#">
        Xem tất cả <span class="material-symbols-outlined text-sm">arrow_forward</span>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Guitar Điện -->
      <div class="group relative overflow-hidden rounded-xl bg-card-dark border border-border-dark aspect-[4/5] md:aspect-[3/4]">
        <div
          class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110 opacity-60 group-hover:opacity-40"
          style="background-image: url('/images/cat-electric.jpg');"
        ></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6 w-full">
          <p class="text-primary font-bold text-sm mb-1 uppercase tracking-wider">Năng lượng cao</p>
          <h3 class="text-white text-2xl font-bold mb-3">Dòng Guitar Điện</h3>
          <div class="h-0 group-hover:h-auto overflow-hidden transition-all duration-300">
            <span class="inline-flex items-center text-white text-sm font-medium border-b border-primary pb-0.5">Mua Guitar Điện</span>
          </div>
        </div>
      </div>
      <!-- Guitar Acoustic -->
      <div class="group relative overflow-hidden rounded-xl bg-card-dark border border-border-dark aspect-[4/5] md:aspect-[3/4]">
        <div
          class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110 opacity-60 group-hover:opacity-40"
          style="background-image: url('/images/cat-acoustic.jpg');"
        ></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6 w-full">
          <p class="text-primary font-bold text-sm mb-1 uppercase tracking-wider">Âm thanh thuần khiết</p>
          <h3 class="text-white text-2xl font-bold mb-3">Dòng Guitar Acoustic</h3>
          <div class="h-0 group-hover:h-auto overflow-hidden transition-all duration-300">
            <span class="inline-flex items-center text-white text-sm font-medium border-b border-primary pb-0.5">Mua Guitar Acoustic</span>
          </div>
        </div>
      </div>
      <!-- Guitar Bass -->
      <div class="group relative overflow-hidden rounded-xl bg-card-dark border border-border-dark aspect-[4/5] md:aspect-[3/4]">
        <div
          class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110 opacity-60 group-hover:opacity-40"
          style="background-image: url('/images/cat-bass.jpg');"
        ></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6 w-full">
          <p class="text-primary font-bold text-sm mb-1 uppercase tracking-wider">Nhịp điệu trầm ấm</p>
          <h3 class="text-white text-2xl font-bold mb-3">Dòng Guitar Bass</h3>
          <div class="h-0 group-hover:h-auto overflow-hidden transition-all duration-300">
            <span class="inline-flex items-center text-white text-sm font-medium border-b border-primary pb-0.5">Mua Guitar Bass</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
