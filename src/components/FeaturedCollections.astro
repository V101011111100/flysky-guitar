---
import { supabase } from '../lib/supabase';

type CategoryRow = { name: string; slug: string };

const { data: categoryRows } = await supabase
  .from('categories')
  .select('name, slug');

const categories = (categoryRows || []) as CategoryRow[];

const categoryMeta = {
  electric: {
    vibe: 'Năng lượng cao',
    title: 'Guitar Điện',
    cta: 'Mua Guitar Điện',
    image: '/images/cat-electric.jpg',
  },
  acoustic: {
    vibe: 'Âm thanh thuần khiết',
    title: 'Guitar Acoustic',
    cta: 'Mua Guitar Acoustic',
    image: '/images/cat-acoustic.jpg',
  },
  classic: {
    vibe: 'Tiếng nylon truyền thống',
    title: 'Guitar Classic',
    cta: 'Mua Guitar Classic',
    image: '/images/cat-acoustic.jpg',
  },
  bass: {
    vibe: 'Nhịp điệu trầm ấm',
    title: 'Guitar Bass',
    cta: 'Mua Guitar Bass',
    image: '/images/cat-bass.jpg',
  },
  piano: {
    vibe: 'Đa tầng hòa âm',
    title: 'Piano & Keyboard',
    cta: 'Mua Piano & Keyboard',
    image: '/images/hero-guitar.jpg',
  },
  ukulele: {
    vibe: 'Vui tươi & nhẹ nhàng',
    title: 'Ukulele',
    cta: 'Mua Ukulele',
    image: '/images/brand-story.jpg',
  },
} as const;

const categoryAliases: Record<string, keyof typeof categoryMeta> = {
  electric: 'electric',
  'guitar-dien': 'electric',
  acoustic: 'acoustic',
  'guitar-acoustic': 'acoustic',
  classic: 'classic',
  'guitar-classic': 'classic',
  'guitar-classical': 'classic',
  bass: 'bass',
  'guitar-bass': 'bass',
  piano: 'piano',
  keyboard: 'piano',
  'piano-keyboard': 'piano',
  ukulele: 'ukulele',
};

const instrumentOrder: (keyof typeof categoryMeta)[] = ['electric', 'acoustic', 'classic', 'bass', 'piano', 'ukulele'];

const normalizedFromName = (name: string): keyof typeof categoryMeta | null => {
  const n = name.toLowerCase();
  if (n.includes('điện') || n.includes('dien')) return 'electric';
  if (n.includes('acoustic')) return 'acoustic';
  if (n.includes('classic') || n.includes('classical')) return 'classic';
  if (n.includes('bass')) return 'bass';
  if (n.includes('piano') || n.includes('keyboard')) return 'piano';
  if (n.includes('ukulele')) return 'ukulele';
  return null;
};

const dbCategoryByType = new Map<keyof typeof categoryMeta, CategoryRow>();
for (const c of categories) {
  const typeBySlug = categoryAliases[c.slug?.toLowerCase()] || null;
  const typeByName = normalizedFromName(c.name || '');
  const mapped = typeBySlug || typeByName;
  if (mapped && !dbCategoryByType.has(mapped)) {
    dbCategoryByType.set(mapped, c);
  }
}

const featuredCategories = instrumentOrder.map((type) => {
  const dbCategory = dbCategoryByType.get(type);
  const meta = categoryMeta[type];
  return {
    slug: dbCategory?.slug || type,
    label: dbCategory?.name || meta.title,
    ...meta,
  };
});
---

<section id="featured-collections" class="py-16 bg-background-dark relative">
  <div class="mx-auto max-w-7xl px-4 lg:px-10">
    <div class="flex items-end justify-between mb-8">
      <div>
        <span class="text-primary font-bold tracking-widest uppercase text-sm">Khám phá</span>
        <h2 class="text-white type-display-section mt-2">Bộ sưu tập nổi bật</h2>
      </div>
      <a class="hidden md:flex items-center gap-1 text-primary font-medium hover:text-white transition-colors" href="/shop">
        Xem tất cả <span class="material-symbols-outlined text-sm">arrow_forward</span>
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {featuredCategories.map((cat) => (
        <a href={`/shop?category=${encodeURIComponent(cat.slug)}`} class="group relative overflow-hidden rounded-xl bg-card-dark border border-border-dark aspect-[4/5] md:aspect-[3/4] block">
          <div
            class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110 opacity-60 group-hover:opacity-40"
            style={`background-image: url('${cat.image}');`}
          ></div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6 w-full">
            <p class="text-primary font-bold text-sm mb-1 uppercase tracking-wider">{cat.vibe}</p>
            <h3 class="text-white text-2xl font-bold mb-3">{cat.label}</h3>
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center text-white text-sm font-medium border-b border-primary pb-0.5">{cat.cta}</span>
              <span class="material-symbols-outlined text-primary text-sm opacity-0 group-hover:opacity-100 transition-opacity">arrow_forward</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
