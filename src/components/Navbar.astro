---
---

<header class="sticky top-0 z-50 w-full border-b border-solid border-border-dark bg-background-dark/95 backdrop-blur-sm px-4 lg:px-10 py-3">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4">
    <div class="flex-shrink-0">
      <a class="flex items-center gap-2.5 text-white group" href="/">
        <img src="/logo.svg" alt="FlySky Guitar Logo" class="flysky-global-logo h-8 w-auto" />
        <h2 class="text-white text-xl font-extrabold tracking-tight" data-setting="flysky_storeName">FlySky Guitar</h2>
      </a>
    </div>
    <nav class="hidden lg:flex items-center gap-8 flex-1 justify-center">
      <a class="text-white/90 hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider" href="/">Trang chủ</a>

      <!-- Cửa hàng dropdown -->
      <div class="relative group py-2" id="shop-dropdown-wrap">
        <a
          href="/shop"
          class="flex items-center gap-1 text-white/90 hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider"
        >
          Cửa hàng
          <span class="material-symbols-outlined text-sm transition-transform duration-200 group-hover:rotate-180">expand_more</span>
        </a>
        <!-- Dropdown menu -->
        <div
          id="shop-dropdown"
          class="absolute top-full left-1/2 -translate-x-1/2 w-56 bg-card-dark border border-border-dark rounded-xl shadow-2xl overflow-hidden mt-1
                 opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0
                 transition-all duration-200 ease-out"
        >
          {[
            { href: '/shop?category=electric', icon: 'electric_bolt', label: 'Guitar Điện', sub: 'Solid & Semi-Hollow' },
            { href: '/shop?category=acoustic', icon: 'forest', label: 'Guitar Acoustic', sub: 'Dreadnought & Jumbo' },
            { href: '/shop?category=bass', icon: 'graphic_eq', label: 'Guitar Bass', sub: '4 & 5 dây' },
            { href: '/shop?category=piano', icon: 'piano', label: 'Piano', sub: 'Grand, Upright & Digital' },
          ].map((item) => (
            <a
              href={item.href}
              class="flex items-center gap-3 px-4 py-3 hover:bg-border-dark/60 hover:text-primary transition-colors border-b border-border-dark/40 last:border-0"
            >
              <span class="material-symbols-outlined text-primary text-[20px] flex-shrink-0">{item.icon}</span>
              <div>
                <p class="text-white text-sm font-semibold">{item.label}</p>
                <p class="text-text-muted text-[11px]">{item.sub}</p>
              </div>
            </a>
          ))}
          <a
            href="/shop"
            class="flex items-center justify-center gap-1 px-4 py-2.5 text-primary text-xs font-bold hover:bg-primary/10 transition-colors"
          >
            Xem tất cả <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
          </a>
        </div>
      </div>

      <a class="text-white/90 hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider" href="/about">Câu chuyện thương hiệu</a>
      <a class="text-white/90 hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider" href="/blog">Blog</a>
    </nav>
    <div class="flex items-center gap-2 lg:gap-4 flex-shrink-0">
      <div class="hidden md:block relative group">
        <form action="/search" method="get" class="relative">
          <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-text-muted">
            <span class="material-symbols-outlined text-[20px]">search</span>
          </div>
          <input name="q" class="block w-48 lg:w-64 rounded-full border border-transparent bg-border-dark/50 py-1.5 pl-10 pr-4 text-xs text-white placeholder-text-muted focus:ring-2 focus:ring-primary focus:bg-border-dark focus:border-primary transition-all" placeholder="Tìm kiếm..." type="text" />
        </form>
      </div>
      <div class="flex items-center gap-1">
        <button class="md:hidden flex items-center justify-center rounded-lg size-10 text-white hover:bg-border-dark transition-colors">
          <span class="material-symbols-outlined">search</span>
        </button>
        <!-- Cart button -->
        <a href="/cart" class="flex items-center justify-center rounded-lg size-10 text-white hover:bg-border-dark transition-colors relative" id="nav-cart-btn" title="Giỏ hàng">
          <span class="material-symbols-outlined">shopping_cart</span>
          <span id="nav-cart-badge" class="absolute top-1.5 right-1.5 min-w-4 h-4 bg-primary text-background-dark text-[10px] font-bold flex items-center justify-center rounded-full px-0.5 hidden">0</span>
        </a>
        <a class="flex items-center justify-center rounded-lg size-10 text-white hover:bg-border-dark transition-colors group relative" href="/admin/login" title="Quản trị">
          <span class="material-symbols-outlined">admin_panel_settings</span>
          <span class="sr-only">Quản trị</span>
          <span class="absolute -bottom-10 right-0 hidden group-hover:block bg-card-dark border border-border-dark text-[10px] text-white px-2 py-1 rounded whitespace-nowrap">Quản trị</span>
        </a>
        <button class="lg:hidden flex items-center justify-center rounded-lg size-10 text-white hover:bg-border-dark transition-colors" id="mobile-menu-btn">
          <span class="material-symbols-outlined">menu</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden fixed inset-0 z-50 pointer-events-none">
    <div class="absolute inset-0 bg-black/60 opacity-0 transition-opacity duration-300" id="mobile-menu-overlay"></div>
    <nav class="absolute right-0 top-0 h-full w-72 bg-background-dark border-l border-border-dark transform translate-x-full transition-transform duration-300 flex flex-col" id="mobile-menu-panel">
      <div class="flex items-center justify-between p-4 border-b border-border-dark">
        <h3 class="text-white font-bold text-lg">Menu</h3>
        <button id="mobile-menu-close" class="text-white hover:text-primary transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div class="flex-1 overflow-y-auto p-4">
        <a href="/" class="block py-3 px-4 text-white hover:bg-border-dark/50 hover:text-primary rounded-lg transition-colors font-semibold">Trang chủ</a>
        <a href="/shop" class="block py-3 px-4 text-white hover:bg-border-dark/50 hover:text-primary rounded-lg transition-colors font-semibold">Cửa hàng</a>
        <a href="/about" class="block py-3 px-4 text-white hover:bg-border-dark/50 hover:text-primary rounded-lg transition-colors font-semibold">Câu chuyện thương hiệu</a>
        <a href="/blog" class="block py-3 px-4 text-white hover:bg-border-dark/50 hover:text-primary rounded-lg transition-colors font-semibold">Blog</a>
        <a href="/contact" class="block py-3 px-4 text-white hover:bg-border-dark/50 hover:text-primary rounded-lg transition-colors font-semibold">Liên hệ</a>
        <div class="border-t border-border-dark my-4"></div>
        <a href="/cart" class="block py-3 px-4 text-primary hover:bg-primary/10 rounded-lg transition-colors font-bold flex items-center gap-2">
          <span class="material-symbols-outlined">shopping_cart</span>
          Giỏ hàng
        </a>
        <a href="/admin/login" class="block py-3 px-4 text-text-muted hover:bg-border-dark/50 hover:text-white rounded-lg transition-colors font-semibold flex items-center gap-2">
          <span class="material-symbols-outlined">admin_panel_settings</span>
          Quản trị
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  import { getCartCount } from '../lib/cart';

  function updateBadge() {
    const badge = document.getElementById('nav-cart-badge');
    if (!badge) return;
    const count = getCartCount();
    if (count > 0) {
      badge.textContent = count > 99 ? '99+' : String(count);
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  }

  updateBadge();
  window.addEventListener('cart-updated', updateBadge);

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  const mobileMenuClose = document.getElementById('mobile-menu-close');

  function openMobileMenu() {
    mobileMenu?.classList.remove('pointer-events-none');
    mobileMenu?.classList.add('pointer-events-auto');
    setTimeout(() => {
      mobileMenuOverlay?.classList.remove('opacity-0');
      mobileMenuPanel?.classList.remove('translate-x-full');
    }, 10);
  }

  function closeMobileMenu() {
    mobileMenuOverlay?.classList.add('opacity-0');
    mobileMenuPanel?.classList.add('translate-x-full');
    setTimeout(() => {
      mobileMenu?.classList.add('pointer-events-none');
      mobileMenu?.classList.remove('pointer-events-auto');
    }, 300);
  }

  mobileMenuBtn?.addEventListener('click', openMobileMenu);
  mobileMenuClose?.addEventListener('click', closeMobileMenu);
  mobileMenuOverlay?.addEventListener('click', closeMobileMenu);
</script>
