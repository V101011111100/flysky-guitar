---
import { supabase } from '../lib/supabase';

// Lấy 4 sản phẩm
const { data: dbData } = await supabase
  .from('products')
  .select(`*, categories(name)`)
  .eq('status', 'active')
  .limit(4);

const bestSellers = (dbData || []).map(p => ({
  id: p.slug,
  categoryLabel: p.categories?.name || 'Sản phẩm',
  name: p.name,
  priceFormatted: new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.price),
  image: (p.gallery_images && p.gallery_images.length > 0) ? p.gallery_images[0] : '/images/default-guitar.webp',
  badge: p.is_featured ? 'Nổi bật' : null
}));
---

<section class="py-16 bg-wood-dark">
  <div class="mx-auto max-w-7xl px-4 lg:px-10">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-white type-display-section">Sản phẩm bán chạy</h2>
      <a href="/shop" class="hidden md:flex items-center gap-1 text-primary font-medium hover:text-white transition-colors text-sm">
        Xem tất cả <span class="material-symbols-outlined text-sm">arrow_forward</span>
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {bestSellers.map((product) => (
        <a
          href={`/products/${product.id}`}
          class="group flex flex-col bg-card-dark rounded-xl overflow-hidden hover:shadow-[0_0_20px_rgba(244,140,37,0.15)] transition-all border border-border-dark cursor-pointer"
        >
          <div class="aspect-square w-full bg-surface-panel relative p-4 flex items-center justify-center overflow-hidden">
            <div
              class="w-full h-full bg-contain bg-center bg-no-repeat group-hover:scale-110 transition-transform duration-300"
              style={`background-image: url("${product.image}");`}
            ></div>
            {product.badge && (
              <div class="absolute top-3 right-3 bg-primary text-background-dark text-xs font-bold px-2 py-1 rounded">
                {product.badge}
              </div>
            )}
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
              <span class="text-white text-xs font-bold bg-white/20 backdrop-blur-sm px-3 py-1.5 rounded-full flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">visibility</span>
                Xem chi tiết
              </span>
            </div>
          </div>
          <div class="p-4 flex flex-col gap-2 flex-grow">
            <p class="text-primary text-[10px] font-bold uppercase tracking-wider">{product.categoryLabel}</p>
            <h3 class="text-white type-title-card group-hover:text-primary transition-colors leading-tight">{product.name}</h3>
            <div class="mt-auto flex items-center justify-between pt-2 border-t border-border-dark/50">
              <span class="text-white font-bold text-base">{product.priceFormatted}</span>
              <span class="bg-border-dark group-hover:bg-primary text-white group-hover:text-background-dark rounded-full p-2 transition-colors">
                <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
