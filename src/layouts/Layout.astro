---
import '../styles/global.css';
import FloatingWidgets from '../components/FloatingWidgets.astro';
import { supabase } from '../lib/supabase';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'FlySky Guitar - Đàn Guitar Thủ Công Cao Cấp', description = 'Đàn guitar thủ công cao cấp dành cho những nghệ sĩ hiện đại. Khơi dậy âm thanh của bạn với FlySky Guitar.' } = Astro.props;

// Fetch settings from Database
const { data: settingsData } = await supabase.from('site_settings').select('*');
const getSetting = (key: string, _default: string) => {
  const item = settingsData?.find((s: any) => s.key === key);
  return item ? item.value : _default;
};

// Maintenance mode check — redirect frontend visitors if active
const maintenanceMode = getSetting('flysky_maintenanceMode', 'false') === 'true';
const currentPath = Astro.url.pathname;
const isMaintenancePage = currentPath === '/maintenance';
if (maintenanceMode && !isMaintenancePage) {
  return Astro.redirect('/maintenance');
}

const clientSettings = {
  logo: getSetting('flysky_logoUrl', ''), // Persisted logo URL from DB (set after R2 upload)
  flysky_storeName: getSetting('flysky_storeName', 'FlySky Guitar Studio'),
  flysky_contactEmail: getSetting('flysky_contactEmail', 'contact@flysky.vn'),
  flysky_storeAddress: getSetting('flysky_storeAddress', '37 Lê Thiện Trị'),
  flysky_contactPhone: getSetting('flysky_contactPhone', '090 123 4567'),
  flysky_supportWarrantyUrl: getSetting('flysky_supportWarrantyUrl', '/blog'),
  flysky_supportShippingReturnUrl: getSetting('flysky_supportShippingReturnUrl', '/payment'),
  flysky_supportCareGuideUrl: getSetting('flysky_supportCareGuideUrl', '/blog'),
  flysky_heroH1: getSetting('flysky_heroH1', 'Đánh Thức Đam Mê Âm Nhạc Của Bạn'),
  flysky_heroSub: getSetting('flysky_heroSub', 'Khám phá bộ sưu tập nhạc cụ cao cấp, được tinh chỉnh hoàn hảo để mang lại cảm hứng sáng tạo bất tận cho mọi nghệ sĩ.'),
  flysky_brandColor: getSetting('flysky_brandColor', '#f48c25'),
  flysky_facebookUrl: getSetting('flysky_facebookUrl', ''),
  flysky_instagramUrl: getSetting('flysky_instagramUrl', ''),
  flysky_youtubeUrl: getSetting('flysky_youtubeUrl', ''),
  flysky_tiktokUrl: getSetting('flysky_tiktokUrl', ''),
};
---

<!doctype html>
<html class="dark" lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-white font-display overflow-x-hidden">
    <slot />
    <FloatingWidgets />
    <script is:inline define:vars={{ clientSettings }}>
      document.addEventListener('DOMContentLoaded', () => {
        // 1. Cập nhật Logo
        if (clientSettings.logo || localStorage.getItem('flysky_custom_logo')) {
          const customLogo = localStorage.getItem('flysky_custom_logo') || clientSettings.logo;
          document.querySelectorAll('.flysky-global-logo').forEach((img) => {
            img.src = customLogo;
          });
        }

        // 2. Cập nhật Nội dung chữ (Text Settings)
        Object.keys(clientSettings).forEach(key => {
          if (key === 'logo' || key === 'flysky_brandColor') return;
          const val = clientSettings[key];
          if (val) {
            document.querySelectorAll(`[data-setting="${key}"]`).forEach(el => {
              if (el.tagName === 'A') {
                  el.href = val;
              } else {
                  el.innerHTML = val;
              }
            });
          }
        });

        // 3. Cập nhật Màu chủ đạo (Accent Color)
        if (clientSettings.flysky_brandColor) {
          document.documentElement.style.setProperty('--color-primary', clientSettings.flysky_brandColor);
        }
      });
    </script>
  </body>
</html>

