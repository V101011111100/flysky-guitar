---
import '../styles/global.css';
import { supabase } from '../lib/supabase';

interface Props {
  title?: string;
  subtitle?: string;
  activeNav?: string;
}
const { title = 'Admin', subtitle = '', activeNav = 'dashboard' } = Astro.props;

let userEmail = '';
let shouldRedirect = false;
let autoLogoutMinutes = 120; // default 2 hours

// --- SSR AUTH CHECK --- //
const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
  shouldRedirect = true;
} else {
  const { data, error } = await supabase.auth.setSession({
    access_token: accessToken.value,
    refresh_token: refreshToken.value,
  });

  if (error || !data.user) {
    Astro.cookies.delete("sb-access-token", { path: "/" });
    Astro.cookies.delete("sb-refresh-token", { path: "/" });
    shouldRedirect = true;
  } else {
    userEmail = data.user.email || 'Admin';
    // Load auto-logout timeout setting
    const { data: timeoutSetting } = await supabase
      .from('site_settings')
      .select('value')
      .eq('key', 'flysky_autoLogoutTimeout')
      .single();
    if (timeoutSetting?.value) {
      autoLogoutMinutes = parseInt(timeoutSetting.value) || 120;
    }
  }
}
// --- END SSR AUTH CHECK --- //
---

<!doctype html>
<html lang="vi">
<head>
  {shouldRedirect && <meta http-equiv="refresh" content="0;url=/admin/login" />}
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | FlySky Admin</title>
  <link rel="icon" href="/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet" />
  <style>
    /* ══ RESET ══ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'Manrope', sans-serif;
      background: #221910;
      color: #f1f5f9;
    }

    /* ══ LAYOUT ══ */
    .app-shell {
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    /* ══ SIDEBAR ══ */
    .sidebar {
      width: 288px;
      flex-shrink: 0;
      background: #2d2218;
      border-right: 1px solid #4a3a2a;
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow-y: auto;
      transition: transform 0.3s ease;
    }

    /* Mobile: sidebar hidden by default, slide in when active */
    @media (max-width: 1024px) {
      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        z-index: 100;
        transform: translateX(-100%);
      }
      .sidebar.active {
        transform: translateX(0);
      }
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        z-index: 99;
      }
      .sidebar-overlay.active {
        display: block;
      }
    }

    .sidebar::-webkit-scrollbar { width: 4px; }
    .sidebar::-webkit-scrollbar-track { background: transparent; }
    .sidebar::-webkit-scrollbar-thumb { background: #4a3a2a; border-radius: 4px; }

    /* Logo */
    .sidebar-logo {
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .logo-name { font-size: 18px; font-weight: 800; color: #f9fafb; line-height: 1.2; }
    .logo-sub  { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .14em; color: rgba(244,140,37,.7); }

    /* Nav */
    .sidebar-nav { flex: 1; padding: 0 16px; }
    .nav-group { padding: 16px 0; }
    .nav-group + .nav-group { border-top: 1px solid #4a3a2a; }
    .nav-group-label {
      display: block;
      font-size: 10px; font-weight: 700;
      color: #64748b;
      text-transform: uppercase; letter-spacing: .12em;
      padding: 0 12px 8px;
    }
    .nav-link {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 12px; border-radius: 8px;
      text-decoration: none;
      font-size: 13.5px; font-weight: 600;
      color: #94a3b8;
      transition: all .15s;
      margin-bottom: 2px;
    }
    .nav-link:hover { background: rgba(255,255,255,.05); color: #f48c25; }
    .nav-link .material-symbols-outlined { font-size: 20px; }
    .nav-link.active {
      background: #f48c25;
      color: #221910;
      font-weight: 700;
    }
    .nav-link.active .material-symbols-outlined { font-variation-settings: 'FILL' 1; }

    /* Add Product Button */
    .sidebar-add-btn {
      margin: 0 16px 16px;
    }
    .sidebar-add-btn a {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      padding: 12px 16px; border-radius: 12px;
      text-decoration: none;
      font-size: 13px; font-weight: 700;
      color: #f48c25;
      background: rgba(244,140,37,.1);
      border: 1px solid rgba(244,140,37,.2);
      transition: all .15s;
    }
    .sidebar-add-btn a:hover { background: rgba(244,140,37,.2); }
    .sidebar-add-btn .material-symbols-outlined { font-size: 18px; }

    /* ══ MAIN AREA ══ */
    .main-area {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: #221910;
    }

    /* ══ HEADER ══ */
    .topbar {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      background: rgba(34,25,16,.9);
      border-bottom: 1px solid #4a3a2a;
      backdrop-filter: blur(12px);
      position: sticky; top: 0; z-index: 20;
    }
    @media (min-width: 768px) {
      .topbar { padding: 20px 32px; }
    }
    .topbar-left { display: flex; align-items: center; gap: 16px; }
    .hamburger-btn {
      display: none;
      background: none;
      border: none;
      color: #f48c25;
      cursor: pointer;
      padding: 8px;
      border-radius: 8px;
      transition: background 0.15s;
    }
    .hamburger-btn:hover { background: rgba(255,255,255,0.06); }
    .hamburger-btn .material-symbols-outlined { font-size: 24px; }
    @media (max-width: 1024px) {
      .hamburger-btn { display: block; }
    }
    .topbar-title  { font-size: 18px; font-weight: 900; color: #f9fafb; letter-spacing: -.02em; }
    @media (min-width: 768px) {
      .topbar-title { font-size: 22px; }
    }
    .topbar-sub    { font-size: 13px; color: #94a3b8; margin-top: 3px; display: none; }
    @media (min-width: 768px) {
      .topbar-sub { display: block; }
    }
    .topbar-right  { display: flex; align-items: center; gap: 12px; }
    @media (min-width: 768px) {
      .topbar-right { gap: 16px; }
    }
    .notif-btn {
      position: relative;
      background: none; border: none; cursor: pointer;
      color: #94a3b8;
      padding: 8px; border-radius: 50%;
      transition: background .15s;
    }
    .notif-btn:hover { background: rgba(255,255,255,.06); }
    .notif-btn .material-symbols-outlined { font-size: 22px; display: block; }
      .notif-dot {
        position: absolute; top: 6px; right: 6px;
        min-width: 16px; height: 16px;
        background: #f48c25; border-radius: 8px;
        border: 2px solid #221910;
        font-size: 9px; font-weight: 800; color: #221910;
        display: flex; align-items: center; justify-content: center;
        padding: 0 3px;
        transition: opacity 0.2s;
      }

      /* Notification Dropdown */
      .notif-wrap { position: relative; }
      .notif-dropdown {
        position: absolute;
        top: calc(100% + 10px);
        right: 0;
        width: min(360px, calc(100vw - 28px));
        max-height: 480px;
        background: rgba(45,34,24,0.97);
        border: 1px solid rgba(244,140,37,0.22);
        border-radius: 14px;
        box-shadow: 0 20px 48px rgba(0,0,0,0.6);
        backdrop-filter: blur(8px);
        z-index: 200;
        display: none;
        flex-direction: column;
        overflow: hidden;
        animation: fadeSlideDown 0.18s ease;
      }
      @media (max-width: 640px) {
        .notif-dropdown {
          right: -42px;
          max-height: 62vh;
        }
      }
      .notif-dropdown.open { display: flex; }
      @keyframes fadeSlideDown {
        from { opacity: 0; transform: translateY(-6px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .notif-drop-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 16px 10px;
        border-bottom: 1px solid rgba(244,140,37,0.12);
      }
      .notif-drop-title { font-size: 13px; font-weight: 800; color: #f1f5f9; }
      .notif-drop-link {
        font-size: 11.5px; font-weight: 600; color: #f48c25;
        text-decoration: none;
      }
      .notif-drop-link:hover { text-decoration: underline; }
      .notif-list {
        overflow-y: auto;
        flex: 1;
      }
      .notif-list::-webkit-scrollbar { width: 4px; }
      .notif-list::-webkit-scrollbar-thumb { background: #4a3a2a; border-radius: 4px; }
      .notif-item {
        display: flex; gap: 10px; align-items: flex-start;
        padding: 11px 14px;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        transition: background 0.12s;
      }
      .notif-item:hover { background: rgba(244,140,37,0.06); }
      .notif-item:last-child { border-bottom: none; }
      .notif-icon-wrap {
        width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        font-size: 15px;
      }
      .notif-body { flex: 1; min-width: 0; }
      .notif-text {
        font-size: 12.5px; font-weight: 600; color: #e2e8f0;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        word-break: break-word;
      }
      .notif-meta {
        font-size: 11px; color: #64748b; margin-top: 2px;
        display: flex; gap: 6px; flex-wrap: wrap;
      }
      .notif-module { color: #94a3b8; font-weight: 500; }
      .notif-drop-empty {
        padding: 36px 16px;
        text-align: center;
        color: #64748b;
        font-size: 13px;
      }
      .notif-loading {
        padding: 28px 16px;
        display: flex; align-items: center; justify-content: center;
        gap: 8px; color: #64748b; font-size: 13px;
      }
    .topbar-divider { width: 1px; height: 40px; background: #4a3a2a; }
    .topbar-user { display: flex; align-items: center; gap: 12px; }
    .user-info-text { text-align: right; }
    .user-name  { font-size: 13.5px; font-weight: 700; color: #f9fafb; }
    .user-role  { font-size: 11px; color: #64748b; }
    .user-avatar-wrap {
      width: 40px; height: 40px; border-radius: 50%;
      border: 2px solid rgba(244,140,37,.35);
      padding: 2px;
    }
    .user-avatar-wrap img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; display: block; }

    /* ══ CONTENT SCROLL ══ */
    .content-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
    }
    @media (min-width: 768px) {
      .content-scroll { padding: 24px; }
    }
    @media (min-width: 1024px) {
      .content-scroll { padding: 32px; }
    }
    .content-scroll::-webkit-scrollbar { width: 6px; }
    .content-scroll::-webkit-scrollbar-track { background: #221910; }
    .content-scroll::-webkit-scrollbar-thumb { background: #4a3a2a; border-radius: 4px; }

    /* ══ SHARED CARD ══ */
    .card {
      background: #2d2218;
      border: 1px solid #4a3a2a;
      border-radius: 16px;
    }
    .card:hover { border-color: rgba(244,140,37,.3); }

    /* ══ BUTTONS ══ */
    .btn-primary {
      background: #f48c25; color: #221910;
      font-weight: 700; font-size: 13px;
      padding: 9px 18px; border-radius: 8px;
      border: none; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      text-decoration: none; white-space: nowrap;
      transition: all .15s;
    }
    .btn-primary:hover { background: #e07b10; }
    .btn-ghost {
      background: none; border: none; cursor: pointer;
      color: #64748b; padding: 8px; border-radius: 8px;
      transition: all .15s;
      display: inline-flex; align-items: center;
    }
    .btn-ghost:hover { background: rgba(244,140,37,.2); color: #f48c25; }

    /* ══ BADGE ══ */
    .badge {
      display: inline-block; padding: 3px 8px;
      border-radius: 4px; font-size: 10px; font-weight: 900;
      text-transform: uppercase; border: 1px solid;
    }
    .badge-new       { background: rgba(244,140,37,.2); color: #f48c25; border-color: rgba(244,140,37,.3); }
    .badge-processing{ background: rgba(59,130,246,.2);  color: #60a5fa; border-color: rgba(59,130,246,.3); }
    .badge-done      { background: rgba(11,218,22,.2);   color: #0bda16; border-color: rgba(11,218,22,.3); }

    /* ══ RESPONSIVE TABLES ══ */
    @media (max-width: 1024px) {
      .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
      .table-responsive table {
        min-width: 800px;
      }
    }
  </style>
  <slot name="head" />
</head>
<body>
{shouldRedirect ? (
  <div style="display:flex; height:100vh; align-items:center; justify-content:center; background:#221910; color:#f48c25; font-family:sans-serif;">
    Đang chuyển hướng đến trang đăng nhập...
  </div>
) : (
<div class="app-shell">

  <!-- ══ SIDEBAR ══ -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <img src="/logo.svg" alt="FlySky Logo" class="flysky-global-logo" style="width: 40px; height: auto;" />
      <div>
        <div class="logo-name">FlySky Guitar</div>
        <div class="logo-sub">Hệ thống quản trị</div>
      </div>
    </div>

    <nav class="sidebar-nav">
      <!-- Chính -->
      <div class="nav-group">
        <span class="nav-group-label">Chính</span>
        <a href="/admin"            class={`nav-link ${activeNav==='dashboard'     ? 'active' : ''}`}><span class="material-symbols-outlined">dashboard</span>Bảng điều khiển</a>
        <a href="/admin/pos"        class={`nav-link ${activeNav==='pos'           ? 'active' : ''}`}><span class="material-symbols-outlined">point_of_sale</span>POS (Bán hàng)</a>
        <a href="/admin/media"      class={`nav-link ${activeNav==='media'         ? 'active' : ''}`}><span class="material-symbols-outlined">perm_media</span>Thư viện Media</a>
        <a href="/admin/inventory"  class={`nav-link ${activeNav==='inventory'     ? 'active' : ''}`}><span class="material-symbols-outlined">inventory_2</span>Kho hàng</a>
        <a href="/admin/orders"     class={`nav-link ${activeNav==='orders'        ? 'active' : ''}`}><span class="material-symbols-outlined">shopping_cart</span>Đơn hàng</a>
        <a href="/admin/shipping"   class={`nav-link ${activeNav==='shipping'      ? 'active' : ''}`}><span class="material-symbols-outlined">local_shipping</span>Vận chuyển</a>
      </div>
      <!-- Quản lý -->
      <div class="nav-group">
        <span class="nav-group-label">Quản lý</span>
        <a href="/admin/consultations" class={`nav-link ${activeNav==='consultations' ? 'active' : ''}`}><span class="material-symbols-outlined">group</span>Khách hàng</a>
        <a href="/admin/reviews"       class={`nav-link ${activeNav==='reviews'       ? 'active' : ''}`}><span class="material-symbols-outlined">reviews</span>Đánh giá</a>
        <a href="/admin/messages"      class={`nav-link ${activeNav==='messages'      ? 'active' : ''}`}><span class="material-symbols-outlined">bar_chart</span>Báo cáo</a>
        <a href="/admin/seo"           class={`nav-link ${activeNav==='seo'           ? 'active' : ''}`}><span class="material-symbols-outlined">campaign</span>SEO &amp; Marketing</a>
      </div>

      <!-- Hệ thống -->
      <div class="nav-group">
        <span class="nav-group-label">Hệ thống</span>
        <a href="/admin/permissions" class={`nav-link ${activeNav==='permissions'   ? 'active' : ''}`}><span class="material-symbols-outlined">shield_person</span>Phân quyền</a>
        <a href="/admin/activity-log" class={`nav-link ${activeNav==='activity-log'  ? 'active' : ''}`}><span class="material-symbols-outlined">history_edu</span>Nhật ký hoạt động</a>
        <a href="/admin/settings"   class={`nav-link ${activeNav==='settings'      ? 'active' : ''}`}><span class="material-symbols-outlined">settings</span>Cài đặt</a>
      </div>
    </nav>

    <div class="sidebar-add-btn">
      <a href="/admin/products">
        <span class="material-symbols-outlined">add_circle</span>
        Thêm sản phẩm mới
      </a>
    </div>
  </aside>

  <!-- Sidebar overlay for mobile -->
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <!-- ══ MAIN ══ -->
  <div class="main-area">
    <header class="topbar">
      <div class="topbar-left">
        <button class="hamburger-btn" id="hamburger-btn">
          <span class="material-symbols-outlined">menu</span>
        </button>
        <div>
          <h1 class="topbar-title">{title}</h1>
          {subtitle && <p class="topbar-sub">{subtitle}</p>}
        </div>
      </div>
      <div class="topbar-right">
        <div class="notif-wrap">
          <button class="notif-btn" id="notif-btn" aria-label="Thông báo" aria-expanded="false">
            <span class="material-symbols-outlined">notifications</span>
            <span class="notif-dot" id="notif-badge" style="display:none;"></span>
          </button>
          <div class="notif-dropdown" id="notif-dropdown" role="menu">
            <div class="notif-drop-header">
              <span class="notif-drop-title">Hoạt động gần đây</span>
              <div style="display:flex;align-items:center;gap:10px;">
                <button type="button" class="notif-drop-link" id="notif-read-all-btn" style="background:none;border:none;cursor:pointer;padding:0;">Read all</button>
                <a href="/admin/activity-log" class="notif-drop-link">Xem tất cả</a>
              </div>
            </div>
            <div class="notif-list" id="notif-list">
              <div class="notif-loading" id="notif-loading">
                <span class="material-symbols-outlined" style="animation:spin 1s linear infinite;font-size:18px;">autorenew</span>
                Đang tải...
              </div>
            </div>
          </div>
        </div>
        <div class="topbar-divider"></div>
        <div class="topbar-user">
          <div class="user-info-text">
            <div class="user-name">{userEmail}</div>
            <div class="user-role">Quản trị viên</div>
          </div>
          <div class="user-avatar-wrap relative group cursor-pointer" onclick="document.getElementById('logout-form').submit();" title="Nhấp để Đăng xuất">
            <img
              src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix&backgroundColor=f48c25"
              alt="Admin avatar"
            />
            <div class="absolute inset-0 bg-black/60 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
               <span class="material-symbols-outlined text-white text-sm">logout</span>
            </div>
            <form id="logout-form" action="/api/auth/signout" method="POST" class="hidden"></form>
          </div>
        </div>
      </div>
    </header>

    <div class="content-scroll">
      <slot />
    </div>
  </div>

</div>

<script is:inline define:vars={{ autoLogoutMinutes }}>
  window._autoLogoutMinutes = autoLogoutMinutes;
</script>

<style>
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
<style is:global>
  /* Ensure notification dropdown styles apply to JS-rendered items */
  .notif-wrap { position: relative; }
  .notif-dropdown {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: min(380px, calc(100vw - 24px));
    max-height: 500px;
    background: rgba(31, 22, 14, 0.98);
    border: 1px solid rgba(244, 140, 37, 0.28);
    border-radius: 14px;
    box-shadow: 0 22px 48px rgba(0,0,0,0.55);
    backdrop-filter: blur(8px);
    z-index: 200;
    display: none;
    flex-direction: column;
    overflow: hidden;
  }
  .notif-dropdown.open { display: flex; }
  .notif-drop-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    border-bottom: 1px solid rgba(244,140,37,0.16);
    background: rgba(255,255,255,0.01);
  }
  .notif-drop-title { font-size: 14px; font-weight: 800; color: #f1f5f9; }
  .notif-drop-link { font-size: 13px; font-weight: 700; color: #f48c25; text-decoration: none; }
  .notif-drop-link:hover { text-decoration: underline; }

  .notif-list {
    padding: 8px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .notif-list::-webkit-scrollbar { width: 5px; }
  .notif-list::-webkit-scrollbar-thumb { background: #4a3a2a; border-radius: 8px; }

  .notif-item {
    display: grid;
    grid-template-columns: 34px 1fr;
    gap: 10px;
    align-items: start;
    padding: 10px 11px;
    border-radius: 10px;
    border: 1px solid rgba(244,140,37,0.1);
    background: rgba(255,255,255,0.01);
    transition: all .15s ease;
  }
  .notif-item:hover {
    background: rgba(244,140,37,0.08);
    border-color: rgba(244,140,37,0.25);
    transform: translateY(-1px);
  }
  .notif-item.unread {
    border-color: rgba(244,140,37,0.35);
    background: rgba(244,140,37,0.06);
  }

  .notif-icon-wrap {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .notif-icon-wrap .material-symbols-outlined {
    font-size: 18px;
    line-height: 1;
  }

  .notif-body { min-width: 0; }
  .notif-text {
    margin: 0;
    font-size: 13px;
    line-height: 1.35;
    color: #e5e7eb;
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    word-break: break-word;
  }
  .notif-meta {
    margin-top: 4px;
    font-size: 11px;
    line-height: 1.3;
    color: #94a3b8;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .notif-module { color: #f8d2a7; font-weight: 700; }
  .notif-drop-empty {
    padding: 30px 16px;
    text-align: center;
    color: #94a3b8;
    font-size: 13px;
  }
  .notif-loading {
    padding: 26px 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #94a3b8;
    font-size: 13px;
  }

  @media (max-width: 640px) {
    .notif-dropdown { right: -42px; max-height: 62vh; }
    .notif-drop-title { font-size: 15px; }
    .notif-item { grid-template-columns: 30px 1fr; padding: 9px; gap: 8px; }
    .notif-icon-wrap { width: 30px; height: 30px; }
    .notif-icon-wrap .material-symbols-outlined { font-size: 16px; }
    .notif-text { font-size: 12px; }
  }
</style>
<script>
  function logout() {
    (document.getElementById('logout-form') as HTMLFormElement)?.submit();
  }
  (window as any).logout = logout;

  // Custom logo check
  const savedLogo = localStorage.getItem('flysky_custom_logo');
  if (savedLogo) {
    document.querySelectorAll('.flysky-global-logo').forEach((img) => {
      (img as HTMLImageElement).src = savedLogo;
    });
  }

  // Mobile sidebar toggle
    // ── NOTIFICATION BELL ──
    const NOTIF_SEEN_KEY = 'flysky_notif_last_seen';
    const notifBtn = document.getElementById('notif-btn') as HTMLButtonElement;
    const notifDropdown = document.getElementById('notif-dropdown');
    const notifList = document.getElementById('notif-list');
    const notifBadge = document.getElementById('notif-badge');
    const notifReadAllBtn = document.getElementById('notif-read-all-btn') as HTMLButtonElement | null;
    let notifLoaded = false;

    const ACTION_ICONS: Record<string, { icon: string; bg: string; color: string }> = {
      'Thêm mới': { icon: 'add_circle', bg: 'rgba(34,197,94,0.15)', color: '#22c55e' },
      'Cập nhật': { icon: 'edit', bg: 'rgba(59,130,246,0.15)', color: '#3b82f6' },
      'Xóa': { icon: 'delete', bg: 'rgba(239,68,68,0.15)', color: '#ef4444' },
      'Bảo mật / Hệ thống': { icon: 'security', bg: 'rgba(244,140,37,0.15)', color: '#f48c25' },
    };

    function escapeHtml(text: string): string {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function timeAgo(dateStr: string): string {
      const diff = Date.now() - new Date(dateStr).getTime();
      const m = Math.floor(diff / 60000);
      if (m < 1) return 'Vừa xong';
      if (m < 60) return `${m} phút trước`;
      const h = Math.floor(m / 60);
      if (h < 24) return `${h} giờ trước`;
      return `${Math.floor(h / 24)} ngày trước`;
    }

    async function loadNotifications() {
      if (!notifList) return;
      const since = localStorage.getItem(NOTIF_SEEN_KEY) || '';
      const sinceMs = since ? new Date(since).getTime() : 0;
      try {
        const res = await fetch(`/api/admin/notifications${since ? `?since=${encodeURIComponent(since)}` : ''}`);
        const data = await res.json();
        if (!data.success) return;

        // Update badge
        if (notifBadge) {
          if (data.unseenCount > 0) {
            notifBadge.textContent = data.unseenCount > 99 ? '99+' : String(data.unseenCount);
            notifBadge.style.display = 'flex';
          } else {
            notifBadge.style.display = 'none';
          }
        }

        // Render list
        if (!data.logs || data.logs.length === 0) {
          notifList.innerHTML = '<div class="notif-drop-empty"><span class="material-symbols-outlined" style="font-size:32px;display:block;margin:0 auto 8px;color:#4a3a2a;">notifications_off</span>Chưa có hoạt động nào</div>';
          return;
        }

        notifList.innerHTML = data.logs.map((log: any) => {
          const meta = ACTION_ICONS[log.action_type] || { icon: 'info', bg: 'rgba(100,116,139,0.15)', color: '#94a3b8' };
          const safeText = escapeHtml(log.action_text || 'Hoạt động hệ thống');
          const safeModule = escapeHtml(log.module_name || 'System');
          const safeUser = log.user_name ? escapeHtml(log.user_name) : '';
          const isUnread = !sinceMs || new Date(log.created_at).getTime() > sinceMs;
          return `
            <div class="notif-item ${isUnread ? 'unread' : ''}" data-created-at="${log.created_at}">
              <div class="notif-icon-wrap" style="background:${meta.bg}">
                <span class="material-symbols-outlined" style="font-size:15px;color:${meta.color}">${meta.icon}</span>
              </div>
              <div class="notif-body">
                <div class="notif-text" title="${safeText}">${safeText}</div>
                <div class="notif-meta">
                  <span class="notif-module">${safeModule}</span>
                  <span>·</span>
                  <span>${timeAgo(log.created_at)}</span>
                  ${safeUser ? `<span>·</span><span>${safeUser}</span>` : ''}
                </div>
              </div>
            </div>
          `;
        }).join('');

        // Mark as read by interaction: hover or click on notification item
        notifList.querySelectorAll<HTMLElement>('.notif-item.unread').forEach((item) => {
          const markByItem = () => {
            const createdAt = item.dataset.createdAt || new Date().toISOString();
            markNotificationsSeen(createdAt);
          };
          item.addEventListener('mouseenter', markByItem, { once: true });
          item.addEventListener('click', markByItem, { once: true });
        });

      } catch (e) {
        if (notifList) notifList.innerHTML = '<div class="notif-drop-empty">Không thể tải thông báo</div>';
      }
    }

    function markNotificationsSeen(seenAt?: string) {
      const nextSeen = seenAt || new Date().toISOString();
      const currentSeen = localStorage.getItem(NOTIF_SEEN_KEY);

      if (!currentSeen || new Date(nextSeen).getTime() > new Date(currentSeen).getTime()) {
        localStorage.setItem(NOTIF_SEEN_KEY, nextSeen);
      }

      if (notifBadge) {
        notifBadge.style.display = 'none';
        notifBadge.textContent = '';
      }

      notifList?.querySelectorAll('.notif-item.unread').forEach((node) => {
        node.classList.remove('unread');
      });
    }

    function markAllNotificationsSeen() {
      const items = Array.from(notifList?.querySelectorAll<HTMLElement>('.notif-item[data-created-at]') || []);
      if (items.length === 0) {
        markNotificationsSeen();
        return;
      }

      // Use latest notification timestamp so currently listed items are all considered seen.
      let latestSeen = new Date(0).toISOString();
      items.forEach((item) => {
        const createdAt = item.dataset.createdAt;
        if (!createdAt) return;
        if (new Date(createdAt).getTime() > new Date(latestSeen).getTime()) {
          latestSeen = createdAt;
        }
      });

      markNotificationsSeen(latestSeen);
    }

    // Initial badge check (lightweight)
    loadNotifications();

    notifBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = notifDropdown?.classList.contains('open');
      if (isOpen) {
        notifDropdown?.classList.remove('open');
        notifBtn.setAttribute('aria-expanded', 'false');
      } else {
        notifDropdown?.classList.add('open');
        notifBtn.setAttribute('aria-expanded', 'true');
        if (!notifLoaded) {
          notifLoaded = true;
          loadNotifications();
        }

        // Mark as read when user actually interacts with dropdown
        notifDropdown?.addEventListener('mouseenter', () => {
          markNotificationsSeen();
        }, { once: true });
      }
    });

    document.addEventListener('click', (e) => {
      if (notifDropdown?.classList.contains('open')) {
        const wrap = document.querySelector('.notif-wrap');
        if (wrap && !wrap.contains(e.target as Node)) {
          notifDropdown.classList.remove('open');
          notifBtn?.setAttribute('aria-expanded', 'false');
        }
      }
    });

    notifReadAllBtn?.addEventListener('click', () => {
      markAllNotificationsSeen();
    });

    // Mobile sidebar toggle
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const sidebar = document.querySelector('.sidebar');
  const sidebarOverlay = document.getElementById('sidebar-overlay');

  function toggleSidebar() {
    sidebar?.classList.toggle('active');
    sidebarOverlay?.classList.toggle('active');
  }

  hamburgerBtn?.addEventListener('click', toggleSidebar);
  sidebarOverlay?.addEventListener('click', toggleSidebar);

  // Close sidebar when clicking nav link on mobile
  const navLinks = document.querySelectorAll('.nav-link');
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 1024) {
        sidebar?.classList.remove('active');
        sidebarOverlay?.classList.remove('active');
      }
    });
  });

  // ── AUTO LOGOUT (only when "Ghi nhớ đăng nhập" was NOT checked) ──
  (function() {
    const _minutes = (window as any)._autoLogoutMinutes || 120;
    const SESSION_TIMEOUT_MS = _minutes === 0 ? 0 : _minutes * 60 * 1000;
    if (SESSION_TIMEOUT_MS === 0) return; // "Không bao giờ" option
    const WARNING_BEFORE_MS  = 60 * 1000; // Cảnh báo trước 1 phút

    function getCookie(name: string): string {
      const match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
      return match ? decodeURIComponent(match[1]) : '';
    }

    // Chỉ áp dụng khi session là "temporary" (không chọn ghi nhớ)
    if (getCookie('sb-session-type') !== 'temporary') return;

    let logoutTimer: ReturnType<typeof setTimeout>;
    let warningTimer: ReturnType<typeof setTimeout>;
    let warningToast: HTMLElement | null = null;

    function createWarningToast() {
      if (warningToast) return;
      warningToast = document.createElement('div');
      warningToast.id = 'auto-logout-warning';
      warningToast.style.cssText = `
        position:fixed;bottom:24px;right:24px;z-index:99999;
        background:#1a1208;border:1px solid rgba(244,140,37,0.4);
        border-radius:12px;padding:16px 20px;max-width:320px;
        box-shadow:0 8px 32px rgba(0,0,0,0.5);
        display:flex;align-items:center;gap:12px;
        animation:slideInRight 0.3s ease;
      `;
      warningToast.innerHTML = `
        <style>
          @keyframes slideInRight {
            from { transform: translateX(120%); opacity: 0; }
            to   { transform: translateX(0);    opacity: 1; }
          }
        </style>
        <span class="material-symbols-outlined" style="color:#f48c25;font-size:24px;flex-shrink:0;">timer</span>
        <div>
          <div style="font-size:13px;font-weight:700;color:#f1f5f9;margin-bottom:3px;">Sắp tự động đăng xuất</div>
          <div style="font-size:12px;color:#a08060;">Bạn không hoạt động trong thời gian dài. Sẽ đăng xuất sau 1 phút.</div>
          <button id="stay-logged-in-btn" style="margin-top:10px;padding:6px 14px;background:#f48c25;color:#0c0a07;border:none;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">
            Tiếp tục làm việc
          </button>
        </div>
      `;
      document.body.appendChild(warningToast);
      document.getElementById('stay-logged-in-btn')?.addEventListener('click', resetTimers);
    }

    function removeWarningToast() {
      if (warningToast) {
        warningToast.remove();
        warningToast = null;
      }
    }

    async function doLogout() {
      removeWarningToast();
      try {
        await fetch('/api/auth/signout', { method: 'POST' });
      } catch {}
      window.location.href = '/admin/login';
    }

    function resetTimers() {
      clearTimeout(logoutTimer);
      clearTimeout(warningTimer);
      removeWarningToast();

      warningTimer = setTimeout(createWarningToast, SESSION_TIMEOUT_MS - WARNING_BEFORE_MS);
      logoutTimer  = setTimeout(doLogout, SESSION_TIMEOUT_MS);
    }

    // Bắt đầu timer ngay khi load trang
    resetTimers();

    // Reset khi người dùng có hoạt động
    const ACTIVITY_EVENTS = ['mousemove', 'mousedown', 'keydown', 'touchstart', 'scroll', 'click'];
    let throttle: ReturnType<typeof setTimeout> | null = null;
    ACTIVITY_EVENTS.forEach(event => {
      document.addEventListener(event, () => {
        if (throttle) return;
        throttle = setTimeout(() => {
          throttle = null;
          resetTimers();
        }, 10000); // throttle 10 giây để tránh reset liên tục
      }, { passive: true });
    });
  })();
</script>
)}
</body>
</html>
