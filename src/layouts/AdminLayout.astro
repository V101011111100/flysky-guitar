---
interface Props {
  title?: string;
  subtitle?: string;
  activeNav?: string;
}
const { title = 'Admin', subtitle = '', activeNav = 'dashboard' } = Astro.props;
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | FlySky Admin</title>
  <link rel="icon" href="/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet" />
  <style>
    /* ══ RESET ══ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'Manrope', sans-serif;
      background: #221910;
      color: #f1f5f9;
    }

    /* ══ LAYOUT ══ */
    .app-shell {
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    /* ══ SIDEBAR ══ */
    .sidebar {
      width: 288px;
      flex-shrink: 0;
      background: #2d2218;
      border-right: 1px solid #4a3a2a;
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow-y: auto;
    }

    .sidebar::-webkit-scrollbar { width: 4px; }
    .sidebar::-webkit-scrollbar-track { background: transparent; }
    .sidebar::-webkit-scrollbar-thumb { background: #4a3a2a; border-radius: 4px; }

    /* Logo */
    .sidebar-logo {
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .logo-icon {
      width: 40px; height: 40px;
      border-radius: 12px;
      background: #f48c25;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 8px 20px rgba(244,140,37,.3);
      flex-shrink: 0;
    }
    .logo-icon .material-symbols-outlined { font-size: 20px; color: #221910; font-variation-settings:'FILL' 1; }
    .logo-name { font-size: 18px; font-weight: 800; color: #f9fafb; line-height: 1.2; }
    .logo-sub  { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .14em; color: rgba(244,140,37,.7); }

    /* Nav */
    .sidebar-nav { flex: 1; padding: 0 16px; }
    .nav-group { padding: 16px 0; }
    .nav-group + .nav-group { border-top: 1px solid #4a3a2a; }
    .nav-group-label {
      display: block;
      font-size: 10px; font-weight: 700;
      color: #64748b;
      text-transform: uppercase; letter-spacing: .12em;
      padding: 0 12px 8px;
    }
    .nav-link {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 12px; border-radius: 8px;
      text-decoration: none;
      font-size: 13.5px; font-weight: 600;
      color: #94a3b8;
      transition: all .15s;
      margin-bottom: 2px;
    }
    .nav-link:hover { background: rgba(255,255,255,.05); color: #f48c25; }
    .nav-link .material-symbols-outlined { font-size: 20px; }
    .nav-link.active {
      background: #f48c25;
      color: #221910;
      font-weight: 700;
    }
    .nav-link.active .material-symbols-outlined { font-variation-settings: 'FILL' 1; }

    /* Add Product Button */
    .sidebar-add-btn {
      margin: 0 16px 16px;
    }
    .sidebar-add-btn a {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      padding: 12px 16px; border-radius: 12px;
      text-decoration: none;
      font-size: 13px; font-weight: 700;
      color: #f48c25;
      background: rgba(244,140,37,.1);
      border: 1px solid rgba(244,140,37,.2);
      transition: all .15s;
    }
    .sidebar-add-btn a:hover { background: rgba(244,140,37,.2); }
    .sidebar-add-btn .material-symbols-outlined { font-size: 18px; }

    /* ══ MAIN AREA ══ */
    .main-area {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: #221910;
    }

    /* ══ HEADER ══ */
    .topbar {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 32px;
      background: rgba(34,25,16,.9);
      border-bottom: 1px solid #4a3a2a;
      backdrop-filter: blur(12px);
      position: sticky; top: 0; z-index: 20;
    }
    .topbar-title  { font-size: 22px; font-weight: 900; color: #f9fafb; letter-spacing: -.02em; }
    .topbar-sub    { font-size: 13px; color: #94a3b8; margin-top: 3px; }
    .topbar-right  { display: flex; align-items: center; gap: 16px; }
    .notif-btn {
      position: relative;
      background: none; border: none; cursor: pointer;
      color: #94a3b8;
      padding: 8px; border-radius: 50%;
      transition: background .15s;
    }
    .notif-btn:hover { background: rgba(255,255,255,.06); }
    .notif-btn .material-symbols-outlined { font-size: 22px; display: block; }
    .notif-dot {
      position: absolute; top: 8px; right: 8px;
      width: 8px; height: 8px;
      background: #f48c25; border-radius: 50%;
      border: 2px solid #221910;
    }
    .topbar-divider { width: 1px; height: 40px; background: #4a3a2a; }
    .topbar-user { display: flex; align-items: center; gap: 12px; }
    .user-info-text { text-align: right; }
    .user-name  { font-size: 13.5px; font-weight: 700; color: #f9fafb; }
    .user-role  { font-size: 11px; color: #64748b; }
    .user-avatar-wrap {
      width: 40px; height: 40px; border-radius: 50%;
      border: 2px solid rgba(244,140,37,.35);
      padding: 2px;
    }
    .user-avatar-wrap img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; display: block; }

    /* ══ CONTENT SCROLL ══ */
    .content-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 32px;
    }
    .content-scroll::-webkit-scrollbar { width: 6px; }
    .content-scroll::-webkit-scrollbar-track { background: #221910; }
    .content-scroll::-webkit-scrollbar-thumb { background: #4a3a2a; border-radius: 4px; }

    /* ══ SHARED CARD ══ */
    .card {
      background: #2d2218;
      border: 1px solid #4a3a2a;
      border-radius: 16px;
    }
    .card:hover { border-color: rgba(244,140,37,.3); }

    /* ══ BUTTONS ══ */
    .btn-primary {
      background: #f48c25; color: #221910;
      font-weight: 700; font-size: 13px;
      padding: 9px 18px; border-radius: 8px;
      border: none; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      text-decoration: none; white-space: nowrap;
      transition: all .15s;
    }
    .btn-primary:hover { background: #e07b10; }
    .btn-ghost {
      background: none; border: none; cursor: pointer;
      color: #64748b; padding: 8px; border-radius: 8px;
      transition: all .15s;
      display: inline-flex; align-items: center;
    }
    .btn-ghost:hover { background: rgba(244,140,37,.2); color: #f48c25; }

    /* ══ BADGE ══ */
    .badge {
      display: inline-block; padding: 3px 8px;
      border-radius: 4px; font-size: 10px; font-weight: 900;
      text-transform: uppercase; border: 1px solid;
    }
    .badge-new       { background: rgba(244,140,37,.2); color: #f48c25; border-color: rgba(244,140,37,.3); }
    .badge-processing{ background: rgba(59,130,246,.2);  color: #60a5fa; border-color: rgba(59,130,246,.3); }
    .badge-done      { background: rgba(11,218,22,.2);   color: #0bda16; border-color: rgba(11,218,22,.3); }
  </style>
</head>
<body>
<div class="app-shell">

  <!-- ══ SIDEBAR ══ -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">
        <span class="material-symbols-outlined">music_note</span>
      </div>
      <div>
        <div class="logo-name">FlySky Guitar</div>
        <div class="logo-sub">Hệ thống quản trị</div>
      </div>
    </div>

    <nav class="sidebar-nav">
      <!-- Chính -->
      <div class="nav-group">
        <span class="nav-group-label">Chính</span>
        <a href="/admin"            class={`nav-link ${activeNav==='dashboard'     ? 'active' : ''}`}><span class="material-symbols-outlined">dashboard</span>Bảng điều khiển</a>
        <a href="/admin/media"      class={`nav-link ${activeNav==='media'         ? 'active' : ''}`}><span class="material-symbols-outlined">perm_media</span>Thư viện Media</a>
        <a href="/admin/inventory"  class={`nav-link ${activeNav==='inventory'     ? 'active' : ''}`}><span class="material-symbols-outlined">inventory_2</span>Kho hàng</a>
        <a href="/admin/orders"     class={`nav-link ${activeNav==='orders'        ? 'active' : ''}`}><span class="material-symbols-outlined">shopping_cart</span>Đơn hàng</a>
      </div>
      <!-- Quản lý -->
      <div class="nav-group">
        <span class="nav-group-label">Quản lý</span>
        <a href="/admin/consultations" class={`nav-link ${activeNav==='consultations' ? 'active' : ''}`}><span class="material-symbols-outlined">group</span>Khách hàng</a>
        <a href="/admin/messages"      class={`nav-link ${activeNav==='messages'      ? 'active' : ''}`}><span class="material-symbols-outlined">bar_chart</span>Báo cáo</a>
        <a href="/admin/seo"           class={`nav-link ${activeNav==='seo'           ? 'active' : ''}`}><span class="material-symbols-outlined">campaign</span>SEO &amp; Marketing</a>
      </div>

      <!-- Hệ thống -->
      <div class="nav-group">
        <span class="nav-group-label">Hệ thống</span>
        <a href="/admin/permissions" class={`nav-link ${activeNav==='permissions'   ? 'active' : ''}`}><span class="material-symbols-outlined">shield_person</span>Phân quyền</a>
        <a href="/admin/activity-log" class={`nav-link ${activeNav==='activity-log'  ? 'active' : ''}`}><span class="material-symbols-outlined">history_edu</span>Nhật ký hoạt động</a>
        <a href="/admin/settings"   class={`nav-link ${activeNav==='settings'      ? 'active' : ''}`}><span class="material-symbols-outlined">settings</span>Cài đặt</a>
      </div>
    </nav>

    <div class="sidebar-add-btn">
      <a href="/admin/products">
        <span class="material-symbols-outlined">add_circle</span>
        Thêm sản phẩm mới
      </a>
    </div>
  </aside>

  <!-- ══ MAIN ══ -->
  <div class="main-area">
    <header class="topbar">
      <div>
        <h1 class="topbar-title">{title}</h1>
        {subtitle && <p class="topbar-sub">{subtitle}</p>}
      </div>
      <div class="topbar-right">
        <button class="notif-btn">
          <span class="material-symbols-outlined">notifications</span>
          <span class="notif-dot"></span>
        </button>
        <div class="topbar-divider"></div>
        <div class="topbar-user">
          <div class="user-info-text">
            <div class="user-name">Admin FlySky</div>
            <div class="user-role">Quản trị viên</div>
          </div>
          <div class="user-avatar-wrap">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCiM9_T4CXFsjLqj0B8D2uUUGv81xQE90W-3c5L24-iHB3gTOuLm7Fq-yVB4rTXOMs7zwaCdm8df4ADioVuIPUMXCd_OqsGJ679GME24mZXAhHJAz6sj-VDY8EkXqZac9Jre2mAF88bf05gDfNKdB7wkR_shaB-Kebj43ewjUr_nLpjkg0mi-mcwIw4zdTQNtxSan2HHdlOwtLs-FdOXq1kPGGKkO8T6QnbJnsY02SRhLEp-NbIEjuA2FmqQo54y7y9LsY1KEKSWtWo"
              alt="Admin avatar"
            />
          </div>
        </div>
      </div>
    </header>

    <div class="content-scroll">
      <slot />
    </div>
  </div>

</div>

<script>
  if (!sessionStorage.getItem('flysky_admin_token')) {
    window.location.href = '/admin/login';
  }
  function logout() {
    sessionStorage.removeItem('flysky_admin_token');
    window.location.href = '/admin/login';
  }
  (window as any).logout = logout;
</script>
</body>
</html>
