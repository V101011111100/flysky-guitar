---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase';

// Lấy danh mụć thực tế từ DB
const { data: catData } = await supabase.from('categories').select('*');
const categories = [
  { id: 'all', label: 'Tất cả' },
  ...(catData || []).map(c => ({ id: c.slug, label: c.name }))
];

// Lấy sản phẩm từ DB — chỉ hiển thị sản phẩm active & out_of_stock (không hiện draft)
const { data: prodData } = await supabase
  .from('products')
  .select(`*, categories(name, slug)`)
  .in('status', ['active', 'out_of_stock'])
  .order('is_featured', { ascending: false })
  .order('created_at', { ascending: false });

const products = (prodData || []).map(p => ({
  id: p.slug, // using slug as id for URL
  category: p.categories?.slug || 'other',
  categoryLabel: p.categories?.name || 'Khác',
  name: p.name,
  description: p.description ? (p.description.length > 100 ? p.description.substring(0, 100) + '...' : p.description) : 'Nhạc cụ chất lượng cao, chế tác tỉ mỉ.',
  price: p.price,
  priceFormatted: new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.price || 0),
  image: p.main_image_url || 'https://images.unsplash.com/photo-1541689592655-f5f52825a3b8?auto=format&fit=crop&q=80',
  rating: 5,
  reviews: Math.floor(Math.random() * 50) + 10,
  inStock: p.status === 'active',
  badge: p.is_featured ? 'Nổi bật' : (p.status === 'out_of_stock' ? 'Hết hàng' : null)
}));
---

<Layout title="Cửa hàng Guitar | FlySky" description="Khám phá bộ sưu tập guitar điện, acoustic và bass cao cấp tại FlySky. Chất lượng thủ công, âm thanh đỉnh cao.">
  <Navbar />

  <!-- Page Hero -->
  <section class="relative py-20 bg-background-dark overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(244,140,37,0.12)_0%,_transparent_60%)]"></div>
    <div class="mx-auto max-w-7xl px-4 lg:px-10 relative z-10 text-center">
      <span class="text-primary font-bold tracking-widest uppercase text-sm">FlySky Store</span>
      <h1 class="text-white text-4xl lg:text-5xl font-extrabold mt-3 mb-4">Bộ Sưu Tập Guitar</h1>
      <p class="text-text-muted text-lg max-w-xl mx-auto">Khám phá từng cây đàn được chế tác tỉ mỉ — từ guitar điện cháy bỏng đến acoustic thuần khiết và bass trầm ấm.</p>
    </div>
  </section>

  <!-- Filter + Grid -->
  <section class="py-14 bg-background-dark min-h-screen">
    <div class="mx-auto max-w-7xl px-4 lg:px-10">

      <!-- Category Filter Tabs -->
      <div class="flex flex-wrap items-center gap-3 mb-10" id="filter-tabs">
        {categories.map((cat) => (
          <button
            data-cat={cat.id}
            class="filter-btn px-5 py-2 rounded-full text-sm font-semibold border transition-all duration-200 bg-transparent text-white/70 border-border-dark hover:border-primary hover:text-primary"
          >
            {cat.label}
          </button>
        ))}

        <!-- Sort -->
        <div class="ml-auto flex items-center gap-2">
          <span class="text-text-muted text-sm hidden sm:inline">Sắp xếp:</span>
          <select id="sort-select" class="bg-card-dark border border-border-dark text-white text-sm rounded-lg px-3 py-2 focus:ring-1 focus:ring-primary outline-none cursor-pointer">
            <option value="default">Mặc định</option>
            <option value="price-asc">Giá tăng dần</option>
            <option value="price-desc">Giá giảm dần</option>
            <option value="rating">Đánh giá cao nhất</option>
          </select>
        </div>
      </div>

      <!-- Results count -->
      <p class="text-text-muted text-sm mb-6">Hiển thị <span id="count-num">{products.length}</span> sản phẩm</p>

      <!-- Product Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="product-grid">
        {products.map((product) => (
          <a
            href={`/products/${product.id}`}
            class={`product-card group flex flex-col bg-card-dark rounded-xl overflow-hidden transition-all duration-300 border cursor-pointer ${product.inStock ? 'hover:shadow-[0_0_24px_rgba(244,140,37,0.18)] border-border-dark' : 'border-border-dark/40 opacity-70'}`}
            data-cat={product.category}
            data-price={product.price}
            data-rating={product.rating}
            data-instock={product.inStock ? '1' : '0'}
          >
            <!-- Image -->
            <div class="aspect-square w-full bg-[#2a2015] relative p-4 flex items-center justify-center overflow-hidden">
              <div
                class="w-full h-full bg-contain bg-center bg-no-repeat group-hover:scale-110 transition-transform duration-500"
                style={`background-image: url("${product.image}");`}
              ></div>
              {product.badge && (
                <div class={`absolute top-3 left-3 text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider ${product.inStock ? 'bg-primary text-background-dark' : 'bg-white/20 text-white/80'}`}>
                  {product.badge}
                </div>
              )}
              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <span class="bg-primary text-background-dark font-bold text-sm px-5 py-2.5 rounded-full flex items-center gap-2">
                  <span class="material-symbols-outlined text-[18px]">visibility</span>
                  Xem chi tiết
                </span>
              </div>
            </div>

            <!-- Info -->
            <div class="p-4 flex flex-col gap-2 flex-grow">
              <span class="text-primary text-xs font-bold uppercase tracking-wider">{product.categoryLabel}</span>
              <h3 class="text-white text-base font-bold group-hover:text-primary transition-colors leading-tight">{product.name}</h3>
              <p class="text-text-muted text-xs leading-relaxed">{product.description}</p>

              <!-- Stars -->
              <div class="flex items-center gap-1 mt-1">
                {Array.from({ length: 5 }).map((_, i) => (
                  <span class={`material-symbols-outlined text-[14px] ${i < product.rating ? 'text-primary' : 'text-border-dark'}`} style="font-variation-settings: 'FILL' 1">star</span>
                ))}
                <span class="text-text-muted text-xs ml-1">({product.reviews})</span>
              </div>

              <!-- Price + Arrow -->
              <div class="mt-auto flex items-center justify-between pt-3 border-t border-border-dark/50">
                <span class={`font-extrabold text-base ${product.inStock ? 'text-white' : 'text-white/50 line-through'}`}>{product.priceFormatted}</span>
                {product.inStock ? (
                  <span class="bg-border-dark group-hover:bg-primary text-white group-hover:text-background-dark rounded-full p-2 transition-colors">
                    <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                  </span>
                ) : (
                  <span class="text-white/40 text-xs font-bold">Hết hàng</span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-24">
        <span class="material-symbols-outlined text-5xl text-border-dark mb-4 block">search_off</span>
        <p class="text-text-muted text-lg">Không tìm thấy sản phẩm phù hợp.</p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.product-card');
  const countNum = document.getElementById('count-num');
  const emptyState = document.getElementById('empty-state');
  const grid = document.getElementById('product-grid');
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;

  // Đọc URL param ?category= để pre-filter
  const urlParam = new URLSearchParams(window.location.search).get('category') || 'all';
  let currentCat = urlParam;
  let currentSort = 'default';

  function setActiveBtn(catId: string) {
    filterBtns.forEach(b => {
      const active = b.dataset.cat === catId;
      b.classList.toggle('bg-primary', active);
      b.classList.toggle('text-background-dark', active);
      b.classList.toggle('border-primary', active);
      b.classList.toggle('text-white/70', !active);
      b.classList.toggle('bg-transparent', !active);
    });
  }

  function applyFilters() {
    const visible: HTMLElement[] = [];

    cards.forEach((card) => {
      const cat = card.dataset.cat || '';
      const show = currentCat === 'all' || cat === currentCat;
      (card as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible.push(card);
    });

    if (currentSort !== 'default' && grid) {
      const sorted = [...grid.querySelectorAll<HTMLElement>('.product-card')].filter(c => c.style.display !== 'none');
      sorted.sort((a, b) => {
        if (currentSort === 'price-asc') return Number(a.dataset.price) - Number(b.dataset.price);
        if (currentSort === 'price-desc') return Number(b.dataset.price) - Number(a.dataset.price);
        if (currentSort === 'rating') return Number(b.dataset.rating) - Number(a.dataset.rating);
        return 0;
      });
      sorted.forEach(card => grid.appendChild(card));
    }

    if (countNum) countNum.textContent = String(visible.length);
    if (emptyState) emptyState.classList.toggle('hidden', visible.length > 0);
  }

  // Apply URL param on load
  setActiveBtn(currentCat);
  applyFilters();

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      currentCat = btn.dataset.cat || 'all';
      setActiveBtn(currentCat);
      applyFilters();
    });
  });

  sortSelect?.addEventListener('change', () => {
    currentSort = sortSelect.value;
    applyFilters();
  });
</script>
