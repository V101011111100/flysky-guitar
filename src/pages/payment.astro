---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase';

// Lấy cài đặt thanh toán từ DB Server-side
const { data: settingsData } = await supabase
  .from('site_settings')
  .select('*')
  .in('key', ['flysky_bankName', 'flysky_bankAccountName', 'flysky_bankAccountNumber', 'flysky_momoPartnerCode', 'flysky_momoAccessKey', 'flysky_momoSecretKey']);

const getSetting = (key: string, _default: string) => {
  const item = settingsData?.find((s: any) => s.key === key);
  return item ? item.value : _default;
};

const bankName = getSetting('flysky_bankName', 'BIDV');
const bankAccountName = getSetting('flysky_bankAccountName', 'CÔNG TY TNHH FLYSKY GUITAR');
const bankAccountNumber = getSetting('flysky_bankAccountNumber', '1234567890');
// momo config
const momoPartnerCode = getSetting('flysky_momoPartnerCode', '');
const momoAccessKey = getSetting('flysky_momoAccessKey', '');
---

<Layout title="Thanh toán đơn hàng | FlySky Guitar" description="Trang thanh toán đơn hàng an toàn.">
  <Navbar />

  <section class="py-12 bg-background-dark min-h-screen">
    <div class="mx-auto max-w-4xl px-4 lg:px-10">
      
      <div id="payment-loading" class="text-center py-20">
        <span class="material-symbols-outlined animate-spin text-4xl text-primary mb-4 block">autorenew</span>
        <p class="text-text-muted">Đang tải thông tin đơn hàng...</p>
      </div>

      <div id="payment-content" class="hidden">
        <div class="text-center mb-10">
          <span class="material-symbols-outlined text-green-500 text-5xl mb-2 block">check_circle</span>
          <h1 class="text-white text-3xl font-extrabold mb-2">Đơn hàng đã được tạo!</h1>
          <p class="text-text-muted text-sm">Vui lòng hoàn tất thanh toán để chúng tôi xử lý đơn hàng.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          
          <!-- Order Summary Sidebar -->
          <div class="bg-card-dark border border-border-dark rounded-2xl p-6 h-fit">
            <h2 class="text-white font-bold text-lg mb-4">Mã đơn: <span id="display-order-num" class="text-primary"></span></h2>
            
            <div class="space-y-4 mb-6">
              <div class="flex justify-between items-center text-sm">
                <span class="text-text-muted">Khách hàng:</span>
                <span id="display-name" class="text-white font-medium"></span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-text-muted">Số điện thoại:</span>
                <span id="display-phone" class="text-white font-medium"></span>
              </div>
              <div class="flex justify-between items-center text-sm border-t border-border-dark pt-4">
                <span class="text-white font-bold">Tổng thanh toán:</span>
                <span id="display-total" class="text-primary text-xl font-extrabold"></span>
              </div>
            </div>

            <p class="text-xs text-text-muted flex items-start gap-2">
              <span class="material-symbols-outlined text-[16px] text-yellow-500">info</span>
              Đơn hàng sẽ tự động cập nhật trạng thái "Đã thanh toán" nếu bạn chuyển khoản đúng nội dung và số tiền.
            </p>
          </div>

          <!-- Payment Methods -->
          <div class="bg-card-dark border border-border-dark rounded-2xl overflow-hidden flex flex-col">
            <div class="flex border-b border-border-dark">
              <button id="tab-btn-bank" class="flex-1 py-4 text-sm font-bold text-white bg-primary/10 border-b-2 border-primary transition-all">Chuyển khoản / VietQR</button>
              <button id="tab-btn-momo" class="flex-1 py-4 text-sm font-bold text-text-muted hover:text-white transition-all">Ví MoMo</button>
              <button id="tab-btn-visa" class="flex-1 py-4 text-sm font-bold text-text-muted hover:text-white transition-all">Thẻ Visa/Master</button>
            </div>

            <div class="p-6 flex-1 bg-background-dark/30 relative">
              
              <!-- Tab Bank -->
              <div id="tab-pane-bank" class="block animate-fade-in text-center">
                <h3 class="text-white font-bold text-md mb-2">Quét mã VietQR để thanh toán</h3>
                <p class="text-text-muted text-xs mb-6">Mở app Ngân hàng > Quét mã QR > Kiểm tra thông tin & Xác nhận</p>

                <div class="bg-white p-4 rounded-xl inline-block mx-auto mb-6 shadow-[0_0_30px_rgba(255,255,255,0.1)] transition-transform hover:scale-105">
                  <!-- QR img will be dynamically generated by JS -->
                  <img id="vietqr-img" src="" alt="VietQR" class="w-48 h-48 object-contain" />
                </div>

                <div class="text-left bg-card-dark rounded-xl p-4 border border-border-dark space-y-3">
                  <div class="flex justify-between items-center">
                    <span class="text-text-muted text-xs">Ngân hàng:</span>
                    <span class="text-white text-sm font-medium">{bankName}</span>
                  </div>
                  <div class="flex justify-between items-center">
                    <span class="text-text-muted text-xs">Chủ tài khoản:</span>
                    <span class="text-white text-sm font-medium">{bankAccountName}</span>
                  </div>
                  <div class="flex justify-between items-center">
                    <span class="text-text-muted text-xs">Số tài khoản:</span>
                    <span class="text-white text-sm font-bold flex items-center gap-2">
                       {bankAccountNumber}
                       <button class="material-symbols-outlined text-[16px] text-primary hover:text-white transition-colors" onclick={`navigator.clipboard.writeText('${bankAccountNumber}');alert('Đã copy STK')`}>content_copy</button>
                    </span>
                  </div>
                  <div class="flex justify-between items-center">
                    <span class="text-text-muted text-xs">Nội dung (Bắt buộc):</span>
                    <span class="text-white text-sm font-bold flex items-center gap-2">
                       <span id="qr-content" class="text-primary"></span>
                       <button class="material-symbols-outlined text-[16px] text-primary hover:text-white transition-colors" id="btn-copy-content">content_copy</button>
                    </span>
                  </div>
                </div>
              </div>

              <!-- Tab MoMo -->
              <div id="tab-pane-momo" class="hidden animate-fade-in text-center">
                 <div class="w-16 h-16 mx-auto bg-[#A50064] rounded-2xl flex items-center justify-center mb-4 mt-6">
                    <span class="text-white font-bold text-xl">MoMo</span>
                 </div>
                 <h3 class="text-white font-bold text-md mb-2">Thanh toán qua Ví MoMo</h3>
                 <p class="text-text-muted text-xs mb-6">Tính năng đang kích hoạt (BETA). Tạm thời sử dụng chuyển khoản thủ công nếu MoMo lỗi.</p>

                 {momoPartnerCode ? (
                    <button class="w-full bg-[#A50064] hover:bg-[#8A0054] text-white font-bold py-3 rounded-xl transition-colors">
                      Mở ứng dụng MoMo ngay
                    </button>
                 ) : (
                    <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl text-sm">
                      Admin chưa cấu hình API MoMo. Vui lòng chọn Chuyển khoản ngân hàng.
                    </div>
                 )}
              </div>

              <!-- Tab Visa -->
              <div id="tab-pane-visa" class="hidden animate-fade-in text-center">
                 <div class="flex justify-center gap-2 mb-6 mt-6">
                    <div class="h-10 px-4 bg-white rounded flex items-center shadow-sm">
                      <span class="text-blue-800 font-extrabold italic text-lg tracking-tighter">VISA</span>
                    </div>
                    <div class="h-10 px-2 bg-black rounded flex items-center shadow-sm">
                       <div class="w-6 h-6 rounded-full bg-red-500 opacity-80 mix-blend-screen -mr-2"></div>
                       <div class="w-6 h-6 rounded-full bg-yellow-500 opacity-80 mix-blend-screen"></div>
                    </div>
                 </div>
                 <h3 class="text-white font-bold text-md mb-2">Thanh toán qua Thẻ Quốc tế</h3>
                 <p class="text-text-muted text-xs mb-6">Hỗ trợ Visa, Mastercard, JCB, Amex.</p>

                 <div class="bg-blue-500/10 border border-blue-500/20 text-blue-400 p-4 rounded-xl text-sm">
                      Cổng thanh toán thẻ đang được tích hợp. Vui lòng quay lại sau hoặc chọn Chuyển khoản.
                 </div>
              </div>

            </div>
          </div>

        </div>

        <div class="mt-10 text-center">
            <a href="/order-success" class="text-primary hover:text-white transition-colors text-sm font-bold flex items-center justify-center gap-1">
              Đi đến trang hoàn tất đơn hàng <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </a>
            <p class="text-text-muted text-xs mt-2">Nhấn vào đây nếu bạn đã thanh toán xong.</p>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<script define:vars={{ bankName, bankAccountNumber, bankAccountName }}>
  function formatPrice(n) {
    return n.toLocaleString('vi-VN') + '₫';
  }

  // Handle Tab switching
  const tabs = ['bank', 'momo', 'visa'];
  tabs.forEach(tab => {
    document.getElementById(`tab-btn-${tab}`)?.addEventListener('click', () => {
      // styles buttons
      tabs.forEach(t => {
        const btn = document.getElementById(`tab-btn-${t}`);
        if(t === tab) {
          btn?.classList.add('bg-primary/10', 'border-primary', 'text-white', 'border-b-2');
          btn?.classList.remove('text-text-muted');
        } else {
          btn?.classList.remove('bg-primary/10', 'border-primary', 'text-white', 'border-b-2');
          btn?.classList.add('text-text-muted');
        }
      });
      // hide/show panes
      tabs.forEach(t => {
        const pane = document.getElementById(`tab-pane-${t}`);
        if(t === tab) {
            pane?.classList.remove('hidden');
            pane?.classList.add('block');
        } else {
            pane?.classList.add('hidden');
            pane?.classList.remove('block');
        }
      });
    });
  });

  const initPayment = () => {
    const orderStr = sessionStorage.getItem('flysky_order');
    if (!orderStr) {
      window.location.href = '/cart'; // No order found, redirect to cart
      return;
    }

    try {
      const order = JSON.parse(orderStr);
      
      document.getElementById('display-order-num').textContent = order.orderNum;
      document.getElementById('display-name').textContent = order.name;
      document.getElementById('display-phone').textContent = order.phone;
      document.getElementById('display-total').textContent = formatPrice(order.total);

      // Remove spaces & diacritics from accountName just in case to avoid URL bugs
      const qrDesc = encodeURIComponent(order.orderNum);
      const qrAccName = encodeURIComponent(bankAccountName);

      const qrUrl = `https://img.vietqr.io/image/${bankName}-${bankAccountNumber}-compact2.jpg?amount=${order.total}&addInfo=${qrDesc}&accountName=${qrAccName}`;
      document.getElementById('vietqr-img').src = qrUrl;

      document.getElementById('qr-content').textContent = order.orderNum;
      
      document.getElementById('btn-copy-content')?.addEventListener('click', () => {
         navigator.clipboard.writeText(order.orderNum);
         alert('Đã copy Nội dung chuyển khoản');
      });

      document.getElementById('payment-loading')?.classList.add('hidden');
      document.getElementById('payment-content')?.classList.remove('hidden');

    } catch (e) {
      console.error(e);
      window.location.href = '/cart';
    }
  };

  initPayment();
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s ease forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
