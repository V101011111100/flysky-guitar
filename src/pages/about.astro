---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase';

const { data: rows } = await supabase.from('site_settings').select('key, value');
const s: Record<string,string> = {};
(rows || []).forEach((r: any) => { s[r.key] = r.value ?? ''; });
const g = (k: string, d: string) => s[k] || d;

const heroTag      = g('flysky_about_hero_tag',       'Ve chung toi');
const heroH1       = g('flysky_about_hero_h1',        'Mang am nhac dich thuc');
const heroH1hi     = g('flysky_about_hero_h1hi',      'cham den tam hon ban');
const heroDesc     = g('flysky_about_hero_desc',      "Hanh trinh cua FlySky Guitar khong chi la mua ban nhac cu. Chung toi duoc sinh ra tu niem dam me che tac va khao khat ket noi nhung nguoi yeu nhac voi nhung cay dan co 'linh hon' thuc su.");
const heroImage    = g('flysky_about_hero_image',     'https://images.unsplash.com/photo-1550985543-f47f38aeeaec?q=80&w=2070&auto=format&fit=crop');
const heroYears    = g('flysky_about_hero_years',     '10 Nam');
const heroYearsSub = g('flysky_about_hero_years_sub', 'Kinh nghiem phan phoi & che tac');

const valTitle = g('flysky_about_values_title', 'Gia tri cot loi');
const valDesc  = g('flysky_about_values_desc',  'Chung toi cam ket duy tri 3 nguyen tac vang trong moi san pham va dich vu ma FlySky Guitar cung cap den tay khach hang.');
const values = [
  { icon: 'verified',   title: g('flysky_about_val1_title','Chat luong nguyen ban'), desc: g('flysky_about_val1_desc','Moi cay dan deu duoc trai qua quy trinh danh gia khat khe truoc khi len ke, dam bao am thanh va cau tao hoan hao nhat.') },
  { icon: 'handshake',  title: g('flysky_about_val2_title','Dong hanh tan tam'),     desc: g('flysky_about_val2_desc','Khong chi ban hang, chung toi o day de ho tro, tu van ky thuat va bao hanh bao duong tron doi cho ban.') },
  { icon: 'music_note', title: g('flysky_about_val3_title','Tinh than nghe sy'),     desc: g('flysky_about_val3_desc','Ton trong su da dang trong phong cach choi. Moi cay dan mang mot cau chuyen phu hop voi ca tinh cua tung nguoi tho.') },
];

const tlTitle = g('flysky_about_timeline_title', 'Cot moc dang nho');
const tlDesc  = g('flysky_about_timeline_desc',  'Nhung dau an hinh thanh nen thuong hieu ngay hom nay.');
const milestones = [
  { year: g('flysky_about_mile1_year','2016'),       title: g('flysky_about_mile1_title','Loi chao san'),         desc: g('flysky_about_mile1_desc','FlySky Guitar duoc hinh thanh nhu mot xuong sua chua va chinh am nho tai Da Nang, phuc vu anh em choi nhac indie dia phuong.'), active: true },
  { year: g('flysky_about_mile2_year','2019'),       title: g('flysky_about_mile2_title','Showroom dau tien'),    desc: g('flysky_about_mile2_desc','Sau 3 nam tich luy, chung toi chinh thuc khai truong showroom offline dau tien tren duong Le Thien Tri va ky ket hop dong phan phoi chinh thuc voi cac thuong hieu lon.'), active: false },
  { year: g('flysky_about_mile3_year','2023 - NAY'), title: g('flysky_about_mile3_title','Vuon xa manh me'),      desc: g('flysky_about_mile3_desc','Tro thanh doi tac lon, nang cap trai nghiem mua ban truc tuyen toan quoc va mang den nhung dac quyen bao hanh chua tung co.'), active: false },
];
---

<Layout title="Cau chuyen thuong hieu | FlySky Guitar" description="Tim hieu ve hanh trinh, su menh va dam me danh cho am nhac cua FlySky Guitar.">
  <Navbar />

  <!-- Breadcrumb -->
  <div class="bg-background-dark border-b border-border-dark/50">
    <div class="mx-auto max-w-7xl px-4 lg:px-10 py-3 flex items-center gap-2 text-sm text-text-muted">
      <a href="/" class="hover:text-primary transition-colors">Trang chu</a>
      <span class="material-symbols-outlined text-[14px]">chevron_right</span>
      <span class="text-white/60">Cau chuyen thuong hieu</span>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="relative py-20 lg:py-28 overflow-hidden bg-background-dark">
    <div class="absolute inset-0 bg-gradient-to-tr from-primary/10 via-background-dark to-background-dark z-0"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary/20 blur-[100px] rounded-full mix-blend-screen opacity-50 z-0 pointer-events-none"></div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-10 z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold mb-6 tracking-wider uppercase">
            <span class="material-symbols-outlined text-[16px]">history_edu</span>
            {heroTag}
          </div>
          <h1 class="text-white text-4xl lg:text-5xl font-extrabold mb-6 leading-tight">
            {heroH1} <br/><span class="text-primary italic">{heroH1hi}</span>
          </h1>
          <p class="text-text-muted text-base lg:text-lg mb-8 leading-relaxed">{heroDesc}</p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/shop" class="bg-primary hover:bg-primary/90 text-background-dark font-extrabold py-3 px-8 rounded-xl transition-all hover:shadow-[0_0_15px_rgba(244,140,37,0.4)] text-center flex items-center justify-center gap-2">
              Xem san pham
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
            <a href="/contact" class="bg-card-dark hover:bg-border-dark text-white font-semibold py-3 px-8 rounded-xl border border-border-dark transition-all text-center">
              Lien he hop tac
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-3xl overflow-hidden border border-border-dark/50 relative shadow-2xl z-10 group">
            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors z-10"></div>
            <img src={heroImage} alt="Guitar workshop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute bottom-6 left-6 z-20">
              <div class="bg-background-dark/80 backdrop-blur-md rounded-2xl p-4 border border-white/10 flex items-center gap-4">
                <div class="p-3 bg-primary rounded-xl flex items-center justify-center text-background-dark">
                  <span class="material-symbols-outlined text-2xl">workspace_premium</span>
                </div>
                <div>
                  <p class="text-white font-bold text-lg">{heroYears}</p>
                  <p class="text-text-muted text-xs">{heroYearsSub}</p>
                </div>
              </div>
            </div>
          </div>
          <div class="absolute -top-6 -right-6 w-full h-full border-2 border-primary/30 rounded-3xl -z-0"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="py-20 bg-card-dark border-t border-border-dark/50 border-b">
    <div class="mx-auto max-w-7xl px-4 lg:px-10">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-white text-3xl font-bold mb-4">{valTitle}</h2>
        <p class="text-text-muted">{valDesc}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        {values.map(item => (
          <div class="bg-background-dark p-8 rounded-3xl border border-border-dark flex flex-col items-center group hover:border-primary/50 transition-colors">
            <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-colors group-hover:scale-110 duration-300">
              <span class="material-symbols-outlined text-primary text-3xl">{item.icon}</span>
            </div>
            <h3 class="text-white text-xl font-bold mb-3">{item.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-24 bg-background-dark">
    <div class="mx-auto max-w-3xl px-4 lg:px-10">
      <div class="text-left mb-16">
        <h2 class="text-white text-3xl font-bold mb-4">{tlTitle}</h2>
        <p class="text-text-muted">{tlDesc}</p>
      </div>
      <div class="relative border-l-2 border-border-dark pl-8 ml-4 lg:ml-0 space-y-12">
        {milestones.map(m => (
          <div class="relative">
            <div class={`absolute -left-[41px] top-1 w-5 h-5 rounded-full border-4 border-background-dark ${m.active ? 'bg-primary' : 'bg-border-dark'}`}></div>
            <p class={`font-bold text-sm mb-1 tracking-widest ${m.active ? 'text-primary' : 'text-text-muted'}`}>{m.year}</p>
            <h4 class="text-white text-lg font-bold mb-2">{m.title}</h4>
            <p class="text-text-muted text-sm leading-relaxed">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>