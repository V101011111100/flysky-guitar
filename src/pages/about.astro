---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase';
import { getAdminMfaState } from '../lib/security';

let isAdmin = false;
const accessToken = Astro.cookies.get('sb-access-token');
const refreshToken = Astro.cookies.get('sb-refresh-token');

if (accessToken && refreshToken) {
  const authState = await getAdminMfaState(accessToken.value, refreshToken.value);
  isAdmin = authState.authenticated && authState.isAdmin && !authState.requiresMfa;
}

const { data: rows } = await supabase.from('site_settings').select('key, value');
const s: Record<string,string> = {};
(rows || []).forEach((r: any) => { s[r.key] = r.value ?? ''; });
const g = (k: string, d: string) => s[k] || d;

const heroTag      = g('flysky_about_hero_tag',       'Về chúng tôi');
const heroH1       = g('flysky_about_hero_h1',        'Mang âm nhạc đích thực');
const heroH1hi     = g('flysky_about_hero_h1hi',      'chạm đến tâm hồn bạn');
const heroDesc     = g('flysky_about_hero_desc',      "Hành trình của FlySky Guitar không chỉ là mua bán nhạc cụ. Chúng tôi được sinh ra từ niềm đam mê chế tác và khao khát kết nối những người yêu nhạc với những cây đàn có 'linh hồn' thực sự.");
const heroImage    = g('flysky_about_hero_image',     'https://images.unsplash.com/photo-1550985543-f47f38aeeaec?q=80&w=2070&auto=format&fit=crop');
const heroYears    = g('flysky_about_hero_years',     '10 Năm');
const heroYearsSub = g('flysky_about_hero_years_sub', 'Kinh nghiệm phân phối & chế tác');

const valTitle = g('flysky_about_values_title', 'Giá trị cốt lõi');
const valDesc  = g('flysky_about_values_desc',  'Chúng tôi cam kết duy trì 3 nguyên tắc vàng trong mọi sản phẩm và dịch vụ mà FlySky Guitar cung cấp đến tay khách hàng.');
const values = [
  { icon: 'verified',   title: g('flysky_about_val1_title','Chất lượng nguyên bản'), desc: g('flysky_about_val1_desc','Mọi cây đàn đều được trải qua quy trình đánh giá khắt khe trước khi lên kệ, đảm bảo âm thanh và cấu tạo hoàn hảo nhất.') },
  { icon: 'handshake',  title: g('flysky_about_val2_title','Đồng hành tận tâm'),     desc: g('flysky_about_val2_desc','Không chỉ bán hàng, chúng tôi ở đây để hỗ trợ, tư vấn kỹ thuật và bảo hành bảo dưỡng trọn đời cho bạn.') },
  { icon: 'music_note', title: g('flysky_about_val3_title','Tinh thần nghệ sĩ'),     desc: g('flysky_about_val3_desc','Tôn trọng sự đa dạng trong phong cách chơi. Mỗi cây đàn mang một câu chuyện phù hợp với cá tính của từng người thợ.') },
];

const tlTitle = g('flysky_about_timeline_title', 'Cột mốc đáng nhớ');
const tlDesc  = g('flysky_about_timeline_desc',  'Những dấu ấn hình thành nên thương hiệu ngày hôm nay.');
const defaultMilestones = [
  { year: g('flysky_about_mile1_year','2016'),       title: g('flysky_about_mile1_title','Lời chào sân'),         desc: g('flysky_about_mile1_desc','FlySky Guitar được hình thành như một xưởng sửa chữa và chỉnh âm nhỏ tại Đà Nẵng, phục vụ anh em chơi nhạc indie địa phương.') },
  { year: g('flysky_about_mile2_year','2019'),       title: g('flysky_about_mile2_title','Showroom đầu tiên'),    desc: g('flysky_about_mile2_desc','Sau 3 năm tích lũy, chúng tôi chính thức khai trương showroom offline đầu tiên trên đường Lê Thiện Trị và ký kết hợp đồng phân phối chính thức với các thương hiệu lớn.') },
  { year: g('flysky_about_mile3_year','2023 - NAY'), title: g('flysky_about_mile3_title','Vươn xa mạnh mẽ'),      desc: g('flysky_about_mile3_desc','Trở thành đối tác lớn, nâng cấp trải nghiệm mua bán trực tuyến toàn quốc và mang đến những đặc quyền bảo hành chưa từng có.') },
];

let milestones = defaultMilestones.map((item, idx) => ({ ...item, active: idx === 0 }));
const timelineItemsRaw = g('flysky_about_timeline_items', '');
if (timelineItemsRaw) {
  try {
    const parsed = JSON.parse(timelineItemsRaw);
    if (Array.isArray(parsed) && parsed.length > 0) {
      milestones = parsed.map((item: any, idx: number) => ({
        year: typeof item?.year === 'string' && item.year.trim() ? item.year.trim() : `Mốc ${idx + 1}`,
        title: typeof item?.title === 'string' && item.title.trim() ? item.title.trim() : 'Tiêu đề mốc',
        desc: typeof item?.desc === 'string' && item.desc.trim() ? item.desc.trim() : 'Mô tả mốc thời gian',
        active: idx === 0,
      }));
    }
  } catch {
    // Keep fallback milestones when saved JSON is invalid.
  }
}
---

<Layout title="Câu chuyện thương hiệu | FlySky Guitar" description="Tìm hiểu về hành trình, sứ mệnh và đam mê dành cho âm nhạc của FlySky Guitar.">
  <Navbar />

  <!-- Breadcrumb -->
  <div class="bg-background-dark border-b border-border-dark/50">
    <div class="mx-auto max-w-7xl px-4 lg:px-10 py-3 flex items-center gap-2 text-sm text-text-muted">
      <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
      <span class="material-symbols-outlined text-[14px]">chevron_right</span>
      <span class="text-white/60">Câu chuyện thương hiệu</span>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="relative py-20 lg:py-28 overflow-hidden bg-background-dark">
    <div class="absolute inset-0 bg-gradient-to-tr from-primary/10 via-background-dark to-background-dark z-0"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary/20 blur-[100px] rounded-full mix-blend-screen opacity-50 z-0 pointer-events-none"></div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-10 z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold mb-6 tracking-wider uppercase">
            <span class="material-symbols-outlined text-[16px]">history_edu</span>
            <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_about_hero_tag' : undefined}>{heroTag}</span>
          </div>
          <h1 class="text-white text-4xl lg:text-5xl font-extrabold mb-6 leading-tight">
            <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_about_hero_h1' : undefined}>{heroH1}</span> <br/><span class={`text-primary italic ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_about_hero_h1hi' : undefined}>{heroH1hi}</span>
          </h1>
          <p class={`text-text-muted text-base lg:text-lg mb-8 leading-relaxed ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_about_hero_desc' : undefined}>{heroDesc}</p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/shop" class="bg-primary hover:bg-primary/90 text-background-dark font-extrabold py-3 px-8 rounded-xl transition-all hover:shadow-[0_0_15px_rgba(244,140,37,0.4)] text-center flex items-center justify-center gap-2">
              Xem sản phẩm
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
            <a href="/contact" class="bg-card-dark hover:bg-border-dark text-white font-semibold py-3 px-8 rounded-xl border border-border-dark transition-all text-center">
              Liên hệ hợp tác
            </a>
          </div>
        </div>
        <div class="relative">
          <div class={`aspect-[4/3] rounded-3xl overflow-hidden border border-border-dark/50 relative shadow-2xl z-10 group ${isAdmin ? 'quick-image-editable' : ''}`} data-image-setting={isAdmin ? 'flysky_about_hero_image' : undefined}>
            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors z-10"></div>
            <img src={heroImage} alt="Guitar workshop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            {isAdmin && (
              <div class="quick-image-overlay">
                <span class="material-symbols-outlined text-[18px]">upload</span>
                Kéo ảnh vào hoặc bấm để đổi
              </div>
            )}
            <div class="absolute bottom-6 left-6 z-20">
              <div class="bg-background-dark/80 backdrop-blur-md rounded-2xl p-4 border border-white/10 flex items-center gap-4">
                <div class="p-3 bg-primary rounded-xl flex items-center justify-center text-background-dark">
                  <span class="material-symbols-outlined text-2xl">workspace_premium</span>
                </div>
                <div>
                  <p class={`text-white font-bold text-lg ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_about_hero_years' : undefined}>{heroYears}</p>
                  <p class={`text-text-muted text-xs ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_about_hero_years_sub' : undefined}>{heroYearsSub}</p>
                </div>
              </div>
            </div>
          </div>
          <div class="absolute -top-6 -right-6 w-full h-full border-2 border-primary/30 rounded-3xl -z-0"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="py-20 bg-card-dark border-t border-border-dark/50 border-b">
    <div class="mx-auto max-w-7xl px-4 lg:px-10">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class={`text-white text-3xl font-bold mb-4 ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_about_values_title' : undefined}>{valTitle}</h2>
        <p class={`text-text-muted ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_about_values_desc' : undefined}>{valDesc}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        {values.map((item, index) => (
          <div class="bg-background-dark p-8 rounded-3xl border border-border-dark flex flex-col items-center group hover:border-primary/50 transition-colors">
            <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-colors group-hover:scale-110 duration-300">
              <span class="material-symbols-outlined text-primary text-3xl">{item.icon}</span>
            </div>
            <h3 class={`text-white text-xl font-bold mb-3 ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? `flysky_about_val${index + 1}_title` : undefined}>{item.title}</h3>
            <p class={`text-text-muted text-sm leading-relaxed ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? `flysky_about_val${index + 1}_desc` : undefined}>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-24 bg-background-dark">
    <div class="mx-auto max-w-3xl px-4 lg:px-10">
      <div class="text-left mb-16">
        <h2 class={`text-white text-3xl font-bold mb-4 ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_about_timeline_title' : undefined}>{tlTitle}</h2>
        <p class={`text-text-muted ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_about_timeline_desc' : undefined}>{tlDesc}</p>
      </div>
      <div id="about-timeline-list" class="relative border-l-2 border-border-dark pl-8 ml-4 lg:ml-0 space-y-12">
        {milestones.map((m) => (
          <div class="relative" data-timeline-item>
            <div class={`absolute -left-[41px] top-1 w-5 h-5 rounded-full border-4 border-background-dark ${m.active ? 'bg-primary' : 'bg-border-dark'}`}></div>
            <p class={`font-bold text-sm mb-1 tracking-widest ${m.active ? 'text-primary' : 'text-text-muted'} ${isAdmin ? 'quick-editable' : ''}`} data-timeline-field={isAdmin ? 'year' : undefined}>{m.year}</p>
            <h4 class={`text-white text-lg font-bold mb-2 ${isAdmin ? 'quick-editable' : ''}`} data-timeline-field={isAdmin ? 'title' : undefined}>{m.title}</h4>
            <p class={`text-text-muted text-sm leading-relaxed ${isAdmin ? 'quick-editable' : ''}`} data-timeline-field={isAdmin ? 'desc' : undefined}>{m.desc}</p>
          </div>
        ))}
      </div>
      {isAdmin && (
        <div class="mt-8">
          <button id="add-about-milestone" type="button" class="about-add-milestone-btn">
            <span class="material-symbols-outlined text-[18px]">add</span>
            Thêm mốc thời gian
          </button>
        </div>
      )}
    </div>
  </section>

  <Footer />

  {isAdmin && (
    <>
      <div id="about-quick-edit-toolbar" class="public-quick-toolbar">
        <button id="toggle-about-edit" type="button" class="public-quick-btn">
          <span class="material-symbols-outlined">edit_square</span>
          <span id="about-edit-label">Chỉnh sửa</span>
        </button>
        <button id="save-about-edit" type="button" class="public-quick-btn hidden">
          <span class="material-symbols-outlined">save</span>
          <span>Lưu</span>
        </button>
        <button id="exit-about-edit" type="button" class="public-quick-btn hidden">
          <span class="material-symbols-outlined">close</span>
          <span>Thoát</span>
        </button>
        <span id="about-edit-status" class="public-quick-status hidden">Đã lưu</span>
      </div>

      <script is:inline>
        const aboutToggleBtn = document.getElementById('toggle-about-edit');
        const aboutSaveBtn = document.getElementById('save-about-edit');
        const aboutExitBtn = document.getElementById('exit-about-edit');
        const aboutEditLabel = document.getElementById('about-edit-label');
        const aboutEditStatus = document.getElementById('about-edit-status');
        const addMilestoneBtn = document.getElementById('add-about-milestone');
        const timelineList = document.getElementById('about-timeline-list');
        let aboutEditMode = false;
        let aboutHasPendingChanges = false;
        let aboutStatusTimer;
        let timelineDirty = false;
        let timelineOriginalMarkup = timelineList?.innerHTML || '';
        const dirtyAboutFields = new Set();

        function syncAboutEditActions() {
          aboutToggleBtn?.classList.toggle('hidden', aboutEditMode);
          aboutSaveBtn?.classList.toggle('hidden', !aboutEditMode || !aboutHasPendingChanges);
          aboutExitBtn?.classList.toggle('hidden', !aboutEditMode);
          if (aboutEditLabel) {
            aboutEditLabel.textContent = aboutEditMode ? 'Đang chỉnh sửa' : 'Chỉnh sửa';
          }
        }

        function updateAboutPendingChanges() {
          aboutHasPendingChanges = dirtyAboutFields.size > 0 || timelineDirty;
          syncAboutEditActions();
        }

        function flashAboutSaved(message = 'Đã lưu') {
          if (!aboutEditStatus) return;
          if (aboutStatusTimer) {
            clearTimeout(aboutStatusTimer);
          }
          aboutEditStatus.textContent = message;
          aboutEditStatus.classList.remove('hidden');
          aboutEditStatus.classList.remove('is-flashing');
          void aboutEditStatus.offsetWidth;
          aboutEditStatus.classList.add('is-flashing');
          aboutStatusTimer = setTimeout(() => {
            aboutEditStatus.classList.add('hidden');
            aboutEditStatus.classList.remove('is-flashing');
          }, 1700);
        }

        async function saveAboutSetting(key, value) {
          let res = await fetch('/api/settings/quick-update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ key, value }),
          });

          if (res.status === 404) {
            res = await fetch('/api/settings/update', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
              body: JSON.stringify({ settings: [{ key, value }] }),
            });
          }

          const data = await res.json().catch(() => ({}));
          if (!res.ok || !data.success) {
            throw new Error(data.error || 'Không thể lưu thay đổi');
          }
        }

        async function uploadAboutImage(file, key, el) {
          const form = new FormData();
          form.append('file', file);
          const uploadRes = await fetch('/api/site-media/upload', { method: 'POST', body: form });
          const uploadData = await uploadRes.json().catch(() => ({}));
          if (!uploadRes.ok || !uploadData.url) {
            throw new Error(uploadData.error || 'Upload thất bại');
          }
          await saveAboutSetting(key, uploadData.url);
          const img = el.querySelector('img');
          if (img) img.src = uploadData.url;
          flashAboutSaved('Đã cập nhật ảnh');
        }

        function handleAboutTextInput(event) {
          const el = event.currentTarget || event.target;
          const nextValue = (el.textContent || '').trim();
          const prevValue = el.dataset.originalValue || '';
          if (nextValue !== prevValue) {
            dirtyAboutFields.add(el);
          } else {
            dirtyAboutFields.delete(el);
          }
          updateAboutPendingChanges();
        }

        function collectTimelineItems() {
          const items = [];
          document.querySelectorAll('[data-timeline-item]').forEach((node) => {
            const yearEl = node.querySelector('[data-timeline-field="year"]');
            const titleEl = node.querySelector('[data-timeline-field="title"]');
            const descEl = node.querySelector('[data-timeline-field="desc"]');
            items.push({
              year: (yearEl?.textContent || '').trim() || 'Mốc mới',
              title: (titleEl?.textContent || '').trim() || 'Tiêu đề mốc',
              desc: (descEl?.textContent || '').trim() || 'Mô tả mốc thời gian',
            });
          });
          return items;
        }

        async function saveTimelineItems() {
          const payload = JSON.stringify(collectTimelineItems());
          await saveAboutSetting('flysky_about_timeline_items', payload);
        }

        function handleTimelineFieldInput(event) {
          const el = event.currentTarget || event.target;
          const nextValue = (el.textContent || '').trim();
          const prevValue = el.dataset.originalValue || '';
          timelineDirty = timelineDirty || nextValue !== prevValue;
          if (!timelineDirty) {
            timelineDirty = Array.from(document.querySelectorAll('[data-timeline-field]')).some((node) => {
              return (node.textContent || '').trim() !== (node.dataset.originalValue || '');
            });
          }
          updateAboutPendingChanges();
        }

        function wireTimelineField(el) {
          el.contentEditable = aboutEditMode ? 'true' : 'false';
          el.dataset.originalValue = el.dataset.originalValue || el.textContent || '';
          if (aboutEditMode) {
            el.classList.add('quick-edit-active');
            el.addEventListener('input', handleTimelineFieldInput);
          } else {
            el.classList.remove('quick-edit-active');
            el.removeEventListener('input', handleTimelineFieldInput);
          }
        }

        function enableAboutTextEditing() {
          document.querySelectorAll('[data-setting-key]').forEach((node) => {
            const el = node;
            el.contentEditable = 'true';
            el.dataset.originalValue = el.textContent || '';
            el.classList.add('quick-edit-active');
            el.addEventListener('input', handleAboutTextInput);
          });

          document.querySelectorAll('[data-timeline-field]').forEach((node) => {
            node.dataset.originalValue = node.textContent || '';
            wireTimelineField(node);
          });
        }

        function disableAboutTextEditing() {
          document.querySelectorAll('[data-setting-key]').forEach((node) => {
            const el = node;
            el.contentEditable = 'false';
            el.classList.remove('quick-edit-active');
            el.removeEventListener('input', handleAboutTextInput);
          });

          document.querySelectorAll('[data-timeline-field]').forEach((node) => {
            wireTimelineField(node);
          });

          dirtyAboutFields.clear();
          timelineDirty = false;
          updateAboutPendingChanges();
        }

        function revertAboutChanges() {
          dirtyAboutFields.forEach((node) => {
            node.textContent = node.dataset.originalValue || '';
          });

          if (timelineDirty && timelineList) {
            timelineList.innerHTML = timelineOriginalMarkup;
          }

          dirtyAboutFields.clear();
          timelineDirty = false;
          updateAboutPendingChanges();
        }

        async function saveAboutChanges() {
          const changedFields = Array.from(document.querySelectorAll('[data-setting-key]')).filter((node) => {
            return (node.textContent || '').trim() !== (node.dataset.originalValue || '');
          });

          for (const node of changedFields) {
            const key = node.dataset.settingKey;
            const nextValue = (node.textContent || '').trim();
            if (!key) continue;

            node.classList.add('quick-saving');
            try {
              await saveAboutSetting(key, nextValue);
              node.dataset.originalValue = nextValue;
            } finally {
              node.classList.remove('quick-saving');
            }
          }

          if (timelineDirty) {
            await saveTimelineItems();
            document.querySelectorAll('[data-timeline-field]').forEach((node) => {
              node.dataset.originalValue = node.textContent || '';
            });
            timelineOriginalMarkup = timelineList?.innerHTML || '';
          }

          dirtyAboutFields.clear();
          timelineDirty = false;
          updateAboutPendingChanges();

          if (changedFields.length > 0 || timelineDirty) {
            flashAboutSaved('Đã lưu thay đổi');
          } else {
            flashAboutSaved('Đã lưu thay đổi');
          }
        }

        function bindAboutImageEditors() {
          document.querySelectorAll('[data-image-setting]').forEach((node) => {
            const el = node;
            const pickFile = () => {
              if (!aboutEditMode) return;
              const input = document.createElement('input');
              input.type = 'file';
              input.accept = 'image/png,image/jpeg,image/jpg,image/webp,image/gif';
              input.addEventListener('change', () => {
                const file = input.files?.[0];
                if (!file) return;
                el.classList.add('quick-saving');
                uploadAboutImage(file, el.dataset.imageSetting, el)
                  .catch((error) => alert(error.message || 'Không thể cập nhật ảnh'))
                  .finally(() => el.classList.remove('quick-saving'));
              });
              input.click();
            };

            el.addEventListener('click', (ev) => {
              if (!aboutEditMode) return;
              ev.preventDefault();
              ev.stopPropagation();
              pickFile();
            });

            el.addEventListener('dragover', (ev) => {
              if (!aboutEditMode) return;
              ev.preventDefault();
              el.classList.add('quick-drag-over');
            });

            el.addEventListener('dragleave', () => el.classList.remove('quick-drag-over'));

            el.addEventListener('drop', (ev) => {
              if (!aboutEditMode) return;
              ev.preventDefault();
              ev.stopPropagation();
              el.classList.remove('quick-drag-over');
              const file = ev.dataTransfer?.files?.[0];
              if (!file) return;
              el.classList.add('quick-saving');
              uploadAboutImage(file, el.dataset.imageSetting, el)
                .catch((error) => alert(error.message || 'Không thể cập nhật ảnh'))
                .finally(() => el.classList.remove('quick-saving'));
            });
          });
        }

        aboutToggleBtn?.addEventListener('click', () => {
          aboutEditMode = true;
          timelineOriginalMarkup = timelineList?.innerHTML || '';
          document.body.classList.add('public-edit-mode');
          enableAboutTextEditing();
          syncAboutEditActions();
        });

        aboutSaveBtn?.addEventListener('click', async () => {
          if (!aboutHasPendingChanges) return;
          aboutSaveBtn.setAttribute('disabled', 'true');
          try {
            await saveAboutChanges();
          } catch (error) {
            alert(error.message || 'Không thể lưu thay đổi');
          } finally {
            aboutSaveBtn.removeAttribute('disabled');
            syncAboutEditActions();
          }
        });

        aboutExitBtn?.addEventListener('click', () => {
          if (aboutHasPendingChanges && !confirm('Bạn có thay đổi chưa lưu. Thoát và bỏ thay đổi?')) {
            return;
          }
          if (aboutHasPendingChanges) {
            revertAboutChanges();
          }
          aboutEditMode = false;
          document.body.classList.remove('public-edit-mode');
          disableAboutTextEditing();
          syncAboutEditActions();
        });

        addMilestoneBtn?.addEventListener('click', () => {
          if (!aboutEditMode) {
            alert('Hãy bật chỉnh sửa nhanh trước khi thêm mốc thời gian.');
            return;
          }

          if (!timelineList) return;

          const item = document.createElement('div');
          item.className = 'relative';
          item.setAttribute('data-timeline-item', 'true');
          item.innerHTML = `
            <div class="absolute -left-[41px] top-1 w-5 h-5 rounded-full border-4 border-background-dark bg-border-dark"></div>
            <p class="font-bold text-sm mb-1 tracking-widest text-text-muted quick-editable" data-timeline-field="year">Mốc mới</p>
            <h4 class="text-white text-lg font-bold mb-2 quick-editable" data-timeline-field="title">Tiêu đề mốc</h4>
            <p class="text-text-muted text-sm leading-relaxed quick-editable" data-timeline-field="desc">Mô tả mốc thời gian</p>
          `;

          timelineList.appendChild(item);
          item.querySelectorAll('[data-timeline-field]').forEach((node) => {
            node.dataset.originalValue = node.textContent || '';
            wireTimelineField(node);
          });
          timelineDirty = true;
          updateAboutPendingChanges();
        });

        bindAboutImageEditors();
        syncAboutEditActions();
      </script>

      <style>
        .public-quick-toolbar {
          position: fixed;
          left: 50%;
          transform: translateX(-50%);
          bottom: 20px;
          z-index: 120;
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 10px;
          flex-wrap: wrap;
          width: min(420px, calc(100vw - 24px));
          padding: 10px;
          border: 1px solid rgba(244, 140, 37, 0.18);
          border-radius: 18px;
          background: rgba(36, 24, 14, 0.72);
          backdrop-filter: blur(12px);
          box-shadow: 0 14px 32px rgba(0, 0, 0, 0.35);
        }
        .public-quick-btn {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          flex: 1 1 160px;
          gap: 8px;
          min-width: 0;
          border: 1px solid rgba(244, 140, 37, 0.35);
          background: rgba(12, 10, 7, 0.96);
          color: #fff;
          border-radius: 999px;
          padding: 12px 16px;
          font: inherit;
          font-weight: 700;
          cursor: pointer;
          box-shadow: 0 10px 30px rgba(0, 0, 0, 0.28);
          white-space: nowrap;
        }
        .public-quick-btn:disabled {
          opacity: 0.65;
          cursor: not-allowed;
        }
        #about-edit-label {
          white-space: nowrap;
        }
        .public-quick-btn.hidden {
          display: none !important;
        }
        .public-quick-status {
          position: absolute;
          left: 50%;
          bottom: calc(100% - 8px);
          transform: translateX(-50%) scale(0.94);
          border-radius: 999px;
          padding: 8px 12px;
          background: rgba(22, 101, 52, 0.92);
          color: #86efac;
          font-size: 12px;
          font-weight: 700;
          border: 1px solid rgba(134, 239, 172, 0.35);
          box-shadow: 0 10px 24px rgba(0, 0, 0, 0.35);
          white-space: nowrap;
          pointer-events: none;
          opacity: 0;
        }
        .public-quick-status.is-flashing {
          animation: quick-save-flash 1.4s ease-out both;
        }
        .public-quick-status.hidden {
          display: none;
        }
        @keyframes quick-save-flash {
          0% {
            opacity: 0;
            transform: translateX(-50%) translateY(6px) scale(0.9);
          }
          22% {
            opacity: 1;
            transform: translateX(-50%) translateY(0) scale(1);
          }
          68% {
            opacity: 1;
            transform: translateX(-50%) translateY(-2px) scale(1);
          }
          100% {
            opacity: 0;
            transform: translateX(-50%) translateY(-8px) scale(0.95);
          }
        }
        @media (max-width: 640px) {
          .public-quick-toolbar {
            left: 12px;
            right: 12px;
            transform: none;
            width: auto;
            bottom: calc(env(safe-area-inset-bottom, 0px) + 10px);
            gap: 8px;
            justify-content: space-between;
          }
          .public-quick-btn {
            flex: 1;
            min-width: 0;
            justify-content: center;
            padding: 11px 12px;
            font-size: 13px;
          }
          #about-edit-label {
            overflow: hidden;
            text-overflow: ellipsis;
          }
          .public-quick-status {
            padding: 8px 10px;
            font-size: 11px;
          }
        }
        .about-add-milestone-btn {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          border: 1px solid rgba(244, 140, 37, 0.35);
          background: rgba(16, 13, 8, 0.92);
          color: #fff;
          border-radius: 999px;
          padding: 10px 14px;
          font: inherit;
          font-weight: 700;
          cursor: pointer;
          transition: border-color 0.2s ease, background 0.2s ease;
        }
        .about-add-milestone-btn:hover {
          border-color: rgba(244, 140, 37, 0.9);
          background: rgba(26, 20, 13, 0.96);
        }
        .quick-edit-active {
          outline: 2px dashed rgba(244, 140, 37, 0.95);
          outline-offset: 6px;
          border-radius: 8px;
          cursor: text;
        }
        .quick-image-editable {
          cursor: pointer;
        }
        .quick-image-overlay {
          position: absolute;
          inset: auto 12px 12px 12px;
          display: none;
          align-items: center;
          justify-content: center;
          gap: 8px;
          padding: 10px 12px;
          border-radius: 12px;
          background: rgba(12, 10, 7, 0.88);
          color: #fff;
          font-size: 12px;
          font-weight: 700;
          z-index: 30;
        }
        .public-edit-mode .quick-image-editable {
          outline: 2px dashed rgba(244, 140, 37, 0.95);
          outline-offset: 4px;
        }
        .public-edit-mode .quick-image-editable .quick-image-overlay {
          display: inline-flex;
        }
        .quick-drag-over {
          outline: 2px solid #f48c25 !important;
          box-shadow: 0 0 0 6px rgba(244, 140, 37, 0.15);
        }
        .quick-saving {
          opacity: 0.6;
          transition: opacity 0.15s ease;
        }
      </style>
    </>
  )}
</Layout>