---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase';
import { getAdminMfaState } from '../../lib/security';

const { id } = Astro.params;

// Check if current user is admin (for inline editing)
let isAdmin = false;
const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (accessToken && refreshToken) {
  const authState = await getAdminMfaState(accessToken.value, refreshToken.value);
  isAdmin = authState.authenticated && authState.isAdmin && !authState.requiresMfa;
}

// Lấy sản phẩm hiện tại
const { data: dbProduct, error } = await supabase
  .from('products')
  .select(`*, categories(id, name, slug)`)
  .eq('slug', id)
  .single();

if (!dbProduct || error) {
  return Astro.redirect('/shop'); // Fallback redirect if not found
}

// Lấy sản phẩm liên quan
const { data: dbRelated } = await supabase
  .from('products')
  .select(`*, categories(name, slug)`)
  .eq('category_id', dbProduct.category_id)
  .neq('id', dbProduct.id)
  .limit(3);

// Lấy danh sách đánh giá
const { data: dbReviews, error: _revErr } = await supabase
  .from('reviews')
  .select('*')
  .eq('product_id', dbProduct.id)
  .eq('status', 'approved')
  .order('created_at', { ascending: false });

const reviews = dbReviews || [];
const totalReviews = reviews.length;
const averageRating = totalReviews > 0 ? (reviews.reduce((acc, r) => acc + r.rating, 0) / totalReviews) : 0;

// Thống kê sao
const starCounts = [0, 0, 0, 0, 0, 0];
reviews.forEach(r => {
  starCounts[r.rating] = (starCounts[r.rating] || 0) + 1;
});
const ratingStats = [5, 4, 3, 2, 1].map(stars => ({
  stars,
  pct: totalReviews > 0 ? Math.round((starCounts[stars] / totalReviews) * 100) : 0
}));

// Helper function to convert video URL to embed URL
function getVideoEmbedUrl(url: string): string | null {
  if (!url) return null;
  
  // YouTube
  const youtubeMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([^&\n?#]+)/);
  if (youtubeMatch) {
    return `https://www.youtube.com/embed/${youtubeMatch[1]}`;
  }
  
  // Vimeo
  const vimeoMatch = url.match(/(?:vimeo\.com\/|vimeo\.com\/video\/)(\d+)/);
  if (vimeoMatch) {
    return `https://player.vimeo.com/video/${vimeoMatch[1]}`;
  }
  
  // If it's already an embed URL, return as is
  if (url.includes('youtube.com/embed/') || url.includes('player.vimeo.com/video/')) {
    return url;
  }
  
  return null;
}

const defaultBenefits = [
  'Miễn phí vận chuyển toàn quốc',
  'Hoàn tiền trong 30 ngày',
  'Bảo hành 2 năm',
];
const defaultFeatureHighlights = [
  'Chất liệu được chọn lọc kỹ càng',
  'Hoàn thiện thủ công tỉ mỉ',
  'Âm thanh vượt trội trong phân khúc',
  'Bền bỉ với thời gian',
];

function normalizeStringArray(value: unknown, fallback: string[]) {
  if (Array.isArray(value)) {
    const items = value
      .filter((item): item is string => typeof item === 'string')
      .map((item) => item.trim())
      .filter(Boolean);
    return items.length > 0 ? items : fallback;
  }

  if (typeof value === 'string' && value.trim()) {
    const items = value
      .split(/\r?\n|,/)
      .map((item) => item.trim())
      .filter(Boolean);
    return items.length > 0 ? items : fallback;
  }

  return fallback;
}

function getConditionLabel(value: string | null | undefined) {
  if (value === 'used') return 'Đàn cũ (đã qua sử dụng)';
  if (value === 'like_new') return 'Like new';
  return 'Mới 100%';
}

const rawGalleryImages: string[] = Array.isArray(dbProduct.gallery_images)
  ? dbProduct.gallery_images.filter((url: unknown): url is string => typeof url === 'string' && url.trim().length > 0)
  : [];
const productImages: string[] = Array.from(new Set(rawGalleryImages.length > 0 ? rawGalleryImages : ['/images/default-guitar.webp']));
const productBenefits = normalizeStringArray(dbProduct.benefits, defaultBenefits);
const productFeatureHighlights = normalizeStringArray(dbProduct.highlight_features, defaultFeatureHighlights);
const productConditionLabel = getConditionLabel(dbProduct.product_condition);

const product = {
  id: dbProduct.slug,
  name: dbProduct.name,
  subtitle: dbProduct.subtitle || (dbProduct.description ? dbProduct.description.substring(0, 100) + '...' : 'Thiết kế đẹp mắt, âm thanh đỉnh cao.'),
  longDescription: dbProduct.description || 'Chưa có mô tả chi tiết.',
  categoryLabel: dbProduct.categories?.name || 'Sản phẩm',
  price: dbProduct.price,
  priceFormatted: new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(dbProduct.price),
  images: productImages,
  videoUrl: dbProduct.video_url || null,
  condition: dbProduct.product_condition || 'new',
  status: dbProduct.status || 'active',
  stockQuantity: dbProduct.stock_quantity ?? 0,
  rating: averageRating,
  reviews: totalReviews,
  badge: dbProduct.is_featured ? 'Nổi bật' : (dbProduct.status === 'out_of_stock' ? 'Hết hàng' : null),
  benefits: productBenefits,
  features: productFeatureHighlights,
  specs: [
    { label: 'Thương hiệu', value: 'FlySky', field: null },
    { label: 'Tình trạng', value: productConditionLabel, field: null, id: 'product-condition-display' },
    ...(dbProduct.spec_body || isAdmin ? [{ label: 'Lưng Hông', value: dbProduct.spec_body || 'Chưa cập nhật', field: 'spec_body' }] : []),
    ...(dbProduct.spec_top || isAdmin ? [{ label: 'Mặt Top', value: dbProduct.spec_top || 'Chưa cập nhật', field: 'spec_top' }] : []),
    ...(dbProduct.spec_neck || isAdmin ? [{ label: 'Cần Đàn', value: dbProduct.spec_neck || 'Chưa cập nhật', field: 'spec_neck' }] : [])
  ]
};

const related = (dbRelated || []).map(rp => ({
  id: rp.slug,
  categoryLabel: rp.categories?.name || 'Khác',
  name: rp.name,
  description: (rp.description || '').substring(0, 50) + '...',
  price: rp.price,
  priceFormatted: new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(rp.price),
  image: (rp.gallery_images && rp.gallery_images.length > 0) ? rp.gallery_images[0] : '/images/default-guitar.webp',
  badge: rp.is_featured ? 'Nổi bật' : null
}));
---

<Layout
  title={`${product.name} | FlySky Guitar`}
  description={product.longDescription}
>
  <Navbar />

  <!-- Breadcrumb -->
  <div class="bg-background-dark border-b border-border-dark/50">
    <div class="mx-auto max-w-7xl px-4 lg:px-10 py-3 flex items-center gap-2 text-sm text-text-muted">
      <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
      <span class="material-symbols-outlined text-[14px]">chevron_right</span>
      <a href="/shop" class="hover:text-primary transition-colors">Cửa hàng</a>
      <span class="material-symbols-outlined text-[14px]">chevron_right</span>
      <span class="text-white/60 truncate">{product.name}</span>
    </div>
  </div>

  <!-- Product Hero -->
  <section class="py-12 bg-background-dark">
    <div class="mx-auto max-w-7xl px-4 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Image Gallery -->
        <div class="flex flex-col gap-4">
          <!-- Main image -->
          <div
            id="main-image"
            class="w-full aspect-square rounded-2xl bg-surface-product-media border border-border-dark overflow-hidden flex items-center justify-center p-8 relative"
          >
            {product.badge && (
              <div class="absolute top-4 left-4 bg-primary text-background-dark text-xs font-extrabold px-3 py-1.5 rounded uppercase tracking-wider z-10">
                {product.badge}
              </div>
            )}
            <img
              id="main-img-el"
              src={product.images[0] as string}
              alt={product.name}
              class="w-full h-full object-contain transition-opacity duration-300"
            />
          </div>
          <!-- Thumbnails -->
          {product.images.length > 1 && (
            <div id="product-thumbnails" class="grid grid-cols-3 sm:grid-cols-4 gap-3">
              {product.images.map((img, i) => (
                <button
                  class={`thumb-btn flex-1 aspect-square rounded-xl bg-surface-product-media border-2 overflow-hidden p-2 transition-all ${i === 0 ? 'border-primary' : 'border-border-dark hover:border-primary/60'}`}
                  data-src={img as string}
                  data-index={i}
                >
                  <img src={img as string} alt={`${product.name} view ${i + 1}`} class="w-full h-full object-contain" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Product Info -->
        <div class="flex flex-col gap-6 lg:sticky lg:top-24">
          <!-- Category + badge -->
          <div class="flex items-center gap-3">
            <span class="text-primary font-bold text-xs uppercase tracking-widest">{product.categoryLabel}</span>
            <span class="w-1 h-1 rounded-full bg-border-dark"></span>
            <span class="text-text-muted text-xs">Thủ công cao cấp</span>
          </div>

          <!-- Name + subtitle -->
          <div>
            <h1 
              class="text-white type-display-section"
              data-editable={isAdmin ? "name" : undefined}
              data-original={product.name}
            >{product.name}</h1>
            <p 
              class={`text-text-muted type-body-lead mt-1 ${isAdmin ? 'quick-editable-copy' : ''}`}
              data-editable={isAdmin ? 'subtitle' : undefined}
            >{product.subtitle}</p>
          </div>

          <!-- Rating -->
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <span
                  class={`material-symbols-outlined text-[18px] ${i < Math.round(product.rating) ? 'text-primary' : 'text-border-dark'}`}
                  style="font-variation-settings: 'FILL' 1"
                >star</span>
              ))}
            </div>
            <span class="text-white font-semibold text-sm">{product.rating.toFixed(1)}</span>
            <span id="reviews-link" class="text-text-muted text-sm cursor-pointer hover:underline">({product.reviews} đánh giá)</span>
          </div>

          <!-- Price -->
          <div class="flex items-baseline gap-3">
            <span 
              class="text-white text-4xl font-extrabold"
              data-editable={isAdmin ? "price" : undefined}
              data-original={product.price}
            >{product.priceFormatted}</span>
          </div>

          <!-- Benefits -->
          <div class="flex flex-wrap gap-4 py-4 border-y border-border-dark/50">
            {product.benefits.map((benefit, index) => (
              <div class="flex items-center gap-2 text-text-muted text-sm">
                <span class="material-symbols-outlined text-primary text-[18px]">
                  {index === 0 ? 'local_shipping' : index === 1 ? 'replay' : 'verified'}
                </span>
                <span
                  class={isAdmin ? 'quick-editable-copy' : ''}
                  data-array-field={isAdmin ? 'benefits' : undefined}
                  data-array-index={isAdmin ? String(index) : undefined}
                >{benefit}</span>
              </div>
            ))}
          </div>

          <!-- Description -->
          <p 
            class="text-text-muted leading-relaxed"
            data-editable={isAdmin ? "description" : undefined}
            data-original={product.longDescription}
          >{product.longDescription}</p>

          <div class="flex flex-col sm:flex-row gap-3">
            <button
              id="btn-add-cart"
              data-product-id={product.id}
              data-product-name={product.name}
              data-product-category={product.categoryLabel}
              data-product-price={product.price}
              data-product-price-formatted={product.priceFormatted}
              data-product-image={product.images[0]}
              class="flex-1 flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-background-dark font-bold py-4 px-6 rounded-xl transition-all duration-200 hover:shadow-[0_0_20px_rgba(244,140,37,0.4)] active:scale-95"
            >
              <span class="material-symbols-outlined">add_shopping_cart</span>
              Thêm vào giỏ hàng
            </button>
            <button
              class="flex items-center justify-center gap-2 bg-border-dark/50 hover:bg-border-dark text-white font-semibold py-4 px-6 rounded-xl border border-border-dark transition-all duration-200"
            >
              <span class="material-symbols-outlined">favorite_border</span>
              Yêu thích
            </button>
          </div>

          <!-- Consult note -->
          <div class="bg-card-dark border border-border-dark rounded-xl p-4 flex gap-3">
            <span class="material-symbols-outlined text-primary flex-shrink-0 mt-0.5">info</span>
            <div>
              <p class="text-white text-sm font-semibold mb-1">Tư vấn trực tiếp</p>
              <p class="text-text-muted text-xs leading-relaxed">Bỏ vào giỏ và gửi yêu cầu, chúng tôi sẽ liên hệ tư vấn chi tiết cho bạn. Không yêu cầu đăng nhập.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Details Tabs -->
  <section class="py-16 bg-surface-section-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-10">
      <!-- Tab nav -->
      <div class="flex gap-1 border-b border-border-dark mb-10">
        {[
          { id: 'features', label: 'Tính năng nổi bật' },
          { id: 'specs', label: 'Thông số kỹ thuật' },
          { id: 'reviews', label: `Đánh giá (${product.reviews})` },
        ].map((tab, i) => (
          <button
            class={`tab-btn px-6 py-3 text-sm font-semibold border-b-2 transition-all -mb-px ${i === 0 ? 'border-primary text-primary' : 'border-transparent text-text-muted hover:text-white'}`}
            data-tab={tab.id}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Tab: Features -->
      <div id="tab-features" class="tab-content">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
          <div>
            <span class="text-primary font-bold tracking-widest uppercase text-sm">Chế tác vì sự xuất sắc</span>
            <h2 class="text-white text-2xl font-bold mt-2 mb-6">Từng chi tiết được mài giũa tỉ mỉ</h2>
            <ul class="flex flex-col gap-4">
              {product.features.map((f, index) => (
                <li class="flex items-start gap-3">
                  <span class="material-symbols-outlined text-primary flex-shrink-0 mt-0.5" style="font-variation-settings: 'FILL' 1">check_circle</span>
                  <span
                    class={`text-text-muted leading-relaxed ${isAdmin ? 'quick-editable-copy' : ''}`}
                    data-array-field={isAdmin ? 'highlight_features' : undefined}
                    data-array-index={isAdmin ? String(index) : undefined}
                  >{f}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="flex flex-col gap-4">
            <div id="product-video-preview" class="relative bg-card-dark rounded-2xl overflow-hidden border border-border-dark aspect-video flex items-center justify-center">
              {product.videoUrl && getVideoEmbedUrl(product.videoUrl) ? (
                <iframe 
                  src={getVideoEmbedUrl(product.videoUrl)}
                  title={`${product.name} Demo`}
                  class="w-full h-full"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              ) : (
                <>
                  <div class="absolute inset-0 bg-cover bg-center opacity-30" style={`background-image: url('${product.images[0]}')`}></div>
                  <div class="relative z-10 text-center p-8">
                    <div class="w-16 h-16 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center mx-auto mb-4 cursor-pointer hover:bg-primary/30 transition-colors">
                      <span class="material-symbols-outlined text-primary text-3xl">play_arrow</span>
                    </div>
                    <p class="text-white font-semibold mb-1">Lắng nghe {product.name} biểu diễn</p>
                    <p class="text-text-muted text-sm">Xem đánh giá & Thử âm thanh</p>
                  </div>
                </>
              )}
            </div>
            {isAdmin && (
              <div id="product-advanced-quick-edit" class="product-advanced-quick-edit">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <label class="product-quick-field sm:col-span-2">
                    <span class="product-quick-label">Link video demo</span>
                    <input id="product-video-url-input" data-product-field="video_url" type="url" class="product-quick-input" value={product.videoUrl || ''} placeholder="https://youtube.com/watch?v=..." />
                  </label>
                  <label class="product-quick-field">
                    <span class="product-quick-label">Tình trạng</span>
                    <select id="product-condition-input" data-product-field="product_condition" class="product-quick-input">
                      <option value="new" selected={product.condition === 'new'}>Mới 100%</option>
                      <option value="used" selected={product.condition === 'used'}>Đàn cũ</option>
                      <option value="like_new" selected={product.condition === 'like_new'}>Like new</option>
                    </select>
                  </label>
                  <label class="product-quick-field">
                    <span class="product-quick-label">Tồn kho</span>
                    <input id="product-stock-input" data-product-field="stock_quantity" type="number" min="0" class="product-quick-input" value={String(product.stockQuantity)} />
                  </label>
                  <label class="product-quick-field sm:col-span-2">
                    <span class="product-quick-label">Trạng thái hiển thị</span>
                    <select id="product-status-input" data-product-field="status" class="product-quick-input">
                      <option value="active" selected={product.status === 'active'}>Đang bán</option>
                      <option value="out_of_stock" selected={product.status === 'out_of_stock'}>Hết hàng</option>
                      <option value="draft" selected={product.status === 'draft'}>Tạm ẩn</option>
                    </select>
                  </label>
                </div>
                <div class="product-quick-image-tools">
                  <button id="product-add-image-btn" type="button" class="product-quick-image-btn">
                    <span class="material-symbols-outlined text-[18px]">add_photo_alternate</span>
                    Thêm ảnh mới cho sản phẩm
                  </button>
                  <p class="product-quick-hint">Mẹo: trong chế độ sửa, nhấn đúp vào ảnh chính hoặc thumbnail để thay ảnh hiện có.</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Tab: Specs -->
      <div id="tab-specs" class="tab-content hidden">
        <div class="max-w-2xl">
          <h2 class="text-white text-2xl font-bold mb-6">Thông số kỹ thuật</h2>
          <div class="divide-y divide-border-dark">
            {product.specs.map((spec) => (
              <div class="flex items-center py-4 gap-4">
                <span class="text-text-muted text-sm w-40 flex-shrink-0">{spec.label}</span>
                <span
                  id={spec.id || undefined}
                  class={`text-white font-medium text-sm ${isAdmin && spec.field ? 'quick-editable-copy' : ''}`}
                  data-editable={isAdmin && spec.field ? spec.field : undefined}
                >{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Tab: Reviews -->
      <div id="tab-reviews" class="tab-content hidden">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          <!-- Rating summary -->
          <div class="bg-card-dark rounded-2xl border border-border-dark p-8 text-center flex flex-col">
            <div class="text-primary text-6xl font-extrabold">{product.rating.toFixed(1)}</div>
            <div class="flex justify-center gap-1 my-3">
              {Array.from({ length: 5 }).map((_, i) => (
                <span class={`material-symbols-outlined ${i < Math.round(product.rating) ? 'text-primary' : 'text-border-dark'}`} style="font-variation-settings: 'FILL' 1">star</span>
              ))}
            </div>
            <p class="text-text-muted text-sm">Dựa trên {product.reviews} đánh giá</p>
            <div class="mt-6 flex flex-col gap-2 text-left mb-8">
              {ratingStats.map((row) => (
                <div class="flex items-center gap-2 text-xs text-text-muted">
                  <span class="w-3">{row.stars}</span>
                  <span class="material-symbols-outlined text-primary text-[12px]" style="font-variation-settings: 'FILL' 1">star</span>
                  <div class="flex-1 bg-border-dark rounded-full h-1.5 overflow-hidden">
                    <div class="bg-primary h-1.5 rounded-full" style={`width: ${row.pct}%`}></div>
                  </div>
                  <span class="w-8 text-right">{row.pct}%</span>
                </div>
              ))}
            </div>
            <button id="btn-write-review" class="mt-auto bg-primary text-background-dark font-bold py-3 rounded-xl transition-all hover:-translate-y-1 hover:shadow-lg w-full">Viết đánh giá</button>
            <p class="text-[10px] text-text-muted mt-2 mt-2 leading-relaxed">Chỉ khách hàng đã mua sản phẩm (được hệ thống nhận diện từ SĐT/Email lúc đặt hàng) mới có quyền đánh giá.</p>
          </div>
          <!-- Sample reviews -->
          <div class="md:col-span-2 flex flex-col gap-5">
            {reviews.length === 0 ? (
               <div class="bg-card-dark rounded-xl border border-border-dark p-12 text-center text-text-muted">
                 Chưa có đánh giá nào cho sản phẩm này. Trở thành người đầu tiên!
               </div>
            ) : reviews.map((review) => (
              <div class="bg-card-dark rounded-xl border border-border-dark p-6">
                <div class="flex items-start justify-between mb-3">
                  <div>
                    <p class="text-white font-semibold">{review.reviewer_name}</p>
                    <p class="text-text-muted text-xs">{new Date(review.created_at).toLocaleDateString('vi-VN')}</p>
                  </div>
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }).map((_, i) => (
                      <span class={`material-symbols-outlined text-[14px] ${i < review.rating ? 'text-primary' : 'text-border-dark'}`} style="font-variation-settings: 'FILL' 1">star</span>
                    ))}
                  </div>
                </div>
                <p class="text-text-muted text-sm leading-relaxed">{review.comment}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  {related.length > 0 && (
    <section class="py-16 bg-background-dark">
      <div class="mx-auto max-w-7xl px-4 lg:px-10">
        <div class="flex items-end justify-between mb-8">
          <div>
            <span class="text-primary font-bold tracking-widest uppercase text-sm">Gợi ý</span>
            <h2 class="text-white text-2xl font-bold mt-1">Có thể bạn sẽ thích</h2>
          </div>
          <a class="hidden md:flex items-center gap-1 text-primary font-medium hover:text-white transition-colors text-sm" href="/shop">
            Xem tất cả <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {related.map((rp) => (
            <a
              href={`/products/${rp.id}`}
              class="group flex flex-col bg-card-dark rounded-xl overflow-hidden hover:shadow-[0_0_24px_rgba(244,140,37,0.18)] transition-all duration-300 border border-border-dark"
            >
              <div class="aspect-square w-full bg-[#2a2015] relative p-4 flex items-center justify-center overflow-hidden">
                <div
                  class="w-full h-full bg-contain bg-center bg-no-repeat group-hover:scale-110 transition-transform duration-500"
                  style={`background-image: url("${rp.image}");`}
                ></div>
                {rp.badge && (
                  <div class="absolute top-3 left-3 bg-primary text-background-dark text-[10px] font-bold px-2 py-1 rounded uppercase">
                    {rp.badge}
                  </div>
                )}
              </div>
              <div class="p-5">
                <span class="text-primary text-xs font-bold uppercase tracking-wider">{rp.categoryLabel}</span>
                <h3 class="text-white text-base font-bold mt-1 group-hover:text-primary transition-colors">{rp.name}</h3>
                <p class="text-text-muted text-xs mt-1">{rp.description}</p>
                <div class="flex items-center justify-between mt-4 pt-3 border-t border-border-dark/50">
                  <span class="text-white font-extrabold">{rp.priceFormatted}</span>
                  <span class="text-primary text-sm font-medium flex items-center gap-1">
                    Xem chi tiết <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer />

  <!-- Admin Inline Edit Toolbar (only visible to admin) -->
  {isAdmin && (
    <div id="admin-toolbar" class="public-quick-toolbar">
      <button
        id="toggle-edit-mode"
        class="public-quick-btn"
        title="Bật chế độ chỉnh sửa nhanh"
      >
        <span class="material-symbols-outlined">edit_square</span>
        <span id="edit-mode-text">Chỉnh sửa</span>
      </button>
      <button
        id="save-edit-mode"
        class="public-quick-btn hidden"
        type="button"
        title="Lưu thay đổi"
      >
        <span class="material-symbols-outlined">save</span>
        <span>Lưu</span>
      </button>
      <button
        id="exit-edit-mode"
        class="public-quick-btn hidden"
        type="button"
        title="Thoát chế độ chỉnh sửa"
      >
        <span class="material-symbols-outlined">close</span>
        <span>Thoát</span>
      </button>
      <span id="edit-status" class="public-quick-status hidden">Đã lưu</span>
    </div>
  )}

  <!-- Product Image Lightbox -->
  <div id="product-lightbox" class="fixed inset-0 z-[70] hidden items-center justify-center bg-black/90 p-4" aria-hidden="true">
    <button id="product-lightbox-close" class="absolute top-4 right-4 h-10 w-10 rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors" aria-label="Đóng xem ảnh">
      <span class="material-symbols-outlined">close</span>
    </button>
    <button id="product-lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 h-11 w-11 rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors" aria-label="Ảnh trước">
      <span class="material-symbols-outlined">chevron_left</span>
    </button>
    <img id="product-lightbox-img" src="" alt="Ảnh sản phẩm full size" class="max-h-[90vh] max-w-[92vw] object-contain rounded-lg" />
    <button id="product-lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 h-11 w-11 rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors" aria-label="Ảnh tiếp theo">
      <span class="material-symbols-outlined">chevron_right</span>
    </button>
  </div>

  <!-- Review Modal -->
  <div id="review-modal" class="fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="bg-background-dark border border-border-dark rounded-2xl w-full max-w-lg p-6 lg:p-8 transform scale-95 transition-transform duration-300" id="review-modal-content">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-white text-xl font-bold">Viết Đánh Giá</h3>
        <button id="close-review-modal" class="text-text-muted hover:text-white transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>

      <form id="review-form" class="space-y-4">
        <input type="hidden" id="rv-product-id" value={dbProduct.id} />
        
        <div class="flex flex-col gap-2 relative">
          <label class="text-text-muted text-sm">Chất lượng sản phẩm <span class="text-red-500">*</span></label>
          <div class="flex gap-1" id="star-rating">
            {[1, 2, 3, 4, 5].map((s) => (
              <button type="button" class="star-btn material-symbols-outlined text-border-dark text-3xl hover:-translate-y-1 transition-transform" data-rating={s} style="font-variation-settings: 'FILL' 1">star</button>
            ))}
          </div>
          <input type="hidden" id="rv-rating" required />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col gap-1">
             <label class="text-text-muted text-sm">Tên của bạn <span class="text-red-500">*</span></label>
             <input type="text" id="rv-name" required class="bg-card-dark border border-border-dark rounded-xl px-4 py-3 text-white outline-none focus:border-primary transition-colors" placeholder="Nguyễn Văn A" />
          </div>
          <div class="flex flex-col gap-1">
             <label class="text-text-muted text-sm">SĐT / Email lúc đặt hàng <span class="text-red-500">*</span></label>
             <input type="text" id="rv-contact" required class="bg-card-dark border border-border-dark rounded-xl px-4 py-3 text-white outline-none focus:border-primary transition-colors" placeholder="0901234567" />
          </div>
        </div>

        <div class="flex flex-col gap-1">
           <label class="text-text-muted text-sm">Nội dung đánh giá</label>
           <textarea id="rv-comment" rows="4" class="bg-card-dark border border-border-dark rounded-xl px-4 py-3 text-white outline-none focus:border-primary transition-colors resize-none" placeholder="Chia sẻ cảm nhận của bạn về sản phẩm này..."></textarea>
        </div>

        <div id="review-alert" class="hidden rounded-xl p-3 text-sm"></div>

        <button type="submit" id="rv-submit-btn" class="w-full bg-primary hover:bg-primary/90 text-background-dark font-bold py-3.5 rounded-xl transition-colors flex justify-center items-center gap-2">
           Gửi đánh giá
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { addToCart } from '../../lib/cart';

  // Image gallery
  const mainImg = document.getElementById('main-img-el') as HTMLImageElement | null;
  const galleryWrapper = document.getElementById('main-image')?.parentElement || null;
  const getThumbButtons = () => Array.from(document.querySelectorAll<HTMLButtonElement>('.thumb-btn'));
  let productGalleryImages = getThumbButtons().length > 0
    ? getThumbButtons().map((btn) => btn.dataset.src || '').filter(Boolean)
    : (mainImg?.src ? [mainImg.src] : []);
  let activeImageIndex = 0;

  function renderThumbnailGallery() {
    if (!galleryWrapper) return;

    let thumbsContainer = document.getElementById('product-thumbnails');

    if (productGalleryImages.length <= 1) {
      thumbsContainer?.remove();
      return;
    }

    if (!thumbsContainer) {
      thumbsContainer = document.createElement('div');
      thumbsContainer.id = 'product-thumbnails';
      thumbsContainer.className = 'grid grid-cols-3 sm:grid-cols-4 gap-3';
      galleryWrapper.appendChild(thumbsContainer);
    }

    thumbsContainer.innerHTML = '';

    productGalleryImages.forEach((src, index) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = `thumb-btn flex-1 aspect-square rounded-xl bg-surface-product-media border-2 overflow-hidden p-2 transition-all ${index === activeImageIndex ? 'border-primary' : 'border-border-dark hover:border-primary/60'}`;
      button.dataset.src = src;
      button.dataset.index = String(index);

      const image = document.createElement('img');
      image.src = src;
      image.alt = `Ảnh sản phẩm ${index + 1}`;
      image.className = 'w-full h-full object-contain';

      button.appendChild(image);
      thumbsContainer.appendChild(button);
    });
  }

  function setActiveImage(index: number, animate = true) {
    if (!mainImg || productGalleryImages.length === 0) return;
    const safeIndex = ((index % productGalleryImages.length) + productGalleryImages.length) % productGalleryImages.length;
    activeImageIndex = safeIndex;

    if (animate) {
      mainImg.style.opacity = '0';
      setTimeout(() => {
        if (mainImg) {
          mainImg.src = productGalleryImages[safeIndex];
          mainImg.style.opacity = '1';
        }
      }, 180);
    } else {
      mainImg.src = productGalleryImages[safeIndex];
      mainImg.style.opacity = '1';
    }

    getThumbButtons().forEach((btn) => {
      const btnIndex = Number(btn.dataset.index || 0);
      btn.classList.toggle('border-primary', btnIndex === safeIndex);
      btn.classList.toggle('border-border-dark', btnIndex !== safeIndex);
    });
  }

  document.addEventListener('click', (event) => {
    const target = event.target instanceof HTMLElement ? event.target.closest('.thumb-btn') as HTMLButtonElement | null : null;
    if (!target) return;

    const idx = Number(target.dataset.index || 0);
    setActiveImage(idx);
  });

  document.addEventListener('dblclick', (event) => {
    const target = event.target instanceof HTMLElement ? event.target.closest('.thumb-btn') as HTMLButtonElement | null : null;
    if (!target) return;

    event.preventDefault();
    const idx = Number(target.dataset.index || 0);

    if (editMode) {
      openProductMediaPicker({ replaceIndex: idx });
      return;
    }

    openProductLightbox(idx);
  });

  // Fullscreen lightbox
  const lightbox = document.getElementById('product-lightbox');
  const lightboxImg = document.getElementById('product-lightbox-img') as HTMLImageElement | null;
  const lightboxClose = document.getElementById('product-lightbox-close');
  const lightboxPrev = document.getElementById('product-lightbox-prev');
  const lightboxNext = document.getElementById('product-lightbox-next');

  function renderLightboxImage() {
    if (!lightboxImg || productGalleryImages.length === 0) return;
    lightboxImg.src = productGalleryImages[activeImageIndex];
  }

  function openProductLightbox(index = activeImageIndex) {
    if (!lightbox || productGalleryImages.length === 0) return;
    activeImageIndex = ((index % productGalleryImages.length) + productGalleryImages.length) % productGalleryImages.length;
    renderLightboxImage();
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeProductLightbox() {
    if (!lightbox) return;
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.removeProperty('overflow');
  }

  function showNextProductImage(step: number) {
    if (productGalleryImages.length === 0) return;
    activeImageIndex = ((activeImageIndex + step) % productGalleryImages.length + productGalleryImages.length) % productGalleryImages.length;
    setActiveImage(activeImageIndex, false);
    renderLightboxImage();
  }

  mainImg?.addEventListener('dblclick', () => {
    if (editMode) {
      openProductMediaPicker({ replaceIndex: activeImageIndex });
      return;
    }

    openProductLightbox(activeImageIndex);
  });
  lightboxClose?.addEventListener('click', closeProductLightbox);
  lightboxPrev?.addEventListener('click', () => showNextProductImage(-1));
  lightboxNext?.addEventListener('click', () => showNextProductImage(1));
  lightboxImg?.addEventListener('click', () => showNextProductImage(1));

  lightbox?.addEventListener('click', (event) => {
    if (event.target === lightbox) {
      closeProductLightbox();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (!lightbox || lightbox.classList.contains('hidden')) return;
    if (event.key === 'Escape') {
      closeProductLightbox();
      return;
    }
    if (event.key === 'ArrowRight') {
      showNextProductImage(1);
      return;
    }
    if (event.key === 'ArrowLeft') {
      showNextProductImage(-1);
    }
  });

  // Tabs
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabContents = document.querySelectorAll<HTMLElement>('.tab-content');

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      tabBtns.forEach((b) => {
        b.classList.toggle('border-primary', b === btn);
        b.classList.toggle('text-primary', b === btn);
        b.classList.toggle('border-transparent', b !== btn);
        b.classList.toggle('text-text-muted', b !== btn);
      });
      tabContents.forEach((c) => {
        c.classList.toggle('hidden', c.id !== `tab-${target}`);
      });
    });
  });

  // Add to cart — thực sự lưu vào localStorage
  const cartBtn = document.getElementById('btn-add-cart') as HTMLButtonElement;
  cartBtn?.addEventListener('click', () => {
    const orig = cartBtn.innerHTML;
    
    // Lấy product data từ data-attributes
    const productId = cartBtn.dataset.productId!;
    const productName = cartBtn.dataset.productName!;
    const productCategory = cartBtn.dataset.productCategory!;
    const productPrice = Number(cartBtn.dataset.productPrice);
    const productPriceFormatted = cartBtn.dataset.productPriceFormatted!;
    const productImage = cartBtn.dataset.productImage!;

    addToCart({
      id: productId,
      name: productName,
      categoryLabel: productCategory,
      price: productPrice,
      priceFormatted: productPriceFormatted,
      image: productImage,
    });

    cartBtn.classList.remove('bg-primary');
    cartBtn.classList.add('bg-green-600');
    cartBtn.innerHTML = '<span class="material-symbols-outlined">check</span>Đã thêm vào giỏ';

    setTimeout(() => {
      cartBtn.innerHTML = orig;
      cartBtn.classList.remove('bg-green-600');
      cartBtn.classList.add('bg-primary');
    }, 3000);
  });

  // Review Modal Logic
  const rvModal = document.getElementById('review-modal');
  const rvModalContent = document.getElementById('review-modal-content');
  const rvBtn = document.getElementById('btn-write-review');
  const rvCloseBtn = document.getElementById('close-review-modal');

  let _rvScrollY = 0;
  function rvLockScroll() {
    _rvScrollY = window.scrollY;
    document.body.style.position = 'fixed';
    document.body.style.top = `-${_rvScrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.overflow = 'hidden';
  }
  function rvUnlockScroll() {
    document.body.style.removeProperty('position');
    document.body.style.removeProperty('top');
    document.body.style.removeProperty('left');
    document.body.style.removeProperty('right');
    document.body.style.removeProperty('overflow');
    window.scrollTo({ top: _rvScrollY, behavior: 'instant' });
  }

  const toggleModal = (show: boolean) => {
    if (show) {
      rvLockScroll();
      rvModal?.classList.remove('opacity-0', 'pointer-events-none');
      rvModalContent?.classList.remove('scale-95');
    } else {
      rvUnlockScroll();
      rvModal?.classList.add('opacity-0', 'pointer-events-none');
      rvModalContent?.classList.add('scale-95');
    }
  };

  rvBtn?.addEventListener('click', () => toggleModal(true));
  rvCloseBtn?.addEventListener('click', () => toggleModal(false));
  rvModal?.addEventListener('click', (e) => {
    if (e.target === rvModal) toggleModal(false);
  });

  // Star Rating Logic
  const starBtns = document.querySelectorAll<HTMLButtonElement>('.star-btn');
  const rvRatingInput = document.getElementById('rv-rating') as HTMLInputElement;

  starBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const rating = Number(btn.dataset.rating);
      rvRatingInput.value = rating.toString();
      starBtns.forEach(b => {
        const bRating = Number(b.dataset.rating);
        b.classList.toggle('text-primary', bRating <= rating);
        b.classList.toggle('text-border-dark', bRating > rating);
      });
    });
  });

  // Form Submit Logic
  const rvForm = document.getElementById('review-form') as HTMLFormElement;
  const rvAlert = document.getElementById('review-alert');
  const rvSubmitBtn = document.getElementById('rv-submit-btn') as HTMLButtonElement;

  function showAlert(msg: string, type: 'error'|'success') {
    if(!rvAlert) return;
    rvAlert.className = `rounded-xl p-3 text-sm mb-4 ${type === 'error' ? 'bg-red-500/10 border border-red-500/20 text-red-500' : 'bg-green-500/10 border border-green-500/20 text-green-500'}`;
    rvAlert.textContent = msg;
    rvAlert.classList.remove('hidden');
  }

  rvForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(!rvAlert || !rvSubmitBtn || !rvRatingInput) return;
    
    if (!rvRatingInput.value) {
      showAlert('Vui lòng chọn số sao đánh giá.', 'error');
      return;
    }

    rvAlert.classList.add('hidden');
    rvSubmitBtn.disabled = true;
    rvSubmitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span> Đang gửi...';

    const productId = (document.getElementById('rv-product-id') as HTMLInputElement).value;
    const reviewerName = (document.getElementById('rv-name') as HTMLInputElement).value;
    const reviewerContact = (document.getElementById('rv-contact') as HTMLInputElement).value;
    const comment = (document.getElementById('rv-comment') as HTMLTextAreaElement).value;

    try {
      const res = await fetch('/api/reviews/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, rating: rvRatingInput.value, comment, reviewerName, reviewerContact })
      });
      const data = await res.json();
      
      if (!res.ok || data.error) throw new Error(data.error);
      
      showAlert(data.message, 'success');
      rvForm.reset();
      starBtns.forEach(b => {
          b.classList.remove('text-primary');
          b.classList.add('text-border-dark');
      });
      rvRatingInput.value = '';
      
      setTimeout(() => toggleModal(false), 3000);
      
    } catch (err: any) {
      showAlert(err.message || 'Lỗi hệ thống', 'error');
    } finally {
      rvSubmitBtn.disabled = false;
      rvSubmitBtn.innerHTML = 'Gửi đánh giá';
    }
  });

  // ── INLINE EDITING (Admin only) ──
  const toggleEditBtn = document.getElementById('toggle-edit-mode');
  const saveEditBtn = document.getElementById('save-edit-mode') as HTMLButtonElement | null;
  const exitEditBtn = document.getElementById('exit-edit-mode');
  const editModeText = document.getElementById('edit-mode-text');
  const editStatus = document.getElementById('edit-status');
  const advancedEditPanel = document.getElementById('product-advanced-quick-edit');
  const productConditionDisplay = document.getElementById('product-condition-display');
  const productVideoPreview = document.getElementById('product-video-preview');
  const productAddImageBtn = document.getElementById('product-add-image-btn') as HTMLButtonElement | null;
  const productFieldInputs = Array.from(document.querySelectorAll('[data-product-field]')) as Array<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>;
  let editMode = false;
  let hasPendingProductChanges = false;
  let productStatusTimer: ReturnType<typeof setTimeout> | null = null;
  let originalGalleryImages = [...productGalleryImages];
  let productMediaInput: HTMLInputElement | null = null;
  let pendingImageReplaceIndex: number | null = null;
  const dirtyProductEls = new Set<HTMLElement>();
  const dirtyProductFields = new Set<string>();

  function getProductEditables() {
    return Array.from(document.querySelectorAll<HTMLElement>('[data-editable], [data-array-field]'));
  }

  function getProductSlug() {
    return window.location.pathname.split('/').filter(Boolean).pop() || '';
  }

  function getConditionLabelFromValue(value: string) {
    switch (String(value || '').trim()) {
      case 'used':
        return 'Đàn cũ';
      case 'like_new':
        return 'Like new';
      default:
        return 'Mới 100%';
    }
  }

  function getProductVideoEmbedUrl(url: string) {
    const trimmed = String(url || '').trim();
    if (!trimmed) return '';

    try {
      const parsed = new URL(trimmed);
      if (parsed.hostname.includes('youtu.be')) {
        const id = parsed.pathname.split('/').filter(Boolean)[0];
        return id ? `https://www.youtube.com/embed/${id}` : '';
      }

      if (parsed.hostname.includes('youtube.com')) {
        if (parsed.pathname.startsWith('/embed/')) {
          return trimmed;
        }
        const id = parsed.searchParams.get('v');
        return id ? `https://www.youtube.com/embed/${id}` : '';
      }
    } catch {
      return '';
    }

    return '';
  }

  function renderVideoPreview(urlValue = (document.getElementById('product-video-url-input') as HTMLInputElement | null)?.value || '') {
    if (!productVideoPreview) return;

    const embedUrl = getProductVideoEmbedUrl(urlValue);
    if (embedUrl) {
      productVideoPreview.innerHTML = '';
      const iframe = document.createElement('iframe');
      iframe.src = embedUrl;
      iframe.title = `${(document.querySelector('[data-editable="name"]')?.textContent || 'Sản phẩm').trim()} Demo`;
      iframe.className = 'w-full h-full';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      productVideoPreview.appendChild(iframe);
      return;
    }

    const fallbackImage = productGalleryImages[0] || mainImg?.src || '/images/default-guitar.webp';
    productVideoPreview.innerHTML = `
      <div class="absolute inset-0 bg-cover bg-center opacity-30" style="background-image: url('${fallbackImage}')"></div>
      <div class="relative z-10 text-center p-8">
        <div class="w-16 h-16 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center mx-auto mb-4 cursor-pointer hover:bg-primary/30 transition-colors">
          <span class="material-symbols-outlined text-primary text-3xl">play_arrow</span>
        </div>
        <p class="text-white font-semibold mb-1">Lắng nghe ${(document.querySelector('[data-editable="name"]')?.textContent || 'sản phẩm').trim()} biểu diễn</p>
        <p class="text-text-muted text-sm">Xem đánh giá & Thử âm thanh</p>
      </div>
    `;
  }

  function recalculateProductDirtyState() {
    dirtyProductEls.clear();
    dirtyProductFields.clear();

    getProductEditables().forEach((el) => {
      if ((el.textContent || '').trim() !== (el.dataset.currentValue || '')) {
        dirtyProductEls.add(el);
      }
    });

    productFieldInputs.forEach((input) => {
      const field = input.dataset.productField || '';
      if (!field) return;
      if ((input.value || '').trim() !== (input.dataset.currentValue || '')) {
        dirtyProductFields.add(field);
      }
    });

    if (JSON.stringify(productGalleryImages) !== JSON.stringify(originalGalleryImages)) {
      dirtyProductFields.add('gallery_images');
    }

    hasPendingProductChanges = dirtyProductEls.size > 0 || dirtyProductFields.size > 0;
    syncProductEditActions();
  }

  function syncProductEditActions() {
    toggleEditBtn?.classList.toggle('hidden', editMode);
    saveEditBtn?.classList.toggle('hidden', !editMode || !hasPendingProductChanges);
    exitEditBtn?.classList.toggle('hidden', !editMode);
    advancedEditPanel?.classList.toggle('is-active', editMode);
    if (editModeText) {
      editModeText.textContent = 'Chỉnh sửa';
    }
  }

  function flashProductSaved(message = 'Đã lưu') {
    if (!editStatus) return;
    if (productStatusTimer) {
      clearTimeout(productStatusTimer);
    }
    editStatus.textContent = message;
    editStatus.classList.remove('hidden');
    editStatus.classList.remove('is-flashing');
    void editStatus.offsetWidth;
    editStatus.classList.add('is-flashing');
    productStatusTimer = setTimeout(() => {
      editStatus.classList.add('hidden');
      editStatus.classList.remove('is-flashing');
      productStatusTimer = null;
    }, 1700);
  }

  function handleProductInput() {
    recalculateProductDirtyState();
  }

  function handleProductFieldChange(event: Event) {
    const input = (event.currentTarget || event.target) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
    if (!input) return;

    const field = input.dataset.productField || '';
    if (field === 'product_condition' && productConditionDisplay) {
      productConditionDisplay.textContent = getConditionLabelFromValue(input.value);
    }
    if (field === 'video_url') {
      renderVideoPreview(input.value);
    }

    recalculateProductDirtyState();
  }

  function enableEditMode() {
    originalGalleryImages = [...productGalleryImages];

    getProductEditables().forEach((htmlEl) => {
      htmlEl.style.outline = '2px dashed #f48c25';
      htmlEl.style.outlineOffset = '4px';
      htmlEl.style.cursor = 'text';
      htmlEl.contentEditable = 'true';
      htmlEl.dataset.currentValue = (htmlEl.textContent || '').trim();
      htmlEl.addEventListener('input', handleProductInput);
    });

    productFieldInputs.forEach((input) => {
      input.disabled = false;
      input.dataset.currentValue = (input.value || '').trim();
      input.addEventListener('input', handleProductFieldChange);
      input.addEventListener('change', handleProductFieldChange);
    });

    recalculateProductDirtyState();
  }

  function disableEditMode() {
    getProductEditables().forEach((htmlEl) => {
      htmlEl.style.outline = 'none';
      htmlEl.style.cursor = 'default';
      htmlEl.contentEditable = 'false';
      htmlEl.removeEventListener('input', handleProductInput);
    });

    productFieldInputs.forEach((input) => {
      input.disabled = true;
      input.removeEventListener('input', handleProductFieldChange);
      input.removeEventListener('change', handleProductFieldChange);
    });

    dirtyProductEls.clear();
    dirtyProductFields.clear();
    hasPendingProductChanges = false;
    syncProductEditActions();
  }

  function revertProductChanges() {
    getProductEditables().forEach((el) => {
      el.textContent = el.dataset.currentValue || '';
    });

    productFieldInputs.forEach((input) => {
      input.value = input.dataset.currentValue || '';
    });

    productGalleryImages = [...originalGalleryImages];
    activeImageIndex = Math.min(activeImageIndex, Math.max(productGalleryImages.length - 1, 0));
    renderThumbnailGallery();
    setActiveImage(activeImageIndex, false);

    if (productConditionDisplay) {
      const conditionInput = document.getElementById('product-condition-input') as HTMLSelectElement | null;
      productConditionDisplay.textContent = getConditionLabelFromValue(conditionInput?.value || 'new');
    }

    renderVideoPreview();
    recalculateProductDirtyState();
  }

  async function postProductQuickUpdate(field: string, value: unknown) {
    const res = await fetch('/api/products/quick-update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: getProductSlug(), field, value })
    });

    const data = await res.json().catch(() => ({}));
    if (!res.ok || !data.success) {
      throw new Error(data.error || 'Không thể lưu thay đổi');
    }

    return data;
  }

  function getDisplayValueForField(field: string, value: unknown, fallback = '') {
    if (field === 'price') {
      const numericValue = Number(value || 0);
      return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(numericValue);
    }

    if (field === 'spec_body' || field === 'spec_top' || field === 'spec_neck') {
      return String(value ?? '').trim() || 'Chưa cập nhật';
    }

    return String(value ?? fallback).trim();
  }

  async function uploadProductImage(file: File, replaceIndex: number | null = null) {
    const formData = new FormData();
    formData.append('file', file);

    productAddImageBtn?.setAttribute('disabled', 'true');

    try {
      const res = await fetch('/api/site-media/upload', {
        method: 'POST',
        body: formData
      });
      const data = await res.json().catch(() => ({}));
      const uploadedUrl = String(data?.url || data?.file?.url || '').trim();

      if (!res.ok || !data?.success || !uploadedUrl) {
        throw new Error(data?.error || 'Không thể tải ảnh lên');
      }
      if (typeof replaceIndex === 'number' && replaceIndex >= 0 && replaceIndex < productGalleryImages.length) {
        productGalleryImages[replaceIndex] = uploadedUrl;
        activeImageIndex = replaceIndex;
      } else {
        productGalleryImages.push(uploadedUrl);
        activeImageIndex = productGalleryImages.length - 1;
      }

      renderThumbnailGallery();
      setActiveImage(activeImageIndex, false);
      renderVideoPreview();
      recalculateProductDirtyState();
      flashProductSaved(typeof replaceIndex === 'number' ? 'Đã thay ảnh, nhớ bấm Lưu' : 'Đã thêm ảnh, nhớ bấm Lưu');
    } finally {
      productAddImageBtn?.removeAttribute('disabled');
    }
  }

  function openProductMediaPicker(options: { replaceIndex?: number } = {}) {
    if (!editMode) {
      flashProductSaved('Hãy bật chế độ chỉnh sửa trước');
      return;
    }

    pendingImageReplaceIndex = typeof options.replaceIndex === 'number' ? options.replaceIndex : null;

    if (!productMediaInput) {
      productMediaInput = document.createElement('input');
      productMediaInput.type = 'file';
      productMediaInput.accept = 'image/*';
      productMediaInput.className = 'hidden';
      productMediaInput.addEventListener('change', async () => {
        const selectedFile = productMediaInput?.files?.[0];
        const replaceIndex = pendingImageReplaceIndex;
        pendingImageReplaceIndex = null;

        if (!selectedFile) return;

        try {
          await uploadProductImage(selectedFile, replaceIndex);
        } catch (err: any) {
          alert('Lỗi tải ảnh: ' + (err?.message || 'Không thể tải ảnh lên'));
        } finally {
          if (productMediaInput) {
            productMediaInput.value = '';
          }
        }
      });
      document.body.appendChild(productMediaInput);
    }

    productMediaInput.click();
  }

  async function saveProductChanges() {
    let changedCount = 0;

    const changedNodes = Array.from(document.querySelectorAll<HTMLElement>('[data-editable]')).filter((el) => {
      return (el.textContent || '').trim() !== (el.dataset.currentValue || '');
    });

    for (const el of changedNodes) {
      const field = el.dataset.editable;
      const newValue = (el.textContent || '').trim();
      const originalValue = el.dataset.currentValue || '';

      if (!field) continue;

      el.style.opacity = '0.5';

      try {
        const payloadValue = field === 'price'
          ? Number.parseInt(newValue.replace(/\D/g, ''), 10) || 0
          : newValue;
        const data = await postProductQuickUpdate(field, payloadValue);
        const displayValue = getDisplayValueForField(field, data.value, newValue);
        el.textContent = displayValue;
        el.dataset.currentValue = displayValue;
        changedCount += 1;
      } catch (err) {
        el.textContent = originalValue;
        throw err;
      } finally {
        el.style.opacity = '1';
      }
    }

    const arrayFields = Array.from(new Set(
      Array.from(document.querySelectorAll<HTMLElement>('[data-array-field]'))
        .map((el) => el.dataset.arrayField || '')
        .filter(Boolean)
    ));

    for (const field of arrayFields) {
      const nodes = Array.from(document.querySelectorAll<HTMLElement>(`[data-array-field="${field}"]`));
      const currentValues = nodes.map((el) => (el.textContent || '').trim());
      const originalValues = nodes.map((el) => el.dataset.currentValue || '');

      if (!currentValues.some((value, index) => value !== originalValues[index])) continue;

      nodes.forEach((el) => {
        el.style.opacity = '0.5';
      });

      try {
        await postProductQuickUpdate(field, currentValues);
        nodes.forEach((el, index) => {
          const nextText = currentValues[index] || '';
          el.textContent = nextText;
          el.dataset.currentValue = nextText;
        });
        changedCount += 1;
      } finally {
        nodes.forEach((el) => {
          el.style.opacity = '1';
        });
      }
    }

    for (const input of productFieldInputs) {
      const field = input.dataset.productField || '';
      const currentValue = (input.value || '').trim();
      const originalValue = input.dataset.currentValue || '';

      if (!field || currentValue === originalValue) continue;

      input.style.opacity = '0.65';

      try {
        const payloadValue = field === 'stock_quantity'
          ? Number.parseInt(currentValue.replace(/\D/g, ''), 10) || 0
          : currentValue;
        const data = await postProductQuickUpdate(field, payloadValue);
        const nextValue = field === 'stock_quantity'
          ? String(data.value ?? payloadValue ?? 0)
          : String(data.value ?? currentValue ?? '');
        input.value = nextValue;
        input.dataset.currentValue = nextValue;
        changedCount += 1;
      } finally {
        input.style.opacity = '1';
      }
    }

    if (JSON.stringify(productGalleryImages) !== JSON.stringify(originalGalleryImages)) {
      await postProductQuickUpdate('gallery_images', productGalleryImages);
      originalGalleryImages = [...productGalleryImages];
      changedCount += 1;
    }

    if (productConditionDisplay) {
      const conditionInput = document.getElementById('product-condition-input') as HTMLSelectElement | null;
      productConditionDisplay.textContent = getConditionLabelFromValue(conditionInput?.value || 'new');
    }

    renderVideoPreview();
    recalculateProductDirtyState();

    if (changedCount > 0) {
      flashProductSaved('Đã lưu thay đổi');
    }
  }

  productAddImageBtn?.addEventListener('click', () => {
    openProductMediaPicker();
  });

  toggleEditBtn?.addEventListener('click', () => {
    editMode = true;
    enableEditMode();
    syncProductEditActions();
  });

  saveEditBtn?.addEventListener('click', async () => {
    if (!hasPendingProductChanges) return;
    saveEditBtn.setAttribute('disabled', 'true');
    try {
      await saveProductChanges();
    } catch (err: any) {
      recalculateProductDirtyState();
      alert('Lỗi lưu: ' + (err?.message || 'Không thể lưu thay đổi'));
    } finally {
      saveEditBtn.removeAttribute('disabled');
      syncProductEditActions();
    }
  });

  exitEditBtn?.addEventListener('click', () => {
    if (hasPendingProductChanges && !confirm('Bạn có thay đổi chưa lưu. Thoát và bỏ thay đổi?')) {
      return;
    }

    if (hasPendingProductChanges) {
      revertProductChanges();
    }

    editMode = false;
    disableEditMode();
    syncProductEditActions();
  });

  renderThumbnailGallery();
  setActiveImage(0, false);
  renderVideoPreview();
  disableEditMode();

  // Reviews link click handler
  const reviewsLink = document.getElementById('reviews-link');
  reviewsLink?.addEventListener('click', () => {
    const reviewsTab = document.querySelector('[data-tab="reviews"]') as HTMLElement;
    reviewsTab?.click();
    const tabReviews = document.getElementById('tab-reviews');
    tabReviews?.scrollIntoView({ behavior: 'smooth' });
  });

</script>

