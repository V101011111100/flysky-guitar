---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase';
import { getAdminMfaState } from '../../lib/security';

const { id } = Astro.params;

// Check if current user is admin (for inline editing)
let isAdmin = false;
const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (accessToken && refreshToken) {
  const authState = await getAdminMfaState(accessToken.value, refreshToken.value);
  isAdmin = authState.authenticated && authState.isAdmin && !authState.requiresMfa;
}

// Lấy sản phẩm hiện tại
const { data: dbProduct, error } = await supabase
  .from('products')
  .select(`*, categories(id, name, slug)`)
  .eq('slug', id)
  .single();

if (!dbProduct || error) {
  return Astro.redirect('/shop'); // Fallback redirect if not found
}

// Lấy sản phẩm liên quan
const { data: dbRelated } = await supabase
  .from('products')
  .select(`*, categories(name, slug)`)
  .eq('category_id', dbProduct.category_id)
  .neq('id', dbProduct.id)
  .limit(3);

// Lấy danh sách đánh giá
const { data: dbReviews, error: _revErr } = await supabase
  .from('reviews')
  .select('*')
  .eq('product_id', dbProduct.id)
  .eq('status', 'approved')
  .order('created_at', { ascending: false });

const reviews = dbReviews || [];
const totalReviews = reviews.length;
const averageRating = totalReviews > 0 ? (reviews.reduce((acc, r) => acc + r.rating, 0) / totalReviews) : 0;

// Thống kê sao
const starCounts = [0, 0, 0, 0, 0, 0];
reviews.forEach(r => {
  starCounts[r.rating] = (starCounts[r.rating] || 0) + 1;
});
const ratingStats = [5, 4, 3, 2, 1].map(stars => ({
  stars,
  pct: totalReviews > 0 ? Math.round((starCounts[stars] / totalReviews) * 100) : 0
}));

// Helper function to convert video URL to embed URL
function getVideoEmbedUrl(url: string): string | null {
  if (!url) return null;
  
  // YouTube
  const youtubeMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([^&\n?#]+)/);
  if (youtubeMatch) {
    return `https://www.youtube.com/embed/${youtubeMatch[1]}`;
  }
  
  // Vimeo
  const vimeoMatch = url.match(/(?:vimeo\.com\/|vimeo\.com\/video\/)(\d+)/);
  if (vimeoMatch) {
    return `https://player.vimeo.com/video/${vimeoMatch[1]}`;
  }
  
  // If it's already an embed URL, return as is
  if (url.includes('youtube.com/embed/') || url.includes('player.vimeo.com/video/')) {
    return url;
  }
  
  return null;
}

const product = {
  id: dbProduct.slug,
  name: dbProduct.name,
  subtitle: dbProduct.description ? dbProduct.description.substring(0, 100) + '...' : 'Thiết kế đẹp mắt, âm thanh đỉnh cao.',
  longDescription: dbProduct.description || 'Chưa có mô tả chi tiết.',
  categoryLabel: dbProduct.categories?.name || 'Sản phẩm',
  price: dbProduct.price,
  priceFormatted: new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(dbProduct.price),
  images: [
    (dbProduct.gallery_images && dbProduct.gallery_images.length > 0) ? dbProduct.gallery_images[0] : '/images/default-guitar.webp',
    ...(Array.isArray(dbProduct.gallery_images) ? dbProduct.gallery_images.slice(1) : [])
  ],
  videoUrl: dbProduct.video_url || null,
  rating: averageRating,
  reviews: totalReviews,
  badge: dbProduct.is_featured ? 'Nổi bật' : (dbProduct.status === 'out_of_stock' ? 'Hết hàng' : null),
  features: [
    'Chất liệu được chọn lọc kỹ càng',
    'Hoàn thiện thủ công tỉ mỉ',
    'Âm thanh vượt trội trong phân khúc',
    'Bền bỉ với thời gian'
  ],
  specs: [
    { label: 'Thương hiệu', value: 'FlySky' },
    { label: 'Tình trạng', value: dbProduct.status === 'out_of_stock' ? 'Hết hàng' : 'Mới 100%' },
    ...(dbProduct.spec_body ? [{ label: 'Lưng Hông', value: dbProduct.spec_body }] : []),
    ...(dbProduct.spec_top ? [{ label: 'Mặt Top', value: dbProduct.spec_top }] : []),
    ...(dbProduct.spec_neck ? [{ label: 'Cần Đàn', value: dbProduct.spec_neck }] : [])
  ]
};

const related = (dbRelated || []).map(rp => ({
  id: rp.slug,
  categoryLabel: rp.categories?.name || 'Khác',
  name: rp.name,
  description: (rp.description || '').substring(0, 50) + '...',
  price: rp.price,
  priceFormatted: new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(rp.price),
  image: (rp.gallery_images && rp.gallery_images.length > 0) ? rp.gallery_images[0] : '/images/default-guitar.webp',
  badge: rp.is_featured ? 'Nổi bật' : null
}));
---

<Layout
  title={`${product.name} | FlySky Guitar`}
  description={product.longDescription}
>
  <Navbar />

  <!-- Breadcrumb -->
  <div class="bg-background-dark border-b border-border-dark/50">
    <div class="mx-auto max-w-7xl px-4 lg:px-10 py-3 flex items-center gap-2 text-sm text-text-muted">
      <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
      <span class="material-symbols-outlined text-[14px]">chevron_right</span>
      <a href="/shop" class="hover:text-primary transition-colors">Cửa hàng</a>
      <span class="material-symbols-outlined text-[14px]">chevron_right</span>
      <span class="text-white/60 truncate">{product.name}</span>
    </div>
  </div>

  <!-- Product Hero -->
  <section class="py-12 bg-background-dark">
    <div class="mx-auto max-w-7xl px-4 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Image Gallery -->
        <div class="flex flex-col gap-4">
          <!-- Main image -->
          <div
            id="main-image"
            class="w-full aspect-square rounded-2xl bg-surface-product-media border border-border-dark overflow-hidden flex items-center justify-center p-8 relative"
          >
            {product.badge && (
              <div class="absolute top-4 left-4 bg-primary text-background-dark text-xs font-extrabold px-3 py-1.5 rounded uppercase tracking-wider z-10">
                {product.badge}
              </div>
            )}
            <img
              id="main-img-el"
              src={product.images[0]}
              alt={product.name}
              class="w-full h-full object-contain transition-opacity duration-300"
            />
          </div>
          <!-- Thumbnails -->
          {product.images.length > 1 && (
            <div class="flex gap-3">
              {product.images.map((img, i) => (
                <button
                  class={`thumb-btn flex-1 aspect-square rounded-xl bg-surface-product-media border-2 overflow-hidden p-2 transition-all ${i === 0 ? 'border-primary' : 'border-border-dark hover:border-primary/60'}`}
                  data-src={img}
                  data-index={i}
                >
                  <img src={img} alt={`${product.name} view ${i + 1}`} class="w-full h-full object-contain" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Product Info -->
        <div class="flex flex-col gap-6 lg:sticky lg:top-24">
          <!-- Category + badge -->
          <div class="flex items-center gap-3">
            <span class="text-primary font-bold text-xs uppercase tracking-widest">{product.categoryLabel}</span>
            <span class="w-1 h-1 rounded-full bg-border-dark"></span>
            <span class="text-text-muted text-xs">Thủ công cao cấp</span>
          </div>

          <!-- Name + subtitle -->
          <div>
            <h1 
              class="text-white type-display-section"
              data-editable={isAdmin ? "name" : undefined}
              data-original={product.name}
            >{product.name}</h1>
            <p class="text-text-muted type-body-lead mt-1">{product.subtitle}</p>
          </div>

          <!-- Rating -->
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <span
                  class={`material-symbols-outlined text-[18px] ${i < Math.round(product.rating) ? 'text-primary' : 'text-border-dark'}`}
                  style="font-variation-settings: 'FILL' 1"
                >star</span>
              ))}
            </div>
            <span class="text-white font-semibold text-sm">{product.rating.toFixed(1)}</span>
            <span id="reviews-link" class="text-text-muted text-sm cursor-pointer hover:underline">({product.reviews} đánh giá)</span>
          </div>

          <!-- Price -->
          <div class="flex items-baseline gap-3">
            <span 
              class="text-white text-4xl font-extrabold"
              data-editable={isAdmin ? "price" : undefined}
              data-original={product.price}
            >{product.priceFormatted}</span>
          </div>

          <!-- Benefits -->
          <div class="flex flex-wrap gap-4 py-4 border-y border-border-dark/50">
            <div class="flex items-center gap-2 text-text-muted text-sm">
              <span class="material-symbols-outlined text-primary text-[18px]">local_shipping</span>
              Miễn phí vận chuyển toàn quốc
            </div>
            <div class="flex items-center gap-2 text-text-muted text-sm">
              <span class="material-symbols-outlined text-primary text-[18px]">replay</span>
              Hoàn tiền trong 30 ngày
            </div>
            <div class="flex items-center gap-2 text-text-muted text-sm">
              <span class="material-symbols-outlined text-primary text-[18px]">verified</span>
              Bảo hành 2 năm
            </div>
          </div>

          <!-- Description -->
          <p 
            class="text-text-muted leading-relaxed"
            data-editable={isAdmin ? "description" : undefined}
            data-original={product.longDescription}
          >{product.longDescription}</p>

          <div class="flex flex-col sm:flex-row gap-3">
            <button
              id="btn-add-cart"
              data-product-id={product.id}
              data-product-name={product.name}
              data-product-category={product.categoryLabel}
              data-product-price={product.price}
              data-product-price-formatted={product.priceFormatted}
              data-product-image={product.images[0]}
              class="flex-1 flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-background-dark font-bold py-4 px-6 rounded-xl transition-all duration-200 hover:shadow-[0_0_20px_rgba(244,140,37,0.4)] active:scale-95"
            >
              <span class="material-symbols-outlined">add_shopping_cart</span>
              Thêm vào giỏ hàng
            </button>
            <button
              class="flex items-center justify-center gap-2 bg-border-dark/50 hover:bg-border-dark text-white font-semibold py-4 px-6 rounded-xl border border-border-dark transition-all duration-200"
            >
              <span class="material-symbols-outlined">favorite_border</span>
              Yêu thích
            </button>
          </div>

          <!-- Consult note -->
          <div class="bg-card-dark border border-border-dark rounded-xl p-4 flex gap-3">
            <span class="material-symbols-outlined text-primary flex-shrink-0 mt-0.5">info</span>
            <div>
              <p class="text-white text-sm font-semibold mb-1">Tư vấn trực tiếp</p>
              <p class="text-text-muted text-xs leading-relaxed">Bỏ vào giỏ và gửi yêu cầu, chúng tôi sẽ liên hệ tư vấn chi tiết cho bạn. Không yêu cầu đăng nhập.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Details Tabs -->
  <section class="py-16 bg-surface-section-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-10">
      <!-- Tab nav -->
      <div class="flex gap-1 border-b border-border-dark mb-10">
        {[
          { id: 'features', label: 'Tính năng nổi bật' },
          { id: 'specs', label: 'Thông số kỹ thuật' },
          { id: 'reviews', label: `Đánh giá (${product.reviews})` },
        ].map((tab, i) => (
          <button
            class={`tab-btn px-6 py-3 text-sm font-semibold border-b-2 transition-all -mb-px ${i === 0 ? 'border-primary text-primary' : 'border-transparent text-text-muted hover:text-white'}`}
            data-tab={tab.id}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Tab: Features -->
      <div id="tab-features" class="tab-content">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
          <div>
            <span class="text-primary font-bold tracking-widest uppercase text-sm">Chế tác vì sự xuất sắc</span>
            <h2 class="text-white text-2xl font-bold mt-2 mb-6">Từng chi tiết được mài giũa tỉ mỉ</h2>
            <ul class="flex flex-col gap-4">
              {product.features.map((f) => (
                <li class="flex items-start gap-3">
                  <span class="material-symbols-outlined text-primary flex-shrink-0 mt-0.5" style="font-variation-settings: 'FILL' 1">check_circle</span>
                  <span class="text-text-muted leading-relaxed">{f}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="relative bg-card-dark rounded-2xl overflow-hidden border border-border-dark aspect-video flex items-center justify-center">
            {product.videoUrl && getVideoEmbedUrl(product.videoUrl) ? (
              <iframe 
                src={getVideoEmbedUrl(product.videoUrl)}
                title={`${product.name} Demo`}
                class="w-full h-full"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            ) : (
              <>
                <div class="absolute inset-0 bg-cover bg-center opacity-30" style={`background-image: url('${product.images[0]}')`}></div>
                <div class="relative z-10 text-center p-8">
                  <div class="w-16 h-16 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center mx-auto mb-4 cursor-pointer hover:bg-primary/30 transition-colors">
                    <span class="material-symbols-outlined text-primary text-3xl">play_arrow</span>
                  </div>
                  <p class="text-white font-semibold mb-1">Lắng nghe {product.name} biểu diễn</p>
                  <p class="text-text-muted text-sm">Xem đánh giá & Thử âm thanh</p>
                </div>
              </>
            )}
          </div>
        </div>
      </div>

      <!-- Tab: Specs -->
      <div id="tab-specs" class="tab-content hidden">
        <div class="max-w-2xl">
          <h2 class="text-white text-2xl font-bold mb-6">Thông số kỹ thuật</h2>
          <div class="divide-y divide-border-dark">
            {product.specs.map((spec) => (
              <div class="flex items-center py-4 gap-4">
                <span class="text-text-muted text-sm w-40 flex-shrink-0">{spec.label}</span>
                <span class="text-white font-medium text-sm">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Tab: Reviews -->
      <div id="tab-reviews" class="tab-content hidden">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          <!-- Rating summary -->
          <div class="bg-card-dark rounded-2xl border border-border-dark p-8 text-center flex flex-col">
            <div class="text-primary text-6xl font-extrabold">{product.rating.toFixed(1)}</div>
            <div class="flex justify-center gap-1 my-3">
              {Array.from({ length: 5 }).map((_, i) => (
                <span class={`material-symbols-outlined ${i < Math.round(product.rating) ? 'text-primary' : 'text-border-dark'}`} style="font-variation-settings: 'FILL' 1">star</span>
              ))}
            </div>
            <p class="text-text-muted text-sm">Dựa trên {product.reviews} đánh giá</p>
            <div class="mt-6 flex flex-col gap-2 text-left mb-8">
              {ratingStats.map((row) => (
                <div class="flex items-center gap-2 text-xs text-text-muted">
                  <span class="w-3">{row.stars}</span>
                  <span class="material-symbols-outlined text-primary text-[12px]" style="font-variation-settings: 'FILL' 1">star</span>
                  <div class="flex-1 bg-border-dark rounded-full h-1.5 overflow-hidden">
                    <div class="bg-primary h-1.5 rounded-full" style={`width: ${row.pct}%`}></div>
                  </div>
                  <span class="w-8 text-right">{row.pct}%</span>
                </div>
              ))}
            </div>
            <button id="btn-write-review" class="mt-auto bg-primary text-background-dark font-bold py-3 rounded-xl transition-all hover:-translate-y-1 hover:shadow-lg w-full">Viết đánh giá</button>
            <p class="text-[10px] text-text-muted mt-2 mt-2 leading-relaxed">Chỉ khách hàng đã mua sản phẩm (được hệ thống nhận diện từ SĐT/Email lúc đặt hàng) mới có quyền đánh giá.</p>
          </div>
          <!-- Sample reviews -->
          <div class="md:col-span-2 flex flex-col gap-5">
            {reviews.length === 0 ? (
               <div class="bg-card-dark rounded-xl border border-border-dark p-12 text-center text-text-muted">
                 Chưa có đánh giá nào cho sản phẩm này. Trở thành người đầu tiên!
               </div>
            ) : reviews.map((review) => (
              <div class="bg-card-dark rounded-xl border border-border-dark p-6">
                <div class="flex items-start justify-between mb-3">
                  <div>
                    <p class="text-white font-semibold">{review.reviewer_name}</p>
                    <p class="text-text-muted text-xs">{new Date(review.created_at).toLocaleDateString('vi-VN')}</p>
                  </div>
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }).map((_, i) => (
                      <span class={`material-symbols-outlined text-[14px] ${i < review.rating ? 'text-primary' : 'text-border-dark'}`} style="font-variation-settings: 'FILL' 1">star</span>
                    ))}
                  </div>
                </div>
                <p class="text-text-muted text-sm leading-relaxed">{review.comment}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  {related.length > 0 && (
    <section class="py-16 bg-background-dark">
      <div class="mx-auto max-w-7xl px-4 lg:px-10">
        <div class="flex items-end justify-between mb-8">
          <div>
            <span class="text-primary font-bold tracking-widest uppercase text-sm">Gợi ý</span>
            <h2 class="text-white text-2xl font-bold mt-1">Có thể bạn sẽ thích</h2>
          </div>
          <a class="hidden md:flex items-center gap-1 text-primary font-medium hover:text-white transition-colors text-sm" href="/shop">
            Xem tất cả <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {related.map((rp) => (
            <a
              href={`/products/${rp.id}`}
              class="group flex flex-col bg-card-dark rounded-xl overflow-hidden hover:shadow-[0_0_24px_rgba(244,140,37,0.18)] transition-all duration-300 border border-border-dark"
            >
              <div class="aspect-square w-full bg-[#2a2015] relative p-4 flex items-center justify-center overflow-hidden">
                <div
                  class="w-full h-full bg-contain bg-center bg-no-repeat group-hover:scale-110 transition-transform duration-500"
                  style={`background-image: url("${rp.image}");`}
                ></div>
                {rp.badge && (
                  <div class="absolute top-3 left-3 bg-primary text-background-dark text-[10px] font-bold px-2 py-1 rounded uppercase">
                    {rp.badge}
                  </div>
                )}
              </div>
              <div class="p-5">
                <span class="text-primary text-xs font-bold uppercase tracking-wider">{rp.categoryLabel}</span>
                <h3 class="text-white text-base font-bold mt-1 group-hover:text-primary transition-colors">{rp.name}</h3>
                <p class="text-text-muted text-xs mt-1">{rp.description}</p>
                <div class="flex items-center justify-between mt-4 pt-3 border-t border-border-dark/50">
                  <span class="text-white font-extrabold">{rp.priceFormatted}</span>
                  <span class="text-primary text-sm font-medium flex items-center gap-1">
                    Xem chi tiết <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer />

  <!-- Admin Inline Edit Toolbar (only visible to admin) -->
  {isAdmin && (
    <div id="admin-toolbar" class="public-quick-toolbar">
      <button
        id="toggle-edit-mode"
        class="public-quick-btn"
        title="Bật/tắt chế độ chỉnh sửa nhanh"
      >
        <span class="material-symbols-outlined">edit_square</span>
        <span id="edit-mode-text">Chỉnh sửa</span>
      </button>
      <span id="edit-status" class="public-quick-status hidden">Đã lưu</span>
    </div>
  )}

  <!-- Review Modal -->
  <div id="review-modal" class="fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="bg-background-dark border border-border-dark rounded-2xl w-full max-w-lg p-6 lg:p-8 transform scale-95 transition-transform duration-300" id="review-modal-content">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-white text-xl font-bold">Viết Đánh Giá</h3>
        <button id="close-review-modal" class="text-text-muted hover:text-white transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>

      <form id="review-form" class="space-y-4">
        <input type="hidden" id="rv-product-id" value={dbProduct.id} />
        
        <div class="flex flex-col gap-2 relative">
          <label class="text-text-muted text-sm">Chất lượng sản phẩm <span class="text-red-500">*</span></label>
          <div class="flex gap-1" id="star-rating">
            {[1, 2, 3, 4, 5].map((s) => (
              <button type="button" class="star-btn material-symbols-outlined text-border-dark text-3xl hover:-translate-y-1 transition-transform" data-rating={s} style="font-variation-settings: 'FILL' 1">star</button>
            ))}
          </div>
          <input type="hidden" id="rv-rating" required />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col gap-1">
             <label class="text-text-muted text-sm">Tên của bạn <span class="text-red-500">*</span></label>
             <input type="text" id="rv-name" required class="bg-card-dark border border-border-dark rounded-xl px-4 py-3 text-white outline-none focus:border-primary transition-colors" placeholder="Nguyễn Văn A" />
          </div>
          <div class="flex flex-col gap-1">
             <label class="text-text-muted text-sm">SĐT / Email lúc đặt hàng <span class="text-red-500">*</span></label>
             <input type="text" id="rv-contact" required class="bg-card-dark border border-border-dark rounded-xl px-4 py-3 text-white outline-none focus:border-primary transition-colors" placeholder="0901234567" />
          </div>
        </div>

        <div class="flex flex-col gap-1">
           <label class="text-text-muted text-sm">Nội dung đánh giá</label>
           <textarea id="rv-comment" rows="4" class="bg-card-dark border border-border-dark rounded-xl px-4 py-3 text-white outline-none focus:border-primary transition-colors resize-none" placeholder="Chia sẻ cảm nhận của bạn về sản phẩm này..."></textarea>
        </div>

        <div id="review-alert" class="hidden rounded-xl p-3 text-sm"></div>

        <button type="submit" id="rv-submit-btn" class="w-full bg-primary hover:bg-primary/90 text-background-dark font-bold py-3.5 rounded-xl transition-colors flex justify-center items-center gap-2">
           Gửi đánh giá
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { addToCart } from '../../lib/cart';

  // Image gallery
  const thumbBtns = document.querySelectorAll<HTMLButtonElement>('.thumb-btn');
  const mainImg = document.getElementById('main-img-el') as HTMLImageElement;

  thumbBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.src;
      if (src && mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = src;
          mainImg.style.opacity = '1';
        }, 200);
      }
      thumbBtns.forEach((b) => {
        b.classList.toggle('border-primary', b === btn);
        b.classList.toggle('border-border-dark', b !== btn);
      });
    });
  });

  // Tabs
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabContents = document.querySelectorAll<HTMLElement>('.tab-content');

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      tabBtns.forEach((b) => {
        b.classList.toggle('border-primary', b === btn);
        b.classList.toggle('text-primary', b === btn);
        b.classList.toggle('border-transparent', b !== btn);
        b.classList.toggle('text-text-muted', b !== btn);
      });
      tabContents.forEach((c) => {
        c.classList.toggle('hidden', c.id !== `tab-${target}`);
      });
    });
  });

  // Add to cart — thực sự lưu vào localStorage
  const cartBtn = document.getElementById('btn-add-cart') as HTMLButtonElement;
  cartBtn?.addEventListener('click', () => {
    const orig = cartBtn.innerHTML;
    
    // Lấy product data từ data-attributes
    const productId = cartBtn.dataset.productId!;
    const productName = cartBtn.dataset.productName!;
    const productCategory = cartBtn.dataset.productCategory!;
    const productPrice = Number(cartBtn.dataset.productPrice);
    const productPriceFormatted = cartBtn.dataset.productPriceFormatted!;
    const productImage = cartBtn.dataset.productImage!;

    addToCart({
      id: productId,
      name: productName,
      categoryLabel: productCategory,
      price: productPrice,
      priceFormatted: productPriceFormatted,
      image: productImage,
    });

    cartBtn.classList.remove('bg-primary');
    cartBtn.classList.add('bg-green-600');
    cartBtn.innerHTML = '<span class="material-symbols-outlined">check</span>Đã thêm vào giỏ';

    setTimeout(() => {
      cartBtn.innerHTML = orig;
      cartBtn.classList.remove('bg-green-600');
      cartBtn.classList.add('bg-primary');
    }, 3000);
  });

  // Review Modal Logic
  const rvModal = document.getElementById('review-modal');
  const rvModalContent = document.getElementById('review-modal-content');
  const rvBtn = document.getElementById('btn-write-review');
  const rvCloseBtn = document.getElementById('close-review-modal');

  let _rvScrollY = 0;
  function rvLockScroll() {
    _rvScrollY = window.scrollY;
    document.body.style.position = 'fixed';
    document.body.style.top = `-${_rvScrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.overflow = 'hidden';
  }
  function rvUnlockScroll() {
    document.body.style.removeProperty('position');
    document.body.style.removeProperty('top');
    document.body.style.removeProperty('left');
    document.body.style.removeProperty('right');
    document.body.style.removeProperty('overflow');
    window.scrollTo({ top: _rvScrollY, behavior: 'instant' });
  }

  const toggleModal = (show: boolean) => {
    if (show) {
      rvLockScroll();
      rvModal?.classList.remove('opacity-0', 'pointer-events-none');
      rvModalContent?.classList.remove('scale-95');
    } else {
      rvUnlockScroll();
      rvModal?.classList.add('opacity-0', 'pointer-events-none');
      rvModalContent?.classList.add('scale-95');
    }
  };

  rvBtn?.addEventListener('click', () => toggleModal(true));
  rvCloseBtn?.addEventListener('click', () => toggleModal(false));
  rvModal?.addEventListener('click', (e) => {
    if (e.target === rvModal) toggleModal(false);
  });

  // Star Rating Logic
  const starBtns = document.querySelectorAll<HTMLButtonElement>('.star-btn');
  const rvRatingInput = document.getElementById('rv-rating') as HTMLInputElement;

  starBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const rating = Number(btn.dataset.rating);
      rvRatingInput.value = rating.toString();
      starBtns.forEach(b => {
        const bRating = Number(b.dataset.rating);
        b.classList.toggle('text-primary', bRating <= rating);
        b.classList.toggle('text-border-dark', bRating > rating);
      });
    });
  });

  // Form Submit Logic
  const rvForm = document.getElementById('review-form') as HTMLFormElement;
  const rvAlert = document.getElementById('review-alert');
  const rvSubmitBtn = document.getElementById('rv-submit-btn') as HTMLButtonElement;

  function showAlert(msg: string, type: 'error'|'success') {
    if(!rvAlert) return;
    rvAlert.className = `rounded-xl p-3 text-sm mb-4 ${type === 'error' ? 'bg-red-500/10 border border-red-500/20 text-red-500' : 'bg-green-500/10 border border-green-500/20 text-green-500'}`;
    rvAlert.textContent = msg;
    rvAlert.classList.remove('hidden');
  }

  rvForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(!rvAlert || !rvSubmitBtn || !rvRatingInput) return;
    
    if (!rvRatingInput.value) {
      showAlert('Vui lòng chọn số sao đánh giá.', 'error');
      return;
    }

    rvAlert.classList.add('hidden');
    rvSubmitBtn.disabled = true;
    rvSubmitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span> Đang gửi...';

    const productId = (document.getElementById('rv-product-id') as HTMLInputElement).value;
    const reviewerName = (document.getElementById('rv-name') as HTMLInputElement).value;
    const reviewerContact = (document.getElementById('rv-contact') as HTMLInputElement).value;
    const comment = (document.getElementById('rv-comment') as HTMLTextAreaElement).value;

    try {
      const res = await fetch('/api/reviews/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, rating: rvRatingInput.value, comment, reviewerName, reviewerContact })
      });
      const data = await res.json();
      
      if (!res.ok || data.error) throw new Error(data.error);
      
      showAlert(data.message, 'success');
      rvForm.reset();
      starBtns.forEach(b => {
          b.classList.remove('text-primary');
          b.classList.add('text-border-dark');
      });
      rvRatingInput.value = '';
      
      setTimeout(() => toggleModal(false), 3000);
      
    } catch (err: any) {
      showAlert(err.message || 'Lỗi hệ thống', 'error');
    } finally {
      rvSubmitBtn.disabled = false;
      rvSubmitBtn.innerHTML = 'Gửi đánh giá';
    }
  });

  // ── INLINE EDITING (Admin only) ──
  const toggleEditBtn = document.getElementById('toggle-edit-mode');
  const editModeText = document.getElementById('edit-mode-text');
  const editStatus = document.getElementById('edit-status');
  let editMode = false;

  if (toggleEditBtn) {
    toggleEditBtn.addEventListener('click', () => {
      editMode = !editMode;
      
      if (editMode) {
        editModeText!.textContent = 'Lưu & Thoát';
        toggleEditBtn.classList.add('is-editing');
        enableEditMode();
      } else {
        editModeText!.textContent = 'Chỉnh sửa';
        toggleEditBtn.classList.remove('is-editing');
        disableEditMode();
      }
    });
  }

  function enableEditMode() {
    const editables = document.querySelectorAll('[data-editable]');
    editables.forEach((el: Element) => {
      const htmlEl = el as HTMLElement;
      htmlEl.style.outline = '2px dashed #f48c25';
      htmlEl.style.outlineOffset = '4px';
      htmlEl.style.cursor = 'text';
      htmlEl.contentEditable = 'true';
      
      // Store original value
      htmlEl.dataset.currentValue = htmlEl.textContent || '';
      
      // On blur, save changes
      htmlEl.addEventListener('blur', handleSave);
    });
  }

  function disableEditMode() {
    const editables = document.querySelectorAll('[data-editable]');
    editables.forEach((el: Element) => {
      const htmlEl = el as HTMLElement;
      htmlEl.style.outline = 'none';
      htmlEl.style.cursor = 'default';
      htmlEl.contentEditable = 'false';
      htmlEl.removeEventListener('blur', handleSave);
    });
  }

  async function handleSave(e: Event) {
    const el = e.target as HTMLElement;
    const field = el.dataset.editable;
    const newValue = el.textContent?.trim() || '';
    const originalValue = el.dataset.currentValue || '';

    if (!field || newValue === originalValue) return;

    // Show saving indicator
    el.style.opacity = '0.5';

    try {
      const productSlug = window.location.pathname.split('/').pop();
      
      const res = await fetch('/api/products/quick-update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: productSlug, field, value: newValue })
      });

      const data = await res.json();

      if (data.success) {
        // Update stored value
        el.dataset.currentValue = newValue;
        
        // Show success status
        if (editStatus) {
          editStatus.classList.remove('hidden');
          setTimeout(() => editStatus.classList.add('hidden'), 2000);
        }

        // If price was updated, format it
        if (field === 'price') {
          const formatted = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(data.value);
          el.textContent = formatted;
          el.dataset.currentValue = formatted;
        }
      } else {
        alert('Lỗi lưu: ' + data.error);
        el.textContent = originalValue;
      }
    } catch (err: any) {
      alert('Lỗi kết nối: ' + err.message);
      el.textContent = originalValue;
    } finally {
      el.style.opacity = '1';
    }
  }

  // Reviews link click handler
  const reviewsLink = document.getElementById('reviews-link');
  reviewsLink?.addEventListener('click', () => {
    const reviewsTab = document.querySelector('[data-tab="reviews"]') as HTMLElement;
    reviewsTab?.click();
    const tabReviews = document.getElementById('tab-reviews');
    tabReviews?.scrollIntoView({ behavior: 'smooth' });
  });

</script>

<style>
  .public-quick-toolbar {
    position: fixed;
    right: 73px;
    bottom: 20px;
    z-index: 120;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .public-quick-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(244, 140, 37, 0.35);
    background: rgba(16, 13, 8, 0.92);
    color: #fff;
    border-radius: 999px;
    padding: 12px 16px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
  }
  .public-quick-btn.is-editing {
    border-color: rgba(34, 197, 94, 0.5);
    background: rgba(22, 101, 52, 0.92);
  }
  .public-quick-status {
    border-radius: 999px;
    padding: 10px 12px;
    background: rgba(22, 101, 52, 0.92);
    color: #86efac;
    font-size: 12px;
    font-weight: 700;
  }
  .public-quick-status.hidden {
    display: none;
  }
</style>
