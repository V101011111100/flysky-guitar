---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { products } from '../../data/products';
---

<AdminLayout title="Tổng quan" activeNav="dashboard">
  <!-- Page header -->
  <div style="margin-bottom:28px;">
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin-bottom:6px;">Tổng quan quản trị</h1>
    <p style="font-size:13px;color:#6b5a46;">Cập nhật mới nhất tình hình kinh doanh và vận hành tại FlySky Guitar.</p>
  </div>

  <!-- Stats row -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;">
    {[
      { label: 'Doanh thu tháng này', value: '125.450.000 ₫', icon: 'payments', color: '#f48c25', bg: 'rgba(244,140,37,0.1)', sub: '+12% so tháng trước' },
      { label: 'Yêu cầu tư vấn mới', value: '28', icon: 'support_agent', color: '#3b82f6', bg: 'rgba(59,130,246,0.1)', sub: '5 chờ xử lý' },
      { label: 'Sản phẩm sắp hết', value: '5', icon: 'inventory_2', color: '#ef4444', bg: 'rgba(239,68,68,0.1)', sub: 'Cần nhập thêm hàng' },
      { label: 'Tổng sản phẩm', value: String(products.length), icon: 'library_music', color: '#10b981', bg: 'rgba(16,185,129,0.1)', sub: `${products.filter(p=>p.category==='piano').length} Piano, ${products.filter(p=>p.category==='electric').length} Điện` },
    ].map(s => (
      <div class="stat-card" style="display:flex;align-items:flex-start;gap:14px;">
        <div class="stat-icon" style={`background:${s.bg};color:${s.color};`}>
          <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">{s.icon}</span>
        </div>
        <div>
          <p class="stat-label">{s.label}</p>
          <p class="stat-value" style={`color:${s.color};font-size:22px;`}>{s.value}</p>
          <p class="stat-sub">{s.sub}</p>
        </div>
      </div>
    ))}
  </div>

  <!-- Charts + Recent consultations -->
  <div style="display:grid;grid-template-columns:1fr 380px;gap:20px;margin-bottom:24px;">
    <!-- Revenue chart (static visual) -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Biến động doanh thu</span>
        <select class="admin-select" style="font-size:12px;padding:5px 10px;">
          <option>7 ngày qua</option>
          <option>30 ngày qua</option>
          <option>Quý này</option>
        </select>
      </div>
      <div class="card-body">
        <!-- SVG Chart -->
        <svg width="100%" height="200" viewBox="0 0 600 200" preserveAspectRatio="none">
          <defs>
            <linearGradient id="grad1" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" style="stop-color:#f48c25;stop-opacity:0.3" />
              <stop offset="100%" style="stop-color:#f48c25;stop-opacity:0" />
            </linearGradient>
          </defs>
          <!-- Grid lines -->
          {[0,1,2,3,4].map((i) => (
            <line x1="0" y1={i * 50} x2="600" y2={i * 50} stroke="#2a2015" stroke-width="1" />
          ))}
          <!-- Area -->
          <path d="M0,150 L80,120 L160,140 L240,80 L320,100 L400,60 L480,90 L560,40 L600,50 L600,200 L0,200 Z" fill="url(#grad1)" />
          <!-- Line -->
          <path d="M0,150 L80,120 L160,140 L240,80 L320,100 L400,60 L480,90 L560,40 L600,50" fill="none" stroke="#f48c25" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          <!-- Dots -->
          {[[0,150],[80,120],[160,140],[240,80],[320,100],[400,60],[480,90],[560,40],[600,50]].map(([x,y]) => (
            <circle cx={x} cy={y} r="4" fill="#f48c25" />
          ))}
        </svg>
        <div style="display:flex;justify-content:space-between;font-size:11px;color:#6b5a46;margin-top:8px;">
          {['T2','T3','T4','T5','T6','T7','CN'].map(d => <span>{d}</span>)}
        </div>
      </div>
    </div>

    <!-- Category breakdown -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Danh mục sản phẩm</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:12px;">
        {[
          { label: 'Guitar Điện', count: products.filter(p=>p.category==='electric').length, pct: 36, color: '#f48c25' },
          { label: 'Guitar Acoustic', count: products.filter(p=>p.category==='acoustic').length, pct: 27, color: '#3b82f6' },
          { label: 'Guitar Bass', count: products.filter(p=>p.category==='bass').length, pct: 18, color: '#10b981' },
          { label: 'Piano', count: products.filter(p=>p.category==='piano').length, pct: 27, color: '#a855f7' },
        ].map(cat => (
          <div>
            <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
              <span style="font-size:13px;font-weight:600;color:#ccc;">{cat.label}</span>
              <span style="font-size:12px;color:#6b5a46;">{cat.count} SP</span>
            </div>
            <div style="background:#0e0a06;border-radius:999px;height:6px;">
              <div style={`width:${cat.pct * (100 / products.length)}%;background:${cat.color};height:6px;border-radius:999px;transition:width 1s;`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Recent consultations + Quick actions -->
  <div style="display:grid;grid-template-columns:1fr 300px;gap:20px;">
    <!-- Recent consultations table -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Yêu cầu tư vấn gần đây</span>
        <a href="/admin/consultations" class="btn-secondary" style="font-size:12px;padding:6px 12px;">Xem tất cả</a>
      </div>
      <div style="overflow-x:auto;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Khách hàng</th>
              <th>Nội dung</th>
              <th>Trạng thái</th>
              <th>Thời gian</th>
            </tr>
          </thead>
          <tbody>
            {[
              { name: 'Nguyễn Văn An', msg: 'Tư vấn guitar điện cho người mới', status: 'pending', time: '5 phút trước' },
              { name: 'Trần Thị Bích', msg: 'Hỏi giá Cordoba C5 acoustic', status: 'contacted', time: '22 phút trước' },
              { name: 'Lê Minh Cường', msg: 'Khóa đàn bị kẹt, cần bảo hành', status: 'closed', time: '1 giờ trước' },
              { name: 'Phạm Thu Hà', msg: 'Tư vấn bass cho nhạc rock', status: 'pending', time: '2 giờ trước' },
              { name: 'Vũ Đình Hùng', msg: 'Hỏi về piano FlySky Grand Concert', status: 'contacted', time: '3 giờ trước' },
            ].map(r => (
              <tr>
                <td style="font-weight:600;color:#fff;">{r.name}</td>
                <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{r.msg}</td>
                <td>
                  <span class={`badge badge-${r.status}`}>
                    {r.status === 'pending' ? '⏳ Chờ xử lý' : r.status === 'contacted' ? '📞 Đã liên hệ' : '✅ Đã chốt'}
                  </span>
                </td>
                <td style="color:#6b5a46;">{r.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Quick actions -->
    <div style="display:flex;flex-direction:column;gap:16px;">
      <div class="card">
        <div class="card-header"><span class="card-title">Thao tác nhanh</span></div>
        <div class="card-body" style="display:flex;flex-direction:column;gap:10px;">
          {[
            { label: 'Xem tư vấn mới', icon: 'support_agent', href: '/admin/consultations' },
            { label: 'Kiểm tra kho hàng', icon: 'inventory_2', href: '/admin/inventory' },
            { label: 'Xem sản phẩm', icon: 'library_music', href: '/admin/products' },
            { label: 'Cấu hình tin nhắn', icon: 'chat_bubble', href: '/admin/messages' },
            { label: 'Cài đặt hệ thống', icon: 'settings', href: '/admin/settings' },
          ].map(a => (
            <a href={a.href} class="btn-secondary" style="justify-content:flex-start;width:100%;">
              <span class="material-symbols-outlined" style="font-size:16px;">{a.icon}</span>
              {a.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
