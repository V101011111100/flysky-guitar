---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// Lấy dữ liệu thực từ database để hiển thị trên bảng điều khiển
const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();

// Orders cho thống kê doanh thu
const { data: ordersRaw } = await supabase
  .from('orders')
  .select('total_amount, status, created_at')
  .order('created_at', { ascending: true });

const orders = ordersRaw || [];

const monthlyRevenue = Array(12).fill(0);
let totalRevenueYear = 0;
let totalRevenueMonth = 0;
let pendingRequests = 0;

for (const o of orders as any[]) {
  const created = new Date(o.created_at);
  if (created.getFullYear() !== currentYear) continue;

  const amount = o.total_amount || 0;

  if (o.status !== 'cancelled') {
    const m = created.getMonth();
    monthlyRevenue[m] += amount;
    totalRevenueYear += amount;
    if (m === currentMonth) {
      totalRevenueMonth += amount;
    }
  }

  if (o.status === 'pending') {
    pendingRequests++;
  }
}

// Thống kê sản phẩm / tồn kho
const { data: productsRaw } = await supabase
  .from('products')
  .select('stock_quantity, status');

const products = productsRaw || [];
const totalProducts = products.length;
const lowStockCount = products.filter((p: any) => (p.stock_quantity ?? 0) > 0 && (p.stock_quantity ?? 0) < 10).length;

function fmtCurrency(n: number) {
  return new Intl.NumberFormat('vi-VN', {
    style: 'currency',
    currency: 'VND',
    maximumFractionDigits: 0,
  }).format(n || 0);
}

const displayMonthRevenue = fmtCurrency(totalRevenueMonth);
const displayYearRevenue = fmtCurrency(totalRevenueYear);
const avgRevenueMonth =
  currentMonth >= 0 ? fmtCurrency(totalRevenueYear / (currentMonth + 1 || 1)) : fmtCurrency(totalRevenueYear);

// Chart Data Calculation
const chartDataRev = Array(6).fill(0);
for (let i = 0; i < 6; i++) {
  const m = currentMonth - 5 + i;
  if (m >= 0) chartDataRev[i] = monthlyRevenue[m];
}
const maxChartRev = Math.max(...chartDataRev) || 1;
const points = chartDataRev.map((rev, i) => {
  const x = i * (800 / 5);
  const y = 220 - (rev / maxChartRev) * 180;
  return `${x},${y}`;
});
const pathD = `M${points[0]} ` + points.slice(1).map(p => `L${p}`).join(' ');
const areaD = `${pathD} L800,280 L0,280 Z`;

// Products & Categories Aggregation
const { data: allProductsRaw } = await supabase
  .from('products')
  .select('id, name, stock_quantity, category_id, categories(name)');

const productRev: Record<string, { qty: number, revenue: number, name: string }> = {};
const categoryRev: Record<string, number> = {};

for (const o of orders as any[]) {
  if (o.status === 'cancelled') continue;
  const items = o.items || [];
  for (const item of items) {
    const pId = item.product_id || item.id;
    if (pId) {
      if (!productRev[pId]) productRev[pId] = { qty: 0, revenue: 0, name: item.name || 'Unknown' };
      productRev[pId].qty += item.quantity || 1;
      productRev[pId].revenue += (item.price || 0) * (item.quantity || 1);
    }
  }
}

const allProducts = allProductsRaw || [];
allProducts.forEach((p: any) => {
  if (productRev[p.id]) {
    const catName = p.categories?.name || 'Khác';
    if (!categoryRev[catName]) categoryRev[catName] = 0;
    categoryRev[catName] += productRev[p.id].revenue;
  }
});

const totalCatRev = Object.values(categoryRev).reduce((a, b) => a + (b as number), 0) || 1;
const categoryStats = Object.keys(categoryRev).map(name => ({
  label: name,
  pct: Math.round((categoryRev[name] / totalCatRev) * 100)
})).sort((a,b) => b.pct - a.pct).slice(0, 4);

const topProductObj = Object.values(productRev).sort((a: any, b: any) => b.qty - a.qty)[0] as any;
const bestSellerName = topProductObj ? topProductObj.name : 'Chưa có thông tin';

// Recent Orders mappings
const recentOrders = orders
  .filter((o: any) => o.status === 'pending' || o.status === 'processing')
  .sort((a: any, b: any) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime())
  .slice(0, 5)
  .map((o: any) => {
    return {
      init: o.customer_name ? o.customer_name.charAt(0).toUpperCase() : 'KH',
      name: o.customer_name || 'Khách lẻ',
      email: o.customer_email || o.customer_phone || 'Không có TT',
      msg: 'Đơn hàng mới',
      prod: o.items && o.items.length > 0 ? o.items[0].name : 'Sản phẩm khác',
      time: new Date(o.created_at).toLocaleDateString('vi-VN', { month: '2-digit', day: '2-digit' }),
      st: o.status === 'pending' ? 'new' : 'processing',
      icon: 'visibility',
      url: `/admin/orders?q=${o.order_number}`
    };
  });
---

<AdminLayout
  title="Tổng quan hệ thống"
  subtitle="Chào mừng quay trở lại, đây là tình hình kinh doanh tháng này."
  activeNav="dashboard"
>

  <!-- ── STAT CARDS ── -->
  <div class="stats-grid">

    <div class="stat-card">
      <div class="stat-top">
        <div class="stat-icon orange-icon">
          <span class="material-symbols-outlined">payments</span>
        </div>
        <span class="tag green-tag">+12.5%</span>
      </div>
      <div class="stat-label">Doanh thu tháng</div>
      <div class="stat-value">{displayMonthRevenue}</div>
    </div>

    <div class="stat-card">
      <div class="stat-top">
        <div class="stat-icon orange-icon">
          <span class="material-symbols-outlined">forum</span>
        </div>
        <span class="tag green-tag">+2</span>
      </div>
      <div class="stat-label">Yêu cầu mới</div>
      <div class="stat-value">{pendingRequests} yêu cầu</div>
    </div>

    <div class="stat-card">
      <div class="stat-top">
        <div class="stat-icon red-icon">
          <span class="material-symbols-outlined">inventory_2</span>
        </div>
        <span class="tag red-tag">Cần nhập</span>
      </div>
      <div class="stat-label">Tồn kho thấp</div>
      <div class="stat-value">{lowStockCount} sản phẩm</div>
    </div>

    <div class="stat-card">
      <div class="stat-top">
        <div class="stat-icon orange-icon">
          <span class="material-symbols-outlined">category</span>
        </div>
        <span style="font-size:11px;font-weight:700;color:#64748b;">Đang bán</span>
      </div>
      <div class="stat-label">Tổng sản phẩm</div>
      <div class="stat-value">{totalProducts} mẫu</div>
    </div>

  </div>

  <!-- ── MID: CHART + CATEGORY ── -->
  <div class="mid-grid">

    <!-- Chart (2/3) -->
    <div class="card chart-card">
      <div class="chart-header">
        <div>
          <div class="section-title">Xu hướng doanh thu</div>
          <div class="chart-meta">
            <span style="color:#64748b;font-size:13px;">Phân tích 6 tháng qua</span>
            <span style="color:#0bda16;font-size:13px;font-weight:700;">+8.2%</span>
          </div>
        </div>
        <div class="period-switcher">
          <button class="period-btn active-period">Tháng</button>
          <button class="period-btn">Năm</button>
        </div>
      </div>

      <div class="chart-area">
        <svg width="100%" height="100%" viewBox="0 0 800 280" preserveAspectRatio="none">
          <defs>
            <linearGradient id="cg" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%"   stop-color="#f48c25" stop-opacity="0.3"/>
              <stop offset="100%" stop-color="#f48c25" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <line stroke="#4a3a2a" stroke-dasharray="4" stroke-width="0.5" x1="0" x2="800" y1="40"  y2="40"/>
          <line stroke="#4a3a2a" stroke-dasharray="4" stroke-width="0.5" x1="0" x2="800" y1="100" y2="100"/>
          <line stroke="#4a3a2a" stroke-dasharray="4" stroke-width="0.5" x1="0" x2="800" y1="160" y2="160"/>
          <line stroke="#4a3a2a" stroke-dasharray="4" stroke-width="0.5" x1="0" x2="800" y1="220" y2="220"/>
          <path d={areaD} fill="url(#cg)"/>
          <path d={pathD} fill="none" stroke="#f48c25" stroke-linecap="round" stroke-width="3"/>
          {points.map(p => (
            <circle cx={p.split(',')[0]} cy={p.split(',')[1]} r="5" fill="#f48c25"/>
          ))}
        </svg>
      </div>

      <div class="month-labels">
        {Array(6).fill(0).map((_, i) => {
          const m = currentMonth - 5 + i;
          return <span>{m >= 0 ? `Tháng ${m+1}` : `Tháng ${12+m+1}`}</span>
        })}
      </div>

      <div class="revenue-stats">
        <div class="rev-box">
          <div class="rev-box-label">Tổng doanh thu kỳ này</div>
          <div class="rev-box-val">{displayYearRevenue}</div>
        </div>
        <div class="rev-box">
          <div class="rev-box-label">Trung bình mỗi tháng</div>
          <div class="rev-box-val">{avgRevenueMonth}</div>
        </div>
      </div>
    </div>

    <div class="card cat-card">
      <div class="section-title" style="margin-bottom:24px;">Hiệu suất danh mục (Theo doanh thu)</div>
      <div class="cat-list">
        {categoryStats.length === 0 ? (
          <div style="color:#64748b;font-size:13px;">Chưa có dữ liệu</div>
        ) : categoryStats.map((c: any) => (
          <div class="cat-item">
            <div class="cat-row">
              <span class="cat-label">{c.label}</span>
              <span class="cat-pct">{c.pct}%</span>
            </div>
            <div class="prog-track">
              <div class="prog-fill" style={`width:${c.pct}%`}></div>
            </div>
          </div>
        ))}
      </div>

      <div class="best-seller-box">
        <div class="best-icon">
          <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;font-size:22px;">military_tech</span>
        </div>
        <div>
          <div class="best-sub">Sản phẩm bán chạy nhất</div>
          <div class="best-name">{bestSellerName}</div>
        </div>
      </div>
    </div>

  </div>

  <!-- ── CONSULTATION TABLE ── -->
  <div class="card table-card">
    <div class="table-header">
      <div class="section-title">Yêu cầu tư vấn gần đây</div>
      <a href="/admin/consultations" class="view-all-link">
        Xem tất cả
        <span class="material-symbols-outlined" style="font-size:18px;vertical-align:middle;">chevron_right</span>
      </a>
    </div>
    <div style="overflow-x:auto;">
      <table class="consult-table">
        <thead>
          <tr>
            <th>Khách hàng</th>
            <th>Nội dung yêu cầu</th>
            <th>Sản phẩm quan tâm</th>
            <th>Thời gian</th>
            <th>Trạng thái</th>
            <th style="text-align:right;">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          {recentOrders.length === 0 ? (
            <tr><td colspan="6" style="text-align:center;color:#64748b;padding:20px;">Không có yêu cầu gần đây.</td></tr>
          ) : recentOrders.map((r: any) => (
            <tr>
              <td>
                <div class="customer-cell">
                  <div class="avatar-circle">{r.init}</div>
                  <div>
                    <div class="cus-name">{r.name}</div>
                    <div class="cus-email">{r.email}</div>
                  </div>
                </div>
              </td>
              <td class="msg-col">{r.msg}</td>
              <td class="prod-col">{r.prod}</td>
              <td class="time-col">{r.time}</td>
              <td>
                {r.st === 'new'        && <span class="badge badge-new">Mới</span>}
                {r.st === 'processing' && <span class="badge badge-processing">Đang xử lý</span>}
                {r.st === 'done'       && <span class="badge badge-done">Đã xong</span>}
              </td>
              <td style="text-align:right;">
                <a class="btn-ghost" href={r.url} title="Xem chi tiết">
                  <span class="material-symbols-outlined" style="font-size:20px;">{r.icon}</span>
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

</AdminLayout>

<style>
  /* ── STATS ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 28px;
  }
  .stat-card {
    background: #2d2218;
    border: 1px solid #4a3a2a;
    border-radius: 16px;
    padding: 24px;
    transition: border-color .2s;
  }
  .stat-card:hover { border-color: rgba(244,140,37,.35); }
  .stat-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }
  .stat-icon {
    width: 44px; height: 44px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
  }
  .orange-icon { background: rgba(244,140,37,.12); color: #f48c25; }
  .red-icon    { background: rgba(239,68,68,.12);  color: #ef4444; }
  .stat-icon .material-symbols-outlined { font-size: 22px; }
  .tag {
    font-size: 11px; font-weight: 700;
    padding: 4px 8px; border-radius: 4px;
  }
  .green-tag { background: rgba(11,218,22,.12); color: #0bda16; }
  .red-tag   { background: rgba(239,68,68,.12); color: #ef4444; }
  .stat-label { font-size: 13px; color: #94a3b8; font-weight: 500; margin-bottom: 4px; }
  .stat-value { font-size: 24px; font-weight: 900; color: #f9fafb; }

  /* ── MID GRID ── */
  .mid-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 24px;
    margin-bottom: 28px;
    align-items: start;
  }

  /* ── CHART ── */
  .chart-card { padding: 32px; }
  .chart-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
  }
  .section-title { font-size: 17px; font-weight: 800; color: #f9fafb; }
  .chart-meta { display: flex; align-items: center; gap: 8px; margin-top: 4px; }
  .period-switcher {
    display: flex;
    background: #221910;
    border: 1px solid #4a3a2a;
    border-radius: 8px;
    padding: 4px;
  }
  .period-btn {
    padding: 6px 16px; border-radius: 6px;
    font-size: 12px; font-weight: 700;
    border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    background: none; color: #94a3b8;
    transition: all .15s;
  }
  .active-period { background: #f48c25; color: #221910; }
  .chart-area {
    height: 280px;
    width: 100%;
  }
  .month-labels {
    display: flex;
    justify-content: space-between;
    padding: 8px 4px 0;
    font-size: 11.5px; color: #64748b; font-weight: 700;
  }
  .revenue-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 28px;
  }
  .rev-box {
    background: #221910;
    border: 1px solid #4a3a2a;
    border-radius: 12px;
    padding: 16px;
  }
  .rev-box-label { font-size: 11px; font-weight: 700; text-transform: uppercase; color: #64748b; margin-bottom: 6px; }
  .rev-box-val   { font-size: 20px; font-weight: 900; color: #f9fafb; }

  /* ── CATEGORY ── */
  .cat-card { padding: 32px; display: flex; flex-direction: column; }
  .cat-list { display: flex; flex-direction: column; gap: 22px; flex: 1; }
  .cat-item { }
  .cat-row {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 8px;
  }
  .cat-label { font-size: 13px; font-weight: 700; color: #cbd5e1; }
  .cat-pct   { font-size: 13px; font-weight: 800; color: #f48c25; }
  .prog-track {
    width: 100%; height: 8px;
    background: #221910; border-radius: 999px; overflow: hidden;
  }
  .prog-fill {
    height: 100%; background: #f48c25; border-radius: 999px;
  }
  .best-seller-box {
    display: flex; align-items: center; gap: 14px;
    margin-top: 28px; padding-top: 24px;
    border-top: 1px solid #4a3a2a;
  }
  .best-icon {
    width: 48px; height: 48px; border-radius: 12px;
    background: rgba(244,140,37,.2);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: #f48c25;
  }
  .best-sub  { font-size: 10px; font-weight: 700; text-transform: uppercase; color: #64748b; margin-bottom: 4px; }
  .best-name { font-size: 14px; font-weight: 900; color: #f9fafb; }

  /* ── TABLE ── */
  .table-card { padding: 32px; margin-bottom: 8px; }
  .table-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 28px;
  }
  .view-all-link {
    font-size: 13px; font-weight: 700;
    color: #f48c25; text-decoration: none;
    display: flex; align-items: center;
  }
  .view-all-link:hover { text-decoration: underline; }

  .consult-table {
    width: 100%; border-collapse: collapse;
  }
  .consult-table th {
    padding: 0 8px 16px;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .1em;
    color: #64748b; text-align: left;
    border-bottom: 1px solid #4a3a2a;
    white-space: nowrap;
  }
  .consult-table td {
    padding: 16px 8px;
    border-bottom: 1px solid rgba(74,58,42,.5);
    vertical-align: middle;
  }
  .consult-table tr:last-child td { border-bottom: none; }
  .consult-table tbody tr:hover td { background: rgba(255,255,255,.03); }

  .customer-cell { display: flex; align-items: center; gap: 12px; }
  .avatar-circle {
    width: 36px; height: 36px; border-radius: 50%;
    background: #374151;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800; color: #f9fafb;
    flex-shrink: 0;
  }
  .cus-name  { font-size: 13.5px; font-weight: 700; color: #f9fafb; }
  .cus-email { font-size: 10px; color: #64748b; margin-top: 1px; }
  .msg-col   { font-size: 13px; color: #cbd5e1; max-width: 220px; }
  .prod-col  { font-size: 13px; font-weight: 700; color: #f48c25; white-space: nowrap; }
  .time-col  { font-size: 13px; color: #94a3b8; white-space: nowrap; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1200px) {
    .mid-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 900px) {
    .stats-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .stats-grid { grid-template-columns: 1fr; gap: 12px; }
    .stat-card { padding: 20px; }
    .chart-card, .cat-card, .table-card { padding: 20px; }
    .revenue-stats { grid-template-columns: 1fr; gap: 12px; }
  }
</style>
