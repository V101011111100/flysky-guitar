---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const id = Astro.url.searchParams.get('id');
let product: any = null;
let isEdit = false;

if (id) {
  const { data, error } = await supabase
    .from('products')
    .select('*')
    .eq('id', id)
    .single();
    
  if (data && !error) {
    product = data;
    isEdit = true;
    console.log('Sản phẩm được load:', product);
    console.log('Video URL:', product.video_url);
  }
}

// Fetch materials/woods for the spec dropdowns
const { data: allProdsArray } = await supabase
  .from('products')
  .select(`
    id,
    name,
    categories ( name, is_top_wood, is_body_wood, is_neck_wood )
  `)
  .order('name', { ascending: true });

const topWoodProducts = (allProdsArray || []).filter(p => (p.categories as any)?.is_top_wood === true);
const bodyWoodProducts = (allProdsArray || []).filter(p => (p.categories as any)?.is_body_wood === true);
const neckWoodProducts = (allProdsArray || []).filter(p => (p.categories as any)?.is_neck_wood === true);

// Fetch all categories for the main category dropdown
const { data: categoriesArray } = await supabase
  .from('categories')
  .select('id, name')
  .order('name', { ascending: true });
---

<AdminLayout
  title={isEdit ? 'Chỉnh sửa sản phẩm' : 'Thêm sản phẩm mới'}
  subtitle={isEdit ? `Đang chỉnh sửa sản phẩm: ${product?.name || id}` : 'Thiết lập thông tin cho sản phẩm dòng Studio & Wood'}
  activeNav="products"
>

  <input type="hidden" id="prod-id" value={isEdit ? product.id : ''} />

  <!-- Header -->
  <header class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
      <h2 class="text-3xl font-extrabold tracking-tight text-white">{isEdit ? 'Chỉnh sửa sản phẩm' : 'Thêm sản phẩm mới'}</h2>
      <p class="text-slate-500 mt-1">{isEdit ? `Đang chỉnh sửa sản phẩm: ${product?.name || id}` : 'Thiết lập thông tin cho sản phẩm dòng Studio & Wood'}</p>
    </div>
    <div class="flex items-center gap-3">
      <a href="/admin/inventory" class="px-5 py-2.5 rounded-lg border border-slate-700 font-bold text-sm hover:bg-slate-800 transition-colors inline-block text-center text-slate-300 no-underline cursor-pointer">Hủy</a>
      <button class="px-5 py-2.5 rounded-lg border border-primary text-primary font-bold text-sm hover:bg-primary/10 transition-colors cursor-pointer">Xem trước</button>
      <button id="btn-save-prod" class="px-5 py-2.5 rounded-lg bg-primary text-background-dark font-bold text-sm hover:opacity-90 transition-opacity flex items-center gap-2 cursor-pointer border-none shadow-[0_4px_16px_rgba(244,140,37,0.25)]">
        <span class="material-symbols-outlined text-[20px]">save</span>
        Lưu thay đổi
      </button>
    </div>
  </header>

  <div class="grid grid-cols-12 gap-8">
    <!-- Left Column: Media & Specifications -->
    <div class="col-span-12 lg:col-span-5 space-y-8">
      
      <!-- Media Management -->
      <section class="bg-primary/5 border border-primary/10 rounded-xl p-6">
        <h3 class="text-lg font-bold mb-4 flex items-center gap-2 text-white">
          <span class="material-symbols-outlined text-primary">image</span>
          Quản lý truyền thông
        </h3>
        <div class="space-y-6">
          
          <!-- Primary Drag & Drop Zone -->
          <div class="flex items-center justify-between mb-4 bg-background-dark/40 p-3 rounded-lg border border-primary/10">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-sm">bolt</span>
              <span class="text-xs font-bold uppercase tracking-wider text-slate-300">Tự động tối ưu dung lượng (WebP)</span>
            </div>
            <!-- Toggle -->
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" value="" class="sr-only peer" checked>
              <div class="w-9 h-5 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
            </label>
          </div>
          
          <div id="uploadZone" onclick="document.getElementById('img-upload-input').click()" class="relative w-full border-2 border-dashed border-primary/30 rounded-xl bg-background-dark/30 hover:bg-background-dark/50 hover:border-primary transition-all cursor-pointer group p-8 flex flex-col items-center justify-center gap-3 text-center overflow-hidden">
            <input type="file" id="img-upload-input" accept="image/*" multiple style="display:none;" />
            <input type="hidden" id="prod-image" value={isEdit ? (product?.gallery_images?.[0] || '') : ''} />
            <input type="hidden" id="gallery-images-json" value={isEdit && product?.gallery_images ? JSON.stringify(product.gallery_images) : '[]'} />
            
            <div class="flex items-center gap-4 relative z-10">
              <span class="material-symbols-outlined text-primary/40 group-hover:text-primary text-4xl transition-colors">image</span>
              <span class="material-symbols-outlined text-primary/40 group-hover:text-primary text-4xl transition-colors">cloud_upload</span>
            </div>
            <div class="relative z-10">
              <p class="text-sm font-semibold text-slate-300">Kéo và thả nhiều ảnh tại đây hoặc click để chọn tệp</p>
              <p class="text-xs text-slate-500 mt-1 uppercase tracking-tighter">Hỗ trợ JPG, PNG, WEBP (Tối đa 15MB)</p>
            </div>
            
            <!-- Upload overlay -->
            <div id="upload-progress-overlay" style="display:none;" class="absolute inset-0 bg-background-dark/80 backdrop-blur-sm z-20 flex-col items-center justify-center gap-2">
              <span class="material-symbols-outlined animate-spin text-primary text-3xl">sync</span>
              <span id="upload-progress-text" class="text-xs font-bold text-slate-100 uppercase tracking-widest">Đang xử lý ảnh...</span>
            </div>
          </div>

          <div class="flex items-center justify-end gap-3 -mt-2">
            <button id="btn-open-r2-picker" type="button" class="inline-flex items-center gap-2 rounded-lg border border-primary/30 bg-background-dark/60 px-3 py-2 text-xs font-bold uppercase tracking-wide text-primary hover:bg-primary/10 transition-colors">
              <span class="material-symbols-outlined text-base">cloud</span>
              Chọn ảnh từ R2
            </button>
          </div>
          
          <!-- Image Thumbnails Grid -->
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 mt-6" id="thumb-grid">
            
            <!-- Add New Image Button -->
            <div onclick="document.getElementById('img-upload-input').click()" class="aspect-square rounded-xl border-2 border-dashed border-primary/30 flex flex-col items-center justify-center bg-background-dark/50 hover:border-primary transition-all cursor-pointer group">
              <span class="material-symbols-outlined text-primary/50 group-hover:text-primary text-3xl">add_a_photo</span>
              <span class="text-[10px] uppercase font-bold text-primary/50 mt-2 group-hover:text-primary text-center">Thêm<br/>ảnh mới</span>
            </div>
            
            <!-- Gallery items will be injected here by JS -->
          </div>
          
        </div>
      </section>
      
      <!-- Tech Specs -->
      <section class="bg-primary/5 border border-primary/10 rounded-xl p-6">
        <h3 class="text-lg font-bold mb-4 flex items-center gap-2 text-white">
          <span class="material-symbols-outlined text-primary">tune</span>
          Thông số kỹ thuật
        </h3>
        <div class="space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Gỗ mặt trước (Top)</label>
              <select id="prod-top" class="w-full bg-background-dark border border-primary/20 rounded-lg py-2.5 px-4 text-sm focus:ring-1 focus:ring-primary outline-none text-slate-200 cursor-pointer transition-colors">
                <option value="">-- Trống / Khác --</option>
                {topWoodProducts.map(mat => (
                  <option value={mat.name} selected={isEdit && product?.spec_top === mat.name}>{mat.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Gỗ lưng &amp; hông (Body)</label>
              <select id="prod-body" class="w-full bg-background-dark border border-primary/20 rounded-lg py-2.5 px-4 text-sm focus:ring-1 focus:ring-primary outline-none text-slate-200 cursor-pointer transition-colors">
                <option value="">-- Trống / Khác --</option>
                {bodyWoodProducts.map(mat => (
                  <option value={mat.name} selected={isEdit && product?.spec_body === mat.name}>{mat.name}</option>
                ))}
              </select>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Cần Đàn (Neck)</label>
              <select id="prod-neck" class="w-full bg-background-dark border border-primary/20 rounded-lg py-2.5 px-4 text-sm focus:ring-1 focus:ring-primary outline-none text-slate-200 cursor-pointer transition-colors">
                <option value="">-- Trống / Khác --</option>
                {neckWoodProducts.map(mat => (
                  <option value={mat.name} selected={isEdit && product?.spec_neck === mat.name}>{mat.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block text-white/50">Pickups</label>
              <select class="w-full bg-background-dark border border-primary/20 rounded-lg py-2.5 px-4 text-sm focus:ring-1 focus:ring-primary outline-none text-slate-400 cursor-not-allowed transition-colors" disabled>
                <option>None (Acoustic only)</option>
              </select>
            </div>
          </div>
        </div>
      </section>
      
    </div>
    
    <!-- Right Column: Product Details -->
    <div class="col-span-12 lg:col-span-7 space-y-8">
      <section class="bg-primary/5 border border-primary/10 rounded-xl p-8">
        <h3 class="text-lg font-bold mb-6 flex items-center gap-2 text-white">
          <span class="material-symbols-outlined text-primary">info</span>
          Thông tin chi tiết
        </h3>
        <div class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Tên sản phẩm *</label>
              <input type="text" id="prod-name" class="w-full bg-background-dark border border-primary/20 rounded-lg py-3 px-4 focus:ring-1 focus:ring-primary outline-none text-base text-slate-100 placeholder-slate-500 transition-colors" placeholder="Ví dụ: FlySky Studio Wood Edition G-200" value={isEdit ? product?.name : ''} required />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Đường dẫn (Slug) *</label>
              <input type="text" id="prod-slug" class="w-full bg-background-dark border border-primary/20 rounded-lg py-3 px-4 focus:ring-1 focus:ring-primary outline-none text-sm font-bold text-primary placeholder-slate-600 transition-colors" placeholder="fs-sw-200-mah" value={isEdit ? product?.slug : ''} required />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Danh mục</label>
              <select id="prod-category" class="w-full bg-background-dark border border-primary/20 rounded-lg py-3 px-4 focus:ring-1 focus:ring-primary outline-none text-sm text-slate-200 cursor-pointer transition-colors">
                <option value="">-- Không chỉ định / Khác --</option>
                {(categoriesArray || []).map(cat => (
                  <option value={cat.id} selected={isEdit && product?.category_id === cat.id}>{cat.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Giá bán (VNĐ) *</label>
              <div class="relative">
                <input type="number" id="prod-price" class="w-full bg-background-dark border border-primary/20 rounded-lg py-3 pl-4 pr-12 focus:ring-1 focus:ring-primary outline-none text-base text-slate-100 transition-colors" placeholder="0" value={isEdit ? product?.price : ''} required />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-primary font-bold">₫</span>
              </div>
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Trạng thái *</label>
              <select id="prod-status" class="w-full bg-background-dark border border-primary/20 rounded-lg py-3 px-4 focus:ring-1 focus:ring-primary outline-none text-sm text-slate-200 cursor-pointer transition-colors">
                <option value="active" selected={isEdit ? product?.status === 'active' : true}>Đang bán</option>
                <option value="draft" selected={isEdit && product?.status === 'draft'}>Bản nháp</option>
                <option value="out_of_stock" selected={isEdit && product?.status === 'out_of_stock'}>Hết hàng</option>
              </select>
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Tình trạng đàn</label>
              <select id="prod-condition" class="w-full bg-background-dark border border-primary/20 rounded-lg py-3 px-4 focus:ring-1 focus:ring-primary outline-none text-sm text-slate-200 cursor-pointer transition-colors">
                <option value="new" selected={isEdit ? (product?.product_condition || 'new') === 'new' : true}>Mới 100%</option>
                <option value="used" selected={isEdit && product?.product_condition === 'used'}>Đàn cũ (đã qua sử dụng)</option>
                <option value="like_new" selected={isEdit && product?.product_condition === 'like_new'}>Like new</option>
              </select>
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Số lượng tồn kho</label>
              <input type="number" id="prod-stock" class="w-full bg-background-dark border border-primary/20 rounded-lg py-3 px-4 focus:ring-1 focus:ring-primary outline-none text-base text-slate-100 transition-colors" placeholder="10" value={isEdit ? product?.stock_quantity : '0'} min="0" required />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Link Video Demo (Bắt buộc) *</label>
              <input type="url" id="prod-video" class="w-full bg-background-dark border border-primary/20 rounded-lg py-3 px-4 focus:ring-1 focus:ring-primary outline-none text-sm text-slate-300 placeholder-slate-600 transition-colors" placeholder="YouTube hoặc Vimeo URL..." value={isEdit ? product?.video_url : ''} required />
              <p class="text-xs text-text-muted mt-1">Ví dụ: https://www.youtube.com/watch?v=dQw4w9WgXcQ</p>
            </div>
          </div>
          
          <!-- Rich Text Editor (Mockup) -->
          <div>
            <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-2 block">Mô tả sản phẩm</label>
            <div class="border border-primary/20 rounded-lg overflow-hidden transition-colors">
              <div class="bg-background-dark/80 border-b border-primary/10 p-2 flex gap-1 flex-wrap">
                <button type="button" class="border-none bg-transparent p-1.5 rounded hover:bg-primary/20 transition-colors text-slate-400 hover:text-primary cursor-pointer"><span class="material-symbols-outlined text-sm">format_bold</span></button>
                <button type="button" class="border-none bg-transparent p-1.5 rounded hover:bg-primary/20 transition-colors text-slate-400 hover:text-primary cursor-pointer"><span class="material-symbols-outlined text-sm">format_italic</span></button>
                <button type="button" class="border-none bg-transparent p-1.5 rounded hover:bg-primary/20 transition-colors text-slate-400 hover:text-primary cursor-pointer"><span class="material-symbols-outlined text-sm">format_underlined</span></button>
                <div class="w-px h-6 bg-primary/20 mx-1"></div>
                <button type="button" class="border-none bg-transparent p-1.5 rounded hover:bg-primary/20 transition-colors text-slate-400 hover:text-primary cursor-pointer"><span class="material-symbols-outlined text-sm">format_list_bulleted</span></button>
                <button type="button" class="border-none bg-transparent p-1.5 rounded hover:bg-primary/20 transition-colors text-slate-400 hover:text-primary cursor-pointer"><span class="material-symbols-outlined text-sm">format_list_numbered</span></button>
                <div class="w-px h-6 bg-primary/20 mx-1"></div>
                <button type="button" class="border-none bg-transparent p-1.5 rounded hover:bg-primary/20 transition-colors text-slate-400 hover:text-primary cursor-pointer"><span class="material-symbols-outlined text-sm">link</span></button>
                <button type="button" class="border-none bg-transparent p-1.5 rounded hover:bg-primary/20 transition-colors text-slate-400 hover:text-primary cursor-pointer"><span class="material-symbols-outlined text-sm">image</span></button>
              </div>
              <textarea id="prod-desc" class="w-full bg-background-dark border-none p-4 text-[13px] focus:ring-0 outline-none resize-none text-slate-200 placeholder-slate-600 font-display leading-[1.6]" placeholder="Nhập mô tả chi tiết về sản phẩm, đặc điểm nổi bật và cảm giác chơi..." rows="8">{isEdit ? product?.description : ''}</textarea>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <!-- Footer Actions Mobile -->
  <div class="mt-10 pt-8 border-t border-primary/10 flex md:hidden flex-col gap-3">
    <button class="w-full px-5 py-3 rounded-lg bg-primary text-background-dark font-bold border-none" onclick="document.getElementById('btn-save-prod').click()">Lưu thay đổi</button>
    <div class="grid grid-cols-2 gap-3">
      <button class="px-5 py-3 bg-transparent rounded-lg border border-primary text-primary font-bold text-sm">Xem trước</button>
      <a href="/admin/inventory" class="text-center bg-transparent px-5 py-3 rounded-lg border border-slate-700 font-bold text-sm text-slate-300 no-underline">Hủy</a>
    </div>
  </div>

  <!-- Image Crop Modal -->
  <div class="fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-black/90 hidden" id="crop-modal" onclick="if(event.target===this) this.classList.add('hidden')">
    <div class="bg-background-dark border border-primary/20 rounded-2xl w-full max-w-4xl overflow-hidden shadow-2xl flex flex-col max-h-[90vh]" onclick="event.stopPropagation()">
      <!-- Modal Header -->
      <div class="p-6 border-b border-primary/10 flex items-center justify-between bg-primary/5">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">crop</span>
          <h3 class="text-xl font-bold text-slate-100">Cắt và điều chỉnh ảnh</h3>
        </div>
        <button class="text-slate-400 hover:text-white transition-colors bg-transparent border-none cursor-pointer" onclick="document.getElementById('crop-modal').classList.add('hidden')">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      
      <!-- Modal Body: Editor Area -->
      <div class="flex-1 overflow-hidden flex flex-col lg:flex-row">
        <!-- Main Preview Area -->
        <div class="flex-1 bg-black/50 relative flex items-center justify-center p-8">
          <div class="relative w-full max-w-md aspect-square border-2 border-primary/50 group">
            <img src="https://images.unsplash.com/photo-1510915361894-db8b60106cb1?w=600&q=70" alt="Crop Preview" class="w-full h-full object-cover opacity-60 mix-blend-luminosity" />
            <!-- Mock Crop Frame -->
            <div class="absolute inset-4 border-2 border-dashed border-white/80 shadow-[0_0_0_9999px_rgba(0,0,0,0.5)] cursor-move">
              <div class="absolute -top-1 -left-1 w-3 h-3 bg-white"></div>
              <div class="absolute -top-1 -right-1 w-3 h-3 bg-white"></div>
              <div class="absolute -bottom-1 -left-1 w-3 h-3 bg-white"></div>
              <div class="absolute -bottom-1 -right-1 w-3 h-3 bg-white"></div>
            </div>
          </div>
        </div>
        
        <!-- Controls Sidebar -->
        <div class="w-full lg:w-72 border-l border-primary/10 p-6 space-y-8 bg-background-dark overflow-y-auto hidden-scrollbar">
          <!-- Aspect Ratio -->
          <div class="bg-primary/10 border border-primary/20 rounded-lg p-3 mb-6">
            <div class="flex items-center justify-between mb-2">
              <span class="text-[10px] font-bold uppercase tracking-widest text-primary">Tối ưu hóa</span>
              <span class="text-[10px] font-bold text-emerald-400">BẬT</span>
            </div>
            <p class="text-[10px] text-slate-400 leading-tight mb-3">Tự động chuyển đổi sang WebP để tăng tốc độ tải trang.</p>
            <div class="flex items-center gap-2 text-emerald-400">
              <span class="material-symbols-outlined text-sm">check_circle</span>
              <span class="text-[10px] font-bold">Đã tối ưu - tiết kiệm 65%</span>
            </div>
          </div>
          
          <div>
            <label class="text-xs font-bold uppercase tracking-widest text-primary/70 mb-4 block">Tỷ lệ khung hình</label>
            <div class="grid grid-cols-2 gap-2">
              <button class="px-3 py-2 rounded border border-primary bg-primary/10 text-primary text-xs font-bold cursor-pointer">1:1 (Vuông)</button>
              <button class="px-3 py-2 bg-transparent rounded border border-primary/20 text-slate-400 text-xs hover:bg-primary/5 hover:text-primary transition-colors cursor-pointer">4:3</button>
              <button class="px-3 py-2 bg-transparent rounded border border-primary/20 text-slate-400 text-xs hover:bg-primary/5 hover:text-primary transition-colors cursor-pointer">16:9</button>
              <button class="px-3 py-2 bg-transparent rounded border border-primary/20 text-slate-400 text-xs hover:bg-primary/5 hover:text-primary transition-colors cursor-pointer">Tự do</button>
            </div>
          </div>
          
          <!-- Zoom & Rotate -->
          <div class="space-y-6">
            <div>
              <div class="flex justify-between items-center mb-2">
                <label class="text-xs font-bold uppercase tracking-widest text-primary/70">Phóng to</label>
                <span class="text-xs text-slate-400">100%</span>
              </div>
              <input type="range" class="w-full h-1.5 rounded-lg appearance-none cursor-pointer bg-primary/20" style="accent-color: #f48c25;"/>
            </div>
            <div>
              <div class="flex justify-between items-center mb-2">
                <label class="text-xs font-bold uppercase tracking-widest text-primary/70">Xoay</label>
                <span class="text-xs text-slate-400">0°</span>
              </div>
              <div class="flex gap-2">
                <button class="flex-1 bg-transparent p-2 rounded border border-primary/20 text-slate-400 hover:text-primary hover:bg-primary/10 transition-colors cursor-pointer"><span class="material-symbols-outlined text-sm">rotate_left</span></button>
                <button class="flex-1 bg-transparent p-2 rounded border border-primary/20 text-slate-400 hover:text-primary hover:bg-primary/10 transition-colors cursor-pointer"><span class="material-symbols-outlined text-sm">rotate_right</span></button>
                <button class="flex-1 bg-transparent p-2 rounded border border-primary/20 text-slate-400 hover:text-primary hover:bg-primary/10 transition-colors cursor-pointer"><span class="material-symbols-outlined text-sm">flip</span></button>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Modal Footer -->
      <div class="p-6 border-t border-primary/10 flex items-center justify-end gap-3 bg-background-dark">
        <button class="px-6 py-2.5 bg-transparent rounded-lg border border-slate-700 font-bold text-slate-300 text-sm hover:bg-slate-800 transition-colors cursor-pointer" onclick="document.getElementById('crop-modal').classList.add('hidden')">Hủy</button>
        <button class="px-6 py-2.5 rounded-lg border-none bg-primary text-background-dark font-bold text-sm hover:opacity-90 transition-opacity cursor-pointer" onclick="document.getElementById('crop-modal').classList.add('hidden')">Áp dụng</button>
      </div>
    </div>
  </div>

  <!-- R2 Media Picker Modal -->
  <div id="r2-picker-modal" class="fixed inset-0 z-[10000] hidden items-center justify-center bg-black/80 p-4" onclick="if(event.target===this) this.classList.add('hidden')">
    <div class="w-full max-w-6xl max-h-[90vh] rounded-2xl border border-primary/20 bg-background-dark shadow-2xl overflow-hidden flex flex-col" onclick="event.stopPropagation()">
      <div class="px-5 py-4 border-b border-primary/10 bg-primary/5 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2 text-white">
          <span class="material-symbols-outlined text-primary">perm_media</span>
          <h3 class="text-lg font-bold">Chọn ảnh từ thư viện R2</h3>
        </div>
        <button id="btn-close-r2-picker" type="button" class="h-9 w-9 rounded-lg border border-primary/20 text-slate-300 hover:text-white hover:bg-white/5 transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>

      <div class="px-5 py-4 border-b border-primary/10 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
        <div class="relative w-full sm:max-w-md">
          <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-[18px]">search</span>
          <input id="r2-picker-search" type="text" placeholder="Tìm theo tên file..." class="w-full rounded-lg border border-primary/20 bg-background-dark py-2.5 pl-10 pr-3 text-sm text-slate-200 placeholder-slate-500 focus:border-primary outline-none" />
        </div>
        <span id="r2-picker-count" class="text-xs font-semibold text-slate-400">0 ảnh đã chọn</span>
      </div>

      <div class="flex-1 overflow-y-auto p-5">
        <div id="r2-picker-loading" class="h-48 flex items-center justify-center gap-3 text-slate-400">
          <span class="material-symbols-outlined animate-spin">progress_activity</span>
          Đang tải thư viện R2...
        </div>
        <div id="r2-picker-grid" class="hidden grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4"></div>
      </div>

      <div class="px-5 py-4 border-t border-primary/10 flex items-center justify-end gap-3 bg-background-dark/70">
        <button id="btn-cancel-r2-picker" type="button" class="px-4 py-2 rounded-lg border border-slate-700 text-slate-300 hover:bg-slate-800 transition-colors">Hủy</button>
        <button id="btn-apply-r2-picker" type="button" class="px-4 py-2 rounded-lg bg-primary text-background-dark font-bold hover:opacity-90 transition-opacity disabled:opacity-40 disabled:cursor-not-allowed" disabled>
          Thêm ảnh đã chọn
        </button>
      </div>
    </div>
  </div>

</AdminLayout>

<style>
  .hidden-scrollbar::-webkit-scrollbar { width: 4px; }
  .hidden-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .hidden-scrollbar::-webkit-scrollbar-thumb { background: #493622; border-radius: 10px; }
  
  @keyframes delete-pop {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.1); opacity: 0.8; }
    100% { transform: scale(0); opacity: 0; }
  }
  .animate-delete {
    animation: delete-pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    pointer-events: none;
  }
</style>

<script>
  window.addEventListener('DOMContentLoaded', () => {
    // Auto generate slug from name
    document.getElementById('prod-name')?.addEventListener('input', (e) => {
      const idField = document.getElementById('prod-id') as HTMLInputElement;
      if (!idField?.value) { // Only auto-generate on create new
         const name = (e.target as HTMLInputElement).value;
         const slug = name.toLowerCase()
          .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)+/g, '');
         const slugEl = document.getElementById('prod-slug') as HTMLInputElement;
         if (slugEl) slugEl.value = slug;
      }
    });

    // Save product
    const btnSave = document.getElementById('btn-save-prod') as HTMLButtonElement;
    if (btnSave) {
      btnSave.addEventListener('click', async () => {
        btnSave.disabled = true;
        btnSave.innerHTML = '<span class="material-symbols-outlined text-[20px] animate-spin">sync</span> Đang lưu...';

        const payload = {
          'prod-id': (document.getElementById('prod-id') as HTMLInputElement)?.value || '',
          'prod-name': (document.getElementById('prod-name') as HTMLInputElement)?.value || '',
          'prod-slug': (document.getElementById('prod-slug') as HTMLInputElement)?.value || '',
          'prod-price': (document.getElementById('prod-price') as HTMLInputElement)?.value || '',
          'prod-desc': (document.getElementById('prod-desc') as HTMLTextAreaElement)?.value || '',
          'prod-body': (document.getElementById('prod-body') as HTMLSelectElement)?.value || '',
          'prod-top': (document.getElementById('prod-top') as HTMLSelectElement)?.value || '',
          'prod-neck': (document.getElementById('prod-neck') as HTMLSelectElement)?.value || '',
          'prod-category': (document.getElementById('prod-category') as HTMLSelectElement)?.value || '',
          'prod-stock': (document.getElementById('prod-stock') as HTMLInputElement)?.value || '0',
          'prod-status': (document.getElementById('prod-status') as HTMLSelectElement)?.value || 'active',
          'prod-condition': (document.getElementById('prod-condition') as HTMLSelectElement)?.value || 'new',
          'prod-gallery': (() => {
            const ordered = getOrderedUiImages();
            return JSON.stringify(ordered.map((img) => img.url));
          })(),
          'prod-video': (document.getElementById('prod-video') as HTMLInputElement)?.value || ''
        };

        try {
          const res = await fetch('/api/products/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await res.json();
          
          if(data.success) {
            alert('Lưu sản phẩm thành công!');
            window.location.href = '/admin/inventory';
          } else {
            alert('Lỗi: ' + data.error);
            btnSave.disabled = false;
            btnSave.innerHTML = '<span class="material-symbols-outlined text-[20px]">save</span> Lưu thay đổi';
          }
        } catch(err) {
          alert('Lỗi kết nối máy chủ');
          btnSave.disabled = false;
          btnSave.innerHTML = '<span class="material-symbols-outlined text-[20px]">save</span> Lưu thay đổi';
        }
      });
    }

    // === HELPER: Remove main image & auto-promote gallery image ===
    (window as any).removeMainImage = () => {
      const urlInput = document.getElementById('prod-image') as HTMLInputElement;
      const previewContainer = document.getElementById('main-thumb-preview');
      const mainImg = document.getElementById('main-thumb-img') as HTMLImageElement;
      const galleryInput = document.getElementById('gallery-images-json') as HTMLInputElement;
      
      let gallery: string[] = [];
      try { gallery = JSON.parse(galleryInput?.value || '[]'); } catch {}

      if (gallery.length > 0) {
        // Auto-promote first gallery image
        const newMain = gallery.shift() as string;
        
        if (mainImg) mainImg.src = newMain;
        if (urlInput) {
          urlInput.value = newMain;
          urlInput.dispatchEvent(new Event('input'));
        }
        
        if (galleryInput) {
          galleryInput.value = JSON.stringify(gallery);
          renderGalleryThumbnails(gallery);
        }
        
        // Brief visual flash to indicate change
        if (previewContainer) {
          previewContainer.style.opacity = '0.5';
          setTimeout(() => previewContainer.style.opacity = '1', 150);
        }
      } else {
        // No gallery images, just remove main image
        if (previewContainer) {
          previewContainer.classList.add('animate-delete');
          setTimeout(() => {
            previewContainer.style.setProperty('display', 'none', 'important');
            previewContainer.classList.remove('animate-delete');
            if (mainImg) mainImg.src = '';
            if (urlInput) {
              urlInput.value = '';
              urlInput.dispatchEvent(new Event('input'));
            }
          }, 300);
        }
      }
    };

    // === UNIFIED GRID RENDERER ===
    function updateThumbGridLegacy() {
      const grid = document.getElementById('thumb-grid');
      const prodImageInput = document.getElementById('prod-image') as HTMLInputElement;
      const galleryInput = document.getElementById('gallery-images-json') as HTMLInputElement;
      if (!grid || !prodImageInput || !galleryInput) return;

      // Hide the hardcoded main-thumb-preview initially
      const staticMainPreview = document.getElementById('main-thumb-preview');
      if (staticMainPreview) staticMainPreview.style.display = 'none';

      // Clear dynamic items
      grid.querySelectorAll('.thumb-gallery-item').forEach(el => el.remove());

      const mainUrl = prodImageInput.value;
      let gallery: string[] = [];
      try { gallery = JSON.parse(galleryInput.value || '[]'); } catch {}

      // Render Main Image if exists
      if (mainUrl) {
        const div = document.createElement('div');
        div.className = 'thumb-gallery-item aspect-square rounded-xl bg-cover bg-center border-2 border-primary relative group overflow-hidden shadow-lg shadow-primary/10 bg-zinc-900';
        div.innerHTML = `
          <img src="${mainUrl}" alt="Main Image" class="absolute inset-0 w-full h-full object-cover mix-blend-luminosity opacity-90" />
          <div class="absolute top-2 left-2 bg-emerald-500/90 text-white text-[9px] font-bold px-2 py-1 rounded-md uppercase tracking-wider z-10 block">Ảnh chính</div>
          <div class="absolute bottom-0 inset-x-0 p-2 flex gap-2 justify-center bg-black/60 backdrop-blur-md opacity-0 group-hover:opacity-100 transition-opacity z-10">
            <button type="button" class="size-8 rounded border-none bg-primary text-background-dark flex items-center justify-center hover:opacity-90 transition-opacity cursor-default">
              <span class="material-symbols-outlined text-[20px] fill-[1]">star</span>
            </button>
            <button type="button" onclick="removeMainImage()" class="size-8 border-none rounded bg-black/60 text-white flex items-center justify-center hover:bg-red-500 transition-colors cursor-pointer" title="Xóa ảnh chính">
              <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
          </div>
        `;
        grid.appendChild(div);
      }

      // Render Gallery Images
      gallery.forEach((url, idx) => {
        const div = document.createElement('div');
        div.className = 'thumb-gallery-item aspect-square rounded-xl bg-cover bg-center border border-primary/20 relative group overflow-hidden hover:border-primary/50 transition-all shadow-md bg-zinc-900';
        div.innerHTML = `
          <img src="${url}" alt="Gallery ${idx + 1}" class="absolute inset-0 w-full h-full object-cover mix-blend-luminosity opacity-80" />
          <div class="absolute bottom-0 inset-x-0 p-2 flex gap-2 justify-center bg-black/60 backdrop-blur-md opacity-0 group-hover:opacity-100 transition-opacity z-10">
            <button type="button" onclick="setAsMainImage(${idx})" class="size-8 rounded border-none bg-background-dark/90 text-slate-400 border border-primary/30 flex items-center justify-center hover:text-primary hover:border-primary transition-all cursor-pointer" title="Đặt làm ảnh chính">
              <span class="material-symbols-outlined text-[20px]">star</span>
            </button>
            <button type="button" onclick="removeGalleryImage(${idx})" class="size-8 rounded border-none bg-black/60 text-white flex items-center justify-center hover:bg-red-500 transition-colors cursor-pointer" title="Xóa ảnh">
              <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
          </div>
        `;
        grid.appendChild(div);
      });
    }

    // === UNIFIED DATA MODEL ===
    // Ensure all images are tracked in a single array to preserve visual order
    let uiImages: { url: string, isMain: boolean }[] = [];
    let r2PickerFiles: Array<{ key: string; url: string; lastModified?: string }> = [];
    const r2PickerSelected = new Set<string>();

    function getOrderedUiImages() {
      if (uiImages.length === 0) return [];
      const main = uiImages.find(img => img.isMain);
      const rest = uiImages.filter(img => !img.isMain);
      return main ? [main, ...rest] : [...uiImages];
    }

    // Initialize data from hidden inputs
    function initGalleryData() {
        const prodImageInput = document.getElementById('prod-image') as HTMLInputElement;
        const galleryInput = document.getElementById('gallery-images-json') as HTMLInputElement;
        
        uiImages = []; // reset

      let galleryUrls: string[] = [];
        if (galleryInput && galleryInput.value) {
            try {
                const arr = JSON.parse(galleryInput.value);
                if (Array.isArray(arr)) {
            galleryUrls = arr.filter((url) => typeof url === 'string' && url.trim()).map((url) => url.trim());
                }
            } catch {}
        }

      if (galleryUrls.length > 0) {
        const dedup = Array.from(new Set(galleryUrls));
        dedup.forEach((url, index) => {
          uiImages.push({ url, isMain: index === 0 });
        });
        return;
      }

      if (prodImageInput && prodImageInput.value) {
        uiImages.push({ url: prodImageInput.value, isMain: true });
      }
    }

    // Sync state back to hidden inputs
    function syncToInputs() {
        const prodImageInput = document.getElementById('prod-image') as HTMLInputElement;
        const galleryInput = document.getElementById('gallery-images-json') as HTMLInputElement;
        
        const ordered = getOrderedUiImages();
        const mainImg = ordered[0] || null;
        const galleryImgs = ordered.map((img) => img.url);

        if (prodImageInput) {
            prodImageInput.value = mainImg ? mainImg.url : '';
            prodImageInput.dispatchEvent(new Event('input', { bubbles: true }));
        }
        if (galleryInput) {
            galleryInput.value = JSON.stringify(galleryImgs);
        }
    }

    // === UNIFIED GRID RENDERER ===
    function updateThumbGrid() {
      const grid = document.getElementById('thumb-grid');
      if (!grid) return;
      const addNewBtn = grid.querySelector('div[onclick*="img-upload-input"]');

      // Hide the hardcoded main-thumb-preview initially
      const staticMainPreview = document.getElementById('main-thumb-preview');
      if (staticMainPreview) staticMainPreview.style.display = 'none';

      // Clear dynamic items
      grid.querySelectorAll('.thumb-gallery-item').forEach(el => el.remove());

      // Render All Images in their current order
      uiImages.forEach((img, idx) => {
        const div = document.createElement('div');
        
        if (img.isMain) {
            div.className = 'thumb-gallery-item aspect-square rounded-xl bg-cover bg-center border-2 border-primary relative group overflow-hidden shadow-lg shadow-primary/10 bg-zinc-900';
            div.innerHTML = `
              <img src="${img.url}" alt="Main Image" class="absolute inset-0 w-full h-full object-cover mix-blend-luminosity opacity-90" />
              <div class="absolute top-2 left-2 bg-emerald-500/90 text-white text-[9px] font-bold px-2 py-1 rounded-md uppercase tracking-wider z-10 block">Ảnh chính</div>
              <div class="absolute bottom-0 inset-x-0 p-2 flex gap-2 justify-center bg-black/60 backdrop-blur-md opacity-0 group-hover:opacity-100 transition-opacity z-10">
                <button type="button" class="size-8 rounded border-none bg-primary text-background-dark flex items-center justify-center hover:opacity-90 transition-opacity cursor-default">
                  <span class="material-symbols-outlined text-[20px] fill-[1]">star</span>
                </button>
                <button type="button" onclick="removeImage(${idx})" class="size-8 border-none rounded bg-black/60 text-white flex items-center justify-center hover:bg-red-500 transition-colors cursor-pointer" title="Xóa ảnh chính">
                  <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
              </div>
            `;
        } else {
            div.className = 'thumb-gallery-item aspect-square rounded-xl bg-cover bg-center border border-primary/20 relative group overflow-hidden hover:border-primary/50 transition-all shadow-md bg-zinc-900';
            div.innerHTML = `
              <img src="${img.url}" alt="Gallery ${idx + 1}" class="absolute inset-0 w-full h-full object-cover mix-blend-luminosity opacity-80" />
              <div class="absolute bottom-0 inset-x-0 p-2 flex gap-2 justify-center bg-black/60 backdrop-blur-md opacity-0 group-hover:opacity-100 transition-opacity z-10">
                <button type="button" onclick="setAsMainImage(${idx})" class="size-8 rounded border-none bg-background-dark/90 text-slate-400 border border-primary/30 flex items-center justify-center hover:text-primary hover:border-primary transition-all cursor-pointer" title="Đặt làm ảnh chính">
                  <span class="material-symbols-outlined text-[20px]">star</span>
                </button>
                <button type="button" onclick="removeImage(${idx})" class="size-8 rounded border-none bg-black/60 text-white flex items-center justify-center hover:bg-red-500 transition-colors cursor-pointer" title="Xóa ảnh">
                  <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
              </div>
            `;
        }
        if (addNewBtn) {
          grid.insertBefore(div, addNewBtn);
        } else {
          grid.appendChild(div);
        }
      });
    }

    function renderGalleryThumbnails(_gallery: string[]) {
      initGalleryData();
      updateThumbGrid();
    }

    // === ACTION HANDLERS ===
    
    (window as any).removeImage = (index: number) => {
        const img = uiImages[index];
        uiImages.splice(index, 1);
        
        // If we deleted the main image, auto-promote the first available image to main
        if (img.isMain && uiImages.length > 0) {
            uiImages[0].isMain = true;
        }
        
        syncToInputs();
        updateThumbGrid();
    };

    (window as any).setAsMainImage = (index: number) => {
        // Clear all mains
        uiImages.forEach(img => img.isMain = false);
        // Set new main
        uiImages[index].isMain = true;
        
        syncToInputs();
        updateThumbGrid();
    };
    
    (window as any).removeGalleryImage = (index: number) => {
        // Remove image at index
        const removed = uiImages.splice(index, 1)[0];
        
        // If removed was main, promote first remaining as main
        if (removed.isMain && uiImages.length > 0) {
            uiImages[0].isMain = true;
        }
        
        syncToInputs();
        updateThumbGrid();
    };

    // === INITIALIZE GALLERY ===
    initGalleryData();
    updateThumbGrid();

    // === R2 PICKER ===
    const r2PickerModal = document.getElementById('r2-picker-modal');
    const r2PickerLoading = document.getElementById('r2-picker-loading');
    const r2PickerGrid = document.getElementById('r2-picker-grid');
    const r2PickerSearch = document.getElementById('r2-picker-search') as HTMLInputElement | null;
    const r2PickerCount = document.getElementById('r2-picker-count');
    const btnOpenR2Picker = document.getElementById('btn-open-r2-picker');
    const btnCloseR2Picker = document.getElementById('btn-close-r2-picker');
    const btnCancelR2Picker = document.getElementById('btn-cancel-r2-picker');
    const btnApplyR2Picker = document.getElementById('btn-apply-r2-picker') as HTMLButtonElement | null;

    function isImageUrl(url: string) {
      return /\.(png|jpe?g|webp|gif|avif|svg)$/i.test(url);
    }

    function updateR2PickerSelectionUi() {
      if (r2PickerCount) {
        r2PickerCount.textContent = `${r2PickerSelected.size} ảnh đã chọn`;
      }
      if (btnApplyR2Picker) {
        btnApplyR2Picker.disabled = r2PickerSelected.size === 0;
      }
    }

    function getFilteredR2Files() {
      const q = (r2PickerSearch?.value || '').trim().toLowerCase();
      const imageFiles = r2PickerFiles.filter((file) => isImageUrl(file.url));
      if (!q) return imageFiles;
      return imageFiles.filter((file) => {
        const fileName = file.key.split('/').pop()?.toLowerCase() || '';
        return fileName.includes(q) || file.url.toLowerCase().includes(q);
      });
    }

    function renderR2PickerGrid() {
      if (!r2PickerGrid) return;
      const files = getFilteredR2Files();
      r2PickerGrid.innerHTML = '';

      if (files.length === 0) {
        r2PickerGrid.innerHTML = '<div class="col-span-full py-16 text-center text-slate-500">Không tìm thấy ảnh phù hợp trong R2.</div>';
        updateR2PickerSelectionUi();
        return;
      }

      files.forEach((file) => {
        const selected = r2PickerSelected.has(file.url);
        const card = document.createElement('button');
        card.type = 'button';
        card.className = `relative rounded-xl border p-2 text-left transition-all ${selected ? 'border-primary bg-primary/10' : 'border-primary/20 bg-background-dark hover:border-primary/60'}`;
        card.innerHTML = `
          <div class="aspect-square rounded-lg bg-background-dark border border-primary/15 overflow-hidden">
            <img src="${file.url}" alt="${file.key}" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <p class="mt-2 text-[11px] text-slate-300 truncate" title="${file.key}">${file.key.split('/').pop() || file.key}</p>
          ${selected ? '<div class="absolute top-3 right-3 h-5 w-5 rounded-full bg-primary text-background-dark flex items-center justify-center"><span class="material-symbols-outlined text-[14px]">check</span></div>' : ''}
        `;
        card.addEventListener('click', () => {
          if (r2PickerSelected.has(file.url)) r2PickerSelected.delete(file.url);
          else r2PickerSelected.add(file.url);
          renderR2PickerGrid();
        });
        r2PickerGrid.appendChild(card);
      });

      updateR2PickerSelectionUi();
    }

    async function ensureR2FilesLoaded() {
      if (r2PickerFiles.length > 0) return;
      if (r2PickerLoading) r2PickerLoading.style.display = 'flex';
      if (r2PickerGrid) r2PickerGrid.classList.add('hidden');

      const res = await fetch('/api/media/list');
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) {
        throw new Error(data.error || 'Không thể tải thư viện R2');
      }

      r2PickerFiles = Array.isArray(data.files) ? data.files : [];
      if (r2PickerLoading) r2PickerLoading.style.display = 'none';
      if (r2PickerGrid) r2PickerGrid.classList.remove('hidden');
      renderR2PickerGrid();
    }

    function openR2Picker() {
      if (!r2PickerModal) return;
      r2PickerModal.classList.remove('hidden');
      r2PickerModal.classList.add('flex');
      ensureR2FilesLoaded().catch((error) => {
        alert(error.message || 'Không thể tải thư viện R2');
        closeR2Picker();
      });
    }

    function closeR2Picker() {
      if (!r2PickerModal) return;
      r2PickerModal.classList.add('hidden');
      r2PickerModal.classList.remove('flex');
    }

    function appendSelectedR2Images() {
      const selectedUrls = getFilteredR2Files()
        .map((file) => file.url)
        .filter((url) => r2PickerSelected.has(url));
      if (selectedUrls.length === 0) return;

      let insertAfterMain = 0;
      const mainIndex = uiImages.findIndex((img) => img.isMain);
      if (mainIndex < 0) {
        const first = selectedUrls[0];
        const exists = uiImages.some((img) => img.url === first);
        if (!exists) {
          uiImages.unshift({ url: first, isMain: true });
        }
        insertAfterMain = 1;
      } else {
        insertAfterMain = mainIndex + 1;
      }

      selectedUrls.forEach((url) => {
        if (uiImages.some((img) => img.url === url)) return;
        uiImages.splice(insertAfterMain, 0, { url, isMain: false });
        insertAfterMain += 1;
      });

      syncToInputs();
      updateThumbGrid();
      closeR2Picker();
      r2PickerSelected.clear();
      updateR2PickerSelectionUi();
    }

    btnOpenR2Picker?.addEventListener('click', openR2Picker);
    btnCloseR2Picker?.addEventListener('click', closeR2Picker);
    btnCancelR2Picker?.addEventListener('click', closeR2Picker);
    btnApplyR2Picker?.addEventListener('click', appendSelectedR2Images);
    r2PickerSearch?.addEventListener('input', renderR2PickerGrid);

    // === MULTI-IMAGE UPLOAD HANDLER ===
    const fileInput = document.getElementById('img-upload-input') as HTMLInputElement;
    const progressOverlay = document.getElementById('upload-progress-overlay');
    const progressText = document.getElementById('upload-progress-text');
    
    if (fileInput) {
      fileInput.addEventListener('change', async (e) => {
        const files = Array.from((e.target as HTMLInputElement).files || []);
        if (!files.length) return;

        // === SHOW PREVIEW IMMEDIATELY BEFORE UPLOAD ===
        const thumbGrid = document.getElementById('thumb-grid');
        const urlInput = document.getElementById('prod-image') as HTMLInputElement;
        const galleryInput = document.getElementById('gallery-images-json') as HTMLInputElement;
        
        // Get current images count to determine if first
        let currentGallery: string[] = [];
        try { currentGallery = JSON.parse(galleryInput?.value || '[]'); } catch {}
        const isFirstImage = !urlInput?.value && currentGallery.length === 0;
        
        for (let fi = 0; fi < files.length; fi++) {
          const file = files[fi];
          
          // Create preview using object URL (immediate preview)
          const objectUrl = URL.createObjectURL(file);
          
          // Create preview element with star and delete buttons
          const previewDiv = document.createElement('div');
          previewDiv.setAttribute('data-object-index', fi.toString());
          previewDiv.className = 'aspect-square rounded-xl overflow-hidden bg-background-dark relative group';
          previewDiv.innerHTML = `
            <img src="${objectUrl}" class="w-full h-full object-cover" />
            <div class="absolute bottom-0 inset-x-0 p-2 flex gap-2 justify-center bg-black/60 backdrop-blur-md opacity-0 group-hover:opacity-100 transition-opacity z-10">
              <button type="button" class="set-main-btn size-8 rounded border-none bg-background-dark/90 text-slate-400 border border-primary/30 flex items-center justify-center hover:text-primary hover:border-primary transition-all cursor-pointer" title="Đặt làm ảnh chính">
                <span class="material-symbols-outlined text-[20px]">star</span>
              </button>
              <button type="button" class="remove-preview-btn size-8 rounded border-none bg-black/60 text-white flex items-center justify-center hover:bg-red-500 transition-colors cursor-pointer" title="Hủy ảnh">
                <span class="material-symbols-outlined text-[20px]">close</span>
              </button>
            </div>
          `;
          
          // Add click handler for remove button
          const removeBtn = previewDiv.querySelector('.remove-preview-btn');
          removeBtn?.addEventListener('click', (e) => {
            e.stopPropagation();
            previewDiv.remove();
            URL.revokeObjectURL(objectUrl);
          });
          
          // Add click handler for set main button - will be processed after upload
          const mainBtn = previewDiv.querySelector('.set-main-btn');
          mainBtn?.addEventListener('click', (e) => {
            e.stopPropagation();
            // Mark this preview as intended main image
            previewDiv.setAttribute('data-intended-main', 'true');
            // Remove mark from other previews
            previewDiv.parentElement?.querySelectorAll('[data-intended-main]').forEach(el => {
              if (el !== previewDiv) {
                el.removeAttribute('data-intended-main');
                // Remove badge if exists
                const badge = el.querySelector('.main-badge');
                if (badge) badge.remove();
              }
            });
            // Add visual badge for main image
            if (!previewDiv.querySelector('.main-badge')) {
              const badge = document.createElement('div');
              badge.className = 'main-badge absolute top-2 left-2 bg-emerald-500/90 text-white text-[9px] font-bold px-2 py-1 rounded-md uppercase tracking-wider z-10 block';
              badge.textContent = 'Ảnh chính';
              previewDiv.appendChild(badge);
            }
          });
          
          // Insert before the "add new" button
          const addBtn = thumbGrid?.querySelector('div[onclick*="img-upload-input"]');
          if (addBtn && thumbGrid) {
            thumbGrid.insertBefore(previewDiv, addBtn);
          }
        }
        // ============================================

        if (progressOverlay) progressOverlay.style.display = 'flex';

        for (let fi = 0; fi < files.length; fi++) {
          const file = files[fi];
          if (progressText) progressText.textContent = `Đang xử lý ảnh ${fi + 1}/${files.length}...`;

          try {
            // 1. Read image
            const img = new Image();
            const objectUrl = URL.createObjectURL(file);
            await new Promise((resolve, reject) => {
              img.onload = resolve;
              img.onerror = reject;
              img.src = objectUrl;
            });

            // 2. Canvas resize + optimize
            const CANVAS_SIZE = 2048; 
            const canvas = document.createElement('canvas');
            canvas.width = CANVAS_SIZE;
            canvas.height = CANVAS_SIZE;
            const ctx = canvas.getContext('2d');
            if (!ctx) throw new Error("Không thể khởi tạo Canvas");

            const gradient = ctx.createRadialGradient(
              CANVAS_SIZE/2, CANVAS_SIZE/2, 0,
              CANVAS_SIZE/2, CANVAS_SIZE/2, CANVAS_SIZE/1.2
            );
            gradient.addColorStop(0, '#352a20');
            gradient.addColorStop(1, '#15110c');
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);

            const scale = Math.min(CANVAS_SIZE / img.width, CANVAS_SIZE / img.height);
            const drawWidth = img.width * scale;
            const drawHeight = img.height * scale;
            const dx = (CANVAS_SIZE - drawWidth) / 2;
            const dy = (CANVAS_SIZE - drawHeight) / 2;
            ctx.drawImage(img, dx, dy, drawWidth, drawHeight);
            URL.revokeObjectURL(objectUrl);

            // 3. Export as WebP (quality 0.92 for zoom-friendly detail)
            if (progressText) progressText.textContent = `Đang tối ưu WebP (${fi + 1}/${files.length})...`;
            const blob = await new Promise<Blob | null>(resolve => canvas.toBlob(resolve, 'image/webp', 0.92));
            if (!blob) throw new Error('Lỗi khi xuất WebP');

            const optimizedFile = new File([blob], file.name.replace(/\.[^/.]+$/, '') + '.webp', { type: 'image/webp' });

            // 4. Upload
            if (progressText) progressText.textContent = `Đang tải lên (${fi + 1}/${files.length})...`;
            const formData = new FormData();
            formData.append('file', optimizedFile);

            const uploadRes = await fetch('/api/products/upload', { method: 'POST', body: formData });
            const uploadData = await uploadRes.json();

            if (uploadData.success && uploadData.url) {
              const url = uploadData.url;
              const thumbGrid = document.getElementById('thumb-grid');

              // Check if this image was marked as intended main
              const previewEl = thumbGrid?.querySelector(`[data-object-index="${fi}"]`);
              const hasMain = uiImages.some(img => img.isMain);
              const isMarkedAsMain = previewEl?.hasAttribute('data-intended-main') || !hasMain;

              if (isMarkedAsMain) {
                // Promote uploaded image to main and keep old main as gallery image.
                uiImages.forEach(img => (img.isMain = false));
                uiImages.unshift({ url, isMain: true });
              } else {
                const mainIndex = uiImages.findIndex(img => img.isMain);
                const insertAt = mainIndex >= 0 ? mainIndex + 1 : 0;
                // Insert right after main so newest uploads are shown first row/top.
                uiImages.splice(insertAt, 0, { url, isMain: false });
              }

              syncToInputs();
              updateThumbGrid();
            } else {
              throw new Error(uploadData.error || 'Upload thất bại');
            }

          } catch (error: any) {
            alert(`Lỗi xử lý ảnh "${file.name}": ` + error.message);
          }
        }

        if (progressOverlay) progressOverlay.style.display = 'none';
        fileInput.value = '';
      });
    }

  });
</script>
