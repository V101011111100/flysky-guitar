---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Thêm sản phẩm mới"
  subtitle="Thiết lập thông tin cho sản phẩm dòng Studio & Wood"
  activeNav="products"
>

  <!-- HEADER ACTIONS -->
  <div class="prd-header">
    <div class="prd-header-left">
      <h2 class="prd-title">Thêm sản phẩm mới</h2>
      <p class="prd-sub">Thiết lập thông tin cho sản phẩm dòng Studio &amp; Wood</p>
    </div>
    <div class="prd-header-actions">
      <button class="btn-ghost">Hủy</button>
      <button class="btn-outline-orange">Xem trước</button>
      <button class="btn-orange">
        <span class="material-symbols-outlined">save</span>
        Lưu thay đổi
      </button>
    </div>
  </div>

  <!-- MAIN GRID -->
  <div class="prd-grid">

    <!-- ── LEFT COLUMN ── -->
    <div class="prd-col-left">

      <!-- Media Management -->
      <section class="prd-card">
        <h3 class="prd-card-title">
          <span class="material-symbols-outlined prd-card-icon">image</span>
          Quản lý truyền thông
        </h3>

        <!-- Optimize toggle -->
        <div class="media-opt-bar">
          <div class="media-opt-left">
            <span class="material-symbols-outlined media-bolt">bolt</span>
            <span class="media-opt-label">Tự động tối ưu dung lượng (WebP/AVIF)</span>
          </div>
          <label class="toggle-label-wrap">
            <input type="checkbox" class="toggle-chk" checked />
            <div class="toggle-track"><div class="toggle-thumb"></div></div>
          </label>
        </div>

        <!-- Drag & Drop zone -->
        <div class="upload-zone" id="uploadZone">
          <div class="upload-icons">
            <span class="material-symbols-outlined upload-icon">image</span>
            <span class="material-symbols-outlined upload-icon">cloud_upload</span>
          </div>
          <p class="upload-text">Kéo và thả ảnh tại đây hoặc click để chọn tệp</p>
          <p class="upload-hint">Hỗ trợ JPG, PNG, WEBP (Tối đa 5MB)</p>
        </div>

        <!-- Thumbnail Grid -->
        <div class="thumb-grid">
          <div class="thumb-add">
            <span class="material-symbols-outlined">add</span>
            <span class="thumb-add-label">Thêm ảnh</span>
          </div>
          <div class="thumb-item" style="background-image:url('https://images.unsplash.com/photo-1510915361894-db8b60106cb1?w=200&q=70')">
            <div class="thumb-overlay">
              <span class="material-symbols-outlined thumb-action" onclick="document.getElementById('crop-modal').style.display='flex'" title="Cắt ảnh">crop</span>
              <span class="material-symbols-outlined thumb-action thumb-del" title="Xóa ảnh">delete</span>
            </div>
            <div class="thumb-badge">-65%</div>
          </div>
          <div class="thumb-item" style="background-image:url('https://images.unsplash.com/photo-1525201548942-d8732f6617a0?w=200&q=70')">
            <div class="thumb-overlay">
              <span class="material-symbols-outlined thumb-action" onclick="document.getElementById('crop-modal').style.display='flex'" title="Cắt ảnh">crop</span>
              <span class="material-symbols-outlined thumb-action thumb-del" title="Xóa ảnh">delete</span>
            </div>
            <div class="thumb-badge">-65%</div>
          </div>
        </div>

        <!-- Video Link -->
        <div class="video-field">
          <label class="prd-label">Link Video Demo Âm thanh</label>
          <div class="icon-input-wrap">
            <span class="material-symbols-outlined inp-icon">play_circle</span>
            <input type="text" class="prd-input inp-with-icon" placeholder="YouTube hoặc Vimeo URL..." />
          </div>
        </div>
      </section>

      <!-- Tech Specs -->
      <section class="prd-card">
        <h3 class="prd-card-title">
          <span class="material-symbols-outlined prd-card-icon">tune</span>
          Thông số kỹ thuật
        </h3>
        <div class="prd-form-grid">
          <div class="form-group">
            <label class="prd-label">Gỗ mặt trước</label>
            <select class="prd-input">
              <option>Spruce (Vân sam)</option>
              <option>Mahogany (Hồng đào)</option>
              <option>Cedar (Tuyết tùng)</option>
              <option>Maple (Phong)</option>
            </select>
          </div>
          <div class="form-group">
            <label class="prd-label">Gỗ lưng &amp; hông</label>
            <select class="prd-input">
              <option>Rosewood (Cẩm ấn)</option>
              <option>Mahogany (Hồng đào)</option>
              <option>Walnut (Óc chó)</option>
              <option>Koa</option>
            </select>
          </div>
          <div class="form-group">
            <label class="prd-label">Pickups</label>
            <select class="prd-input">
              <option>Fishman Presys II</option>
              <option>L.R. Baggs Anthem</option>
              <option>Taylor Expression System 2</option>
              <option>None (Acoustic only)</option>
            </select>
          </div>
          <div class="form-group">
            <label class="prd-label">Khóa đàn (Tuners)</label>
            <select class="prd-input">
              <option>Grover Rotomatics</option>
              <option>Gotoh 510</option>
              <option>Schaller GrandTune</option>
              <option>Standard Die-cast</option>
            </select>
          </div>
        </div>
      </section>
    </div>

    <!-- ── RIGHT COLUMN ── -->
    <div class="prd-col-right">
      <section class="prd-card">
        <h3 class="prd-card-title">
          <span class="material-symbols-outlined prd-card-icon">info</span>
          Thông tin chi tiết
        </h3>

        <!-- Product Name (full width) -->
        <div class="form-group form-full" style="margin-bottom:20px;">
          <label class="prd-label">Tên sản phẩm</label>
          <input type="text" class="prd-input prd-input-lg" placeholder="Ví dụ: FlySky Studio Wood Edition G-200" />
        </div>

        <!-- 2-col fields -->
        <div class="prd-form-grid" style="margin-bottom:20px;">
          <div class="form-group">
            <label class="prd-label">Mã SKU</label>
            <input type="text" class="prd-input prd-input-upper" placeholder="FS-SW-200-MAH" />
          </div>
          <div class="form-group">
            <label class="prd-label">Danh mục</label>
            <select class="prd-input">
              <option>Acoustic Guitars</option>
              <option>Electric Guitars</option>
              <option>Classical Guitars</option>
              <option>Accessories</option>
            </select>
          </div>
          <div class="form-group">
            <label class="prd-label">Giá bán (VNĐ)</label>
            <div class="icon-input-wrap">
              <input type="number" class="prd-input prd-input-currency" placeholder="0" />
              <span class="currency-sym">₫</span>
            </div>
          </div>
          <div class="form-group">
            <label class="prd-label">Số lượng tồn kho</label>
            <input type="number" class="prd-input" placeholder="10" />
          </div>
        </div>

        <!-- Rich Text Editor -->
        <div class="form-group">
          <label class="prd-label">Mô tả sản phẩm</label>
          <div class="rte-wrap">
            <div class="rte-toolbar">
              <button class="rte-btn"><span class="material-symbols-outlined">format_bold</span></button>
              <button class="rte-btn"><span class="material-symbols-outlined">format_italic</span></button>
              <button class="rte-btn"><span class="material-symbols-outlined">format_underlined</span></button>
              <div class="rte-sep"></div>
              <button class="rte-btn"><span class="material-symbols-outlined">format_list_bulleted</span></button>
              <button class="rte-btn"><span class="material-symbols-outlined">format_list_numbered</span></button>
              <div class="rte-sep"></div>
              <button class="rte-btn"><span class="material-symbols-outlined">link</span></button>
              <button class="rte-btn"><span class="material-symbols-outlined">image</span></button>
            </div>
            <textarea class="rte-body" rows="9" placeholder="Nhập mô tả chi tiết về sản phẩm, đặc điểm nổi bật và cảm giác chơi..."></textarea>
          </div>
        </div>
      </section>
    </div>
  </div>

</AdminLayout>

<!-- ── IMAGE CROP MODAL ── -->
<div class="crop-modal" id="crop-modal" style="display:none;" onclick="if(event.target===this) this.style.display='none'">
  <div class="crop-dialog">
    <!-- Modal Header -->
    <div class="crop-header">
      <div class="crop-header-left">
        <span class="material-symbols-outlined" style="color:#f48c25;">crop</span>
        <h3 class="crop-title">Cắt và điều chỉnh ảnh</h3>
      </div>
      <button class="crop-close-btn" onclick="document.getElementById('crop-modal').style.display='none'">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>

    <!-- Modal Body -->
    <div class="crop-body">
      <!-- Preview -->
      <div class="crop-preview-area">
        <div class="crop-frame">
          <img src="https://images.unsplash.com/photo-1510915361894-db8b60106cb1?w=600&q=70" alt="Crop preview" class="crop-img" />
          <div class="crop-selection">
            <div class="crop-handle tl"></div>
            <div class="crop-handle tr"></div>
            <div class="crop-handle bl"></div>
            <div class="crop-handle br"></div>
          </div>
        </div>
      </div>

      <!-- Controls -->
      <div class="crop-controls">
        <!-- Optimize bar -->
        <div class="crop-opt-bar">
          <div class="crop-opt-head">
            <span class="crop-opt-label">Tối ưu hóa</span>
            <span class="crop-opt-status">BẬT</span>
          </div>
          <p class="crop-opt-desc">Tự động chuyển đổi sang WebP/AVIF để tăng tốc độ tải trang.</p>
          <div class="crop-opt-confirm">
            <span class="material-symbols-outlined crop-check-icon">check_circle</span>
            <span class="crop-check-text">Đã tối ưu - tiết kiệm 65%</span>
          </div>
        </div>

        <!-- Aspect Ratio -->
        <div class="crop-ctrl-group">
          <label class="prd-label" style="margin-bottom:12px;">Tỷ lệ khung hình</label>
          <div class="ratio-grid">
            <button class="ratio-btn ratio-active">1:1 (Vuông)</button>
            <button class="ratio-btn">4:3</button>
            <button class="ratio-btn">16:9</button>
            <button class="ratio-btn">Tự do</button>
          </div>
        </div>

        <!-- Zoom -->
        <div class="crop-ctrl-group">
          <div class="crop-slider-head">
            <label class="prd-label">Phóng to</label>
            <span class="crop-slider-val">100%</span>
          </div>
          <input type="range" class="crop-slider" />
        </div>

        <!-- Rotate -->
        <div class="crop-ctrl-group">
          <div class="crop-slider-head">
            <label class="prd-label">Xoay</label>
            <span class="crop-slider-val">0°</span>
          </div>
          <div class="rotate-btns">
            <button class="rotate-btn"><span class="material-symbols-outlined">rotate_left</span></button>
            <button class="rotate-btn"><span class="material-symbols-outlined">rotate_right</span></button>
            <button class="rotate-btn"><span class="material-symbols-outlined">flip</span></button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal Footer -->
    <div class="crop-footer">
      <button class="btn-ghost" onclick="document.getElementById('crop-modal').style.display='none'">Hủy</button>
      <button class="btn-orange" onclick="document.getElementById('crop-modal').style.display='none'">Áp dụng</button>
    </div>
  </div>
</div>

<style>
  /* ── PAGE HEADER ── */
  .prd-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 20px; margin-bottom: 32px; flex-wrap: wrap;
  }
  .prd-title { font-size: 26px; font-weight: 900; color: #f9fafb; }
  .prd-sub   { font-size: 13px; color: #94a3b8; margin-top: 4px; }
  .prd-header-actions { display: flex; align-items: center; gap: 10px; }
  .btn-ghost {
    padding: 9px 18px; border-radius: 10px;
    border: 1px solid #4a3a2a; background: none; color: #94a3b8;
    font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Manrope', sans-serif;
    transition: background .15s;
  }
  .btn-ghost:hover { background: #2d2218; color: #f9fafb; }
  .btn-outline-orange {
    padding: 9px 18px; border-radius: 10px;
    border: 1px solid #f48c25; background: none; color: #f48c25;
    font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Manrope', sans-serif;
    transition: background .15s;
  }
  .btn-outline-orange:hover { background: rgba(244,140,37,.1); }
  .btn-orange {
    display: flex; align-items: center; gap: 6px;
    padding: 9px 18px; border-radius: 10px;
    background: #f48c25; color: #221910; border: none;
    font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Manrope', sans-serif;
    box-shadow: 0 4px 16px rgba(244,140,37,.25); transition: filter .15s;
  }
  .btn-orange:hover { filter: brightness(1.08); }
  .btn-orange .material-symbols-outlined { font-size: 18px; }

  /* ── MAIN GRID ── */
  .prd-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 28px;
    align-items: start;
  }
  .prd-col-left, .prd-col-right { display: flex; flex-direction: column; gap: 24px; }

  /* ── CARD ── */
  .prd-card {
    background: rgba(244,140,37,.04);
    border: 1px solid rgba(74,58,42,.6);
    border-radius: 16px; padding: 24px;
    display: flex; flex-direction: column; gap: 18px;
  }
  .prd-card-title {
    display: flex; align-items: center; gap: 10px;
    font-size: 16px; font-weight: 800; color: #f9fafb;
  }
  .prd-card-icon { font-size: 20px; color: #f48c25; }

  /* ── LABELS & INPUTS ── */
  .prd-label {
    display: block; font-size: 10px; font-weight: 800;
    text-transform: uppercase; letter-spacing: .1em; color: rgba(244,140,37,.75);
    margin-bottom: 8px;
  }
  .prd-input {
    width: 100%; background: #2d2218; border: 1px solid rgba(74,58,42,.8);
    border-radius: 10px; padding: 10px 16px;
    font-size: 13px; color: #f1f5f9; font-family: 'Manrope', sans-serif;
    outline: none; transition: border .2s; box-sizing: border-box;
  }
  .prd-input:focus { border-color: #f48c25; }
  .prd-input::placeholder { color: #64748b; }
  .prd-input-lg   { font-size: 15px; padding: 12px 16px; }
  .prd-input-upper{ text-transform: uppercase; }
  .prd-input-currency { padding-right: 40px; }
  .icon-input-wrap { position: relative; display: flex; align-items: center; }
  .inp-icon { position: absolute; left: 14px; font-size: 18px; color: #94a3b8; pointer-events: none; }
  .inp-with-icon { padding-left: 44px; }
  .currency-sym { position: absolute; right: 14px; font-size: 16px; font-weight: 800; color: #f48c25; pointer-events: none; }

  /* ── FORM GRID ── */
  .prd-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { display: flex; flex-direction: column; }
  .form-full { grid-column: 1 / -1; }

  /* ── OPTIMIZE TOGGLE BAR ── */
  .media-opt-bar {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; padding: 12px 16px; border-radius: 10px;
    background: rgba(34,25,16,.4); border: 1px solid rgba(244,140,37,.1);
  }
  .media-opt-left { display: flex; align-items: center; gap: 8px; }
  .media-bolt { font-size: 16px; color: #f48c25; }
  .media-opt-label { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; color: #e2e8f0; }

  /* Toggle (reuse from settings) */
  .toggle-label-wrap { display: flex; align-items: center; cursor: pointer; }
  .toggle-chk { position: absolute; opacity: 0; width: 0; height: 0; }
  .toggle-track { width: 40px; height: 22px; border-radius: 999px; background: #475569; position: relative; transition: background .2s; flex-shrink: 0; }
  .toggle-chk:checked + .toggle-track { background: #f48c25; }
  .toggle-thumb { position: absolute; top: 2px; left: 2px; width: 18px; height: 18px; border-radius: 50%; background: #fff; transition: left .2s; }
  .toggle-chk:checked + .toggle-track .toggle-thumb { left: 20px; }

  /* ── UPLOAD ZONE ── */
  .upload-zone {
    border: 2px dashed rgba(244,140,37,.3); border-radius: 14px;
    background: rgba(34,25,16,.3); padding: 32px 20px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 12px; text-align: center; cursor: pointer;
    transition: border-color .2s, background .2s;
  }
  .upload-zone:hover { border-color: #f48c25; background: rgba(34,25,16,.5); }
  .upload-icons { display: flex; gap: 16px; }
  .upload-icon { font-size: 36px; color: rgba(244,140,37,.4); transition: color .2s; }
  .upload-zone:hover .upload-icon { color: #f48c25; }
  .upload-text { font-size: 13px; font-weight: 600; color: #cbd5e1; }
  .upload-hint { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: #64748b; }

  /* ── THUMBNAIL GRID ── */
  .thumb-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
  }
  .thumb-add {
    aspect-ratio: 1; border-radius: 10px;
    border: 2px dashed rgba(244,140,37,.3);
    background: rgba(34,25,16,.5);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 4px;
    cursor: pointer; transition: border-color .2s;
  }
  .thumb-add:hover { border-color: #f48c25; }
  .thumb-add .material-symbols-outlined { font-size: 22px; color: rgba(244,140,37,.5); }
  .thumb-add-label { font-size: 8px; font-weight: 800; text-transform: uppercase; letter-spacing: .06em; color: rgba(244,140,37,.5); }
  .thumb-item {
    aspect-ratio: 1; border-radius: 10px;
    background-size: cover; background-position: center;
    border: 1px solid rgba(244,140,37,.2);
    position: relative; overflow: hidden;
    box-shadow: 0 0 0 1px rgba(52,211,153,.25);
  }
  .thumb-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,.65);
    display: flex; align-items: center; justify-content: center; gap: 12px;
    opacity: 0; transition: opacity .2s;
  }
  .thumb-item:hover .thumb-overlay { opacity: 1; }
  .thumb-action {
    font-size: 20px; color: #fff; cursor: pointer; transition: color .15s;
  }
  .thumb-action:hover { color: #f48c25; }
  .thumb-del:hover { color: #f87171 !important; }
  .thumb-badge {
    position: absolute; top: 4px; right: 4px;
    background: rgba(52,211,153,.9); color: #fff;
    font-size: 8px; font-weight: 900; padding: 2px 6px; border-radius: 999px;
  }

  /* ── VIDEO FIELD ── */
  .video-field { }

  /* ── RICH TEXT EDITOR ── */
  .rte-wrap { border: 1px solid rgba(74,58,42,.8); border-radius: 10px; overflow: hidden; }
  .rte-toolbar {
    display: flex; align-items: center; gap: 2px;
    padding: 8px 10px;
    background: rgba(34,25,16,.6); border-bottom: 1px solid rgba(74,58,42,.5);
    flex-wrap: wrap;
  }
  .rte-btn {
    width: 30px; height: 30px; border-radius: 6px;
    border: none; background: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: #94a3b8; transition: background .15s, color .15s;
  }
  .rte-btn:hover { background: rgba(244,140,37,.2); color: #f48c25; }
  .rte-btn .material-symbols-outlined { font-size: 16px; }
  .rte-sep { width: 1px; height: 20px; background: rgba(74,58,42,.6); margin: 0 4px; }
  .rte-body {
    width: 100%; background: #2d2218; border: none; padding: 16px;
    font-size: 13px; color: #f1f5f9; font-family: 'Manrope', sans-serif;
    outline: none; resize: none; box-sizing: border-box; line-height: 1.6;
  }
  .rte-body::placeholder { color: #64748b; }

  /* ── CROP MODAL ── */
  .crop-modal {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.9);
    display: flex; align-items: center; justify-content: center; padding: 20px;
  }
  .crop-dialog {
    background: #221910; border: 1px solid rgba(244,140,37,.2);
    border-radius: 20px; width: 100%; max-width: 900px;
    max-height: 90vh; overflow: hidden;
    display: flex; flex-direction: column;
    box-shadow: 0 25px 60px rgba(0,0,0,.8);
  }
  .crop-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px; border-bottom: 1px solid rgba(244,140,37,.1);
    background: rgba(244,140,37,.04);
  }
  .crop-header-left { display: flex; align-items: center; gap: 10px; }
  .crop-title { font-size: 17px; font-weight: 800; color: #f9fafb; }
  .crop-close-btn {
    background: none; border: none; color: #94a3b8;
    cursor: pointer; padding: 4px; transition: color .15s;
  }
  .crop-close-btn:hover { color: #f9fafb; }
  .crop-close-btn .material-symbols-outlined { font-size: 22px; }

  .crop-body { display: flex; flex: 1; overflow: hidden; }

  /* Preview area */
  .crop-preview-area {
    flex: 1; background: rgba(0,0,0,.5);
    display: flex; align-items: center; justify-content: center; padding: 32px;
  }
  .crop-frame {
    position: relative; max-width: 360px; width: 100%;
    aspect-ratio: 1; border: 2px solid rgba(244,140,37,.4);
  }
  .crop-img { width: 100%; height: 100%; object-fit: cover; opacity: .6; display: block; }
  .crop-selection {
    position: absolute; inset: 16px;
    border: 2px dashed rgba(255,255,255,.8);
    box-shadow: 0 0 0 9999px rgba(0,0,0,.45);
    cursor: move;
  }
  .crop-handle {
    position: absolute; width: 12px; height: 12px; background: #fff;
  }
