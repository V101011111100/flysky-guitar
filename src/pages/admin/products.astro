    outline: none; resize: none; box-sizing: border-box; line-height: 1.6;
  }
  .rte-body::placeholder { color: #64748b; }

  /* ── CROP MODAL ── */
  .crop-modal {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.9);
    display: flex; align-items: center; justify-content: center; padding: 20px;
  }
  .crop-dialog {
    background: #221910; border: 1px solid rgba(244,140,37,.2);
    border-radius: 20px; width: 100%; max-width: 900px;
    max-height: 90vh; overflow: hidden;
    display: flex; flex-direction: column;
    box-shadow: 0 25px 60px rgba(0,0,0,.8);
  }
  .crop-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px; border-bottom: 1px solid rgba(244,140,37,.1);
    background: rgba(244,140,37,.04);
  }
  .crop-header-left { display: flex; align-items: center; gap: 10px; }
  .crop-title { font-size: 17px; font-weight: 800; color: #f9fafb; }
  .crop-close-btn {
    background: none; border: none; color: #94a3b8;
    cursor: pointer; padding: 4px; transition: color .15s;
  }
  .crop-close-btn:hover { color: #f9fafb; }
  .crop-close-btn .material-symbols-outlined { font-size: 22px; }

  .crop-body { display: flex; flex: 1; overflow: hidden; }

  /* Preview area */
  .crop-preview-area {
    flex: 1; background: rgba(0,0,0,.5);
    display: flex; align-items: center; justify-content: center; padding: 32px;
  }
  .crop-frame {
    position: relative; max-width: 360px; width: 100%;
    aspect-ratio: 1; border: 2px solid rgba(244,140,37,.4);
  }
  .crop-img { width: 100%; height: 100%; object-fit: cover; opacity: .6; display: block; }
  .crop-selection {
    position: absolute; inset: 16px;
    border: 2px dashed rgba(255,255,255,.8);
    box-shadow: 0 0 0 9999px rgba(0,0,0,.45);
    cursor: move;
  }
  .crop-handle {
    position: absolute; width: 12px; height: 12px; background: #fff;
  }
  .crop-handle.tl { top: -1px; left: -1px; }
  .crop-handle.tr { top: -1px; right: -1px; }
  .crop-handle.bl { bottom: -1px; left: -1px; }
  .crop-handle.br { bottom: -1px; right: -1px; }

  /* Controls sidebar */
  .crop-controls {
    width: 270px; flex-shrink: 0;
    border-left: 1px solid rgba(74,58,42,.4);
    padding: 20px; overflow-y: auto;
    display: flex; flex-direction: column; gap: 20px;
    background: #221910;
  }
  .crop-opt-bar {
    padding: 14px; background: rgba(244,140,37,.08);
    border: 1px solid rgba(244,140,37,.2); border-radius: 10px;
  }
  .crop-opt-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
  .crop-opt-label { font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: .14em; color: #f48c25; }
  .crop-opt-status { font-size: 9px; font-weight: 900; color: #34d399; }
  .crop-opt-desc { font-size: 10px; color: #94a3b8; line-height: 1.5; margin-bottom: 10px; }
  .crop-opt-confirm { display: flex; align-items: center; gap: 6px; }
  .crop-check-icon { font-size: 14px; color: #34d399; }
  .crop-check-text { font-size: 9px; font-weight: 800; color: #34d399; }

  .crop-ctrl-group { }
  .ratio-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .ratio-btn {
    padding: 7px 4px; border-radius: 6px;
    border: 1px solid rgba(74,58,42,.6);
    background: none; color: #94a3b8;
    font-size: 11px; font-weight: 700; cursor: pointer;
    font-family: 'Manrope', sans-serif; transition: all .15s;
  }
  .ratio-btn:hover { border-color: #f48c25; color: #f48c25; }
  .ratio-active { border-color: #f48c25 !important; background: rgba(244,140,37,.1) !important; color: #f48c25 !important; }

  .crop-slider-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
  .crop-slider-val { font-size: 11px; color: #94a3b8; }
  .crop-slider {
    width: 100%; height: 4px; border-radius: 999px;
    background: rgba(244,140,37,.2);
    accent-color: #f48c25; cursor: pointer;
  }
  .rotate-btns { display: flex; gap: 8px; }
  .rotate-btn {
    flex: 1; padding: 8px; border-radius: 8px;
    border: 1px solid rgba(74,58,42,.6); background: none;
    color: #94a3b8; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all .15s;
  }
  .rotate-btn:hover { border-color: #f48c25; color: #f48c25; background: rgba(244,140,37,.1); }
  .rotate-btn .material-symbols-outlined { font-size: 18px; }

  .crop-footer {
    padding: 16px 24px; border-top: 1px solid rgba(74,58,42,.4);
    display: flex; align-items: center; justify-content: flex-end; gap: 10px;
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .prd-grid { grid-template-columns: 1fr; }
    .thumb-grid { grid-template-columns: repeat(4, 1fr); }
    .crop-controls { width: 220px; }
  }
  @media (max-width: 700px) {
    .prd-form-grid { grid-template-columns: 1fr; }
    .prd-header { flex-direction: column; }
    .crop-body { flex-direction: column; }
    .crop-controls { width: 100%; border-left: none; border-top: 1px solid rgba(74,58,42,.4); }
  }
</style>

<script>
  window.addEventListener('DOMContentLoaded', () => {
    // Auto generate slug from name
    document.getElementById('prod-name')?.addEventListener('input', (e) => {
      const idField = document.getElementById('prod-id') as HTMLInputElement;
      if (!idField?.value) { // Only auto-generate on create new
         const name = (e.target as HTMLInputElement).value;
         const slug = name.toLowerCase()
          .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)+/g, '');
         const slugEl = document.getElementById('prod-slug') as HTMLInputElement;
         if (slugEl) slugEl.value = slug;
      }
    });

    // Save product
    const btnSave = document.getElementById('btn-save-prod') as HTMLButtonElement;
    if (btnSave) {
      btnSave.addEventListener('click', async () => {
        btnSave.disabled = true;
        btnSave.textContent = 'Đang lưu...';

        const payload = {
          'prod-id': (document.getElementById('prod-id') as HTMLInputElement)?.value || '',
          'prod-name': (document.getElementById('prod-name') as HTMLInputElement)?.value || '',
          'prod-slug': (document.getElementById('prod-slug') as HTMLInputElement)?.value || '',
          'prod-price': (document.getElementById('prod-price') as HTMLInputElement)?.value || '',
          'prod-image': (document.getElementById('prod-image') as HTMLInputElement)?.value || '',
          'prod-desc': (document.getElementById('prod-desc') as HTMLTextAreaElement)?.value || '',
          'prod-body': (document.getElementById('prod-body') as HTMLSelectElement)?.value || '',
          'prod-top': (document.getElementById('prod-top') as HTMLSelectElement)?.value || '',
          'prod-neck': (document.getElementById('prod-neck') as HTMLSelectElement)?.value || '',
          'prod-category': (document.getElementById('prod-category') as HTMLSelectElement)?.value || '',
          'prod-stock': (document.getElementById('prod-stock') as HTMLInputElement)?.value || '0',
          'prod-status': (document.getElementById('prod-status') as HTMLSelectElement)?.value || 'active'
        };

        try {
          const res = await fetch('/api/products/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await res.json();
          
          if(data.success) {
            alert('Lưu sản phẩm thành công!');
            window.location.href = '/admin/inventory';
          } else {
            alert('Lỗi: ' + data.error);
            btnSave.disabled = false;
            btnSave.textContent = 'Lưu thay đổi';
          }
        } catch(err) {
          alert('Lỗi kết nối máy chủ');
          btnSave.disabled = false;
          btnSave.textContent = 'Lưu thay đổi';
        }
      });
    }

    // TỐI ƯU VÀ UPLOAD ẢNH BẰNG CANVAS (Client-side)
    const fileInput = document.getElementById('img-upload-input') as HTMLInputElement;
    const progressOverlay = document.getElementById('upload-progress-overlay');
    const progressText = document.getElementById('upload-progress-text');
    
    if (fileInput) {
      fileInput.addEventListener('change', async (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (!file) return;

        // Bật trạng thái loading
        if (progressOverlay) progressOverlay.style.display = 'flex';
        if (progressText) progressText.textContent = 'Đang xử lý ảnh độ phân giải cao...';

        try {
          // 1. Đọc file ảnh dưới dạng Image object
          const img = new Image();
          const objectUrl = URL.createObjectURL(file);
          
          await new Promise((resolve, reject) => {
            img.onload = resolve;
            img.onerror = reject;
            img.src = objectUrl;
          });

          // 2. Thiết lập Canvas với Kích Thước Lớn (Full HD / 4K)
          // Đã tăng lên 2048x2048 để cho độ nét trên màn hình lớn.
          const CANVAS_SIZE = 2048; 
          const canvas = document.createElement('canvas');
          canvas.width = CANVAS_SIZE;
          canvas.height = CANVAS_SIZE;
          const ctx = canvas.getContext('2d');
          
          if (!ctx) throw new Error("Không thể khởi tạo Canvas");

          // 3. Đổ nền mặc định (nếu là ảnh PNG/trong suốt thì nền này sẽ lót phía dưới)
          // Màu lấy từ CSS biến `.bg-default-guitar` (tương đương radial gradient #352a20 -> #15110c)
          // Canvas không hỗ trợ vẽ Radial gradient CSS dễ dàng 1 dòng, nên ta sẽ tự cấu hình Gradient
          const gradient = ctx.createRadialGradient(
            CANVAS_SIZE/2, CANVAS_SIZE/2, 0,
            CANVAS_SIZE/2, CANVAS_SIZE/2, CANVAS_SIZE/1.2
          );
          gradient.addColorStop(0, '#352a20');
          gradient.addColorStop(1, '#15110c');
          
          ctx.fillStyle = gradient;
          ctx.fillRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);

          // 4. Tính toán Fit Ảnh (Object-fit: Contain) mà không bị méo (Aspect Ratio)
          const scale = Math.min(CANVAS_SIZE / img.width, CANVAS_SIZE / img.height);
          const drawWidth = img.width * scale;
          const drawHeight = img.height * scale;
          
          // Căn giữa tấm ảnh
          const dx = (CANVAS_SIZE - drawWidth) / 2;
          const dy = (CANVAS_SIZE - drawHeight) / 2;

          // Vẽ ảnh gốc lên Canvas
          ctx.drawImage(img, dx, dy, drawWidth, drawHeight);
          URL.revokeObjectURL(objectUrl);

          // 5. Xuất Canvas ra file WebP siêu nhẹ với chất lượng 85%
          if (progressText) progressText.textContent = 'Đang tối ưu dung lượng WebP...';
          const blob = await new Promise<Blob | null>(resolve => canvas.toBlob(resolve, 'image/webp', 0.85));
          
          if (!blob) throw new Error("Lỗi khi xuất định dạng WebP");

          // Tạo File từ Blob để gửi lên server
          const optimizedFile = new File([blob], file.name.replace(/\.[^/.]+$/, "") + ".webp", { type: 'image/webp' });

          // 6. Upload file WebP lên API của chúng ta (local file system saving)
          if (progressText) progressText.textContent = 'Đang tải lên hệ thống...';
          const formData = new FormData();
          formData.append('file', optimizedFile);

          const uploadRes = await fetch('/api/products/upload', {
            method: 'POST',
            body: formData
          });

          const uploadData = await uploadRes.json();
          if (uploadData.success && uploadData.url) {
            // Thành công: Đưa URL trả về vào Input và update thumbnail preview
            const urlInput = document.getElementById('prod-image') as HTMLInputElement;
            if (urlInput) {
               urlInput.value = uploadData.url;
               // Trigger in case we want to listen to changes later
               urlInput.dispatchEvent(new Event('input'));
            }

            // Update UI 
            const imgPreviewEl = document.getElementById('main-thumb-img') as HTMLImageElement;
            const previewContainer = document.getElementById('main-thumb-preview');
            const optBadge = document.getElementById('thumb-opt-badge');

            if (imgPreviewEl) imgPreviewEl.src = uploadData.url;
            if (previewContainer) previewContainer.style.display = 'block';
            if (optBadge) {
               optBadge.style.display = 'block';
               // Calculate savings roughly 
               const savings = Math.max(10, Math.floor(100 - (optimizedFile.size / file.size * 100)));
               optBadge.textContent = '-' + (savings > 0 ? savings : 10) + '% WebP';
            }
          } else {
             throw new Error(uploadData.error || "Upload thất bại");
          }

        } catch (error: any) {
          alert('Lỗi xử lý ảnh: ' + error.message);
        } finally {
          // Tắt trạng thái loading
          if (progressOverlay) progressOverlay.style.display = 'none';
          fileInput.value = ''; // xóa file sau khi xong để có thể up lại cùng 1 file
        }
      });
    }

  });
</script>
