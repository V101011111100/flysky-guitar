---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Quản lý vận chuyển"
  subtitle="Quản lý đối tác giao hàng, API tích hợp và vận đơn theo thời gian thực."
  activeNav="shipping"
>
  <section class="shipping-page">
    <div class="sp-head">
      <div>
        <h2>Quản lý Đối tác Vận chuyển</h2>
        <p>Thiết lập API, gán vận đơn cho đơn hàng và theo dõi trạng thái giao hàng tập trung.</p>
      </div>
      <button id="btn-refresh" class="sp-btn-outline" type="button">Làm mới dữ liệu</button>
    </div>

    <div class="sp-stats" id="sp-stats"></div>

    <section class="sp-card">
      <div class="sp-card-head">
        <h3>Kết nối nhà vận chuyển</h3>
        <span class="sp-card-note">Bật/tắt kết nối và cấu hình API từng đối tác</span>
      </div>
      <div class="sp-provider-grid" id="sp-provider-grid"></div>
    </section>

    <section class="sp-card">
      <div class="sp-card-head">
        <h3>Cấu hình chi phí vận chuyển</h3>
        <span class="sp-card-note">Đồng bộ từ bảng shipping_rates</span>
      </div>
      <div class="sp-table-wrap">
        <table class="sp-table">
          <thead>
            <tr>
              <th>Phương thức</th>
              <th>Trạng thái API</th>
              <th>Loại tính giá</th>
              <th>Phí cơ bản</th>
              <th>Phí/Kg</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody id="sp-rates-body"></tbody>
        </table>
      </div>
    </section>

    <section class="sp-card">
      <div class="sp-card-head">
        <h3>Quản lý đơn hàng vận chuyển</h3>
        <span class="sp-card-note">Gán đối tác, mã vận đơn, trạng thái giao hàng</span>
      </div>
      <div class="sp-table-wrap">
        <table class="sp-table">
          <thead>
            <tr>
              <th>Mã đơn</th>
              <th>Khách hàng</th>
              <th>Tổng tiền</th>
              <th>Đơn vị vận chuyển</th>
              <th>Mã vận đơn</th>
              <th>Trạng thái</th>
              <th>ETA</th>
              <th>Vị trí hiện tại</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody id="sp-orders-body"></tbody>
        </table>
      </div>
    </section>

    <section class="sp-card">
      <div class="sp-card-head">
        <h3>Theo dõi đơn hàng thời gian thực</h3>
      </div>
      <div class="sp-logs" id="sp-logs"></div>
    </section>
  </section>

  <div class="sp-modal" id="provider-modal" aria-hidden="true">
    <div class="sp-modal-content">
      <div class="sp-modal-head">
        <h3 id="provider-modal-title">Cấu hình API</h3>
        <button type="button" id="provider-modal-close" class="sp-icon-btn">✕</button>
      </div>
      <div id="provider-form" class="sp-form-grid"></div>
      <div class="sp-modal-actions">
        <button type="button" id="provider-modal-cancel" class="sp-btn-outline">Hủy</button>
        <button type="button" id="provider-modal-save" class="sp-btn-primary">Lưu cấu hình</button>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  type Provider = {
    id: string;
    provider_code: string;
    provider_name: string;
    enabled: boolean;
    config: Record<string, any>;
    updated_at: string;
  };

  type Tracking = {
    id: string;
    order_id: string;
    provider_code: string;
    tracking_number: string;
    status: string;
    current_location: string | null;
    estimated_delivery: string | null;
    updated_at: string;
    created_at: string;
    order?: {
      order_number?: string;
      customer_name?: string;
      customer_phone?: string;
      total_amount?: number;
    };
  };

  type Order = {
    id: string;
    order_number: string;
    customer_name: string;
    customer_phone: string;
    total_amount: number;
    status: string;
    created_at: string;
  };

  const providerLabels: Record<string, string> = {
    ghtk: 'GHTK',
    ghn: 'GHN',
    viettel_post: 'Viettel Post',
    vnpost: 'VNPost',
    jnt: 'J&T',
    self_delivery: 'Tự giao',
  };

  const providerShortCode: Record<string, string> = {
    ghtk: 'GK',
    ghn: 'GN',
    viettel_post: 'VT',
    vnpost: 'VN',
    jnt: 'JT',
    self_delivery: 'SD',
  };

  const trackingStatusLabel: Record<string, string> = {
    pending: 'Chờ lấy hàng',
    picked_up: 'Đã lấy hàng',
    in_transit: 'Đang vận chuyển',
    out_for_delivery: 'Đang giao',
    delivered: 'Đã giao',
    failed: 'Thất bại',
    returned: 'Hoàn hàng',
  };

  type ProviderFieldSchema = {
    key: string;
    label: string;
    type?: string;
    placeholder?: string;
    action?: 'generate-secret';
    helpText?: string;
  };

  const providerFieldSchemas: Record<string, ProviderFieldSchema[]> = {
    ghtk: [
      { key: 'api_url', label: 'API URL' },
      { key: 'shop_id', label: 'Shop ID' },
      { key: 'api_token', label: 'API Token', type: 'password', placeholder: 'Để trống để giữ token cũ' },
      { key: 'pick_address.address', label: 'Địa chỉ lấy hàng' },
      { key: 'pick_address.ward', label: 'Phường/Xã' },
      { key: 'pick_address.district', label: 'Quận/Huyện' },
      { key: 'pick_address.province', label: 'Tỉnh/Thành phố' },
    ],
    viettel_post: [
      { key: 'api_url', label: 'API URL' },
      { key: 'customer_id', label: 'Customer ID' },
      { key: 'username', label: 'Username' },
      { key: 'password', label: 'Password', type: 'password', placeholder: 'Để trống để giữ password cũ' },
      { key: 'sender_phone', label: 'SĐT người gửi' },
      { key: 'sender_address', label: 'Địa chỉ lấy hàng' },
      { key: 'webhook_url', label: 'Webhook URL', placeholder: 'https://your-domain.com/api/webhooks/viettel-post' },
      {
        key: 'webhook_secret',
        label: 'Webhook Secret',
        type: 'password',
        placeholder: 'Để trống để giữ secret cũ',
        action: 'generate-secret',
        helpText: 'Secret này cần trùng với ô Secret parameters trong Viettel Partner.',
      },
      { key: 'update_order_type', label: 'UpdateOrder TYPE mặc định', placeholder: '1' },
      { key: 'update_order_note', label: 'Ghi chú UpdateOrder mặc định' },
      { key: 'register_hook_message', label: 'Lý do re-sync hành trình (registerOrderHook)' },
      { key: 'print_type', label: 'Print TYPE mặc định', placeholder: '1' },
      { key: 'print_token', label: 'Print Token (tùy chọn)', type: 'password', placeholder: 'Để trống nếu chưa được Viettel cấp' },
    ],
    ghn: [
      { key: 'api_url', label: 'API URL' },
      { key: 'shop_id', label: 'Shop ID' },
      { key: 'from_district_id', label: 'District ID kho gửi' },
      { key: 'api_token', label: 'API Token', type: 'password', placeholder: 'Để trống để giữ token cũ' },
    ],
    vnpost: [
      { key: 'api_url', label: 'API URL' },
      { key: 'customer_code', label: 'Mã khách hàng' },
      { key: 'api_key', label: 'API Key', type: 'password', placeholder: 'Để trống để giữ key cũ' },
    ],
    jnt: [
      { key: 'api_url', label: 'API URL' },
      { key: 'customer_code', label: 'Mã khách hàng' },
      { key: 'api_key', label: 'API Key', type: 'password', placeholder: 'Để trống để giữ key cũ' },
    ],
    self_delivery: [
      { key: 'base_fee', label: 'Phí cơ bản' },
      { key: 'free_shipping_threshold', label: 'Ngưỡng miễn phí ship' },
    ],
  };

  let providers: Provider[] = [];
  let rates: any[] = [];
  let trackings: Tracking[] = [];
  let orders: Order[] = [];

  let activeProviderCode = '';

  const statsEl = document.getElementById('sp-stats') as HTMLDivElement;
  const providerGridEl = document.getElementById('sp-provider-grid') as HTMLDivElement;
  const ratesBodyEl = document.getElementById('sp-rates-body') as HTMLTableSectionElement;
  const ordersBodyEl = document.getElementById('sp-orders-body') as HTMLTableSectionElement;
  const logsEl = document.getElementById('sp-logs') as HTMLDivElement;

  const providerModal = document.getElementById('provider-modal') as HTMLDivElement;
  const providerModalTitle = document.getElementById('provider-modal-title') as HTMLHeadingElement;
  const providerForm = document.getElementById('provider-form') as HTMLDivElement;

  function formatCurrency(value: number): string {
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND', maximumFractionDigits: 0 }).format(value || 0);
  }

  function formatDate(value: string | null | undefined): string {
    if (!value) return '—';
    return new Date(value).toLocaleString('vi-VN', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  }

  function getByPath(obj: Record<string, any>, path: string): any {
    return path.split('.').reduce((acc: any, seg) => (acc ? acc[seg] : undefined), obj);
  }

  function setByPath(obj: Record<string, any>, path: string, value: any): void {
    const segs = path.split('.');
    let cursor: Record<string, any> = obj;

    for (let i = 0; i < segs.length - 1; i++) {
      const seg = segs[i];
      if (!cursor[seg] || typeof cursor[seg] !== 'object') {
        cursor[seg] = {};
      }
      cursor = cursor[seg];
    }

    cursor[segs[segs.length - 1]] = value;
  }

  function toast(message: string, type: 'success' | 'error' = 'success') {
    const node = document.createElement('div');
    node.className = `sp-toast ${type === 'error' ? 'sp-toast-error' : ''}`;
    node.textContent = message;
    document.body.appendChild(node);
    setTimeout(() => {
      node.style.opacity = '0';
      setTimeout(() => node.remove(), 260);
    }, 2400);
  }

  function generateSecretHex(bytes = 24): string {
    const byteLength = Math.max(16, Math.min(64, Number(bytes) || 24));
    const arr = new Uint8Array(byteLength);

    if (window.crypto?.getRandomValues) {
      window.crypto.getRandomValues(arr);
    } else {
      for (let i = 0; i < arr.length; i++) {
        arr[i] = Math.floor(Math.random() * 256);
      }
    }

    return Array.from(arr)
      .map((b) => b.toString(16).padStart(2, '0'))
      .join('');
  }

  async function loadDashboard() {
    const res = await fetch('/api/admin/shipping/dashboard');
    const data = await res.json();

    if (!res.ok || !data.success) {
      throw new Error(data.error || 'Không thể tải dữ liệu vận chuyển');
    }

    providers = data.providers || [];
    rates = data.rates || [];
    trackings = data.trackings || [];
    orders = data.orders || [];

    renderStats();
    renderProviders();
    renderRates();
    renderOrders();
    renderLogs();
  }

  function renderStats() {
    const activeProviders = providers.filter((p) => p.enabled).length;
    const inTransit = trackings.filter((t) => ['picked_up', 'in_transit', 'out_for_delivery'].includes(t.status)).length;
    const failed = trackings.filter((t) => ['failed', 'returned'].includes(t.status)).length;
    const waitingAssign = orders.filter((o) => {
      return !trackings.find((t) => t.order_id === o.id);
    }).length;

    statsEl.innerHTML = `
      <div class="sp-stat-card">
        <p class="sp-stat-label">Tổng đối tác</p>
        <div class="sp-stat-row"><span class="sp-stat-value">${String(providers.length).padStart(2, '0')}</span><span class="sp-up">+${activeProviders} mới</span></div>
      </div>
      <div class="sp-stat-card">
        <p class="sp-stat-label">Đang giao hàng</p>
        <div class="sp-stat-row"><span class="sp-stat-value">${inTransit}</span><span class="sp-chip">Đang xử lý</span></div>
      </div>
      <div class="sp-stat-card">
        <p class="sp-stat-label">Giao thất bại</p>
        <div class="sp-stat-row"><span class="sp-stat-value">${failed}</span><span class="sp-down">${failed > 0 ? 'Cần xử lý' : '0%'}</span></div>
      </div>
      <div class="sp-stat-card sp-stat-focus">
        <p class="sp-stat-label">Chờ gán vận đơn</p>
        <div class="sp-stat-row"><span class="sp-stat-value">${waitingAssign}</span><span class="sp-up">Realtime</span></div>
      </div>
    `;
  }

  function renderProviders() {
    providerGridEl.innerHTML = providers
      .map((provider) => {
        return `
          <article class="sp-provider-card">
            <div class="sp-provider-logo">${providerShortCode[provider.provider_code] || 'SP'}</div>
            <div class="sp-provider-main">
              <h4>${provider.provider_name}</h4>
              <span class="sp-pill ${provider.enabled ? 'sp-pill-green' : 'sp-pill-gray'}">
                ${provider.enabled ? 'ĐANG HOẠT ĐỘNG' : 'CHƯA KẾT NỐI'}
              </span>
            </div>
            <div class="sp-provider-actions">
              ${provider.enabled ? `
                <label class="sp-switch">
                  <span>Tự động kết nối</span>
                  <input type="checkbox" data-provider-toggle="${provider.provider_code}" ${provider.enabled ? 'checked' : ''}>
                </label>
              ` : `
                <label class="sp-switch">
                  <span>Bật kết nối</span>
                  <input type="checkbox" data-provider-toggle="${provider.provider_code}" ${provider.enabled ? 'checked' : ''}>
                </label>
              `}
              <button class="sp-btn-primary" data-provider-config="${provider.provider_code}" type="button">${provider.enabled ? 'Cài đặt API' : 'Kết nối ngay'}</button>
            </div>
          </article>
        `;
      })
      .join('');

    providerGridEl.querySelectorAll<HTMLInputElement>('[data-provider-toggle]').forEach((input) => {
      input.addEventListener('change', async () => {
        const providerCode = input.dataset.providerToggle || '';
        try {
          await updateProvider(providerCode, { enabled: input.checked });
          toast('Đã cập nhật trạng thái kết nối');
        } catch (error: any) {
          input.checked = !input.checked;
          toast(error.message || 'Không thể cập nhật trạng thái', 'error');
        }
      });
    });

    providerGridEl.querySelectorAll<HTMLButtonElement>('[data-provider-config]').forEach((button) => {
      button.addEventListener('click', () => {
        const providerCode = button.dataset.providerConfig || '';
        openProviderModal(providerCode);
      });
    });
  }

  function renderRates() {
    if (!rates.length) {
      ratesBodyEl.innerHTML = `<tr><td colspan="6" class="sp-empty">Chưa có dữ liệu cấu hình phí vận chuyển.</td></tr>`;
      return;
    }

    ratesBodyEl.innerHTML = rates
      .map((rate) => {
        const route = `${rate.from_province || 'Toàn quốc'} → ${rate.to_province || 'Toàn quốc'}`;
        const weight = `${rate.weight_from ?? 0}kg - ${rate.weight_to ?? '∞'}kg`;
        return `
          <tr>
            <td>
              <div class="sp-method-cell">
                <span class="sp-method-code">${providerShortCode[rate.provider_code] || 'SP'}</span>
                <div>
                  <p class="sp-method-title">${providerLabels[rate.provider_code] || rate.provider_code}</p>
                  <p class="sp-method-sub">${route}</p>
                </div>
              </div>
            </td>
            <td>${rate.enabled ? '<span class="sp-dot ok"></span> Hoạt động' : '<span class="sp-dot off"></span> Ngoại tuyến'}</td>
            <td><span class="sp-type-chip">${weight.includes('∞') ? 'Theo cân nặng' : 'Cố định'}</span></td>
            <td>${formatCurrency(Number(rate.base_fee || 0))}</td>
            <td>${rate.per_kg_fee ? `${formatCurrency(Number(rate.per_kg_fee || 0))}/kg` : '—'}</td>
            <td><button class="sp-icon-ghost" type="button">⚙</button></td>
          </tr>
        `;
      })
      .join('');
  }

  function renderOrders() {
    if (!orders.length) {
      ordersBodyEl.innerHTML = `<tr><td colspan="9" class="sp-empty">Không có đơn hàng cần xử lý vận chuyển.</td></tr>`;
      return;
    }

    const providerOptions = providers
      .map((p) => `<option value="${p.provider_code}">${p.provider_name}</option>`)
      .join('');

    ordersBodyEl.innerHTML = orders
      .slice(0, 40)
      .map((order) => {
        const existing = trackings.find((tracking) => tracking.order_id === order.id);

        return `
          <tr data-order-row="${order.id}">
            <td>#${order.order_number}</td>
            <td>
              <div>${order.customer_name || 'Khách lẻ'}</div>
              <div class="sp-muted">${order.customer_phone || ''}</div>
            </td>
            <td>${formatCurrency(Number(order.total_amount || 0))}</td>
            <td>
              <select data-field="provider">
                ${providerOptions}
              </select>
            </td>
            <td><input data-field="tracking" type="text" value="${existing?.tracking_number || ''}" placeholder="Nhập mã vận đơn"></td>
            <td>
              <select data-field="status">
                <option value="pending">Chờ lấy hàng</option>
                <option value="picked_up">Đã lấy hàng</option>
                <option value="in_transit">Đang vận chuyển</option>
                <option value="out_for_delivery">Đang giao</option>
                <option value="delivered">Đã giao</option>
                <option value="failed">Thất bại</option>
                <option value="returned">Hoàn hàng</option>
              </select>
            </td>
            <td><input data-field="eta" type="datetime-local" value="${existing?.estimated_delivery ? new Date(existing.estimated_delivery).toISOString().slice(0, 16) : ''}"></td>
            <td><input data-field="location" type="text" value="${existing?.current_location || ''}" placeholder="Bưu cục hiện tại"></td>
            <td><button class="sp-btn-primary" type="button" data-save-order="${order.id}">Lưu</button></td>
          </tr>
        `;
      })
      .join('');

    ordersBodyEl.querySelectorAll<HTMLTableRowElement>('tr[data-order-row]').forEach((row) => {
      const orderId = row.dataset.orderRow || '';
      const existing = trackings.find((tracking) => tracking.order_id === orderId);

      const providerSelect = row.querySelector<HTMLSelectElement>('select[data-field="provider"]');
      const statusSelect = row.querySelector<HTMLSelectElement>('select[data-field="status"]');

      if (providerSelect) providerSelect.value = existing?.provider_code || 'ghtk';
      if (statusSelect) statusSelect.value = existing?.status || 'pending';
    });

    ordersBodyEl.querySelectorAll<HTMLButtonElement>('button[data-save-order]').forEach((button) => {
      button.addEventListener('click', async () => {
        const orderId = button.dataset.saveOrder || '';
        const row = ordersBodyEl.querySelector<HTMLTableRowElement>(`tr[data-order-row="${orderId}"]`);
        if (!row) return;

        const providerCode = row.querySelector<HTMLSelectElement>('select[data-field="provider"]')?.value || '';
        const trackingNumber = row.querySelector<HTMLInputElement>('input[data-field="tracking"]')?.value.trim() || '';
        const status = row.querySelector<HTMLSelectElement>('select[data-field="status"]')?.value || 'pending';
        const etaRaw = row.querySelector<HTMLInputElement>('input[data-field="eta"]')?.value || '';
        const currentLocation = row.querySelector<HTMLInputElement>('input[data-field="location"]')?.value.trim() || '';

        if (!trackingNumber) {
          toast('Cần nhập mã vận đơn trước khi lưu', 'error');
          return;
        }

        button.disabled = true;
        try {
          const payload = {
            orderId,
            providerCode,
            trackingNumber,
            status,
            currentLocation,
            estimatedDelivery: etaRaw ? new Date(etaRaw).toISOString() : null,
          };

          const res = await fetch('/api/admin/shipping/trackings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();

          if (!res.ok || !data.success) {
            throw new Error(data.error || 'Không thể lưu vận đơn');
          }

          toast('Đã cập nhật thông tin vận chuyển');
          await loadDashboard();
        } catch (error: any) {
          toast(error.message || 'Không thể lưu vận đơn', 'error');
        } finally {
          button.disabled = false;
        }
      });
    });
  }

  function renderLogs() {
    if (!trackings.length) {
      logsEl.innerHTML = '<div class="sp-empty">Chưa có lịch sử tracking.</div>';
      return;
    }

    logsEl.innerHTML = trackings
      .slice(0, 12)
      .map((tracking) => {
        const status = trackingStatusLabel[tracking.status] || tracking.status;
        const orderCode = tracking.order?.order_number || 'N/A';
        const provider = providerLabels[tracking.provider_code] || tracking.provider_code;

        return `
          <article class="sp-log-item">
            <div>
              <p class="sp-log-title">#${orderCode} • ${tracking.tracking_number}</p>
              <p class="sp-log-sub">${provider} • ${status}${tracking.current_location ? ` - ${tracking.current_location}` : ''}</p>
            </div>
            <div class="sp-log-time">Cập nhật: ${formatDate(tracking.updated_at)}</div>
          </article>
        `;
      })
      .join('');
  }

  function openProviderModal(providerCode: string) {
    const provider = providers.find((p) => p.provider_code === providerCode);
    if (!provider) return;

    activeProviderCode = providerCode;
    providerModalTitle.textContent = `Cấu hình API - ${provider.provider_name}`;

    const schema = providerFieldSchemas[providerCode] || [
      { key: 'api_url', label: 'API URL' },
      { key: 'api_key', label: 'API Key', type: 'password', placeholder: 'Để trống để giữ key cũ' },
    ];

    const computedWebhookUrl = `${window.location.origin}/api/webhooks/viettel-post`;

    providerForm.innerHTML = schema
      .map((field) => {
        const value = getByPath(provider.config || {}, field.key);
        const inputType = field.type || 'text';
        const displayValue = inputType === 'password'
          ? ''
          : (value ?? (providerCode === 'viettel_post' && field.key === 'webhook_url' ? computedWebhookUrl : ''));
        const actionHtml = field.action === 'generate-secret'
          ? `<button type="button" class="sp-btn-outline sp-inline-btn" data-generate-secret="${field.key}">Gen</button>`
          : '';
        const helpTextHtml = field.helpText ? `<small class="sp-input-help">${field.helpText}</small>` : '';

        return `
          <label class="sp-form-group">
            <span>${field.label}</span>
            <div class="sp-input-row">
              <input
                type="${inputType}"
                data-config-key="${field.key}"
                value="${String(displayValue)}"
                placeholder="${field.placeholder || ''}"
                autocomplete="off"
              >
              ${actionHtml}
            </div>
            ${helpTextHtml}
          </label>
        `;
      })
      .join('');

    providerForm.querySelectorAll<HTMLButtonElement>('button[data-generate-secret]').forEach((button) => {
      button.addEventListener('click', () => {
        const key = button.dataset.generateSecret || '';
        if (!key) return;

        const input = providerForm.querySelector<HTMLInputElement>(`input[data-config-key="${key}"]`);
        if (!input) return;

        input.value = generateSecretHex(24);
        input.focus();
        input.select();
        toast('Đã tạo webhook secret mới, nhớ bấm Lưu cấu hình');
      });
    });

    providerModal.classList.add('open');
    providerModal.setAttribute('aria-hidden', 'false');
    const _sy = window.scrollY;
    providerModal.dataset.scrollY = String(_sy);
    document.body.style.position = 'fixed';
    document.body.style.top = `-${_sy}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.overflow = 'hidden';
  }

  function closeProviderModal() {
    providerModal.classList.remove('open');
    providerModal.setAttribute('aria-hidden', 'true');
    providerForm.innerHTML = '';
    activeProviderCode = '';
    const sy = Number(providerModal.dataset.scrollY || 0);
    document.body.style.removeProperty('position');
    document.body.style.removeProperty('top');
    document.body.style.removeProperty('left');
    document.body.style.removeProperty('right');
    document.body.style.removeProperty('overflow');
    window.scrollTo({ top: sy, behavior: 'instant' });
  }

  async function updateProvider(providerCode: string, patch: { enabled?: boolean; config?: Record<string, any> }) {
    const res = await fetch('/api/admin/shipping/providers', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        providerCode,
        enabled: patch.enabled,
        config: patch.config,
      }),
    });
    const data = await res.json();

    if (!res.ok || !data.success) {
      throw new Error(data.error || 'Không thể cập nhật nhà vận chuyển');
    }

    await loadDashboard();
  }

  document.getElementById('provider-modal-close')?.addEventListener('click', closeProviderModal);
  document.getElementById('provider-modal-cancel')?.addEventListener('click', closeProviderModal);
  document.getElementById('provider-modal-save')?.addEventListener('click', async () => {
    if (!activeProviderCode) return;

    const config: Record<string, any> = {};
    providerForm.querySelectorAll<HTMLInputElement>('input[data-config-key]').forEach((input) => {
      const key = input.dataset.configKey || '';
      if (!key) return;
      setByPath(config, key, input.value);
    });

    const current = providers.find((p) => p.provider_code === activeProviderCode);

    try {
      await updateProvider(activeProviderCode, {
        enabled: current?.enabled,
        config,
      });
      toast('Đã lưu cấu hình API');
      closeProviderModal();
    } catch (error: any) {
      toast(error.message || 'Không thể lưu cấu hình API', 'error');
    }
  });

  providerModal.addEventListener('click', (event) => {
    if (event.target === providerModal) {
      closeProviderModal();
    }
  });

  document.getElementById('btn-refresh')?.addEventListener('click', async () => {
    try {
      await loadDashboard();
      toast('Đã làm mới dữ liệu');
    } catch (error: any) {
      toast(error.message || 'Không thể làm mới dữ liệu', 'error');
    }
  });

  loadDashboard().catch((error) => {
    toast(error.message || 'Không thể tải dữ liệu vận chuyển', 'error');
  });
</script>

