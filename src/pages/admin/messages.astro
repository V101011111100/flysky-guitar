---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const currentYear = new Date().getFullYear();

// Fetch orders
const { data: ordersRaw } = await supabase
  .from('orders')
  .select('*')
  .order('created_at', { ascending: true });

const orders = ordersRaw || [];

const monthlyRevenue = Array(12).fill(0);
let totalRevenueYear = 0;
let totalSalesQty = 0;

const productRev: Record<string, { qty: number, revenue: number, name: string, img: string }> = {};

for (const o of orders as any[]) {
  if (o.status === 'cancelled') continue;
  const created = new Date(o.created_at);
  if (created.getFullYear() === currentYear) {
    const amount = o.total_amount || 0;
    const m = created.getMonth(); // 0 to 11
    monthlyRevenue[m] += amount;
    totalRevenueYear += amount;
    
    // Items
    const items = o.items || [];
    for (const item of items) {
      const pId = item.product_id || item.id;
      if (pId) {
        if (!productRev[pId]) productRev[pId] = { qty: 0, revenue: 0, name: item.name || 'Unknown', img: item.image || '' };
        const q = item.quantity || 1;
        productRev[pId].qty += q;
        productRev[pId].revenue += (item.price || 0) * q;
        totalSalesQty += q;
      }
    }
  }
}

// Data for bar chart
const maxMonth = Math.max(...monthlyRevenue) || 1;
const barData = monthlyRevenue.map(rev => (rev / maxMonth) * 100);
const months = ['Th1','Th2','Th3','Th4','Th5','Th6','Th7','Th8','Th9','Th10','Th11','Th12'];

// Categories Performance
const { data: allProductsRaw } = await supabase
  .from('products')
  .select('id, category_id, categories(name)');

const categoryRev: Record<string, number> = {};
(allProductsRaw || []).forEach((p: any) => {
  if(productRev[p.id]) {
    const catName = p.categories?.name || 'Khác';
    if (!categoryRev[catName]) categoryRev[catName] = 0;
    categoryRev[catName] += productRev[p.id].revenue;
  }
});

const totalCatRev = Object.values(categoryRev).reduce((a, b) => a + b, 0) || 1;
const categories = Object.keys(categoryRev).map(name => ({
  name: name,
  pct: Math.round((categoryRev[name] / totalCatRev) * 100)
})).sort((a,b) => b.pct - a.pct).slice(0, 4);

// Top Products
const topProducts = Object.keys(productRev).map(id => {
  const data = productRev[id];
  const prodInfo = (allProductsRaw || []).find((p:any) => p.id === id);
  const catName = prodInfo?.categories?.name || 'Accessories';
  let catClass = 'cat-acc';
  if (catName.toLowerCase().includes('acoustic')) catClass = 'cat-acou';
  else if (catName.toLowerCase().includes('electric')) catClass = 'cat-elec';
  else if (catName.toLowerCase().includes('bass')) catClass = 'cat-bass';
  
  return {
    name: data.name,
    cat: catName,
    catClass: catClass,
    img: data.img || '',
    qty: data.qty,
    revenue: new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(data.revenue),
    pct: Math.round((data.revenue / totalRevenueYear) * 100) || 0
  };
}).sort((a,b) => b.qty - a.qty).slice(0, 5);

// KPIs
const fmtCurrency = (n: number) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(n);
const validOrdersCount = orders.filter((o:any) => o.status !== 'cancelled' && new Date(o.created_at).getFullYear() === currentYear).length;
const avgOrderValue = validOrdersCount > 0 ? totalRevenueYear / validOrdersCount : 0;
---

<AdminLayout
  title="Báo cáo doanh thu chi tiết theo năm"
  subtitle="Phân tích chuyên sâu về hiệu suất kinh doanh của FlySky"
  activeNav="messages"
>

  <!-- ── FILTER BAR ── -->
  <div class="rpt-filter-bar">
    <div class="year-btns">
      <button class="year-btn">Năm 2023</button>
      <button class="year-btn year-active">Năm 2024</button>
      <button class="year-btn">Năm 2025</button>
    </div>
    <div class="period-switcher">
      <button class="period-btn">Hàng ngày</button>
      <button class="period-btn">Hàng tháng</button>
      <button class="period-btn period-active">Hàng năm</button>
    </div>
    <div class="export-btns">
      <button class="btn-export-pdf">
        <span class="material-symbols-outlined">download</span>
        Tải PDF
      </button>
      <button class="btn-export-excel">
        <span class="material-symbols-outlined">table_chart</span>
        Xuất Excel
      </button>
    </div>
  </div>

  <!-- ── KPI CARDS ── -->
  <div class="kpi-grid">

    <div class="kpi-card">
      <div class="kpi-top">
        <div class="kpi-icon orange"><span class="material-symbols-outlined">payments</span></div>
        <span class="kpi-trend up"><span class="material-symbols-outlined">trending_up</span>Tốt</span>
      </div>
      <p class="kpi-label">Tổng doanh thu năm</p>
      <h3 class="kpi-val">{fmtCurrency(totalRevenueYear)}</h3>
    </div>

    <div class="kpi-card">
      <div class="kpi-top">
        <div class="kpi-icon blue"><span class="material-symbols-outlined">show_chart</span></div>
        <span class="kpi-trend up"><span class="material-symbols-outlined">add</span>--</span>
      </div>
      <p class="kpi-label">Số lượng đơn hàng hoàn tất</p>
      <h3 class="kpi-val">{validOrdersCount} đơn</h3>
    </div>

    <div class="kpi-card">
      <div class="kpi-top">
        <div class="kpi-icon purple"><span class="material-symbols-outlined">shopping_basket</span></div>
        <span class="kpi-trend down"><span class="material-symbols-outlined">trending_flat</span>--</span>
      </div>
      <p class="kpi-label">Giá trị đơn hàng trung bình</p>
      <h3 class="kpi-val">{fmtCurrency(avgOrderValue)}</h3>
    </div>

    <div class="kpi-card">
      <div class="kpi-top">
        <div class="kpi-icon orange-light"><span class="material-symbols-outlined">inventory_2</span></div>
        <span class="kpi-trend up"><span class="material-symbols-outlined">trending_up</span>Tốt</span>
      </div>
      <p class="kpi-label">Tổng sản phẩm đã bán</p>
      <h3 class="kpi-val">{totalSalesQty} chiếc</h3>
    </div>

  </div>

  <!-- ── CHARTS ── -->
  <div class="chart-grid">

    <!-- Bar Chart -->
    <div class="chart-card">
      <div class="chart-header">
        <div>
          <h4 class="chart-title">Biểu đồ doanh thu theo tháng</h4>
          <p class="chart-sub">Dữ liệu doanh thu thực tế trong năm 2024</p>
        </div>
        <select class="unit-select">
          <option>Đơn vị: Triệu VNĐ</option>
          <option>Đơn vị: Tỷ VNĐ</option>
        </select>
      </div>
      <div class="bar-chart-area">
        {barData.map((h, i) => (
          <div class="bar-col">
            <div class={`bar-fill ${i === 11 ? 'bar-highlight' : ''}`} style={`height:${h}%`}></div>
            <span class="bar-label">{months[i]}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Category -->
    <div class="chart-card cat-chart-card">
      <h4 class="chart-title" style="margin-bottom:24px;">Doanh thu theo danh mục</h4>
      <div class="cat-bars">
        {categories.map((c, i) => (
          <div class="cat-item">
            <div class="cat-row">
              <span class="cat-name">{c.name}</span>
              <span class="cat-pct">{c.pct}%</span>
            </div>
            <div class="prog-track">
              <div class="prog-bar" style={`width:${c.pct}%;opacity:${1 - i*0.15}`}></div>
            </div>
          </div>
        ))}
      </div>
      <div class="cat-footer">
        <p class="cat-note">Top categories represent 75% of total wood source usage.</p>
      </div>
    </div>

  </div>

  <!-- ── TOP 5 TABLE ── -->
  <div class="top-card">
    <div class="top-header">
      <h4 class="chart-title">Top 5 Sản phẩm bán chạy nhất</h4>
      <button class="view-all">Xem tất cả</button>
    </div>
    <div style="overflow-x:auto;">
      <table class="top-table">
        <thead>
          <tr>
            <th>Sản phẩm</th>
            <th>Danh mục</th>
            <th>Số lượng đã bán</th>
            <th>Doanh thu</th>
            <th>Tỷ trọng</th>
          </tr>
        </thead>
        <tbody>
          {topProducts.map(p => (
            <tr>
              <td>
                <div class="prod-cell">
                  <div class="prod-img">
                    {p.img ? <img src={p.img} alt={p.name} /> : <div style="display:flex;align-items:center;justify-content:center;height:100%;"><span class="material-symbols-outlined" style="color:#64748b;font-size:20px;">image</span></div>}
                  </div>
                  <span class="prod-name">{p.name}</span>
                </div>
              </td>
              <td><span class={`cat-chip ${p.catClass}`}>{p.cat}</span></td>
              <td class="qty-col">{p.qty}</td>
              <td class="rev-col">{p.revenue}</td>
              <td>
                <div class="ratio-cell">
                  <div class="ratio-bar">
                    <div class="ratio-fill" style={`width:${p.pct}%`}></div>
                  </div>
                  <span class="ratio-txt">{p.pct}%</span>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Footer -->
  <footer class="rpt-footer">
    © 2024 FlySky Guitar Studio &amp; Wood. All rights reserved. Design for premium guitar manufacturers.
  </footer>

</AdminLayout>

<style>
  /* ── FILTER BAR ── */
  .rpt-filter-bar {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .year-btns { display: flex; gap: 8px; }
  .year-btn {
    padding: 8px 16px; border-radius: 8px;
    background: rgba(30,41,59,.6); border: 1px solid #334155;
    color: #94a3b8; font-size: 13px; font-weight: 600;
    font-family: 'Manrope', sans-serif; cursor: pointer;
    transition: border-color .15s;
  }
  .year-btn:hover { border-color: rgba(244,140,37,.4); }
  .year-active { background: #f48c25; color: #221910; font-weight: 700; border-color: #f48c25; }
  .period-switcher {
    display: flex;
    background: rgba(30,41,59,.5);
    border: 1px solid #334155;
    border-radius: 8px; padding: 4px; margin-left: auto;
  }
  .period-btn {
    padding: 6px 14px; border-radius: 6px;
    background: none; border: none; cursor: pointer;
    font-size: 12px; font-weight: 700; color: #94a3b8;
    font-family: 'Manrope', sans-serif; transition: all .15s;
  }
  .period-btn:hover { color: #f1f5f9; }
  .period-active { background: #f48c25; color: #221910; box-shadow: 0 4px 12px rgba(244,140,37,.3); }
  .export-btns { display: flex; gap: 8px; }
  .btn-export-pdf {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: 8px;
    background: rgba(30,41,59,.6); border: 1px solid #334155;
    color: #f1f5f9; font-size: 13px; font-weight: 700;
    font-family: 'Manrope', sans-serif; cursor: pointer; transition: background .15s;
  }
  .btn-export-pdf:hover { background: rgba(51,65,85,.8); }
  .btn-export-pdf .material-symbols-outlined { font-size: 18px; }
  .btn-export-excel {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: 8px;
    background: rgba(244,140,37,.1); border: 1px solid rgba(244,140,37,.2);
    color: #f48c25; font-size: 13px; font-weight: 700;
    font-family: 'Manrope', sans-serif; cursor: pointer; transition: background .15s;
  }
  .btn-export-excel:hover { background: rgba(244,140,37,.2); }
  .btn-export-excel .material-symbols-outlined { font-size: 18px; }

  /* ── KPI ── */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 28px;
  }
  .kpi-card {
    background: rgba(30,41,59,.35);
    border: 1px solid rgba(51,65,85,.5);
    border-radius: 12px; padding: 24px;
    transition: border-color .2s;
  }
  .kpi-card:hover { border-color: rgba(244,140,37,.3); }
  .kpi-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
  .kpi-icon { width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
  .kpi-icon .material-symbols-outlined { font-size: 20px; }
  .kpi-icon.orange       { background: rgba(244,140,37,.1); color: #f48c25; }
  .kpi-icon.blue         { background: rgba(59,130,246,.1); color: #60a5fa; }
  .kpi-icon.purple       { background: rgba(168,85,247,.1); color: #c084fc; }
  .kpi-icon.orange-light { background: rgba(249,115,22,.1); color: #fb923c; }
  .kpi-trend {
    font-size: 11px; font-weight: 700;
    display: flex; align-items: center; gap: 2px;
  }
  .kpi-trend .material-symbols-outlined { font-size: 14px; }
  .kpi-trend.up   { color: #34d399; }
  .kpi-trend.down { color: #f87171; }
  .kpi-label { font-size: 13px; color: #94a3b8; font-weight: 500; margin-bottom: 4px; }
  .kpi-val   { font-size: 22px; font-weight: 900; color: #f9fafb; }

  /* ── CHARTS GRID ── */
  .chart-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 24px;
    margin-bottom: 28px;
    align-items: start;
  }
  .chart-card {
    background: rgba(30,41,59,.35);
    border: 1px solid rgba(51,65,85,.5);
    border-radius: 12px; padding: 28px;
  }
  .chart-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 28px;
  }
  .chart-title { font-size: 16px; font-weight: 800; color: #f9fafb; }
  .chart-sub   { font-size: 11px; color: #94a3b8; margin-top: 4px; }
  .unit-select {
    background: rgba(15,23,42,.8); border: none;
    color: #94a3b8; font-size: 12px; font-weight: 700;
    border-radius: 8px; padding: 6px 12px; cursor: pointer;
    font-family: 'Manrope', sans-serif; outline: none;
  }

  /* Bar chart */
  .bar-chart-area {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    height: 280px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(51,65,85,.5);
    gap: 6px;
  }
  .bar-col {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: flex-end; height: 100%;
    position: relative;
  }
  .bar-fill {
    width: 100%;
    background: rgba(244,140,37,.25);
    border-radius: 4px 4px 0 0;
    transition: background .2s;
    position: relative; overflow: hidden;
  }
  .bar-fill::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 50%;
    background: rgba(244,140,37,.4);
  }
  .bar-fill.bar-highlight { background: rgba(244,140,37,.45); }
  .bar-fill.bar-highlight::after { background: #f48c25; }
  .bar-col:hover .bar-fill { background: rgba(244,140,37,.4); }
  .bar-label {
    position: absolute; bottom: -22px;
    font-size: 9px; font-weight: 700;
    color: #64748b; text-transform: uppercase; white-space: nowrap;
  }

  /* Category bars */
  .cat-chart-card { display: flex; flex-direction: column; }
  .cat-bars { display: flex; flex-direction: column; gap: 20px; }
  .cat-item { }
  .cat-row { display: flex; justify-content: space-between; margin-bottom: 8px; }
  .cat-name { font-size: 12px; font-weight: 700; color: #cbd5e1; }
  .cat-pct  { font-size: 12px; font-weight: 700; color: #f48c25; }
  .prog-track {
    width: 100%; height: 8px;
    background: #334155; border-radius: 999px; overflow: hidden;
  }
  .prog-bar {
    height: 100%; background: #f48c25; border-radius: 999px;
    box-shadow: 0 0 8px rgba(244,140,37,.4);
  }
  .cat-footer {
    margin-top: 24px; padding-top: 24px;
    border-top: 1px solid rgba(51,65,85,.5);
  }
  .cat-note { font-size: 11px; color: #64748b; }

  /* ── TOP TABLE ── */
  .top-card {
    background: rgba(30,41,59,.35);
    border: 1px solid rgba(51,65,85,.5);
    border-radius: 12px; overflow: hidden;
    margin-bottom: 8px;
  }
  .top-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 24px; border-bottom: 1px solid rgba(51,65,85,.5);
  }
  .view-all {
    font-size: 12px; font-weight: 700; color: #f48c25;
    background: none; border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
  }
  .view-all:hover { text-decoration: underline; }

  .top-table { width: 100%; border-collapse: collapse; text-align: left; }
  .top-table thead { background: rgba(15,23,42,.5); }
  .top-table th {
    padding: 14px 24px;
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .1em;
    color: #64748b; white-space: nowrap;
  }
  .top-table tbody tr { border-top: 1px solid rgba(51,65,85,.3); transition: background .15s; }
  .top-table tbody tr:hover { background: rgba(51,65,85,.2); }
  .top-table td { padding: 16px 24px; vertical-align: middle; }

  .prod-cell { display: flex; align-items: center; gap: 12px; }
  .prod-img  {
    width: 40px; height: 40px; border-radius: 6px;
    background: #334155; overflow: hidden; flex-shrink: 0;
  }
  .prod-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-name { font-size: 13.5px; font-weight: 700; color: #f9fafb; }

  .cat-chip {
    display: inline-block; padding: 3px 8px; border-radius: 4px;
    font-size: 10px; font-weight: 700; text-transform: uppercase;
  }
