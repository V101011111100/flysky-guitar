---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const { data: settingsData } = await supabase.from('site_settings').select('key, value');
const siteConfig = settingsData?.reduce((acc: any, row: any) => ({ ...acc, [row.key]: row.value }), {}) || {};
const globalStoreName = siteConfig['flysky_storeName'] || 'FlySky Guitar';
---

<AdminLayout title="Mẫu thông báo & In ấn" subtitle="Quản lý Hóa đơn, Email" activeNav="newsletter">
  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: #4a3a2a; border-radius: 10px; }
      .btn-orange-gradient { background: linear-gradient(135deg, #e67e22 0%, #d35400 100%); }
      .variable-chip { cursor: pointer; display: inline-block; background: #2d241e; border: 1px solid #e67e22; color: #e67e22; border-radius: 4px; padding: 2px 7px; font-size: 11px; font-family: monospace; margin: 2px; transition: all .15s; }
      .variable-chip:hover { background: #e67e22; color: white; }
    </style>
  </Fragment>

  <script is:inline define:vars={{ globalStoreName }}>
    window.GLOBAL_STORE_NAME = globalStoreName;
  </script>

  <script is:inline>
    document.addEventListener('alpine:init', () => {
      Alpine.data('templateEditor', () => ({
        
        getStoreName() {
          return window.GLOBAL_STORE_NAME || 'FlySky Guitar';
        },
        
        getStoreLogo() {
          return localStorage.getItem('flysky_custom_logo') || '/logo.svg';
        },

        activeTab: 'invoice_a4',
        tabs: [
          { id: 'invoice_a4', label: 'Hóa đơn A4', icon: 'receipt_long' },
          { id: 'invoice_thermal', label: 'Phiếu in nhiệt', icon: 'receipt' },
          { id: 'email_order_confirm', label: 'Email đơn hàng', icon: 'mark_email_read' },
          { id: 'email_shipping', label: 'Email vận chuyển', icon: 'local_shipping' },
          { id: 'email_survey', label: 'Email khảo sát', icon: 'rate_review' },
          { id: 'email_custom', label: 'Bản tin Marketing', icon: 'campaign' },
        ],

        // --- MOCK DATA for preview ---
        mock: {
          customer_name: 'Nguyễn Văn An',
          customer_phone: '0987 654 321',
          customer_address: '456 Lê Lợi, TP. Hồ Chí Minh',
          order_id: 'FSG-260319-1234',
          order_date: '19/03/2026',
          order_time: '15:30',
          product_name: 'Guitar Acoustic Classic Wood',
          product_image: 'https://images.unsplash.com/photo-1510915361894-db8b60106cb1?w=80&h=80&fit=crop',
          product_qty: 1,
          product_price: '12.000.000đ',
          total: '12.000.000đ',
          payment_method: 'Tiền mặt',
        },

        // Available variables per template type
        varGroups: {
          invoice_a4: [
            { label: 'Khách hàng', vars: ['customer_name', 'customer_phone'] },
            { label: 'Đơn hàng', vars: ['order_id', 'order_date', 'total'] },
          ],
          invoice_thermal: [
            { label: 'Khách hàng', vars: ['customer_name', 'customer_phone'] },
            { label: 'Đơn hàng', vars: ['order_id', 'order_date', 'order_time', 'total', 'payment_method'] },
          ],
          email_order_confirm: [
            { label: 'Khách hàng', vars: ['customer_name', 'customer_phone'] },
            { label: 'Sản phẩm', vars: ['product_name', 'product_price', 'product_qty'] },
            { label: 'Đơn hàng', vars: ['order_id', 'order_date', 'total'] },
          ],
          email_shipping: [
            { label: 'Khách hàng', vars: ['customer_name', 'customer_phone'] },
            { label: 'Đơn hàng', vars: ['order_id', 'order_date', 'product_name'] },
            { label: 'Vận chuyển', vars: ['shipping_unit', 'tracking_code', 'delivery_eta'] },
          ],
          email_survey: [
            { label: 'Khách hàng', vars: ['customer_name'] },
            { label: 'Sản phẩm', vars: ['product_name', 'order_id'] },
          ],
          email_custom: [
            { label: 'Khách hàng', vars: ['customer_name', 'customer_phone'] },
            { label: 'Cửa hàng', vars: ['store_name', 'store_phone'] },
          ],
        },

        templates: [],
        currentTemplateId: null,
        currentTemplateName: 'Mẫu Mới',
        settings: {},
        saving: false,
        loading: false,
        showVars: false,

        init() {
          this.$watch('activeTab', () => { this.fetchTemplates(); });
          this.fetchTemplates();
        },

        defaultSettings(type) {
          if (type === 'invoice_a4' || type === 'invoice_thermal') {
            return {
              invoice_store_name: 'FLYSKY GUITAR',
              invoice_slogan: 'Âm thanh từ tâm hồn - Chất lượng từ đam mê',
              invoice_address: 'Số 123 Đường Nhạc Cụ, Quận 1, TP. HCM',
              invoice_phone: 'Hotline: 090 123 4567',
              invoice_website: 'Website: www.flyskyguitar.vn',
              invoice_policy: 'Sản phẩm được đổi trả trong vòng 07 ngày nếu có lỗi từ nhà sản xuất.\nVui lòng giữ nguyên hóa đơn và tem bảo hành khi cần hỗ trợ.\nKhông áp dụng đổi trả với hàng đã qua sử dụng làm trầy xước.',
              invoice_footer_msg: 'Cảm ơn quý khách đã tin tưởng FlySky Guitar!',
            };
          }
          if (type === 'email_order_confirm') {
            return {
              email_store_name: 'FlySky Guitar',
              email_support_phone: '1900 123 456',
              email_store_address: '123 Đường Nhạc Cụ, Quận 1, TP. Hồ Chí Minh',
              email_store_hours: '08:00 - 21:00 hàng ngày',
              email_subject: 'Cảm ơn {{customer_name}} đã mua hàng tại FlySky Guitar!',
              email_hero_title: 'Cảm ơn bạn đã tin chọn FlySky Guitar',
              email_greeting: 'Chào bạn {{customer_name}}!',
              email_body: 'Chúng tôi hy vọng bạn đang tận hưởng cây đàn mới của mình. Ý kiến của bạn rất quan trọng để chúng tôi hoàn thiện dịch vụ và sản phẩm hơn nữa.',
              email_cta_primary: 'Gửi đánh giá nhanh',
              email_cta_secondary: 'Viết nhận xét chi tiết',
              email_warranty_text: 'Bảo hành tận tâm',
              email_warranty_sub: 'Chính sách 24 tháng',
            };
          }
          if (type === 'email_shipping') {
            return {
              email_store_name: 'FlySky Guitar',
              email_subject: 'Đơn hàng {{order_id}} của bạn đang trên đường đến!',
              email_hero_title: 'Đơn hàng của bạn đang trên đường đến!',
              email_hero_subtitle: 'Tin vui! Đơn hàng của bạn đã được đóng gói cẩn thận và bàn giao cho đơn vị vận chuyển.',
              email_shipping_unit: 'GIAO HÀNG NHANH (GHN)',
              email_status_text: 'Trạng thái: Đang vận chuyển',
              email_eta_text: 'Dự kiến giao: 2-3 ngày làm việc',
              email_cta: 'Theo dõi đơn hàng',
              email_admin_note: '* Admin của FlySky sẽ sớm liên hệ với bạn để tư vấn thêm về việc bảo quản đàn trong suốt hành trình.',
              email_support_phone: '1900 xxxx',
              email_support_email: 'contact@flyskyguitar.com',
              email_store_address: '456 Đường Giai Điệu, Quận 3, TP. Hồ Chí Minh',
              email_store_name_footer: 'FlySky Guitar Showroom',
            };
          }
          if (type === 'email_survey') {
            return {
              email_store_name: 'FlySky Guitar',
              email_subject: 'Bạn đánh giá thế nào về trải nghiệm tại FlySky Guitar?',
              email_hero_title: 'Ý kiến của bạn giúp chúng tôi tốt hơn',
              email_greeting: 'Xin chào {{customer_name}}!',
              email_body: 'Cảm ơn bạn đã ghé thăm FlySky Guitar. Chúng tôi luôn muốn cải thiện dịch vụ và sản phẩm. Bạn có thể dành vài phút để chia sẻ trải nghiệm không?',
              email_cta_primary: 'Đánh giá ngay',
              email_cta_secondary: 'Xem ưu đãi mới nhất',
              email_support_phone: '1900 123 456',
              email_store_address: '123 Đường Nhạc Cụ, Quận 1, TP. Hồ Chí Minh',
            };
          }
          if (type === 'email_custom') {
            return {
              email_store_name: 'FlySky Guitar',
              email_subject: 'Chào {{customer_name}}, FlySky có thông báo mới!',
              email_hero_title: 'Tin tức từ FlySky Guitar',
              email_greeting: 'Xin chào {{customer_name}}!',
              email_body: 'Nhập nội dung chương trình khuyến mãi hoặc thông báo của bạn tại đây...',
              email_cta_primary: 'Đến cửa hàng ngay',
              email_support_phone: '1900 123 456',
              email_store_address: '123 Đường Nhạc Cụ, Quận 1, TP. Hồ Chí Minh',
            };
          }
          return {};
        },

        async fetchTemplates() {
          this.loading = true;
          try {
            const res = await fetch(`/api/get-templates?type=${this.activeTab}`);
            const data = await res.json();
            this.templates = data.templates || [];
            if (this.templates.length > 0) {
              const active = this.templates.find(t => t.is_active) || this.templates[0];
              this.loadTemplateToEditor(active);
            } else {
              this.createNewTemplate();
            }
          } catch (e) { console.error('Lấy list mẫu lỗi', e); }
          this.loading = false;
        },

        loadTemplateToEditor(tpl) {
          this.currentTemplateId = tpl.id;
          this.currentTemplateName = tpl.name;
          this.settings = JSON.parse(JSON.stringify(tpl.settings || this.defaultSettings(this.activeTab)));
        },

        createNewTemplate() {
          this.currentTemplateId = null;
          this.currentTemplateName = 'Mẫu Mới';
          this.settings = this.defaultSettings(this.activeTab);
        },

        async saveTemplate() {
          if (!this.currentTemplateName.trim()) return alert('Vui lòng nhập tên mẫu!');
          this.saving = true;
          try {
            const body = {
              id: this.currentTemplateId,
              name: this.currentTemplateName,
              type: this.activeTab,
              settings: this.settings,
            };
            if (!this.currentTemplateId && this.templates.length === 0) body.is_active = true;

            const res = await fetch('/api/get-templates', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body)
            });
            const data = await res.json();
            if (res.ok) {
              alert('Đã lưu mẫu thành công!');
              await this.fetchTemplates();
              if (data.template) this.currentTemplateId = data.template.id;
            } else { alert('Lỗi: ' + data.error); }
          } catch (e) { alert('Lỗi: ' + e.message); }
          this.saving = false;
        },

        async setActiveTemplate(id) {
          if (!confirm('Đặt làm mẫu mặc định?')) return;
          const res = await fetch('/api/templates/set-active', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, type: this.activeTab })
          });
          if (res.ok) await this.fetchTemplates();
        },

        async deleteTemplate(id) {
          if (!confirm('Chắc chắn muốn xóa?')) return;
          const res = await fetch(`/api/templates/${id}`, { method: 'DELETE' });
          if (res.ok) {
            if (this.currentTemplateId === id) this.createNewTemplate();
            await this.fetchTemplates();
          }
        },

        // Replace {{var}} tokens with mock data for preview
        preview(text) {
          if (!text) return '';
          let out = text;
          for (const [key, val] of Object.entries(this.mock)) {
            out = out.replaceAll(`{{${key}}}`, `<span class="bg-amber-100 text-amber-800 rounded px-0.5 font-semibold">${val}</span>`);
          }
          return out.replace(/\n/g, '<br/>');
        },

        // Insert variable token at active input position
        insertVar(varName) {
          const token = `{{${varName}}}`;
          const el = document.activeElement;
          if (el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA')) {
            const key = el.getAttribute('x-bind:id') || el.id;
            const start = el.selectionStart;
            const end = el.selectionEnd;
            el.value = el.value.slice(0, start) + token + el.value.slice(end);
            el.dispatchEvent(new Event('input'));
            el.setSelectionRange(start + token.length, start + token.length);
          } else {
            navigator.clipboard.writeText(token).then(() => {
              alert(`Đã copy token: ${token}\nDán (Ctrl+V) vào ô muốn điền.`);
            });
          }
        },

        formatHtml(text) {
          if (!text) return '';
          return text.replace(/\n/g, '<br/>');
        },

        getInvoicePolicies() {
          if (!this.settings.invoice_policy) return [];
          return this.settings.invoice_policy.split(/\r?\n/).filter(p => p.trim() !== '');
        }
      }));
    });
  </script>

  <div class="h-full flex text-slate-100 bg-[#221910] overflow-hidden" x-data="templateEditor()">

    <!-- LEFT SIDEBAR -->
    <aside class="w-80 bg-[#1a1412] border-r border-[#3a2a1c] flex flex-col overflow-hidden shrink-0">

      <!-- Template Type Tabs -->
      <div class="p-5 border-b border-[#3a2a1c] bg-[#2d2218] shrink-0">
        <p class="text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-3">Loại mẫu thiết kế</p>
        <div class="flex flex-col gap-1.5">
          <template x-for="tab in tabs" :key="tab.id">
            <button @click="activeTab = tab.id"
              :class="activeTab === tab.id ? 'bg-[#e67e22]/20 text-[#e67e22] border-[#e67e22]' : 'border-transparent text-slate-400 hover:bg-[#3a2a1c] hover:text-white'"
              class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-semibold border transition-all text-left">
              <span class="material-symbols-outlined text-lg" x-text="tab.icon"></span>
              <span x-text="tab.label"></span>
            </button>
          </template>
        </div>
      </div>

      <!-- Saved Templates List -->
      <div class="p-4 border-b border-[#3a2a1c] shrink-0">
        <div class="flex justify-between items-center mb-2">
          <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Danh sách mẫu lưu</span>
          <button @click="createNewTemplate()" class="text-[#e67e22] text-xs font-bold hover:underline flex items-center gap-1">
            <span class="material-symbols-outlined text-[13px]">add_circle</span> Mẫu mới
          </button>
        </div>
        <div x-show="loading" class="text-xs text-slate-500 italic py-1">Đang tải...</div>
        <div class="flex flex-col gap-1.5 max-h-36 overflow-y-auto" x-show="!loading">
          <template x-for="tpl in templates" :key="tpl.id">
            <div class="flex items-center justify-between bg-[#2d241e] rounded px-2.5 py-2 border"
                 :class="tpl.id === currentTemplateId ? 'border-[#e67e22]/60' : 'border-transparent'">
              <div class="flex items-center gap-1.5 cursor-pointer flex-1 min-w-0" @click="loadTemplateToEditor(tpl)">
                <span class="material-symbols-outlined text-[13px]" :class="tpl.id === currentTemplateId ? 'text-[#e67e22]' : 'text-slate-600'">edit_document</span>
                <span class="text-xs truncate" :class="tpl.id === currentTemplateId ? 'text-white font-bold' : 'text-slate-400'" x-text="tpl.name"></span>
                <span x-show="tpl.is_active" class="shrink-0 px-1 rounded bg-green-500/20 text-green-400 text-[9px] uppercase font-bold">Mặc định</span>
              </div>
              <div class="flex shrink-0 opacity-50 hover:opacity-100">
                <button x-show="!tpl.is_active" @click="setActiveTemplate(tpl.id)" title="Đặt mặc định" class="text-slate-500 hover:text-green-400 p-0.5"><span class="material-symbols-outlined text-[13px]">check_circle</span></button>
                <button x-show="!tpl.is_active" @click="deleteTemplate(tpl.id)" title="Xóa" class="text-slate-500 hover:text-red-400 p-0.5"><span class="material-symbols-outlined text-[13px]">delete</span></button>
              </div>
            </div>
          </template>
          <div x-show="templates.length === 0 && !loading" class="text-xs text-slate-500 italic py-1">Chưa có mẫu.</div>
        </div>
      </div>

      <!-- Config Form -->
      <div class="flex-1 overflow-y-auto p-5 space-y-4">

        <div>
          <label class="block text-[10px] uppercase tracking-widest text-[#e67e22] font-bold mb-1">Tên Mẫu</label>
          <input type="text" x-model="currentTemplateName" class="w-full bg-transparent font-bold text-base border-b-2 border-[#e67e22] pb-1 text-white focus:outline-none">
        </div>

        <!-- A4 / Thermal shared store fields -->
        <template x-if="activeTab === 'invoice_a4' || activeTab === 'invoice_thermal'">
          <div class="space-y-3">
            <p class="text-[10px] text-slate-500 uppercase tracking-widest">Thông tin cửa hàng</p>
            <div>
              <label class="block text-xs text-slate-400 mb-1">Câu slogan</label>
              <input type="text" x-model="settings.invoice_slogan" class="w-full bg-[#2d241e] border border-[#3a2a1c] rounded px-2.5 py-1.5 text-sm text-white focus:border-[#e67e22] outline-none">
            </div>
            <div>
              <label class="block text-xs text-slate-400 mb-1">Địa chỉ</label>
              <textarea rows="2" x-model="settings.invoice_address" class="w-full bg-[#2d241e] border border-[#3a2a1c] rounded px-2.5 py-1.5 text-sm text-white focus:border-[#e67e22] outline-none resize-none"></textarea>
            </div>
            <div>
              <label class="block text-xs text-slate-400 mb-1">Hotline</label>
              <input type="text" x-model="settings.invoice_phone" class="w-full bg-[#2d241e] border border-[#3a2a1c] rounded px-2.5 py-1.5 text-sm text-white focus:border-[#e67e22] outline-none">
            </div>
            <div>
              <label class="block text-xs text-slate-400 mb-1">Website</label>
              <input type="text" x-model="settings.invoice_website" class="w-full bg-[#2d241e] border border-[#3a2a1c] rounded px-2.5 py-1.5 text-sm text-white focus:border-[#e67e22] outline-none">
            </div>
            <template x-if="activeTab === 'invoice_a4'">
              <div>
                <label class="block text-xs text-slate-400 mb-1">Chính sách đổi trả</label>
                <textarea rows="3" x-model="settings.invoice_policy" class="w-full bg-[#2d241e] border border-[#3a2a1c] rounded px-2.5 py-1.5 text-sm text-white focus:border-[#e67e22] outline-none resize-none"></textarea>
                <p class="text-[10px] text-slate-600 mt-0.5">Xuống dòng để tách mục.</p>
              </div>
            </template>
            <div>
              <label class="block text-xs text-slate-400 mb-1">Lời cảm ơn cuối phiếu</label>
              <input type="text" x-model="settings.invoice_footer_msg" class="w-full bg-[#2d241e] border border-[#3a2a1c] rounded px-2.5 py-1.5 text-sm text-white focus:border-[#e67e22] outline-none">
            </div>
          </div>
        </template>

        <!-- Email Order Confirmation Fields -->
        <template x-if="activeTab === 'email_order_confirm'">
          <div class="space-y-3">
            <p class="text-[10px] text-slate-500 uppercase tracking-widest">Nội dung Email</p>

            <!-- Variable strip -->
            <div class="bg-[#2d241e] rounded p-2.5 border border-[#3a2a1c]">
              <p class="text-[10px] text-slate-500 mb-2">Click chip để copy rồi dán vào ô văn bản 👇</p>
              <template x-for="grp in (varGroups[activeTab] || [])">
                <div class="mb-1.5">
                  <span class="text-[9px] text-slate-600 uppercase tracking-wider" x-text="grp.label"></span>
                  <div>
                    <template x-for="v in grp.vars">
                      <span class="variable-chip" x-text="'{{' + v + '}}'" @click="insertVar(v)"></span>
                    </template>
                  </div>
                </div>
              </template>
            </div>

            <div>
              <label class="block text-xs text-slate-400 mb-1">Tiêu đề Email (Subject)</label>
              <input type="text" id="field_subject" x-model="settings.email_subject" class="w-full bg-[#2d241e] border border-[#3a2a1c] rounded px-2.5 py-1.5 text-sm text-white focus:border-[#e67e22] outline-none">
            </div>
            <div>
              <label class="block text-xs text-slate-400 mb-1">Tiêu đề ảnh banner</label>
              <input type="text" id="field_hero_title" x-model="settings.email_hero_title" class="w-full bg-[#2d241e] border border-[#3a2a1c] rounded px-2.5 py-1.5 text-sm text-white focus:border-[#e67e22] outline-none">
            </div>
            <div>
              <label class="block text-xs text-slate-400 mb-1">Lời chào</label>
              <input type="text" id="field_greeting" x-model="settings.email_greeting" class="w-full bg-[#2d241e] border border-[#3a2a1c] rounded px-2.5 py-1.5 text-sm text-white focus:border-[#e67e22] outline-none">
            </div>
            <div>
              <label class="block text-xs text-slate-400 mb-1">Đoạn văn chính</label>
              <textarea rows="3" id="field_body" x-model="settings.email_body" class="w-full bg-[#2d241e] border border-[#3a2a1c] rounded px-2.5 py-1.5 text-sm text-white focus:border-[#e67e22] outline-none resize-none"></textarea>
            </div>
            <div>
              <label class="block text-xs text-slate-400 mb-1">Nút hành động chính</label>
