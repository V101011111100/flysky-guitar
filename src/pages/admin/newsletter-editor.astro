  <title>Trình chỉnh sửa bản tin | FlySky Admin</title>

  <!-- Global styles (including Tailwind preflight and utilities) -->
  <link rel="stylesheet" href="/src/styles/global.css" />

  <!-- Google Fonts: Manrope -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Material Symbols -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <style>
    /* 
      We map specific colors from the target design to CSS variables,
      using Tailwind's arbitrary values or existing variables where possible.
    */
    :root {
      --color-primary-hex: #f48c25;
      --color-bg-light: #f8f7f5;
      --color-bg-dark: #221910;
    }

    body { 
      font-family: 'Manrope', sans-serif; /* Aligning with the Admin standard */
      background-color: var(--color-bg-dark);
      color: #f1f5f9;
      margin: 0; 
      padding: 0;
    }

    /* Custom Scrollbar for the builder areas */
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #493622; border-radius: 10px; }
    
    .wood-gradient {
      background: linear-gradient(135deg, #342618 0%, #221910 100%);
    }

    /* Utility mappings to cover some of the missing Tailwind arbitrary values if needed */
    .text-primary-custom { color: #f48c25; }
    .bg-primary-custom { background-color: #f48c25; }
    .bg-primary-5 { background-color: rgba(244, 140, 37, 0.05); }
    .bg-primary-10 { background-color: rgba(244, 140, 37, 0.1); }
    .bg-primary-20 { background-color: rgba(244, 140, 37, 0.2); }
    .bg-primary-30 { background-color: rgba(244, 140, 37, 0.3); }
    
    .border-primary-10 { border-color: rgba(244, 140, 37, 0.1); }
    .border-primary-20 { border-color: rgba(244, 140, 37, 0.2); }
    .border-primary-30 { border-color: rgba(244, 140, 37, 0.3); }

    .hover\:bg-primary-10:hover { background-color: rgba(244, 140, 37, 0.1); }
    
    .text-background-dark { color: #221910; }
    .bg-background-dark { background-color: #221910; }
    
    .ring-primary-40 { --tw-ring-color: rgba(244, 140, 37, 0.4); }
  </style>
</head>

<body class="h-screen w-screen overflow-hidden flex flex-col font-sans">
  <div class="flex h-screen overflow-hidden w-full">
