                <button class="w-full border border-gray-300 text-gray-700 py-3 rounded-lg text-sm font-medium" x-text="settings.email_cta_secondary"></button>
              </div>

              <!-- Support row -->
              <div class="grid grid-cols-2 gap-4 mt-6 text-[11px] text-gray-600">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-[#e67e22] text-[18px]">headset_mic</span>
                  <div>
                    <p class="font-bold text-gray-800">Hỗ trợ kỹ thuật</p>
                    <p x-text="settings.email_support_phone"></p>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-[#e67e22] text-[18px]">local_shipping</span>
                  <div>
                    <p class="font-bold text-gray-800" x-text="settings.email_warranty_text"></p>
                    <p x-text="settings.email_warranty_sub"></p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Email Footer -->
            <div class="bg-[#1e293b] text-gray-400 px-6 py-8 text-center text-[11px]">
              <div class="flex justify-center gap-4 mb-4">
                <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20"><span class="material-symbols-outlined text-[15px] text-white">language</span></a>
                <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20"><span class="material-symbols-outlined text-[15px] text-white">share</span></a>
                <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20"><span class="material-symbols-outlined text-[15px] text-white">email</span></a>
              </div>
              <p class="font-bold text-white text-sm" x-text="getStoreName() + ' Showroom'"></p>
              <p class="mt-1" x-text="settings.email_store_address"></p>
              <p class="mt-0.5" x-text="'Mở cửa: ' + settings.email_store_hours"></p>
              <div class="border-t border-white/10 mt-5 pt-4 flex justify-between text-[10px] text-gray-600">
                <span>© 2026 FLYSKY GUITAR</span>
                <div class="flex gap-4">
                  <a href="#" class="hover:text-white">Chính sách</a>
                  <a href="#" class="hover:text-white">Hủy đăng ký</a>
                </div>
              </div>
            </div>
          </div>
        </template>
        <!-- PREVIEW: Email Custom (Bản tin Marketing) -->
        <template x-if="activeTab === 'email_custom'">
          <div class="w-full max-w-[500px] shadow-2xl rounded overflow-hidden border border-gray-300 bg-white text-[#1e293b] text-sm" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
            
            <div class="bg-gray-50 border-b border-gray-200 flex items-center justify-center px-5 py-4">
              <div class="flex flex-col items-center">
                <img :src="getStoreLogo()" alt="Logo" class="w-12 h-12 object-contain mb-1">
                <span class="font-bold text-[#1e293b] text-[15px] uppercase tracking-wider" x-text="getStoreName()"></span>
              </div>
            </div>

            <!-- Hero Banner -->
            <div class="relative h-48 bg-gray-900 flex items-center justify-center text-center p-6">
              <img src="https://images.unsplash.com/photo-1525201548942-d8732f6617a0?w=600&q=80" alt="Music" class="absolute inset-0 w-full h-full object-cover opacity-40">
              <div class="relative z-10 w-full">
                <h2 class="text-white text-2xl font-black leading-tight drop-shadow-md" x-text="settings.email_hero_title"></h2>
              </div>
            </div>

            <!-- Main Content -->
            <div class="px-8 py-10 bg-white">
              <h3 class="text-lg font-bold mb-4 text-[#e67e22]" x-html="preview(settings.email_greeting)"></h3>
              <p class="text-gray-700 leading-relaxed text-[15px]" x-html="formatHtml(preview(settings.email_body))"></p>
              
              <div class="mt-8 text-center" x-show="settings.email_cta_primary">
                <a href="#" class="inline-block bg-[#e67e22] text-white font-bold py-3.5 px-8 rounded-lg text-sm shadow-md hover:bg-[#d35400] transition-colors" x-text="settings.email_cta_primary"></a>
              </div>
            </div>

            <!-- Footer -->
            <div class="bg-gray-50 border-t border-gray-200 px-8 py-6 text-center">
              <p class="font-bold text-[#1e293b] text-[13px] mb-1" x-text="getStoreName()"></p>
              <p class="text-gray-500 text-[11px] mb-1" x-text="settings.email_store_address"></p>
              <p class="text-gray-500 text-[11px]">Hỗ trợ: <span class="font-medium" x-text="settings.email_support_phone"></span></p>
              
              <div class="mt-4 flex justify-center gap-3 opacity-60">
                <div class="w-6 h-6 rounded-full bg-blue-600 text-white flex items-center justify-center text-[10px]">f</div>
                <div class="w-6 h-6 rounded-full bg-sky-500 text-white flex items-center justify-center text-[10px]">t</div>
                <div class="w-6 h-6 rounded-full bg-pink-600 text-white flex items-center justify-center text-[10px]">ig</div>
              </div>
            </div>

          </div>
        </template>

        <!-- PREVIEW: Email Shipping -->
        <template x-if="activeTab === 'email_shipping'">
          <div class="w-full max-w-[480px] shadow-2xl rounded overflow-hidden border border-gray-300 bg-white text-[#1e293b] text-sm" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
            
            <div class="bg-white border-b border-gray-100 flex items-center justify-between px-5 py-3">
              <div class="flex items-center gap-2">
                <img :src="getStoreLogo()" alt="Logo" class="w-6 h-6 object-contain">
                <span class="font-bold text-[#1e293b] text-sm" x-text="getStoreName()"></span>
              </div>
              <span class="text-[10px] text-gray-500 uppercase tracking-wider">VẬN CHUYỂN</span>
            </div>

            <div class="p-8 text-center bg-white">
              <h2 class="text-xl font-black text-[#1e293b] mb-2" x-html="preview(settings.email_hero_title)"></h2>
              <p class="text-[13px] text-gray-500 mb-6" x-html="preview(settings.email_hero_subtitle)"></p>
              
              <div class="bg-blue-50 border border-blue-100 rounded-lg p-5 mb-6 text-left">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-[11px] font-bold text-blue-800 uppercase tracking-wider">Trạng thái hiện tại</span>
                  <span class="material-symbols-outlined text-blue-600">local_shipping</span>
                </div>
                <p class="font-bold text-blue-900 text-[15px]" x-text="settings.email_status_text"></p>
                <div class="mt-3 text-[12px] text-blue-800 space-y-1">
                   <p x-text="settings.email_eta_text"></p>
                   <p class="font-semibold" x-text="settings.email_shipping_unit"></p>
                </div>
              </div>

              <a href="#" class="inline-block bg-[#e67e22] text-white font-bold py-3 px-8 rounded-lg shadow" x-text="settings.email_cta"></a>
              <p class="text-[11px] text-gray-400 mt-5 text-left italic border-t border-gray-100 pt-3" x-text="settings.email_admin_note"></p>
            </div>

            <div class="bg-slate-900 border-t border-gray-200 px-6 py-8 text-center text-[11px] text-gray-400">
              <p class="font-bold text-white text-[13px] mb-1" x-text="getStoreName()"></p>
              <p x-text="settings.email_support_email || 'contact@flyskyguitar.com'"></p>
              <p x-text="settings.email_support_phone"></p>
            </div>
          </div>
        </template>

        <!-- PREVIEW: Email Survey -->
        <template x-if="activeTab === 'email_survey'">
          <div class="w-full max-w-[480px] shadow-2xl rounded overflow-hidden border border-gray-300 bg-white text-[#1e293b] text-sm" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
            
            <div class="bg-white border-b border-gray-100 flex items-center justify-between px-5 py-3">
              <div class="flex items-center gap-2">
                <img :src="getStoreLogo()" alt="Logo" class="w-6 h-6 object-contain">
                <span class="font-bold text-[#1e293b] text-sm" x-text="getStoreName()"></span>
              </div>
              <span class="text-[10px] text-gray-500 uppercase tracking-wider">ĐÁNH GIÁ TRẢI NGHIỆM</span>
            </div>

            <div class="px-8 py-10 bg-white text-center">
              <h2 class="text-2xl font-black text-[#1e293b] mb-4" x-html="preview(settings.email_hero_title)"></h2>
              <h3 class="text-lg font-bold mb-2 text-[#e67e22]" x-html="preview(settings.email_greeting)"></h3>
              <p class="text-gray-600 leading-relaxed mb-8" x-html="formatHtml(preview(settings.email_body))"></p>
              
              <div class="flex flex-col justify-center gap-3">
                <a href="#" class="inline-block bg-[#e67e22] text-white font-bold py-3.5 px-6 rounded-lg text-sm shadow-md hover:bg-[#d35400] transition-colors" x-text="settings.email_cta_primary"></a>
                <template x-if="settings.email_cta_secondary">
                  <a href="#" class="inline-block border border-gray-300 bg-gray-50 text-gray-700 font-bold py-3 px-6 rounded-lg text-sm hover:bg-gray-100 transition-colors" x-text="settings.email_cta_secondary"></a>
                </template>
              </div>
            </div>

            <div class="bg-gray-50 border-t border-gray-200 px-8 py-6 text-center text-[11px] text-gray-500">
              <p class="font-bold text-[#1e293b] text-[13px] mb-1" x-text="getStoreName()"></p>
              <p x-text="settings.email_store_address"></p>
              <p class="mt-1">Hỗ trợ hotline: <span class="font-semibold text-gray-700" x-text="settings.email_support_phone"></span></p>
            </div>
          </div>
        </template>

      </div>
    </main>
  </div>
</AdminLayout>
