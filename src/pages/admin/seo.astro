  .mkt-add-wf-btn { margin: 0 24px 24px 24px; width: calc(100% - 48px); }
  /* ── NEWSLETTER & CUSTOMERS TAB ── */
  .nl-container { display: flex; flex-direction: column; gap: 24px; }
  
