---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';
import { describeMarketingWorkflow } from '../../lib/marketing';

// 1. Fetch SEO Settings (from site_settings KV table)
const { data: settingsData } = await supabase.from('site_settings').select('key, value').like('key', 'seo_%');
const seo = settingsData?.reduce((acc: any, curr: any) => {
  acc[curr.key.replace('seo_', '')] = curr.value;
  return acc;
}, {
  meta_title: '',
  meta_description: '',
  meta_keywords: '',
  sitemap_url: '/sitemap.xml',
  gsc_id: '',
  ga4_id: '',
  fb_pixel_id: ''
});

// 2. Fetch Email Campaigns
const showAllCampaigns = Astro.url.searchParams.get('all_campaigns') === '1';
const campaignLimit = showAllCampaigns ? 100 : 5;
const { data: campaignsData } = await supabase.from('email_campaigns').select('*').order('created_at', { ascending: false }).limit(campaignLimit);
const emailCampaigns = campaignsData || [];

// 3. Fetch Automated Workflows
const { data: workflowsData } = await supabase.from('marketing_workflows').select('*').order('created_at', { ascending: true });
const marketingWorkflows = (workflowsData || []).map((workflow: any) => ({
  ...workflow,
  runtimeMeta: describeMarketingWorkflow(workflow),
}));

// 4. Fetch Newsletter Subscribers Stats & List
const { count: totalSubscribers } = await supabase.from('newsletter_subscribers').select('*', { count: 'exact', head: true });
const { data: recentSubscribersData } = await supabase.from('newsletter_subscribers').select('*').order('joined_at', { ascending: false }).limit(5);
const recentSubscribers = recentSubscribersData || [];

// 5. Calculate Average Open Rate (Mock stat based on campaigns)
const avgOpenRate = emailCampaigns.length > 0 
  ? (emailCampaigns.reduce((acc:any, c:any) => acc + Number(c.open_rate || 0), 0) / emailCampaigns.length).toFixed(1)
  : '0.0';

// 6. Fetch Active Discounts
const { data: discountData } = await supabase.from('discounts').select('*').eq('status', 'Đang hoạt động').limit(3);
const activeDiscounts = discountData || [];

// 7. Fetch Newsletter Templates
const { data: templateData } = await supabase.from('newsletter_templates').select('*').order('created_at', { ascending: false }).limit(3);
const newsletterTemplates = templateData || [];
---

<AdminLayout
  title="SEO & Marketing"
  subtitle="Tối ưu công cụ tìm kiếm và quản lý chiến dịch marketing cho FlySky Guitar."
  activeNav="seo"
>

  <!-- TABS -->
  <div class="seo-tabs">
    <button class="seo-tab seo-tab-active" data-seo-tab="meta" onclick="switchSeoTab('meta', this)">Cấu hình SEO</button>
    <button class="seo-tab" data-seo-tab="tools" onclick="switchSeoTab('tools', this)">Marketing Tools</button>
    <button class="seo-tab" data-seo-tab="newsletter" onclick="switchSeoTab('newsletter', this)">Bản tin &amp; Khách hàng</button>
  </div>

  <!-- TAB: CẤU HÌNH SEO -->
  <div id="seo-tab-meta" class="seo-tab-pane">
    <div class="seo-grid">

      <!-- LEFT COLUMN -->
      <div class="seo-col-main">

        <!-- Meta Tags -->
        <section class="seo-card">
          <div class="seo-card-head">
            <span class="material-symbols-outlined seo-icon">language</span>
            <h3 class="seo-card-title">Cấu hình thẻ Meta</h3>
          </div>
          <div class="seo-fields">
            <div class="form-group">
              <label class="seo-label">Meta Title mặc định</label>
              <input type="text" id="seo-meta-title" class="seo-input" value={seo.meta_title} />
              <p class="seo-hint">Được đề xuất: 50-60 ký tự.</p>
            </div>
            <div class="form-group">
              <label class="seo-label">Meta Description mặc định</label>
              <textarea id="seo-meta-desc" class="seo-input seo-textarea" rows="4">{seo.meta_description}</textarea>
              <p class="seo-hint">Được đề xuất: 150-160 ký tự.</p>
            </div>
            <div class="form-group">
              <label class="seo-label">Từ khóa (Keywords)</label>
              <input type="text" id="seo-meta-keywords" class="seo-input" value={seo.meta_keywords} placeholder="guitar, studio, wood guitar..." />
            </div>
          </div>
        </section>

        <!-- Technical SEO -->
        <section class="seo-card">
          <div class="seo-card-head">
            <span class="material-symbols-outlined seo-icon">data_object</span>
            <h3 class="seo-card-title">Cấu hình kỹ thuật</h3>
          </div>
          <div class="seo-tech-grid">
            <div class="form-group">
              <label class="seo-label">Sitemap URL</label>
              <div class="seo-input-group">
                <input type="text" id="seo-sitemap" class="seo-input seo-input-readonly" value={seo.sitemap_url} readonly />
                <button class="seo-input-btn">
                  <span class="material-symbols-outlined">open_in_new</span>
                </button>
              </div>
            </div>
            <div class="form-group">
              <label class="seo-label">Robots.txt</label>
              <button class="seo-dashed-btn">
                <span class="material-symbols-outlined">edit</span>
                Chỉnh sửa tệp Robots
              </button>
            </div>
          </div>
          <div class="form-group" style="margin-top:16px;">
            <label class="seo-label">Google Search Console ID</label>
            <div class="seo-icon-input">
              <span class="material-symbols-outlined seo-input-icon">verified_user</span>
              <input type="text" id="seo-gsc-id" class="seo-input seo-input-icon-pad" value={seo.gsc_id} placeholder="G-XXXXXXXXXX" />
            </div>
          </div>
        </section>

        <!-- Marketing & Analytics -->
        <section class="seo-card">
          <div class="seo-card-head">
            <span class="material-symbols-outlined seo-icon">ads_click</span>
            <h3 class="seo-card-title">Marketing &amp; Analytics</h3>
          </div>
          <div class="seo-tech-grid">
            <div class="seo-analytics-card">
              <label class="seo-label-tiny">Google Analytics 4</label>
              <input type="text" id="seo-ga4-id" class="seo-input" value={seo.ga4_id} placeholder="UA-000000-01" />
            </div>
            <div class="seo-analytics-card">
              <label class="seo-label-tiny">Facebook Pixel ID</label>
              <input type="text" id="seo-fb-pixel" class="seo-input" value={seo.fb_pixel_id} placeholder="1234567890" />
            </div>
          </div>
        </section>
      </div>

      <!-- RIGHT COLUMN -->
      <div class="seo-col-side">

        <!-- Google Preview -->
        <div class="google-preview-card">
          <h3 class="gp-title">
            <span class="material-symbols-outlined" style="color:#f48c25; font-size:18px;">visibility</span>
            Google Search Preview
          </h3>
          <div class="gp-body">
            <div class="gp-site-row">
              <div class="gp-favicon">FS</div>
              <div>
                <div class="gp-domain">flysky-guitar.vn</div>
                <div class="gp-url">https://flysky-guitar.vn</div>
              </div>
            </div>
            <div class="gp-headline" id="gp-preview-title">{seo.meta_title || 'Thêm tiêu đề trang web...'}</div>
            <p class="gp-snippet" id="gp-preview-desc">{seo.meta_description || 'Thêm mô tả cho trang web của bạn...'}</p>
          </div>
          <div class="gp-actions">
            <button class="btn-save-orange" id="btn-save-seo">
              <span class="material-symbols-outlined">save</span>
              Lưu cấu hình
            </button>
            <button class="btn-reset">
              <span class="material-symbols-outlined">restart_alt</span>
              Khôi phục mặc định
            </button>
          </div>
        </div>

        <!-- Active Discounts -->
        <div class="seo-side-card">
          <div class="seo-side-card-head">
            <h3 class="seo-side-title">Mã giảm giá hoạt động</h3>
            <span class="badge-running">{activeDiscounts.length} ĐANG CHẠY</span>
          </div>
          <div class="discount-list">
            {activeDiscounts.map((dc: any) => (
              <div class="discount-row">
                <span class="discount-code">{dc.code}</span>
                <span class="discount-val">
                  {dc.discount_type === 'percent' ? `-${dc.discount_value}%` : `-${Number(dc.discount_value)/1000}k`}
                </span>
              </div>
            ))}
            {activeDiscounts.length === 0 && <p style="color:#64748b; font-size:12px;">Không có mã dồi dào chạy.</p>}
          </div>
          <a href="/admin/discounts" class="seo-manage-btn">Quản lý mã giảm giá</a>
        </div>

        <!-- Banner card -->
        <div class="banner-preview-card">
          <div class="banner-thumb">
            <div class="banner-grad"></div>
            <div class="banner-info-overlay">
              <p class="banner-cat">Banner quảng cáo</p>
              <p class="banner-name">Khuyến mãi Mùa Thu</p>
            </div>
          </div>
          <div class="banner-foot">
            <span class="banner-size">Kích thước: 1200x400px</span>
            <button class="banner-edit-btn">
              <span class="material-symbols-outlined">edit</span>
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- TAB: MARKETING TOOLS -->
  <div id="seo-tab-tools" class="seo-tab-pane" style="display:none;">
    <div class="mkt-container">
      <!-- Marketing Header & Action -->
      <div class="mkt-header">
        <div>
          <h3 class="mkt-title">Tổng quan Marketing</h3>
          <p class="mkt-sub">Quản lý chiến dịch email và quy trình tự động hóa.</p>
        </div>
        <button class="btn-orange mkt-create-btn" id="btn-create-campaign">
          <span class="material-symbols-outlined">add_circle</span>
          Tạo chiến dịch mới
        </button>
      </div>

      <div class="mkt-grid">
        <!-- Email Campaigns Section -->
        <div class="mkt-col-main">
          <section class="seo-card mkt-card">
            <div class="mkt-card-head">
              <div class="mkt-card-title-wrap">
                <span class="material-symbols-outlined seo-icon">mail</span>
                <h4 class="seo-card-title">Chiến dịch Email gần đây</h4>
              </div>
              <button class="mkt-view-all" id="btn-view-all-campaigns">{showAllCampaigns ? 'Thu gọn' : 'Xem tất cả'}</button>
            </div>
            <div class="mkt-table-wrap">
              <table class="mkt-table">
                <thead>
                  <tr>
                    <th>Tiêu đề chiến dịch</th>
                    <th>Trạng thái</th>
                    <th>Tỉ lệ mở</th>
                    <th>Tỉ lệ click</th>
                  </tr>
                </thead>
                <tbody>
                  {emailCampaigns.map((cp: any) => (
                    <tr>
                      <td>
                        <div class="mkt-cp-title">{cp.title}</div>
                        <div class="mkt-cp-date">
                          {cp.status === 'ĐANG CHỜ' ? 'Đang lên lịch: ' : 'Gửi lúc: '}
                          {new Date(cp.sent_at).toLocaleDateString('vi-VN')}
                        </div>
                      </td>
                      <td>
                        {cp.status === 'HOÀN THÀNH' && <span class="mkt-badge mkt-badge-done">{cp.status}</span>}
                        {cp.status === 'ĐANG CHỜ' && <span class="mkt-badge mkt-badge-pending">{cp.status}</span>}
                        {cp.status !== 'HOÀN THÀNH' && cp.status !== 'ĐANG CHỜ' && <span class="mkt-badge">{cp.status}</span>}
                      </td>
                      <td class="mkt-stat">{cp.open_rate > 0 ? `${cp.open_rate}%` : '-'}</td>
                      <td class="mkt-stat">{cp.click_rate > 0 ? `${cp.click_rate}%` : '-'}</td>
                    </tr>
                  ))}
                  {emailCampaigns.length === 0 && (
                    <tr><td colspan="4" style="text-align:center;color:#64748b;padding:24px;">Chưa có chiến dịch nào</td></tr>
                  )}
                </tbody>
              </table>
            </div>
          </section>
        </div>

        <!-- Automated Workflows Section -->
        <div class="mkt-col-side">
          <section class="seo-card mkt-card">
            <div class="mkt-card-head" style="margin-bottom:20px; border-bottom:none; padding-bottom:0;">
              <div class="mkt-card-title-wrap">
                <span class="material-symbols-outlined seo-icon" style="color:#f48c25;">automation</span>
                <h4 class="seo-card-title">Quy trình tự động</h4>
              </div>
            </div>
            
            <div class="mkt-workflows">
              {marketingWorkflows.map((wf: any) => (
                <div class="mkt-wf-item">
                  <div class="mkt-wf-head">
                    <div class="mkt-wf-icon-wrap"><span class="material-symbols-outlined mkt-wf-icon">{wf.icon || 'settings_suggest'}</span></div>
                    <label class="mkt-wf-chk-wrap">
                      <input type="checkbox" class="mkt-wf-chk wf-toggle" data-id={wf.id} checked={wf.is_active} />
                      <span class="mkt-wf-custom-chk"></span>
                    </label>
                  </div>
                  <div class="mkt-wf-title">{wf.title}</div>
                  <div class="mkt-wf-desc">{wf.description}</div>
                  {wf.trigger_event && (
                    <div class="mkt-wf-runtime">Trigger: {wf.trigger_event === 'newsletter_subscribed' ? 'Đăng ký bản tin mới' : (wf.trigger_event === 'order_created' ? 'Đơn hàng mới tạo' : wf.trigger_event)}</div>
                  )}
                  <div class="mkt-wf-meta-row">
                    <span class={`mkt-wf-pill ${wf.runtimeMeta.supported ? 'mkt-wf-pill-live' : 'mkt-wf-pill-warn'}`}>
                      {wf.runtimeMeta.automationMode}
                    </span>
                    {typeof wf.trigger_count === 'number' && (
                      <span class="mkt-wf-runtime">{wf.trigger_count} lượt chạy</span>
                    )}
                  </div>
                  <div class="mkt-wf-note">{wf.runtimeMeta.detail}</div>
                  {wf.last_triggered_at && (
                    <div class="mkt-wf-runtime">Chạy gần nhất: {new Date(wf.last_triggered_at).toLocaleString('vi-VN')}</div>
                  )}
                  {wf.last_status && wf.last_status !== 'never' && (
                    <div class="mkt-wf-runtime">Trạng thái gần nhất: {wf.last_status}</div>
                  )}
                  <div class="mkt-wf-actions">
                    <button
                      type="button"
                      class="mkt-action-btn mkt-action-edit btn-edit-workflow"
                      data-id={wf.id}
                      data-title={wf.title || ''}
                      data-description={wf.description || ''}
                      data-icon={wf.icon || 'settings_suggest'}
                      data-workflow-key={wf.workflow_key || wf.runtimeMeta.key || 'custom_manual'}
                      data-trigger-event={wf.trigger_event || 'newsletter_subscribed'}
                      data-email-subject={wf.email_subject || ''}
                      data-email-body={wf.email_body || ''}
                    >
                      <span class="material-symbols-outlined">edit</span>
                      Sửa
                    </button>
                    <button type="button" class="mkt-action-btn mkt-action-delete btn-delete-workflow" data-id={wf.id}>
                      <span class="material-symbols-outlined">delete</span>
                      Xóa
                    </button>
                  </div>
                </div>
              ))}
              {marketingWorkflows.length === 0 && <p style="color:#64748b; font-size:13px;">Chưa có workflow nào</p>}
            </div>

            <button class="seo-dashed-btn mkt-add-wf-btn" id="btn-add-workflow">
              <span class="material-symbols-outlined">add</span>
              Thêm quy trình mới
            </button>

            <form class="mkt-wf-form" id="workflow-create-form" hidden>
              <div class="mkt-wf-form-head">
                <div>
                  <h5 id="workflow-form-title">Tạo workflow mới</h5>
                  <p id="workflow-form-subtitle">Chọn loại workflow, trigger và nội dung email sẽ gửi tự động.</p>
                </div>
                <button type="button" class="mkt-wf-form-close" id="btn-close-workflow-form">
                  <span class="material-symbols-outlined">close</span>
                </button>
              </div>

              <input type="hidden" id="workflow-id" value="" />

              <div class="mkt-wf-form-grid">
                <label class="mkt-field">
                  <span>Loại workflow</span>
                  <select id="workflow-key" class="mkt-input">
                    <option value="custom_manual">Workflow custom</option>
                    <option value="welcome_series">Chuỗi chào mừng</option>
                    <option value="abandoned_cart">Giỏ hàng bỏ quên</option>
                    <option value="birthday_offer">Chúc mừng sinh nhật</option>
                  </select>
                </label>

                <label class="mkt-field">
                  <span>Icon</span>
                  <input id="workflow-icon" class="mkt-input" type="text" value="settings_suggest" placeholder="settings_suggest" />
                </label>

                <label class="mkt-field mkt-field-full">
                  <span>Tên workflow</span>
                  <input id="workflow-title" class="mkt-input" type="text" value="Workflow mới" placeholder="Ví dụ: Nhắc quay lại cửa hàng" />
                </label>

                <label class="mkt-field mkt-field-full">
                  <span>Mô tả</span>
                  <textarea id="workflow-description" class="mkt-input mkt-textarea" rows="3" placeholder="Mô tả ngắn về workflow này"></textarea>
                </label>

                <label class="mkt-field mkt-custom-only">
                  <span>Trigger event</span>
                  <select id="workflow-trigger-event" class="mkt-input">
                    <option value="newsletter_subscribed">Đăng ký bản tin mới</option>
                    <option value="order_created">Đơn hàng mới tạo</option>
                  </select>
                </label>

                <label class="mkt-field mkt-custom-only mkt-field-full">
                  <span>Tiêu đề email</span>
                  <input id="workflow-email-subject" class="mkt-input" type="text" value="FlySky Guitar có thông báo dành cho {{customer_name}}" placeholder="Có thể dùng {{customer_name}}, {{order_number}}, {{total_amount}}" />
                </label>

                <label class="mkt-field mkt-custom-only mkt-field-full">
                  <span>Nội dung email</span>
                  <textarea id="workflow-email-body" class="mkt-input mkt-textarea" rows="5" placeholder="Xin chào {{customer_name}}, đây là workflow tự động từ FlySky Guitar."></textarea>
                </label>
              </div>

              <div class="mkt-wf-form-actions">
                <button type="button" class="mkt-btn-secondary" id="btn-cancel-workflow-form">Huỷ</button>
                <button type="submit" class="btn-orange mkt-btn-submit" id="btn-submit-workflow-form">
                  <span class="material-symbols-outlined">check_circle</span>
                  <span id="workflow-submit-label">Tạo workflow</span>
                </button>
              </div>
            </form>
          </section>
        </div>
      </div>
    </div>
  </div>

  <!-- TAB: NEWSLETTER & CUSTOMERS -->
  <div id="seo-tab-newsletter" class="seo-tab-pane" style="display:none;">
    <div class="nl-container">
      
      <!-- Top Stats Row -->
      <div class="nl-stats-row">
        <div class="nl-stat-card">
          <p class="nl-stat-label">Tổng người đăng ký</p>
          <h4 class="nl-stat-val">{totalSubscribers?.toLocaleString('vi-VN') || 0}</h4>
          <p class="nl-stat-trend text-green"><span class="material-symbols-outlined">trending_up</span> +12% tháng này *(Mock)*</p>
        </div>
        <div class="nl-stat-card">
          <p class="nl-stat-label">Tỷ lệ mở trung bình</p>
          <h4 class="nl-stat-val">{avgOpenRate}%</h4>
          <p class="nl-stat-desc">Dựa trên {emailCampaigns.length} chiến dịch</p>
        </div>
        <div class="nl-stat-card">
          <p class="nl-stat-label">Chiến dịch đã gửi</p>
          <h4 class="nl-stat-val">{emailCampaigns.filter((c:any) => c.status === 'HOÀN THÀNH').length}</h4>
          <p class="nl-stat-desc">Cập nhật lúc {new Date().toLocaleTimeString('vi-VN')}</p>
        </div>
        <div class="nl-stat-card nl-stat-action">
          <button class="btn-orange nl-btn-full" id="btn-send-newsletter">
            <span class="material-symbols-outlined">send</span> Gửi bản tin mới
          </button>
        </div>
      </div>

      <!-- Main Layout -->
      <div class="nl-main-layout">
        <!-- Left Column -->
        <div class="nl-col-main">
          
          <!-- Subscriber Growth Chart -->
          <section class="seo-card nl-card">
            <div class="nl-card-head">
              <h3 class="nl-card-title">
                <span class="material-symbols-outlined text-orange">insights</span>
                Subscriber Growth
              </h3>
              <select class="nl-select">
                <option>30 ngày qua</option>
                <option>90 ngày qua</option>
              </select>
            </div>
            <div class="nl-chart-area">
              <div class="nl-chart-bars">
                <div class="nl-bar" style="height: 40%"></div>
                <div class="nl-bar" style="height: 55%"></div>
                <div class="nl-bar" style="height: 45%"></div>
                <div class="nl-bar" style="height: 70%"></div>
                <div class="nl-bar" style="height: 85%"></div>
                <div class="nl-bar nl-bar-active" style="height: 95%"></div>
                <div class="nl-bar" style="height: 75%"></div>
              </div>
              <div class="nl-chart-labels">
                <span>Thứ 2</span><span>Thứ 3</span><span>Thứ 4</span><span>Thứ 5</span>
                <span>Thứ 6</span><span>Thứ 7</span><span>CN</span>
              </div>
            </div>
          </section>

          <!-- Latest Subscribers -->
          <section class="seo-card nl-card" style="padding:0; overflow:hidden;">
            <div class="nl-card-head" style="padding:24px; border-bottom:1px solid rgba(244,140,37,.1);">
              <h3 class="nl-card-title">
                <span class="material-symbols-outlined text-orange">group</span>
                Người đăng ký mới nhất
              </h3>
              <button class="nl-btn-text">Xem tất cả</button>
            </div>
            <div class="nl-table-wrap">
              <table class="nl-table">
                <thead>
                  <tr>
                    <th>Email</th>
                    <th>Ngày tham gia</th>
                    <th>Trạng thái</th>
                    <th style="text-align:right;">Hành động</th>
                  </tr>
                </thead>
                <tbody>
                  {recentSubscribers.map((sub: any) => (
                    <tr>
                      <td><span class="nl-email">{sub.email}</span></td>
                      <td><span class="nl-date">{new Date(sub.joined_at).toLocaleDateString('vi-VN')}</span></td>
                      <td>
                        {sub.status === 'Đang hoạt động' 
                         ? <span class="mkt-badge mkt-badge-done">Đang hoạt động</span> 
                         : <span class="mkt-badge" style="background:rgba(100,116,139,.1); color:#94a3b8;">{sub.status}</span>
                        }
                      </td>
                      <td style="text-align:right;">
                        <button class="nl-action-btn"><span class="material-symbols-outlined">more_vert</span></button>
                      </td>
                    </tr>
                  ))}
                  {recentSubscribers.length === 0 && (
                    <tr><td colspan="4" style="text-align:center;color:#64748b;padding:24px;">Chưa có subscriber nào</td></tr>
                  )}
                </tbody>
              </table>
            </div>
          </section>

        </div>

        <!-- Right Column -->
        <div class="nl-col-side">
          
          <!-- Newsletter Templates -->
          <section class="seo-card nl-card">
            <div class="nl-card-head" style="margin-bottom:16px;">
              <h3 class="nl-side-title">Mẫu bản tin</h3>
              <a href="/admin/newsletter-editor" class="nl-btn-text" style="text-decoration: none; display: inline-block;">Thêm mẫu</a>
            </div>
            <div class="nl-tpl-list">
              {newsletterTemplates.map((tpl: any) => (
                <div class="nl-tpl-item">
                  <div class="nl-tpl-cover">
                    <span class="material-symbols-outlined">{tpl.icon}</span>
                    <div class="nl-tpl-overlay">
                      <button class="nl-tpl-btn"><span class="material-symbols-outlined">edit</span></button>
                      <button class="nl-tpl-btn"><span class="material-symbols-outlined">preview</span></button>
                    </div>
                  </div>
                  <div class="nl-tpl-info">
                    <div class="nl-tpl-name">{tpl.name}</div>
                    <div class="nl-tpl-meta">{tpl.type === 'system' ? 'Hệ thống tự động' : 'Tùy chỉnh'}</div>
                  </div>
                </div>
              ))}
              {newsletterTemplates.length === 0 && <p style="font-size:12px;color:#64748b;padding:12px;">Chưa có mẫu bản tin nào.</p>}
            </div>
          </section>

          <!-- Marketing Tips -->
          <div class="nl-tips-card">
            <h3 class="nl-tips-title">
              <span class="material-symbols-outlined">auto_awesome</span>
              Mẹo Marketing
            </h3>
            <p class="nl-tips-text">Gửi bản tin vào sáng thứ 3 thường có tỷ lệ mở cao nhất đối với lĩnh vực nhạc cụ &amp; studio.</p>
            <button class="nl-tips-btn">Xem phân tích chi tiết</button>
          </div>

        </div>
      </div>
    </div>
  </div>

</AdminLayout>

<script>
  function switchSeoTab(tab: string, btn: HTMLElement) {
    document.querySelectorAll('.seo-tab-pane').forEach((p) => (p as HTMLElement).style.display = 'none');
    document.querySelectorAll('.seo-tab').forEach((b) => b.classList.remove('seo-tab-active'));
    const pane = document.getElementById('seo-tab-' + tab);
    if (pane) pane.style.display = 'block';
    btn.classList.add('seo-tab-active');
  }
  (window as any).switchSeoTab = switchSeoTab;

  document.addEventListener('DOMContentLoaded', () => {
    const activeTabFromUrl = new URLSearchParams(window.location.search).get('tab');
    if (activeTabFromUrl) {
      const tabBtn = document.querySelector(`.seo-tab[data-seo-tab="${activeTabFromUrl}"]`) as HTMLElement | null;
      if (tabBtn) switchSeoTab(activeTabFromUrl, tabBtn);
    }

    const titleInput = document.getElementById('seo-meta-title') as HTMLInputElement | null;
    const descInput = document.getElementById('seo-meta-desc') as HTMLTextAreaElement | null;
    const previewTitle = document.getElementById('gp-preview-title');
    const previewDesc = document.getElementById('gp-preview-desc');

    if (titleInput && previewTitle) {
      titleInput.addEventListener('input', (e) => {
        previewTitle.textContent = (e.target as HTMLInputElement).value || 'Thêm tiêu đề trang web...';
      });
    }

    if (descInput && previewDesc) {
      descInput.addEventListener('input', (e) => {
        previewDesc.textContent = (e.target as HTMLTextAreaElement).value || 'Thêm mô tả cho trang web của bạn...';
      });
    }

    const btnSaveSeo = document.getElementById('btn-save-seo') as HTMLButtonElement | null;
    if (btnSaveSeo && titleInput && descInput) {
      btnSaveSeo.addEventListener('click', async () => {
        const payload = {
          meta_title: titleInput.value,
          meta_description: descInput.value,
          meta_keywords: (document.getElementById('seo-meta-keywords') as HTMLInputElement)?.value || '',
          gsc_id: (document.getElementById('seo-gsc-id') as HTMLInputElement)?.value || '',
          ga4_id: (document.getElementById('seo-ga4-id') as HTMLInputElement)?.value || '',
          fb_pixel_id: (document.getElementById('seo-fb-pixel') as HTMLInputElement)?.value || '',
        };

        const oldText = btnSaveSeo.innerHTML;
        btnSaveSeo.innerHTML = '<span class="material-symbols-outlined">sync</span> Đang lưu...';
        btnSaveSeo.style.opacity = '0.7';

        try {
          const res = await fetch('/api/seo/save-settings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const result = await res.json();
          if (result.success) {
            btnSaveSeo.innerHTML = '<span class="material-symbols-outlined">check</span> Đã lưu';
            btnSaveSeo.style.background = '#22c55e';
            btnSaveSeo.style.color = '#fff';
            setTimeout(() => {
              btnSaveSeo.innerHTML = oldText;
              btnSaveSeo.style.background = '#f48c25';
              btnSaveSeo.style.color = 'white';
              btnSaveSeo.style.opacity = '1';
            }, 2500);
          } else {
            alert('Lỗi lưu cấu hình: ' + (result.error || 'Unknown error'));
            btnSaveSeo.innerHTML = oldText;
            btnSaveSeo.style.opacity = '1';
          }
        } catch {
          alert('Không thể kết nối lưu cấu hình.');
          btnSaveSeo.innerHTML = oldText;
          btnSaveSeo.style.opacity = '1';
        }
      });
    }

    const workflowToggles = document.querySelectorAll('.wf-toggle');
    workflowToggles.forEach(toggle => {
      toggle.addEventListener('change', async (e) => {
        const el = e.target as HTMLInputElement;
        const id = el.dataset.id;
        const isActive = el.checked;

        if (!id) return;

        try {
          const res = await fetch('/api/seo/toggle-workflow', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, isActive })
          });
          if (!res.ok) throw new Error('toggle failed');
        } catch {
          el.checked = !isActive;
          alert('Không thể cập nhật workflow.');
        }
      });
    });

    const runCampaignSend = async (btn: HTMLButtonElement) => {
      const subject = prompt('Tiêu đề chiến dịch email', 'Bản tin mới từ FlySky Guitar')?.trim();
      if (!subject) return;
      const content = prompt('Nội dung chính của email', 'FlySky Guitar vừa có cập nhật mới dành cho bạn. Truy cập website để xem chi tiết.')?.trim();
      if (!content) return;

      const oldText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="material-symbols-outlined">sync</span> Đang gửi...';

      try {
        const res = await fetch('/api/seo/send-newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ subject, content }),
        });
        const data = await res.json().catch(() => ({}));

        if (!res.ok || !data.success) {
          alert(data.error || 'Gửi chiến dịch thất bại.');
          return;
        }

        alert(`Đã gửi: ${data.sent}/${data.total} email. Lỗi: ${data.failed}.`);
        window.location.reload();
      } catch (err: any) {
        alert('Không thể gửi chiến dịch: ' + (err?.message || 'Lỗi không xác định'));
      } finally {
        btn.disabled = false;
        btn.innerHTML = oldText;
      }
    };

    const btnSendNewsletter = document.getElementById('btn-send-newsletter') as HTMLButtonElement | null;
    if (btnSendNewsletter) {
      btnSendNewsletter.addEventListener('click', async () => {
        await runCampaignSend(btnSendNewsletter);
      });
    }

    const btnCreateCampaign = document.getElementById('btn-create-campaign') as HTMLButtonElement | null;
    if (btnCreateCampaign) {
      btnCreateCampaign.addEventListener('click', async () => {
        await runCampaignSend(btnCreateCampaign);
      });
    }

    const btnViewAllCampaigns = document.getElementById('btn-view-all-campaigns') as HTMLButtonElement | null;
    if (btnViewAllCampaigns) {
      btnViewAllCampaigns.addEventListener('click', () => {
        const params = new URLSearchParams(window.location.search);
        const showingAll = params.get('all_campaigns') === '1';
        params.set('tab', 'tools');
        if (showingAll) params.delete('all_campaigns');
        else params.set('all_campaigns', '1');
        window.location.search = params.toString();
      });
    }

    const btnAddWorkflow = document.getElementById('btn-add-workflow') as HTMLButtonElement | null;
    const workflowForm = document.getElementById('workflow-create-form') as HTMLFormElement | null;
    const workflowIdInput = document.getElementById('workflow-id') as HTMLInputElement | null;
    const workflowKeyInput = document.getElementById('workflow-key') as HTMLSelectElement | null;
    const workflowTitleInput = document.getElementById('workflow-title') as HTMLInputElement | null;
    const workflowDescriptionInput = document.getElementById('workflow-description') as HTMLTextAreaElement | null;
    const workflowIconInput = document.getElementById('workflow-icon') as HTMLInputElement | null;
    const workflowTriggerEventInput = document.getElementById('workflow-trigger-event') as HTMLSelectElement | null;
    const workflowEmailSubjectInput = document.getElementById('workflow-email-subject') as HTMLInputElement | null;
    const workflowEmailBodyInput = document.getElementById('workflow-email-body') as HTMLTextAreaElement | null;
    const workflowFormTitle = document.getElementById('workflow-form-title') as HTMLElement | null;
    const workflowFormSubtitle = document.getElementById('workflow-form-subtitle') as HTMLElement | null;
    const workflowSubmitBtn = document.getElementById('btn-submit-workflow-form') as HTMLButtonElement | null;
    const workflowSubmitLabel = document.getElementById('workflow-submit-label') as HTMLElement | null;
    const workflowCustomFields = document.querySelectorAll<HTMLElement>('.mkt-custom-only');
    const editWorkflowButtons = document.querySelectorAll<HTMLButtonElement>('.btn-edit-workflow');
    const deleteWorkflowButtons = document.querySelectorAll<HTMLButtonElement>('.btn-delete-workflow');

    let workflowMode: 'create' | 'edit' = 'create';

    const setWorkflowMode = (mode: 'create' | 'edit') => {
      workflowMode = mode;

      if (workflowFormTitle) {
        workflowFormTitle.textContent = mode === 'edit' ? 'Sửa workflow' : 'Tạo workflow mới';
      }

      if (workflowFormSubtitle) {
        workflowFormSubtitle.textContent = mode === 'edit'
          ? 'Cập nhật thông tin, trigger và nội dung email cho workflow.'
          : 'Chọn loại workflow, trigger và nội dung email sẽ gửi tự động.';
      }

      if (workflowSubmitLabel) {
        workflowSubmitLabel.textContent = mode === 'edit' ? 'Lưu thay đổi' : 'Tạo workflow';
      }
    };

    const workflowPresetMap: Record<string, { title: string; description: string; icon: string; triggerEvent: string; emailSubject: string; emailBody: string; }> = {
      custom_manual: {
        title: 'Workflow mới',
        description: 'Workflow tuỳ chỉnh chạy theo trigger bạn chọn.',
        icon: 'settings_suggest',
        triggerEvent: 'newsletter_subscribed',
        emailSubject: 'FlySky Guitar có thông báo dành cho {{customer_name}}',
        emailBody: 'Xin chào {{customer_name}}, đây là workflow tự động từ FlySky Guitar.',
      },
      welcome_series: {
        title: 'Chuỗi chào mừng',
        description: 'Gửi email chào mừng khi có subscriber mới.',
        icon: 'waving_hand',
        triggerEvent: 'newsletter_subscribed',
        emailSubject: '',
        emailBody: '',
      },
      abandoned_cart: {
        title: 'Giỏ hàng bỏ quên',
        description: 'Workflow chuẩn bị sẵn cho nhắc giỏ hàng bỏ quên.',
        icon: 'shopping_cart_checkout',
        triggerEvent: 'order_created',
        emailSubject: '',
        emailBody: '',
      },
      birthday_offer: {
        title: 'Chúc mừng sinh nhật',
        description: 'Workflow chuẩn bị sẵn cho ưu đãi sinh nhật.',
        icon: 'cake',
        triggerEvent: 'newsletter_subscribed',
        emailSubject: '',
        emailBody: '',
      },
    };

    const syncWorkflowFormState = (applyPreset: boolean = true) => {
      if (!workflowKeyInput) return;
      const selectedKey = workflowKeyInput.value || 'custom_manual';
      const preset = workflowPresetMap[selectedKey] || workflowPresetMap.custom_manual;
      const isCustom = selectedKey === 'custom_manual';

      if (applyPreset) {
        if (workflowTitleInput) workflowTitleInput.value = preset.title;
        if (workflowDescriptionInput) workflowDescriptionInput.value = preset.description;
        if (workflowIconInput) workflowIconInput.value = preset.icon;
        if (workflowTriggerEventInput) workflowTriggerEventInput.value = preset.triggerEvent;
        if (workflowEmailSubjectInput) workflowEmailSubjectInput.value = preset.emailSubject;
        if (workflowEmailBodyInput) workflowEmailBodyInput.value = preset.emailBody;
      }

      workflowCustomFields.forEach((field) => {
        field.hidden = !isCustom;
      });
    };

    const openCreateWorkflowForm = () => {
      if (!workflowForm) return;
      setWorkflowMode('create');
      workflowForm.reset();
      if (workflowIdInput) workflowIdInput.value = '';
      if (workflowKeyInput) workflowKeyInput.value = 'custom_manual';
      workflowForm.hidden = false;
      btnAddWorkflow?.setAttribute('hidden', 'true');
      syncWorkflowFormState(true);
      workflowForm.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    };

    const closeWorkflowForm = () => {
      if (!workflowForm) return;
      workflowForm.hidden = true;
      btnAddWorkflow?.removeAttribute('hidden');
      workflowForm.reset();
      if (workflowIdInput) workflowIdInput.value = '';
      if (workflowKeyInput) workflowKeyInput.value = 'custom_manual';
      setWorkflowMode('create');
      syncWorkflowFormState(true);
    };

    btnAddWorkflow?.addEventListener('click', openCreateWorkflowForm);
    document.getElementById('btn-close-workflow-form')?.addEventListener('click', closeWorkflowForm);
    document.getElementById('btn-cancel-workflow-form')?.addEventListener('click', closeWorkflowForm);
    workflowKeyInput?.addEventListener('change', () => syncWorkflowFormState(true));
    setWorkflowMode('create');
    syncWorkflowFormState(true);

    editWorkflowButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (!workflowForm || !workflowKeyInput) return;

        const workflowId = button.dataset.id || '';
        const workflowKey = button.dataset.workflowKey || 'custom_manual';
        const fallbackPreset = workflowPresetMap[workflowKey] || workflowPresetMap.custom_manual;

        if (workflowIdInput) workflowIdInput.value = workflowId;

        if (workflowKeyInput.querySelector(`option[value="${workflowKey}"]`)) {
          workflowKeyInput.value = workflowKey;
        } else {
          workflowKeyInput.value = 'custom_manual';
        }

        if (workflowTitleInput) workflowTitleInput.value = button.dataset.title || fallbackPreset.title;
        if (workflowDescriptionInput) workflowDescriptionInput.value = button.dataset.description || fallbackPreset.description;
        if (workflowIconInput) workflowIconInput.value = button.dataset.icon || fallbackPreset.icon;
        if (workflowTriggerEventInput) workflowTriggerEventInput.value = button.dataset.triggerEvent || fallbackPreset.triggerEvent;
        if (workflowEmailSubjectInput) workflowEmailSubjectInput.value = button.dataset.emailSubject || fallbackPreset.emailSubject;
        if (workflowEmailBodyInput) workflowEmailBodyInput.value = button.dataset.emailBody || fallbackPreset.emailBody;

        setWorkflowMode('edit');
        syncWorkflowFormState(false);

        workflowForm.hidden = false;
        btnAddWorkflow?.setAttribute('hidden', 'true');
        workflowForm.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    });

    deleteWorkflowButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const workflowId = button.dataset.id || '';
        if (!workflowId) {
          alert('Không tìm thấy workflow để xoá.');
          return;
        }

        const confirmed = window.confirm('Bạn có chắc muốn xoá workflow này? Hành động này không thể hoàn tác.');
        if (!confirmed) return;

        const oldContent = button.innerHTML;
        button.disabled = true;
        button.innerHTML = '<span class="material-symbols-outlined">sync</span> Đang xoá...';

        try {
          const res = await fetch('/api/seo/delete-workflow', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: workflowId }),
          });
          const data = await res.json().catch(() => ({}));

          if (!res.ok || !data.success) {
            alert(data.error || 'Xoá workflow thất bại.');
            return;
          }

          alert('Đã xoá workflow thành công.');
          window.location.reload();
        } catch (err: any) {
          alert('Không thể xoá workflow: ' + (err?.message || 'Lỗi không xác định'));
        } finally {
          button.disabled = false;
          button.innerHTML = oldContent;
        }
      });
    });

    workflowForm?.addEventListener('submit', async (event) => {
      event.preventDefault();

      const workflowId = workflowIdInput?.value.trim() || '';
      const workflowKey = workflowKeyInput?.value || 'custom_manual';
      const title = workflowTitleInput?.value.trim() || '';
      const description = workflowDescriptionInput?.value.trim() || '';
      const icon = workflowIconInput?.value.trim() || 'settings_suggest';
      const triggerEvent = workflowKey === 'custom_manual' ? (workflowTriggerEventInput?.value || 'newsletter_subscribed') : null;
      const emailSubject = workflowKey === 'custom_manual' ? (workflowEmailSubjectInput?.value.trim() || '') : '';
      const emailBody = workflowKey === 'custom_manual' ? (workflowEmailBodyInput?.value.trim() || '') : '';

      if (!title) {
        alert('Vui lòng nhập tên workflow.');
        return;
      }

      if (workflowKey === 'custom_manual' && (!emailSubject || !emailBody)) {
        alert('Workflow custom cần có tiêu đề và nội dung email.');
        return;
      }

      if (workflowMode === 'edit' && !workflowId) {
        alert('Không tìm thấy workflow để cập nhật.');
        return;
      }

      const oldText = workflowSubmitBtn?.innerHTML || '';
      if (workflowSubmitBtn) {
        workflowSubmitBtn.disabled = true;
        workflowSubmitBtn.innerHTML = `<span class="material-symbols-outlined">sync</span> ${workflowMode === 'edit' ? 'Đang lưu...' : 'Đang tạo...'}`;
      }

      try {
        const endpoint = workflowMode === 'edit' ? '/api/seo/update-workflow' : '/api/seo/create-workflow';

        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: workflowId, title, description, icon, workflowKey, triggerEvent, emailSubject, emailBody }),
        });
        const data = await res.json().catch(() => ({}));

        if (!res.ok || !data.success) {
          alert(data.error || (workflowMode === 'edit' ? 'Cập nhật workflow thất bại.' : 'Tạo workflow thất bại.'));
          return;
        }

        alert(workflowMode === 'edit' ? 'Đã cập nhật workflow thành công.' : 'Đã tạo workflow mới thành công.');
        window.location.reload();
      } catch (err: any) {
        alert(`Không thể ${workflowMode === 'edit' ? 'cập nhật' : 'tạo'} workflow: ` + (err?.message || 'Lỗi không xác định'));
      } finally {
        if (workflowSubmitBtn) {
          workflowSubmitBtn.disabled = false;
          workflowSubmitBtn.innerHTML = oldText;
        }
      }
    });
  });
</script>

<style>
  /* ── CSS BIẾN DÙNG CHUNG ── */
  :root {
    /* Define any CSS variables here if needed */
  }

  /* ── TABS ── */
  .seo-tabs {
    display: flex; border-bottom: 1px solid rgba(244,140,37,.1);
    margin-bottom: 32px; overflow-x: auto; gap: 0;
  }
  .seo-tabs::-webkit-scrollbar { display: none; }
  .seo-tab {
    padding: 12px 24px; font-size: 14px; font-weight: 500;
    background: none; border: none; cursor: pointer;
    color: #cbad90;
    border-bottom: 2px solid transparent; margin-bottom: -1px;
    white-space: nowrap; transition: all .15s;
  }
  .seo-tab:hover { color: #f1f5f9; }
  .seo-tab-active { color: #f48c25; border-bottom-color: #f48c25; font-weight: 700; }
  .seo-tab-pane { }

  .btn-orange {
    background: #f48c25; color: #221910; border: none; cursor: pointer;
    font-weight: 700; border-radius: 8px; transition: all .15s;
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.2), inset 0 2px 0 rgba(255,255,255,0.2), 0 4px 12px rgba(244,140,37,.2);
  }
  .btn-orange:hover { filter: brightness(1.08); box-shadow: inset 0 0 0 1px rgba(0,0,0,0.2), inset 0 2px 0 rgba(255,255,255,0.2), 0 6px 16px rgba(244,140,37,.3); }

  /* ── GRID ── */
  .seo-grid { display: grid; grid-template-columns: 1fr 320px; gap: 28px; align-items: start; }
  .seo-col-main { display: flex; flex-direction: column; gap: 24px; }
  .seo-col-side  { display: flex; flex-direction: column; gap: 20px; position: sticky; top: 0; }

  /* ── CARD ── */
  .seo-card {
    background: rgba(244,140,37,.03);
    border: 1px solid rgba(244,140,37,.1);
    border-radius: 14px; padding: 24px;
    display: flex; flex-direction: column; gap: 20px;
  }
  .seo-card-head { display: flex; align-items: center; gap: 10px; padding-bottom: 16px; border-bottom: 1px solid rgba(244,140,37,.08); }
  .seo-icon { font-size: 20px; color: #f48c25; }
  .seo-card-title { font-size: 16px; font-weight: 700; color: #f9fafb; }
  .seo-fields { display: flex; flex-direction: column; gap: 18px; }

  /* ── FORM ── */
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .seo-label { font-size: 13px; font-weight: 700; color: rgba(244,140,37,.85); }
  .seo-label-tiny { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: rgba(244,140,37,.75); }
  .seo-input {
    width: 100%; background: rgba(244,140,37,.05); border: 1px solid rgba(244,140,37,.2);
    border-radius: 10px; padding: 11px 16px;
    font-size: 13px; color: #f1f5f9; font-family: 'Nunito', sans-serif;
    outline: none; transition: border .2s; box-sizing: border-box;
  }
  .seo-input:focus { border-color: #f48c25; }
  .seo-input::placeholder { color: #64748b; }
  .seo-textarea { resize: vertical; }
  .seo-input-readonly { background: rgba(34,25,16,.5); color: #64748b; cursor: not-allowed; border-radius: 10px 0 0 10px; }
  .seo-hint { font-size: 11px; color: #64748b; }

  .seo-input-group { display: flex; }
  .seo-input-btn {
    background: rgba(244,140,37,.1); border: 1px solid rgba(244,140,37,.2); border-left: none;
    border-radius: 0 10px 10px 0; padding: 0 14px; cursor: pointer;
    color: #f1f5f9; transition: background .15s;
  }
  .seo-input-btn:hover { background: #f48c25; color: #221910; }
  .seo-input-btn .material-symbols-outlined { font-size: 16px; }

  .seo-dashed-btn {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    padding: 10px 16px; border-radius: 10px;
