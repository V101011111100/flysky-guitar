                    </td>
                    <td><span class="mkt-badge mkt-badge-done">HOÀN THÀNH</span></td>
                    <td class="mkt-stat">24.8%</td>
                    <td class="mkt-stat">3.2%</td>
                  </tr>
                  <tr>
                    <td>
