                    <span class="mkt-wf-custom-chk"></span>
                  </label>
                </div>
                <div class="mkt-wf-title">Chuỗi chào mừng</div>
                <div class="mkt-wf-desc">Gửi khi khách hàng đăng ký tài khoản mới.</div>
              </div>
              
              <!-- Workflow 2 -->
              <div class="mkt-wf-item">
                <div class="mkt-wf-head">
                  <div class="mkt-wf-icon-wrap"><span class="material-symbols-outlined mkt-wf-icon">shopping_cart_checkout</span></div>
                  <label class="mkt-wf-chk-wrap">
