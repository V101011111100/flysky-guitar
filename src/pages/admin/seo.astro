  /* Workflows */
  .mkt-workflows { display: flex; flex-direction: column; gap: 16px; padding: 0 24px 24px 24px; }
  .mkt-wf-item {
    background: rgba(244,140,37,.05); border: 1px solid rgba(244,140,37,.15);
    border-radius: 12px; padding: 16px; transition: border-color .2s;
