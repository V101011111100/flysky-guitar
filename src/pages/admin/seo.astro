---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="SEO & Marketing"
  subtitle="Tối ưu công cụ tìm kiếm và quản lý chiến dịch marketing cho FlySky Guitar."
  activeNav="seo"
>

  <!-- TABS -->
  <div class="seo-tabs">
    <button class="seo-tab seo-tab-active" onclick="switchSeoTab('meta', this)">Cấu hình SEO</button>
    <button class="seo-tab" onclick="switchSeoTab('tools', this)">Marketing Tools</button>
    <button class="seo-tab" onclick="switchSeoTab('newsletter', this)">Bản tin &amp; Khách hàng</button>
  </div>

  <!-- TAB: CẤU HÌNH SEO -->
  <div id="seo-tab-meta" class="seo-tab-pane">
    <div class="seo-grid">

      <!-- LEFT COLUMN -->
      <div class="seo-col-main">

        <!-- Meta Tags -->
        <section class="seo-card">
          <div class="seo-card-head">
            <span class="material-symbols-outlined seo-icon">language</span>
            <h3 class="seo-card-title">Cấu hình thẻ Meta</h3>
          </div>
          <div class="seo-fields">
            <div class="form-group">
              <label class="seo-label">Meta Title mặc định</label>
              <input type="text" class="seo-input" value="FlySky Guitar - Nhạc cụ cao cấp & Studio chuyên nghiệp" />
              <p class="seo-hint">Được đề xuất: 50-60 ký tự.</p>
            </div>
            <div class="form-group">
              <label class="seo-label">Meta Description mặc định</label>
              <textarea class="seo-input seo-textarea" rows="4">Khám phá thế giới nhạc cụ FlySky Guitar, chuyên cung cấp các dòng guitar gỗ thủ công, thiết bị phòng thu và dịch vụ thu âm chuyên nghiệp tại Việt Nam.</textarea>
              <p class="seo-hint">Được đề xuất: 150-160 ký tự.</p>
            </div>
            <div class="form-group">
              <label class="seo-label">Từ khóa (Keywords)</label>
              <input type="text" class="seo-input" placeholder="guitar, studio, wood guitar, flysky..." />
            </div>
          </div>
        </section>

        <!-- Technical SEO -->
        <section class="seo-card">
          <div class="seo-card-head">
            <span class="material-symbols-outlined seo-icon">data_object</span>
            <h3 class="seo-card-title">Cấu hình kỹ thuật</h3>
          </div>
          <div class="seo-tech-grid">
            <div class="form-group">
              <label class="seo-label">Sitemap URL</label>
              <div class="seo-input-group">
                <input type="text" class="seo-input seo-input-readonly" value="/sitemap.xml" readonly />
                <button class="seo-input-btn">
                  <span class="material-symbols-outlined">open_in_new</span>
                </button>
              </div>
            </div>
            <div class="form-group">
              <label class="seo-label">Robots.txt</label>
              <button class="seo-dashed-btn">
                <span class="material-symbols-outlined">edit</span>
                Chỉnh sửa tệp Robots
              </button>
            </div>
          </div>
          <div class="form-group" style="margin-top:16px;">
            <label class="seo-label">Google Search Console ID</label>
            <div class="seo-icon-input">
              <span class="material-symbols-outlined seo-input-icon">verified_user</span>
              <input type="text" class="seo-input seo-input-icon-pad" placeholder="G-XXXXXXXXXX" />
            </div>
          </div>
        </section>

        <!-- Marketing & Analytics -->
        <section class="seo-card">
          <div class="seo-card-head">
            <span class="material-symbols-outlined seo-icon">ads_click</span>
            <h3 class="seo-card-title">Marketing &amp; Analytics</h3>
          </div>
          <div class="seo-tech-grid">
            <div class="seo-analytics-card">
              <label class="seo-label-tiny">Google Analytics 4</label>
              <input type="text" class="seo-input" placeholder="UA-000000-01" />
            </div>
            <div class="seo-analytics-card">
              <label class="seo-label-tiny">Facebook Pixel ID</label>
              <input type="text" class="seo-input" placeholder="1234567890" />
            </div>
          </div>
        </section>
      </div>

      <!-- RIGHT COLUMN -->
      <div class="seo-col-side">

        <!-- Google Preview -->
        <div class="google-preview-card">
          <h3 class="gp-title">
            <span class="material-symbols-outlined" style="color:#f48c25; font-size:18px;">visibility</span>
            Google Search Preview
          </h3>
          <div class="gp-body">
            <div class="gp-site-row">
              <div class="gp-favicon">FS</div>
              <div>
                <div class="gp-domain">flysky-guitar.vn</div>
                <div class="gp-url">https://flysky-guitar.vn</div>
              </div>
            </div>
            <div class="gp-headline">FlySky Guitar - Nhạc cụ cao cấp &amp; Studio chuyên nghiệp</div>
            <p class="gp-snippet">Khám phá thế giới nhạc cụ FlySky Guitar, chuyên cung cấp các dòng guitar gỗ thủ công, thiết bị phòng thu và dịch vụ thu âm chuyên nghiệp...</p>
          </div>
          <div class="gp-actions">
            <button class="btn-save-orange">
              <span class="material-symbols-outlined">save</span>
              Lưu cấu hình
            </button>
            <button class="btn-reset">
              <span class="material-symbols-outlined">restart_alt</span>
              Khôi phục mặc định
            </button>
          </div>
        </div>

        <!-- Active Discounts -->
        <div class="seo-side-card">
          <div class="seo-side-card-head">
            <h3 class="seo-side-title">Mã giảm giá hoạt động</h3>
            <span class="badge-running">3 ĐANG CHẠY</span>
          </div>
          <div class="discount-list">
            <div class="discount-row">
              <span class="discount-code">WOODGUITAR20</span>
              <span class="discount-val">-20%</span>
            </div>
            <div class="discount-row">
              <span class="discount-code">STUDIOSET</span>
              <span class="discount-val">500k</span>
            </div>
          </div>
          <a href="/admin/discounts" class="seo-manage-btn">Quản lý mã giảm giá</a>
        </div>

        <!-- Banner card -->
        <div class="banner-preview-card">
          <div class="banner-thumb">
            <div class="banner-grad"></div>
            <div class="banner-info-overlay">
              <p class="banner-cat">Banner quảng cáo</p>
              <p class="banner-name">Khuyến mãi Mùa Thu</p>
            </div>
          </div>
          <div class="banner-foot">
            <span class="banner-size">Kích thước: 1200x400px</span>
            <button class="banner-edit-btn">
              <span class="material-symbols-outlined">edit</span>
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>

