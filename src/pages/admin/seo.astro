  .mkt-wf-head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 8px; }
  .mkt-wf-icon-wrap {
    width: 32px; height: 32px; border-radius: 8px;
    background: rgba(244,140,37,.1); display: flex; align-items: center; justify-content: center;
  }
