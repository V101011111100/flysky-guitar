  /* Custom Checkbox */
  .mkt-wf-chk-wrap { position: relative; display: inline-block; width: 18px; height: 18px; cursor: pointer; }
  .mkt-wf-chk { position: absolute; opacity: 0; width: 0; height: 0; }
  .mkt-wf-custom-chk {
    position: absolute; inset: 0; border: 1px solid rgba(244,140,37,.2);
    background: rgba(244,140,37,.08); border-radius: 4px; transition: all .15s;
    display: flex; align-items: center; justify-content: center;
  }
  .mkt-wf-custom-chk::after {
    content: ''; width: 4px; height: 8px; border: solid rgba(244,140,37,.08);
    border-width: 0 2px 2px 0; transform: rotate(45deg);
    opacity: 0; transition: opacity .1s; margin-bottom: 2px;
  }
  .mkt-wf-chk:checked ~ .mkt-wf-custom-chk { background: #f48c25; border-color: #f48c25; }
  .mkt-wf-chk:checked ~ .mkt-wf-custom-chk::after { opacity: 1; }

  .mkt-wf-title { font-size: 13px; font-weight: 700; color: #f1f5f9; }
