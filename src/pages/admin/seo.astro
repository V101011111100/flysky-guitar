                      <div class="mkt-cp-date">Gửi lúc: 08/10/2023</div>
                    </td>
                    <td><span class="mkt-badge mkt-badge-done">HOÀN THÀNH</span></td>
                    <td class="mkt-stat">18.5%</td>
