---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// URL Params for filtering and pagination
const url = new URL(Astro.request.url);
const searchParams = url.searchParams;

const page = parseInt(searchParams.get('page') || '1');
const limit = 10;
const roleFilter = searchParams.get('role') || '';
const actionFilter = searchParams.get('action') || '';
const periodFilter = searchParams.get('period') || 'Tháng này';
const startParam = searchParams.get('start');
const endParam = searchParams.get('end');

let query = supabase.from('activity_logs').select('*', { count: 'exact' });

if (roleFilter) query = query.eq('user_role', roleFilter);
if (actionFilter) query = query.eq('action_type', actionFilter);

const now = new Date();
let startDate = new Date(0);
let isCustomRange = false;

if (periodFilter === 'Hôm nay') {
  startDate = new Date(now.setHours(0,0,0,0));
} else if (periodFilter === '7 ngày qua') {
  startDate = new Date(); startDate.setDate(startDate.getDate() - 7);
} else if (periodFilter === '30 ngày qua') {
  startDate = new Date(); startDate.setDate(startDate.getDate() - 30);
} else if (periodFilter === 'Tháng này') {
  startDate = new Date(now.getFullYear(), now.getMonth(), 1);
} else if (periodFilter === 'Custom' && startParam && endParam) {
  isCustomRange = true;
  const customStart = new Date(startParam);
  const customEnd = new Date(endParam);
  customEnd.setHours(23, 59, 59, 999);
  query = query.gte('created_at', customStart.toISOString()).lte('created_at', customEnd.toISOString());
}

if (!isCustomRange) {
  query = query.gte('created_at', startDate.toISOString());
}
query = query.order('created_at', { ascending: false });
query = query.range((page - 1) * limit, page * limit - 1);

const { data: logs, count } = await query;
const totalCount = count || 0;
const totalPages = Math.ceil(totalCount / limit) || 1;

// Stats calculation
const todayStart = new Date();
todayStart.setHours(0,0,0,0);

const [{ count: todayUpdates }, { count: securityAlerts }, { data: activeUsersData }] = await Promise.all([
  supabase.from('activity_logs').select('*', { count: 'exact', head: true }).in('action_type', ['Thêm mới', 'Cập nhật']).gte('created_at', todayStart.toISOString()),
  supabase.from('activity_logs').select('*', { count: 'exact', head: true }).eq('action_type', 'Bảo mật / Hệ thống').gte('created_at', todayStart.toISOString()),
  supabase.from('activity_logs').select('user_name').gte('created_at', todayStart.toISOString())
]);

const distinctUsersCount = new Set((activeUsersData || []).map(r => r.user_name)).size;

const roles = ['Hệ thống', 'Quản trị viên', 'Nhân viên bán hàng', 'Quản lý kho', 'Kỹ thuật', 'SystemAdmin', 'Admin'];
const actionTypes = ['Thêm mới', 'Cập nhật', 'Xóa', 'Bảo mật / Hệ thống'];
const periods = ['Hôm nay', '7 ngày qua', '30 ngày qua', 'Tháng này', 'Tất cả'];

function getActionColor(action: string) {
  if (action === 'Thêm mới') return 'dot-green';
  if (action === 'Xóa') return 'dot-red';
  if (action === 'Cập nhật') return 'dot-blue';
  return 'dot-primary';
}

function formatDate(ds: string) {
  const d = new Date(ds);
  return {
    time: d.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit', second: '2-digit' }),
    date: d.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' })
  };
}
---

<AdminLayout title="Quản lý Nhật ký" activeNav="activity-log">
  <div class="log-container">
    <div class="log-content-wrapper">
      
      <!-- Title & Actions -->
      <div class="log-header">
        <div>
          <h1 class="log-title">Nhật ký hoạt động hệ thống</h1>
          <p class="log-subtitle">Giám sát và kiểm tra mọi thay đổi dữ liệu trong hệ thống FlySky Guitar.</p>
        </div>
        <div class="log-actions">
          <div class="export-dropdown-wrapper">
            <button class="export-btn" id="export-btn">
              <span class="material-symbols-outlined">file_download</span>
              Xuất báo cáo (CSV/PDF)
              <span class="material-symbols-outlined icon-sm">expand_more</span>
            </button>
            <div class="export-dropdown">
              <div class="export-dp-header">
                <p class="export-dp-title">Chọn thời gian</p>
                <div class="export-dp-grid">
                  <button class="dp-btn dp-btn-active">Hôm nay</button>
                  <button class="dp-btn">Tuần này</button>
                  <button class="dp-btn">Tháng này</button>
                  <button class="dp-btn dp-btn-icon" id="btn-open-datepicker">
                    <span class="material-symbols-outlined icon-xs">calendar_today</span>Tùy chọn
                  </button>
                </div>
              </div>
              <div class="dp-divider"></div>
              <a href={`/api/export-logs?period=${periodFilter}`} id="btn-export-csv" class="dp-action-btn" style="text-decoration:none;">
                <span class="material-symbols-outlined icon-lg">table_view</span>
                Tải xuống CSV
              </a>
              <a href="#" class="dp-action-btn" style="text-decoration:none;" onclick="alert('Tính năng PDF đang được phát triển!')">
                <span class="material-symbols-outlined icon-lg">picture_as_pdf</span>
                Tải xuống PDF
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Filters -->
      <form class="log-filters" id="filter-form" method="GET" action="/admin/activity-log">
        <div class="filter-group">
          <label class="filter-label">Khoảng thời gian</label>
          <select class="filter-select" name="period">
            {periods.map(p => <option value={p} selected={p === periodFilter}>{p}</option>)}
          </select>
        </div>
        <div class="filter-group">
          <label class="filter-label">Vai trò người dùng</label>
          <select class="filter-select" name="role">
            <option value="">Tất cả vai trò</option>
            {roles.map(r => <option value={r} selected={r === roleFilter}>{r}</option>)}
          </select>
        </div>
        <div class="filter-group">
          <label class="filter-label">Phân loại hành động</label>
          <select class="filter-select" name="action">
            <option value="">Tất cả hành động</option>
            {actionTypes.map(a => <option value={a} selected={a === actionFilter}>{a}</option>)}
          </select>
        </div>
        <div class="filter-action">
          <button type="submit" class="filter-btn">
            <span class="material-symbols-outlined">filter_list</span>
            Lọc kết quả
          </button>
        </div>
      </form>

      <!-- Data Table -->
      <div class="log-table-wrapper">
        <table class="log-table">
          <thead>
            <tr>
              <th>Thời gian</th>
              <th>Người dùng</th>
              <th>Hành động</th>
              <th>Module</th>
              <th>IP Address</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {!logs || logs.length === 0 ? (
              <tr>
                <td colspan="6" style="text-align:center; padding: 32px; color: #64748b;">
                  Không tìm thấy nhật ký hoạt động nào phù hợp.
                </td>
              </tr>
            ) : logs.map((log: any) => {
              const { time, date } = formatDate(log.created_at);
              return (
                <tr>
                  <td>
                    <p class="time-main">{time}</p>
                    <p class="date-sub">{date}</p>
                  </td>
                  <td>
                    <div class="user-cell">
                      <div class="user-avatar" style="background-color: #334155; display:flex; align-items:center; justify-content:center; color:#fff; font-size:12px; font-weight:bold;">
                        {log.user_name ? log.user_name.substring(0,2).toUpperCase() : 'SYS'}
                      </div>
                      <div>
                        <p class="user-name">{log.user_name || 'Hệ thống'}</p>
                        <p class="user-role">{log.user_role || 'System'}</p>
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="action-cell">
                      <span class={`dot ${getActionColor(log.action_type)}`}></span>
                      <p class="action-text">{log.action_text}</p>
                    </div>
                  </td>
                  <td>
                    <span class="module-badge">{log.module_name}</span>
                  </td>
                  <td class="ip-address">{log.ip_address || '127.0.0.1'}</td>
                  <td class="action-col">
                    <button class="view-btn"><span class="material-symbols-outlined icon-lg">visibility</span></button>
                  </td>
                </tr>
              )
            })}
          </tbody>
        </table>
        
        <!-- Pagination -->
        <div class="pagination">
          <p class="page-info">
            Hiển thị {Math.min((page - 1) * limit + 1, totalCount)} đến {Math.min(page * limit, totalCount)} của {totalCount} kết quả
          </p>
          <div class="page-controls">
            <a href={`?page=${Math.max(page - 1, 1)}&period=${periodFilter}&role=${roleFilter}&action=${actionFilter}${startParam ? '&start='+startParam+'&end='+endParam : ''}`} class={`page-btn ${page <= 1 ? 'page-disabled' : ''}`} style="text-decoration:none;">Trước</a>
            <span class="page-btn page-active">{page} / {totalPages}</span>
            <a href={`?page=${Math.min(page + 1, totalPages)}&period=${periodFilter}&role=${roleFilter}&action=${actionFilter}${startParam ? '&start='+startParam+'&end='+endParam : ''}`} class={`page-btn ${page >= totalPages ? 'page-disabled' : ''}`} style="text-decoration:none;">Tiếp</a>
          </div>
        </div>
      </div>

      <!-- Stats Summary -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon-wrap icon-blue">
            <span class="material-symbols-outlined">edit_note</span>
          </div>
          <div>
            <p class="stat-val">{todayUpdates || 0}</p>
            <p class="stat-label">Cập nhật hôm nay</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon-wrap icon-red">
            <span class="material-symbols-outlined">warning</span>
          </div>
          <div>
            <p class="stat-val">{securityAlerts || 0}</p>
            <p class="stat-label">Cảnh báo bảo mật</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon-wrap icon-green">
            <span class="material-symbols-outlined">person_check</span>
          </div>
          <div>
            <p class="stat-val">{distinctUsersCount}</p>
            <p class="stat-label">Người dùng hoạt động</p>
          </div>
        </div>
      </div>
      
    </div>
    
    <!-- Success Toast Positioned -->
    <div class="toast-notification">
      <div class="toast-content">
        <div class="toast-icon">
          <span class="material-symbols-outlined">check_circle</span>
        </div>
        <div>
          <p class="toast-title">Yêu cầu đã được tiếp nhận</p>
          <p class="toast-desc">Đang chuẩn bị tệp báo cáo của bạn...</p>
        </div>
        <div class="toast-progress-wrap">
          <div class="toast-progress-track">
            <div class="toast-progress-bar"></div>
          </div>
        </div>
      </div>
    </div>
    <!-- Datepicker Modal -->
    <div id="datepicker-modal" class="dp-modal-overlay" style="display: none;">
      <div class="dp-modal-content">
        <!-- Sidebar -->
        <div class="dp-sidebar">
          <h3 class="dp-sidebar-title">Lựa chọn nhanh</h3>
          <button class="dp-side-btn">Hôm nay</button>
          <button class="dp-side-btn">Hôm qua</button>
          <button class="dp-side-btn dp-side-btn-active">7 ngày qua</button>
          <button class="dp-side-btn">30 ngày qua</button>
          <button class="dp-side-btn">Tháng này</button>
          <button class="dp-side-btn">Tháng trước</button>
          <div class="dp-sidebar-bottom">
            <div class="dp-date-input-group">
              <div>
                <p class="dp-date-label">Từ ngày</p>
                <input type="date" id="dp-start-date" class="dp-date-box" style="width: 130px; background: transparent; color: #f1f5f9; outline: none; border-radius: 4px; padding: 4px; border: 1px solid rgba(244,140,37,0.3);" />
              </div>
              <div style="margin-top: 12px;">
                <p class="dp-date-label">Đến ngày</p>
                <input type="date" id="dp-end-date" class="dp-date-box" style="width: 130px; background: transparent; color: #f1f5f9; outline: none; border-radius: 4px; padding: 4px; border: 1px solid rgba(244,140,37,0.3);" />
              </div>
            </div>
          </div>
        </div>
        <!-- Main Area -->
        <div class="dp-main">
          <div class="dp-header">
            <div class="dp-month-nav">
              <button class="dp-nav-btn" id="btn-prev-month"><span class="material-symbols-outlined">chevron_left</span></button>
              <h4 class="dp-month-title" id="month-title-1">Tháng 5, 2024</h4>
            </div>
            <div class="dp-month-nav">
              <h4 class="dp-month-title" id="month-title-2">Tháng 6, 2024</h4>
              <button class="dp-nav-btn" id="btn-next-month"><span class="material-symbols-outlined">chevron_right</span></button>
            </div>
          </div>
          <div class="dp-calendars" id="dp-calendars-container">
            <!-- Calendars will be injected here by JS -->
          </div>
          <div class="dp-actions-wrap">
            <button class="dp-btn-cancel" data-close-datepicker>Hủy bỏ</button>
            <button class="dp-btn-apply" id="btn-apply-date">Áp dụng</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Setup Datepicker logic
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('datepicker-modal');
    const btnOpen = document.getElementById('btn-open-datepicker');
    const btnsClose = document.querySelectorAll('[data-close-datepicker]');

    if (btnOpen && modal) {
      btnOpen.addEventListener('click', () => {
        modal.style.display = 'flex';
      });
    }

    btnsClose.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (modal) modal.style.display = 'none';
      });
    });

    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.style.display = 'none';
        }
      });
    }

    // Export Dropdown Period Selection Logic
    const exportPeriodBtns = document.querySelectorAll('.export-dropdown .dp-btn:not(#btn-open-datepicker)');
    const csvExportBtn = document.getElementById('btn-export-csv') as HTMLAnchorElement;
    
    // Set initial active based on URL
    const urlParams = new URLSearchParams(window.location.search);
    const currentUrlPeriod = urlParams.get('period') || 'Tháng này';
    const startParam = urlParams.get('start');
    const endParam = urlParams.get('end');

    // Default CSV href
    if (csvExportBtn) {
      if (currentUrlPeriod === 'Custom' && startParam && endParam) {
        csvExportBtn.href = `/api/export-logs?period=Custom&start=${startParam}&end=${endParam}`;
      } else {
        csvExportBtn.href = `/api/export-logs?period=${encodeURIComponent(currentUrlPeriod)}`;
      }
    }

    exportPeriodBtns.forEach(btn => {
      if(btn.textContent?.trim() === currentUrlPeriod) {
        exportPeriodBtns.forEach(b => b.classList.remove('dp-btn-active'));
        btn.classList.add('dp-btn-active');
      }
    });

    exportPeriodBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        // Update active class
        exportPeriodBtns.forEach(b => b.classList.remove('dp-btn-active'));
        btn.classList.add('dp-btn-active');
        
        // Update CSV link directly
        const period = btn.textContent?.trim() || 'Tất cả';
        if (csvExportBtn) {
          csvExportBtn.href = `/api/export-logs?period=${encodeURIComponent(period)}`;
        }
      });
    });

    // Sidebar & Date inputs logic
    const customStart = document.getElementById('dp-start-date') as HTMLInputElement;
    const customEnd = document.getElementById('dp-end-date') as HTMLInputElement;
    const dpSideBtns = document.querySelectorAll('.dp-side-btn');
    const btnApply = document.getElementById('btn-apply-date');
    
    function formatDateForInput(d: Date) { 
      return d.toISOString().split('T')[0]; 
    }

    // --- Calendar State & Rendering Logic ---
    let currentBaseMonth = new Date();
    currentBaseMonth.setDate(1);

    let selectedStart: Date | null = null;
    let selectedEnd: Date | null = null;
    
    // Parse from UI inputs if exist
    if (customStart && customStart.value) selectedStart = new Date(customStart.value);
    if (customEnd && customEnd.value) selectedEnd = new Date(customEnd.value);
    
    // Fallback if not set
    if (!selectedStart || isNaN(selectedStart.getTime())) selectedStart = new Date();
    if (!selectedEnd || isNaN(selectedEnd.getTime())) selectedEnd = new Date();
    
    // Set view to month of selectedEnd
    currentBaseMonth = new Date(selectedEnd.getFullYear(), selectedEnd.getMonth(), 1);

    const monthTitle1 = document.getElementById('month-title-1');
    const monthTitle2 = document.getElementById('month-title-2');
    const calContainer = document.getElementById('dp-calendars-container');
    const btnPrevMonth = document.getElementById('btn-prev-month');
    const btnNextMonth = document.getElementById('btn-next-month');

    function isSameDay(d1: Date, d2: Date) {
      return d1.getFullYear() === d2.getFullYear() && d1.getMonth() === d2.getMonth() && d1.getDate() === d2.getDate();
    }

    function renderCalendar() {
      if (!calContainer || !monthTitle1 || !monthTitle2) return;

      const y1 = currentBaseMonth.getFullYear();
      const m1 = currentBaseMonth.getMonth();

      let d2 = new Date(y1, m1 + 1, 1);
      const y2 = d2.getFullYear();
      const m2 = d2.getMonth();

      monthTitle1.textContent = `Tháng ${m1 + 1}, ${y1}`;
      monthTitle2.textContent = `Tháng ${m2 + 1}, ${y2}`;

      calContainer.innerHTML = '';
      calContainer.appendChild(createCalGrid(y1, m1));
      calContainer.appendChild(createCalGrid(y2, m2));
    }

    let clickStep = 0; // 0: select start, 1: select end

    function createCalGrid(year: number, month: number) {
      const wrapper = document.createElement('div');
      wrapper.className = 'dp-cal';

      const header = document.createElement('div');
      header.className = 'dp-days-header';
      ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'].forEach(d => {
        const el = document.createElement('div');
        el.className = 'dp-day-name';
        el.textContent = d;
        header.appendChild(el);
      });
      wrapper.appendChild(header);

      const grid = document.createElement('div');
      grid.className = 'dp-days-grid';

      const firstDay = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const daysInPrevMonth = new Date(year, month, 0).getDate();

      // Prev month filler
      for (let i = 0; i < firstDay; i++) {
        const d = document.createElement('div');
        d.className = 'dp-day dp-day-muted';
        d.textContent = String(daysInPrevMonth - firstDay + i + 1);
        grid.appendChild(d);
      }

      // Current month days
      for (let i = 1; i <= daysInMonth; i++) {
        const cellDate = new Date(year, month, i);
        const d = document.createElement('div');
        d.className = 'dp-day';
        d.textContent = String(i);

        // Styling based on selection
        if (selectedStart && selectedEnd) {
          const tCell = cellDate.getTime();
          const tStart = new Date(selectedStart.getFullYear(), selectedStart.getMonth(), selectedStart.getDate()).getTime();
          const tEnd = new Date(selectedEnd.getFullYear(), selectedEnd.getMonth(), selectedEnd.getDate()).getTime();

          if (tCell === tStart && tCell === tEnd) {
             d.classList.add('dp-day-start');
             d.classList.add('dp-day-end');
          } else if (tCell === tStart) {
             d.classList.add('dp-day-start');
          } else if (tCell === tEnd) {
             d.classList.add('dp-day-end');
          } else if (tCell > tStart && tCell < tEnd) {
             d.classList.add('dp-day-in-range');
          }
        } else if (selectedStart && isSameDay(cellDate, selectedStart)) {
             d.classList.add('dp-day-start');
             d.classList.add('dp-day-end');
        }

        d.addEventListener('click', () => {
          if (clickStep === 0) {
             selectedStart = cellDate;
             selectedEnd = null; // reset end
             clickStep = 1;
          } else {
             if (cellDate < selectedStart!) {
                selectedEnd = selectedStart;
                selectedStart = cellDate;
             } else {
                selectedEnd = cellDate;
             }
             clickStep = 0;
          }
          
          if (customStart && selectedStart) customStart.value = formatDateForInput(selectedStart);
          if (customEnd && selectedEnd) customEnd.value = formatDateForInput(selectedEnd);

          renderCalendar();
        });

        grid.appendChild(d);
      }

      const totalCells = firstDay + daysInMonth;
      const nextMonthCells = (7 - (totalCells % 7)) % 7;
      for (let i = 1; i <= nextMonthCells; i++) {
        const d = document.createElement('div');
        d.className = 'dp-day dp-day-muted';
        d.textContent = String(i);
        grid.appendChild(d);
      }

      wrapper.appendChild(grid);
      return wrapper;
    }

    if (btnPrevMonth) {
      btnPrevMonth.addEventListener('click', () => {
        currentBaseMonth.setMonth(currentBaseMonth.getMonth() - 1);
        renderCalendar();
      });
    }

    if (btnNextMonth) {
      btnNextMonth.addEventListener('click', () => {
        currentBaseMonth.setMonth(currentBaseMonth.getMonth() + 1);
        renderCalendar();
      });
    }
    
    // Initial Render
    renderCalendar();

    // Listen to manual input changes to re-render calendar
    [customStart, customEnd].forEach(input => {
       if(input) {
          input.addEventListener('change', () => {
             if (customStart.value) selectedStart = new Date(customStart.value);
             if (customEnd.value) selectedEnd = new Date(customEnd.value);
             renderCalendar();
          });
       }
    });

  });
</script>

<style>
  .log-container {
    padding: 0;
  }
  .log-content-wrapper {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Header */
  .log-header {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .log-header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }
  .log-title {
    font-size: 30px;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
    color: #f1f5f9;
  }
  .log-subtitle {
    color: #94a3b8;
    font-size: 16px;
  }

  /* Export Button & Dropdown */
  .export-dropdown-wrapper {
    position: relative;
    display: inline-block;
  }
  .export-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(244, 140, 37, 0.1);
    color: #f48c25;
    border: 1px solid rgba(244, 140, 37, 0.2);
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
