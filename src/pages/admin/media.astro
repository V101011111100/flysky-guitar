---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Thư viện Media" activeNav="media">
  <div class="media-container">
    <!-- Directory Sidebar -->
    <aside class="dir-sidebar">
      <div class="dir-header">
        <h3 class="dir-title">Thư mục</h3>
        <button class="icon-btn" title="Thêm thư mục mới">
          <span class="material-symbols-outlined">create_new_folder</span>
        </button>
      </div>
      <nav class="dir-nav" id="dir-nav">
        <!-- Dynamically populated from R2 folders -->
      </nav>
    </aside>

    <!-- Main Content Area -->
    <main class="media-main">
      <!-- Header Bar -->
      <header class="media-header">
        <div class="breadcrumb">
          <div class="bc-flex">
            <span class="material-symbols-outlined text-primary">perm_media</span>
            <span class="bc-text-muted">Thư viện</span>
            <span class="material-symbols-outlined bc-separator">chevron_right</span>
            <span class="bc-text-active">Guitar Acoustic</span>
          </div>
          <div class="search-box">
            <span class="material-symbols-outlined search-icon">search</span>
            <input class="search-input" placeholder="Tìm kiếm tệp..." type="text"/>
          </div>
        </div>
        <div class="header-actions">
          <label class="btn-upload" style="cursor: pointer;">
            <span class="material-upload"></span>
            <span class="material-symbols-outlined">cloud_upload</span>
            Tải lên mới
            <input type="file" id="file-upload" style="display: none;" accept="image/*,video/*" multiple />
          </label>
          <button class="icon-btn">
            <span class="material-symbols-outlined">notifications</span>
          </button>
        </div>
      </header>

      <!-- Toolbar / Filters -->
      <div class="toolbar">
        <div class="filters-flex">
          <button class="filter-chip chip-active">Tất cả</button>
          <button class="filter-chip">Hình ảnh</button>
          <button class="filter-chip">Videos</button>
          <button class="filter-chip">Thư mục</button>
          <div class="divider-y"></div>
          <select class="sort-select">
            <option>Mới nhất</option>
            <option>Cũ nhất</option>
            <option>Kích thước (Lớn nhất)</option>
          </select>
        </div>
        <div class="actions-flex">
          <button class="action-icon text-red" title="Xóa tệp"><span class="material-symbols-outlined">delete</span></button>
          <button class="action-icon text-primary" title="Di chuyển"><span class="material-symbols-outlined">folder_shared</span></button>
          <button class="action-icon text-primary" title="Tải xuống"><span class="material-symbols-outlined">download</span></button>
        </div>
      </div>

      <!-- Media Grid -->
      <div class="grid-scroll-area">
        <div id="media-loading" style="display: flex; justify-content: center; padding: 40px; color: #94a3b8;">
          <span class="material-symbols-outlined" style="animation: spin 1s linear infinite;">autorenew</span>
          <span style="margin-left: 8px;">Đang tải danh sách...</span>
        </div>
        <div class="media-grid" id="media-grid" style="display: none;">
          <!-- Dynamically populated -->
        </div>
      </div>
      </div>
    </main>

    <!-- Details Sidebar -->
    <aside class="details-sidebar" id="details-sidebar" style="display: none;">
      <div class="details-header">
        <h3 class="details-title">
          <span class="material-symbols-outlined text-primary">info</span>
          Chi tiết tệp
        </h3>
      </div>
      <div class="details-scroll" id="details-content">
        <!-- Content will be injected here -->
      </div>
      <!-- Sidebar Actions -->
      <div class="details-actions">
        <button class="btn-block btn-primary-lg" id="btn-copy-url">
          <span class="material-symbols-outlined icon-norm">content_copy</span>
          Sao chép liên kết URL
        </button>
        <button class="btn-block btn-danger-out" id="btn-delete-file">
          <span class="material-symbols-outlined icon-norm">delete_forever</span>
          Xóa tệp
        </button>
      </div>
    </aside>
  </div>
  
  <div id="toast-container" style="position: fixed; bottom: 20px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 10px;"></div>
</AdminLayout>

<script is:inline>
  let filesData = [];
  let selectedFile = null;

  const mediaGrid = document.getElementById('media-grid');
  const mediaLoading = document.getElementById('media-loading');
  const fileUpload = document.getElementById('file-upload');
  const detailsSidebar = document.getElementById('details-sidebar');
  const detailsContent = document.getElementById('details-content');
  const btnDelete = document.getElementById('btn-delete-file');
  const btnCopy = document.getElementById('btn-copy-url');
  
  function showToast(message, type = 'success') {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;
    toast.innerHTML = `<span class="material-symbols-outlined">${type === 'success' ? 'check_circle' : 'error'}</span> ${message}`;
    container.appendChild(toast);
    
    // Animate in
    setTimeout(() => toast.style.transform = 'translateY(0)', 10);
    
    // Remove after 3s
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translateY(20px)';
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }

  function formatBytes(bytes, decimals = 2) {
      if (!+bytes) return '0 Bytes';
      const k = 1024;
      const dm = decimals < 0 ? 0 : decimals;
      const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB', 'PB', 'EB', 'ZB', 'YB'];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      return `${parseFloat((bytes / Math.pow(k, i)).toFixed(dm))} ${sizes[i]}`;
  }

  function formatDate(dateString) {
      const options = { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' };
      return new Date(dateString).toLocaleDateString('vi-VN', options);
  }

  function getFileName(key) {
      const parts = key.split('/');
      return parts[parts.length - 1];
  }

  function renderGrid() {
      if (!mediaGrid) return;
      mediaGrid.innerHTML = '';
      
      filesData.forEach(file => {
          const isSelected = selectedFile && selectedFile.key === file.key;
          const fileName = getFileName(file.key);
          
          const item = document.createElement('div');
          item.className = `grid-item ${isSelected ? 'item-selected' : ''}`;
          item.onclick = () => selectFile(file);
          
          const badgeChecked = isSelected ? `
            <div class="item-badge-checked">
              <span class="material-symbols-outlined material-fill">check</span>
            </div>
          ` : '<div class="item-badge-hover"></div>';
          
          const isLinked = file.linkedProducts && file.linkedProducts.length > 0;
          const linkBadge = isLinked ? `
            <div class="item-badge-linked" title="Đang được sử dụng bởi sản phẩm">
              <span class="material-symbols-outlined material-fill" style="font-size: 14px;">link</span>
            </div>
          ` : '';
          
          item.innerHTML = `
            ${badgeChecked}
            ${linkBadge}
            <div class="item-img" style="background-image: url('${file.url}')"></div>
            <div class="item-overlay ${isSelected ? 'item-overlay-visible' : ''}">
              <p class="item-title">${fileName}</p>
            </div>
          `;
          mediaGrid.appendChild(item);
      });
  }

  function renderSidebar() {
      if (!selectedFile) {
          detailsSidebar.style.display = 'none';
          return;
      }
      
      const fileName = getFileName(selectedFile.key);
      const isImg = fileName.match(/\.(jpeg|jpg|gif|png|webp|avif|svg)$/i) != null;
      
      detailsContent.innerHTML = `
        <div class="preview-box">
          <div class="preview-img" style="${isImg ? `background-image: url('${selectedFile.url}')` : 'background: #3f3f46; display:flex; align-items:center; justify-content:center;'}">
            ${!isImg ? '<span class="material-symbols-outlined" style="font-size: 48px; color: #94a3b8;">insert_drive_file</span>' : ''}
          </div>
        </div>
        <div class="info-group">
          <div>
            <label class="info-label">Tên tệp</label>
            <p class="info-val break-words">${fileName}</p>
          </div>
          <div class="info-grid-2">
            <div>
              <label class="info-label">Kích thước</label>
              <p class="info-val">${formatBytes(selectedFile.size)}</p>
            </div>
            <div>
              <label class="info-label">Ngày tải lên</label>
              <p class="info-val" style="font-size: 11px;">${formatDate(selectedFile.lastModified)}</p>
            </div>
          </div>
            <div>
              <label class="info-label">URL Tệp</label>
              <p class="info-val break-words" style="font-size: 11px; color: #94a3b8;">${selectedFile.url}</p>
            </div>
          </div>
          ${selectedFile.linkedProducts && selectedFile.linkedProducts.length > 0 ? `
            <div style="margin-top: 16px; padding: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 8px;">
              <div style="display:flex; align-items:center; gap:6px; color:#ef4444; font-weight:700; font-size:12px; margin-bottom: 6px;">
                <span class="material-symbols-outlined material-fill" style="font-size:16px;">warning</span>
                Ảnh đang được sử dụng
              </div>
              <ul style="margin:0; padding-left:16px; color:#fca5a5; font-size:11px;">
                ${selectedFile.linkedProducts.map((p) => `<li>${p}</li>`).join('')}
              </ul>
              <p style="margin-top: 6px; font-size: 10px; color: #f87171;">Xóa tệp này sẽ làm mất ảnh của (các) sản phẩm trên.</p>
            </div>
          ` : ''}
      `;
      
      detailsSidebar.style.display = 'flex';
  }

  function selectFile(file) {
      if (selectedFile && selectedFile.key === file.key) {
          selectedFile = null; // deselect
      } else {
          selectedFile = file;
      }
      renderGrid();
      renderSidebar();
  }

  function renderFolderTree() {
      const dirNav = document.getElementById('dir-nav');
      if (!dirNav) return;
      
      // Extract unique folders from paths
      const folders = new Set();
      filesData.forEach(file => {
          const parts = file.key.split('/');
          // If the file is in a subfolder inside flysky-media, like 'flysky-media/folder/img.jpg'
          if (parts.length > 2) { 
               // e.g. parts = ['flysky-media', 'Guitar Acoustic', 'img.jpg']
               const folderName = parts[1];
               folders.add(folderName);
          }
      });

      let html = `
        <a class="nav-item nav-item-active" href="#">
          <span class="material-symbols-outlined material-fill">folder_open</span>
          <span class="nav-text">Tất cả tệp</span>
        </a>
      `;

      Array.from(folders).sort().forEach(folder => {
          html += `
            <a class="nav-item" href="#">
              <span class="material-symbols-outlined">folder</span>
              <span class="nav-text">${folder}</span>
            </a>
          `;
      });

      dirNav.innerHTML = html;
  }

  async function fetchMedia() {
      try {
          mediaLoading.style.display = 'flex';
          mediaGrid.style.display = 'none';
          const res = await fetch('/api/media/list');
          const data = await res.json();
          if (data.success) {
              filesData = data.files;
              selectedFile = null;
              renderFolderTree();
              renderGrid();
              renderSidebar();
              mediaLoading.style.display = 'none';
              mediaGrid.style.display = 'grid';
          } else {
              showToast('Không thể tải danh sách tệp', 'error');
          }
      } catch (e) {
          showToast('Lỗi kết nối máy chủ', 'error');
      }
  }

  async function handleFileUpload(e) {
      const files = e.target.files;
      if (!files || files.length === 0) return;
      
      showToast('Đang tải lên...', 'success');
      
      for (let i = 0; i < files.length; i++) {
          const formData = new FormData();
          formData.append('file', files[i]);
          
          try {
              const res = await fetch('/api/upload', {
                  method: 'POST',
                  body: formData
              });
              const data = await res.json();
              if (data.success && data.url) {
                  // Prepend to filesData immediately for quick feedback
                  filesData.unshift({
                      key: data.path,
                      url: data.url,
                      size: files[i].size,
                      lastModified: new Date().toISOString()
                  });
              } else {
                  showToast(`Lỗi tải lên: ${files[i].name}`, 'error');
              }
          } catch (err) {
              showToast(`Lỗi tải lên: ${files[i].name}`, 'error');
          }
      }
      
      showToast('Tải lên hoàn tất!', 'success');
      selectedFile = filesData[0]; // Select the most recently uploaded
      renderGrid();
      renderSidebar();
      
      // Clear input
      e.target.value = '';
  }

  async function handleDelete() {
      if (!selectedFile) return;
      
      const isLinked = selectedFile.linkedProducts && selectedFile.linkedProducts.length > 0;
      let confirmMessage = `Bạn có chắc muốn xóa tệp này vĩnh viễn không?`;
      if (isLinked) {
          confirmMessage = `CẢNH BÁO: Tệp này đang được sử dụng bởi ${selectedFile.linkedProducts.length} sản phẩm (VD: ${selectedFile.linkedProducts[0]}).\n\nNếu bạn tiếp tục xóa, ảnh của các sản phẩm này cũng sẽ bị gỡ bỏ.\nBạn có chắc chắn muốn XÓA LIÊN HOÀN không?`;
      }

      if (!confirm(confirmMessage)) return;
      
      const originalBtnText = btnDelete.innerHTML;
      btnDelete.innerHTML = '<span class="material-symbols-outlined icon-norm" style="animation: spin 1s linear infinite;">autorenew</span> Đang xóa...';
      btnDelete.disabled = true;
      
      try {
          const res = await fetch('/api/media/delete', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ key: selectedFile.key })
          });
          const data = await res.json();
          
          if (data.success) {
              filesData = filesData.filter(f => f.key !== selectedFile.key);
              selectedFile = null;
              renderGrid();
              renderSidebar();
              showToast('Đã xóa tệp thành công!', 'success');
          } else {
              showToast(data.error || 'Không thể xóa tệp', 'error');
          }
      } catch (e) {
          showToast('Lỗi máy chủ khi xóa tệp', 'error');
      } finally {
          btnDelete.innerHTML = originalBtnText;
          btnDelete.disabled = false;
      }
  }
  
  function copyToClipboard() {
      if (!selectedFile) return;
      navigator.clipboard.writeText(selectedFile.url).then(() => {
          const originalText = btnCopy.innerHTML;
          btnCopy.innerHTML = '<span class="material-symbols-outlined icon-norm">check</span> Đã sao chép!';
          btnCopy.style.background = '#10b981';
          showToast('Đã chép URL vào khay nhớ!', 'success');
          
          setTimeout(() => {
              btnCopy.innerHTML = originalText;
              btnCopy.style.background = '';
          }, 2000);
      });
  }

  const gridScrollArea = document.querySelector('.grid-scroll-area');
  if (gridScrollArea) {
      gridScrollArea.addEventListener('click', (e) => {
          // If the user clicked directly on the flex container or grid container (the empty space), deselect.
          if (e.target.classList.contains('grid-scroll-area') || e.target.id === 'media-grid') {
              selectedFile = null;
              renderGrid();
              renderSidebar();
          }
      });
  }

  // Initialize
  if (fileUpload) fileUpload.addEventListener('change', handleFileUpload);
  if (btnDelete) btnDelete.addEventListener('click', handleDelete);
  if (btnCopy) btnCopy.addEventListener('click', copyToClipboard);

  document.addEventListener('DOMContentLoaded', fetchMedia);
</script>

<style is:global>
  /* Override the default padding and scrolling from AdminLayout's content-scroll to make this a full screen flex container */
  .content-scroll:has(.media-container) {
    padding: 0 !important;
    overflow: hidden !important;
    display: flex;
    flex-direction: column;
  }
</style>

<style is:global>
  /* ══ GENERAL & LAYOUT ══ */
  .material-fill { font-variation-settings: 'FILL' 1; }
  .text-primary { color: #f48c25; }
  .text-red { color: #ef4444; }
  .break-words { word-break: break-all; }
  
  .media-container {
    display: flex;
    height: 100%;
    width: 100%;
    overflow: hidden;
    background: #221910;
  }

  /* ══ DIRECTORY SIDEBAR ══ */
  .dir-sidebar {
    width: 240px;
    border-right: 1px solid rgba(244,140,37,0.1);
    background: rgba(34,25,16,0.8);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }
  .dir-header {
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .dir-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
  }
  .icon-btn {
    padding: 6px;
    border-radius: 8px;
    color: #f48c25;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .icon-btn:hover {
    background: rgba(244,140,37,0.1);
  }
  .icon-btn .material-symbols-outlined { font-size: 20px; }

  .dir-nav {
    flex: 1;
    padding: 0 12px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 8px;
    color: #94a3b8;
    text-decoration: none;
    transition: all 0.2s;
  }
  .nav-item:hover {
    background: rgba(244,140,37,0.05);
    color: #f48c25;
  }
  .nav-item-active {
    background: rgba(244,140,37,0.1);
    color: #f48c25;
  }
  .nav-text {
    font-size: 14px;
    font-weight: 500;
  }
  .nav-item .material-symbols-outlined { font-size: 18px; }

  .nav-group-wrapper {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sub-nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-left: 24px;
    border-left: 1px solid rgba(244,140,37,0.1);
    padding-left: 8px;
  }
  .sub-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-radius: 6px;
    color: #64748b;
    font-size: 12px;
    text-decoration: none;
    transition: color 0.2s;
  }
  .sub-item:hover {
    color: #f48c25;
  }

  /* ══ MAIN CONTENT ══ */
  .media-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: rgba(24,24,27,0.3); /* dark:bg-zinc-900/30 */
  }

  /* Header */
  .media-header {
    height: 64px;
    border-bottom: 1px solid rgba(244,140,37,0.1);
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(34,25,16,0.5);
    backdrop-filter: blur(12px);
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 24px;
    flex: 1;
  }
  .bc-flex {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
    font-weight: 700;
  }
  .bc-text-muted { color: #94a3b8; font-weight: 500; }
  .bc-separator { color: #64748b; font-size: 14px; }
  .bc-text-active { color: #fff; }

  .search-box {
    position: relative;
    width: 100%;
    max-width: 400px;
  }
  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-size: 18px;
  }
  .search-input {
    width: 100%;
    padding: 8px 16px 8px 36px;
    background: #27272a; /* dark:bg-zinc-800 */
    border: none;
    border-radius: 8px;
    color: #f1f5f9;
    font-size: 14px;
    outline: none;
    transition: box-shadow 0.2s;
  }
  .search-input:focus {
    box-shadow: 0 0 0 2px #f48c25;
  }
  .search-input::placeholder { color: #64748b; }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .btn-upload {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #f48c25;
    color: #fff;
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 14px;
    border: none;
    cursor: pointer;
    transition: filter 0.2s;
  }
  .btn-upload:hover { filter: brightness(1.1); }
  .btn-upload .material-symbols-outlined { font-size: 18px; }

  /* Toolbar Filter */
  .toolbar {
    padding: 16px 24px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(244,140,37,0.1);
    background: rgba(24,24,27,0.1);
  }
  .filters-flex {
    display: flex;
    align-items: center;
    gap: 8px;
    overflow-x: auto;
  }
  .filter-chip {
    padding: 6px 16px;
    border-radius: 9999px;
    background: #27272a;
    color: #94a3b8;
    font-size: 14px;
    font-weight: 500;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-chip:hover {
    background: #3f3f46;
  }
  .chip-active {
    background: rgba(244,140,37,0.2);
    color: #f48c25;
    border-color: rgba(244,140,37,0.2);
    font-weight: 600;
  }
  .chip-active:hover { background: rgba(244,140,37,0.2); }
  
  .divider-y {
    width: 1px;
    height: 24px;
    background: rgba(244,140,37,0.1);
    margin: 0 8px;
  }
  .sort-select {
    background: transparent;
    border: none;
    color: #94a3b8;
    font-size: 14px;
    font-weight: 500;
    outline: none;
    cursor: pointer;
  }

  .actions-flex {
    display: flex;
    align-items: center;
    gap: 4px;
    border-left: 1px solid rgba(244,140,37,0.1);
    padding-left: 16px;
    margin-left: 16px;
  }
  .action-icon {
    padding: 8px;
    border-radius: 8px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #94a3b8;
    transition: all 0.2s;
  }
  .action-icon:hover {
    background: rgba(244,140,37,0.1);
  }
  .action-icon.text-red:hover {
    background: rgba(239,68,68,0.1);
    color: #ef4444;
  }
  .action-icon.text-primary:hover {
    color: #f48c25;
