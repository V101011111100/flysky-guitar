---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// Lấy sản phẩm từ CSDL để hiển thị
const { data: products, error } = await supabase
  .from('products')
  .select(`
    *,
    categories ( name )
  `)
  .order('created_at', { ascending: false });

const items = products?.map(p => ({
  id: p.id,
  catId: p.category_id,
  sku: p.slug?.toUpperCase() || 'NO-SKU',
  name: p.name,
  img: (p.gallery_images && p.gallery_images.length > 0) ? p.gallery_images[0] : '/images/default-guitar.webp',
  cat: p.categories?.name || 'Khác',
  rawPrice: p.price || 0,
  price: new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.price || 0),
  qty: p.stock_quantity ?? 0,
  pct: Math.min(100, (p.stock_quantity ?? 0) * 2), // visually scale max 50 for the bar
  status: p.status === 'out_of_stock' || (p.stock_quantity ?? 0) <= 0 ? 'out' : (p.stock_quantity < 10 ? 'low' : 'in'),
  dbStatus: p.status,
  desc: p.description || '',
  spec_body: p.spec_body || '',
  spec_top: p.spec_top || '',
  spec_neck: p.spec_neck || ''
})) || [];

const totalItems = items.length;
const lowStock = items.filter(i => i.status === 'low').length;
const inStock = items.filter(i => i.status === 'in').length;
const outOfStock = items.filter(i => i.status === 'out').length;
---

<AdminLayout
  title="Quản lý Kho hàng"
  subtitle="Theo dõi và cập nhật số lượng tồn kho theo thời gian thực"
  activeNav="inventory"
>
  <!-- ── HEADER ACTIONS ── -->
  <div class="inv-actions">
    <div class="search-box">
      <span class="material-symbols-outlined search-icon">search</span>
      <input type="text" placeholder="Tìm kiếm sản phẩm..." class="search-input" />
    </div>
    <div class="header-btns-group">
      <input type="file" id="excel-import-input" accept=".xlsx, .xls, .csv" style="display: none;" />
      <button class="btn-ghost" onclick="document.getElementById('excel-import-input').click()">
        <span class="material-symbols-outlined">upload_file</span>
        <span class="btn-label-full">Nhập Excel</span>
        <span class="btn-label-short" style="display:none;">Nhập</span>
      </button>
      
      <!-- Export Dropdown -->
      <div class="export-dropdown-wrapper">
        <button class="btn-ghost" id="btn-export-menu">
          <span class="material-symbols-outlined">download</span>
          <span class="btn-label-full">Xuất Excel</span>
          <span class="btn-label-short" style="display:none;">Xuất</span>
          <span class="material-symbols-outlined" style="font-size: 16px; margin-left: 4px;">expand_more</span>
        </button>
        <div class="export-menu hidden" id="export-menu">
          <a href="/api/products/export?format=full" class="export-menu-item" title="Xuất toàn bộ sản phẩm">
            <span class="material-symbols-outlined">inventory_2</span>
            <span>Tất cả sản phẩm</span>
          </a>
          <a href="/api/products/export?format=active" class="export-menu-item" title="Chỉ xuất sản phẩm đang bán">
            <span class="material-symbols-outlined">check_circle</span>
            <span>Sản phẩm hoạt động</span>
          </a>
          <a href="/api/products/export?format=lowstock" class="export-menu-item" title="Xuất sản phẩm sắp hết hàng">
            <span class="material-symbols-outlined">warning</span>
            <span>Sắp hết hàng</span>
          </a>
        </div>
      </div>
      
      <a href="/admin/products" class="btn-add-inv" style="text-decoration: none;">
        <span class="material-symbols-outlined">add_circle</span>
        <span class="btn-label-full">Thêm sản phẩm mới</span>
        <span class="btn-label-short" style="display:none;">Thêm mới</span>
      </a>
    </div>
  </div>

  <!-- ── STAT CARDS ── -->
  <div class="inv-stats">

    <div class="inv-card">
      <div class="inv-card-top">
        <span class="inv-card-label">Tổng sản phẩm</span>
        <div class="inv-icon blue-icon">
          <span class="material-symbols-outlined">inventory</span>
        </div>
      </div>
      <div class="inv-card-val-row">
        <span class="inv-card-val">{totalItems}</span>
      </div>
    </div>

    <div class="inv-card">
      <div class="inv-card-top">
        <span class="inv-card-label">Sắp hết hàng</span>
        <div class="inv-icon orange-icon">
          <span class="material-symbols-outlined">warning</span>
        </div>
      </div>
      <div class="inv-card-val-row">
        <span class="inv-card-val orange-val">{lowStock}</span>
        <span class="inv-tag muted">Cần nhập sớm</span>
      </div>
    </div>

    <div class="inv-card">
      <div class="inv-card-top">
        <span class="inv-card-label">Sẵn có</span>
        <div class="inv-icon green-icon">
          <span class="material-symbols-outlined">check_circle</span>
        </div>
      </div>
      <div class="inv-card-val-row">
        <span class="inv-card-val">{inStock}</span>
      </div>
    </div>

    <div class="inv-card">
      <div class="inv-card-top">
        <span class="inv-card-label">Hết hàng</span>
        <div class="inv-icon red-icon">
          <span class="material-symbols-outlined">dangerous</span>
        </div>
      </div>
      <div class="inv-card-val-row">
        <span class="inv-card-val red-val">{outOfStock}</span>
      </div>
    </div>

  </div>

  <!-- ── TABLE CARD ── -->
  <div class="inv-table-card">
    <!-- Filter Tabs -->
    <div class="inv-tabs">
      <button class="inv-tab inv-tab-active">Tất cả</button>
      <button class="inv-tab">Đàn Guitar</button>
      <button class="inv-tab">Phụ kiện</button>
      <button class="inv-tab">Gỗ &amp; Vật liệu</button>
      <button class="inv-tab">Khác</button>
    </div>

    <!-- Table -->
    <div style="overflow-x:auto;">
      <table class="inv-table">
        <thead>
          <tr>
            <th>Mã SKU</th>
            <th>Tên sản phẩm</th>
            <th>Danh mục</th>
            <th style="text-align:right;">Giá bán</th>
            <th>Tồn kho</th>
            <th>Trạng thái</th>
            <th style="text-align:center;">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          {items.map(item => (
            <tr
              class={`inv-row ${item.status === 'out' || item.dbStatus === 'draft' ? 'row-faded' : ''}`}
              data-category={item.cat}
              data-search={`${item.sku} ${item.name} ${item.cat}`.toLowerCase()}
            >
              <td class="sku-col">
                {item.sku}
                {item.dbStatus === 'draft' && (
                  <>
                    <br/><span class="cat-chip" style="margin-top:4px;font-size:9px;">BẢN NHÁP</span>
                  </>
                )}
              </td>
              <td>
                <div class="prod-cell">
                  <div class="prod-img">
                    <img src={item.img} alt={item.name} loading="lazy" decoding="async" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.onerror=null;this.src='/images/default-guitar.webp';" />
                  </div>
                  <span class="prod-name">{item.name}</span>
                </div>
              </td>
              <td>
                <span class="cat-chip">{item.cat}</span>
              </td>
              <td class="price-col">{item.price}</td>
              <td>
                <div class="stock-cell">
                  <div class="stock-bar">
                    <div
                      class={`stock-fill ${item.status === 'in' ? 'fill-green' : item.status === 'low' ? 'fill-orange' : 'fill-red'}`}
                      style={`width:${item.pct}%`}
                    ></div>
                  </div>
                  <span class={`stock-num ${item.status === 'low' ? 'orange-txt' : item.status === 'out' ? 'red-txt' : ''}`}>
                    {item.qty}
                  </span>
                </div>
              </td>
              <td>
                {item.status === 'in' && (
                  <span class="status-dot green-status">
                    <span class="dot dot-green pulse"></span>Còn hàng
                  </span>
                )}
                {item.status === 'low' && (
                  <span class="status-dot orange-status">
                    <span class="dot dot-orange"></span>Sắp hết
                  </span>
                )}
                {item.status === 'out' && (
                  <span class="status-dot red-status">
                    <span class="dot dot-red"></span>Hết hàng
                  </span>
                )}
              </td>
              <td class="actions-center">
                <div class="act-row">
                  <a href={`/admin/products?id=${item.id}`} class="act-ico" title="Sửa">
                    <span class="material-symbols-outlined">edit</span>
                  </a>
                  <button class="act-ico text-red-400 hover:text-red-500 hover:bg-red-500/10" title="Xóa" onclick={`deleteProduct('${item.id}')`}>
                    <span class="material-symbols-outlined">delete</span>
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="inv-pagination">
      <span class="page-info">Hiển thị {totalItems > 0 ? 1 : 0}-{Math.min(10, totalItems)} trên {totalItems} sản phẩm</span>
      <div class="page-btns">
        <button class="page-nav"><span class="material-symbols-outlined">chevron_left</span></button>
        <button class="pnum pnum-active">1</button>
        <button class="page-nav"><span class="material-symbols-outlined">chevron_right</span></button>
      </div>
    </div>
  </div>

  <!-- Import Preview Modal -->
  <div id="import-preview-modal" class="modal hidden">
    <div class="modal-overlay" onclick="closeImportModal()"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h2>Preview dữ liệu nhập</h2>
        <button class="close-btn" onclick="closeImportModal()"><span class="material-symbols-outlined">close</span></button>
      </div>
      
      <div class="modal-body">
        <div class="preview-stats">
          <div class="stat-box">
            <span class="stat-label">Tổng dòng:</span>
            <span class="stat-value" id="preview-total">0</span>
          </div>
          <div class="stat-box">
            <span class="stat-label">Hợp lệ:</span>
            <span class="stat-value valid" id="preview-valid">0</span>
          </div>
          <div class="stat-box">
            <span class="stat-label">Lỗi:</span>
            <span class="stat-value error" id="preview-errors">0</span>
          </div>
          <div class="stat-box">
            <span class="stat-label">Bỏ qua:</span>
            <span class="stat-value warning" id="preview-skipped">0</span>
          </div>
        </div>

        <div class="preview-warnings" id="preview-warnings-box" style="display: none;">
          <p class="warning-title">⚠️ Các dòng bỏ qua:</p>
          <ul id="preview-warnings-list"></ul>
        </div>

        <div class="preview-table-wrapper">
          <p class="preview-label">Preview dữ liệu (10 dòng đầu):</p>
          <table class="preview-table">
            <thead>
              <tr>
                <th>Tên sản phẩm</th>
                <th>SKU</th>
                <th>Danh mục</th>
                <th>Giá</th>
                <th>Tồn kho</th>
                <th>Trạng thái</th>
              </tr>
            </thead>
            <tbody id="preview-table-body">
              <!-- Auto-populated by JS -->
            </tbody>
          </table>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn-cancel" onclick="closeImportModal()">Hủy</button>
        <button class="btn-confirm" id="btn-confirm-import" onclick="confirmImport()">
          <span class="material-symbols-outlined">upload_file</span>
          Tiếp tục nhập
        </button>
      </div>
    </div>
  </div>

</AdminLayout>

<script>
  let pendingFile: File | null = null;

  // Close import modal
  (window as any).closeImportModal = () => {
    const modal = document.getElementById('import-preview-modal');
    if (modal) modal.classList.add('hidden');
    pendingFile = null;
    const fileInput = document.getElementById('excel-import-input') as HTMLInputElement;
    if (fileInput) fileInput.value = '';
  };

  // Confirm import after preview
  (window as any).confirmImport = async () => {
    if (!pendingFile) return;
    
    const modal = document.getElementById('import-preview-modal');
    const confirmBtn = document.getElementById('btn-confirm-import') as HTMLButtonElement;
    
    if (modal && confirmBtn) {
      confirmBtn.disabled = true;
      confirmBtn.innerHTML = '<span class="material-symbols-outlined">hourglass_bottom</span> Đang nhập...';
    }

    const formData = new FormData();
    formData.append('file', pendingFile);

    try {
      const res = await fetch('/api/products/import', {
        method: 'POST',
        body: formData
      });
      const data = await res.json();
      
      if (data.success) {
        const skipped = Number(data.skippedCount || 0);
        const failed = Number(data.failedCount || 0);
        const parts = [`✅ Nhập thành công ${data.count} sản phẩm!`];
        if (skipped > 0) parts.push(`📝 Bỏ qua ${skipped} dòng.`);
        if (failed > 0) parts.push(`⚠️ ${failed} dòng lỗi.`);
        
        alert(parts.join('\n'));
        window.location.reload();
      } else {
        alert('❌ Lỗi nhập: ' + (data.error || 'Không xác định'));
      }
    } catch (err) {
      alert('❌ Lỗi kết nối máy chủ.');
    } finally {
      if (confirmBtn) {
        confirmBtn.disabled = false;
        confirmBtn.innerHTML = '<span class="material-symbols-outlined">upload_file</span> Tiếp tục nhập';
      }
      (window as any).closeImportModal();
    }
  };

  const fileInput = document.getElementById('excel-import-input') as HTMLInputElement;
  if(fileInput) {
    fileInput.addEventListener('change', async () => {
      const file = fileInput.files?.[0];
      if(!file) return;

      pendingFile = file;
      
      // Show loading state
      const modal = document.getElementById('import-preview-modal');
      const tbody = document.getElementById('preview-table-body');
      if (modal && tbody) {
        modal.classList.remove('hidden');
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:20px;"><span class="material-symbols-outlined" style="animation: spin 1s linear infinite;">hourglass_bottom</span> Đang xử lý file...</td></tr>';
      }

      const formData = new FormData();
      formData.append('file', file);

      try {
        const res = await fetch('/api/products/import-preview', {
          method: 'POST',
          body: formData
        });
        const data = await res.json();

        if (!data.success) {
          alert('❌ ' + (data.error || 'Lỗi xử lý file'));
          (window as any).closeImportModal();
          return;
        }

        // Update stats
        document.getElementById('preview-total')!.textContent = data.totalRows;
        document.getElementById('preview-valid')!.textContent = data.validRows;
        document.getElementById('preview-errors')!.textContent = data.errorCount;
        document.getElementById('preview-skipped')!.textContent = data.skippedCount;

        // Show warnings if any
        const warningsBox = document.getElementById('preview-warnings-box');
        const warningsList = document.getElementById('preview-warnings-list');
        if (data.skippedDetails && data.skippedDetails.length > 0 && warningsBox && warningsList) {
          warningsList.innerHTML = data.skippedDetails.map((skip: any) => 
            `<li>Dòng ${skip.rowIndex}: ${skip.reason}</li>`
          ).join('');
          warningsBox.style.display = 'block';
        } else if (warningsBox) {
          warningsBox.style.display = 'none';
        }

        // Populate preview table
        if (tbody && data.preview) {
          tbody.innerHTML = data.preview.map((row: any) => `
            <tr ${row.errors.length > 0 ? 'class="row-error"' : ''}>
              <td><strong>${row.formatted.name}</strong></td>
              <td>${row.formatted.sku}</td>
              <td>${row.formatted.category}</td>
              <td>${row.formatted.price.toLocaleString('vi-VN')} ₫</td>
              <td>${row.formatted.stock}</td>
              <td>${row.errors.length > 0 ? `<span class="error-badge">${row.errors.join('; ')}</span>` : '<span class="ok-badge">✓</span>'}</td>
            </tr>
          `).join('');
        }

      } catch (err) {
        alert('❌ Lỗi xử lý file. Vui lòng thử lại.');
        (window as any).closeImportModal();
      }
    });
  }

  const btnExport = document.getElementById('btn-export-menu');
  const exportMenu = document.getElementById('export-menu');
  
  if(btnExport && exportMenu) {
    btnExport.addEventListener('click', (e) => {
      e.stopPropagation();
      exportMenu.classList.toggle('hidden');
    });
    
    // Close menu when clicking outside
    document.addEventListener('click', () => {
      exportMenu.classList.add('hidden');
    });
    
    // Prevent closing when clicking on menu items
    exportMenu.addEventListener('click', (e) => {
      e.stopPropagation();
    });
  }

  // --- Filter Tabs Logic ---
  const tabs = document.querySelectorAll('.inv-tab');
  const rows = document.querySelectorAll('.inv-row');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Update active tab styling
      tabs.forEach(t => t.classList.remove('inv-tab-active'));
      tab.classList.add('inv-tab-active');

      const selectedCat = tab.textContent?.trim();

      // Show/hide rows
      rows.forEach(row => {
        const rowCat = (row as HTMLElement).dataset.category;
        
        // Flexible matching
        let match = false;
        if (selectedCat === 'Tất cả') {
          match = true;
        } else if (selectedCat === 'Đàn Guitar') {
          // match Đàn Guitar Điện, Đàn Guitar Acoustic
          match = rowCat?.includes('Guitar') || false;
        } else {
          match = rowCat?.includes(selectedCat) || false;
        }

        if (match) {
          (row as HTMLElement).style.display = '';
        } else {
          (row as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  // --- Search by tên / SKU / danh mục ---
  const searchInput = document.querySelector('.search-input') as HTMLInputElement | null;
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      rows.forEach(row => {
        const el = row as HTMLElement;
        const baseMatch = !q || (el.dataset.search || '').includes(q) || (el.textContent || '').toLowerCase().includes(q);
        el.style.display = baseMatch ? '' : 'none';
      });
    });
  }

  // Delete product function
  (window as any).deleteProduct = async (id: any) => {
    if(confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')) {
      try {
        const res = await fetch('/api/products/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });
        const data = await res.json();
        if(data.success) {
          window.location.reload();
        } else {
          alert('Lỗi: ' + data.error);
        }
      } catch(err) {
        alert('Lỗi khi xóa!');
      }
    }
  };

</script>

<style>
  .inv-actions {
    display: flex; gap: 12px; align-items: center;
    justify-content: flex-end;
    margin-bottom: 24px;
  }
  .search-box {
    position: relative;
    display: flex; align-items: center;
  }
  .search-icon {
    position: absolute; left: 12px;
    font-size: 20px; color: rgba(244,140,37,.4);
    pointer-events: none;
  }
  .search-input {
    padding: 9px 16px 9px 40px;
    width: 260px;
    background: rgba(244,140,37,.05);
    border: 1px solid rgba(244,140,37,.2);
    border-radius: 8px;
    font-size: 13px; color: #f1f5f9;
    font-family: 'Manrope', sans-serif;
    outline: none; transition: border .2s;
  }
  .search-input::placeholder { color: rgba(244,140,37,.35); }
  .search-input:focus { border-color: #f48c25; }
  .header-btns-group { display: flex; gap: 8px; align-items: center; position: relative; }
  .btn-ghost {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: 8px;
    border: 1px solid rgba(244,140,37,.3); background: rgba(244,140,37,.05); color: #f48c25;
    font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Manrope', sans-serif;
    transition: all .15s;
  }
  .btn-ghost:hover { background: rgba(244,140,37,.15); }
  .btn-ghost .material-symbols-outlined { font-size: 18px; }

  .btn-add-inv {
    display: flex; align-items: center; gap: 8px;
    padding: 9px 18px; border-radius: 8px;
    background: #f48c25; color: #221910;
    font-size: 13px; font-weight: 700;
    border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    transition: filter .15s;
  }
  .btn-add-inv:hover { filter: brightness(1.1); }
  .btn-add-inv .material-symbols-outlined { font-size: 18px; }

  /* ── STATS ── */
  .inv-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }
  .inv-card {
    background: rgba(244,140,37,.05);
    border: 1px solid rgba(244,140,37,.1);
    border-radius: 12px;
    padding: 20px;
    display: flex; flex-direction: column; gap: 12px;
    transition: border-color .2s;
  }
  .inv-card:hover { border-color: rgba(244,140,37,.25); }
  .inv-card-top {
    display: flex; justify-content: space-between; align-items: center;
  }
  .inv-card-label {
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .12em;
    color: rgba(244,140,37,.65);
  }
  .inv-icon {
    width: 36px; height: 36px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .inv-icon .material-symbols-outlined { font-size: 20px; }
  .blue-icon   { background: rgba(59,130,246,.1);  color: #60a5fa; }
  .orange-icon { background: rgba(249,115,22,.1);   color: #fb923c; }
  .green-icon  { background: rgba(16,185,129,.1);   color: #34d399; }
  .red-icon    { background: rgba(239,68,68,.1);    color: #f87171; }

  .inv-card-val-row { display: flex; align-items: flex-end; gap: 10px; }
  .inv-card-val  { font-size: 30px; font-weight: 900; color: #f9fafb; line-height: 1; }
  .orange-val    { color: #fb923c; }
  .red-val       { color: #f87171; }
  .inv-tag {
    font-size: 11px; font-weight: 700;
    margin-bottom: 4px;
    display: flex; align-items: center; gap: 2px;
  }
  .inv-tag.green { color: #34d399; }
