---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// Lấy sản phẩm từ CSDL để hiển thị
const { data: products, error } = await supabase
  .from('products')
  .select(`
    *,
    categories ( name )
  `)
  .order('created_at', { ascending: false });

const items = products?.map(p => ({
  id: p.id,
  catId: p.category_id,
  sku: p.slug?.toUpperCase() || 'NO-SKU',
  name: p.name,
  img: p.main_image_url || 'https://images.unsplash.com/photo-1541689592655-f5f52825a3b8?w=200&q=70',
  cat: p.categories?.name || 'Khác',
  rawPrice: p.price || 0,
  price: new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.price || 0),
  qty: p.stock_quantity ?? 0,
  pct: Math.min(100, (p.stock_quantity ?? 0) * 2), // visually scale max 50 for the bar
  status: p.status === 'out_of_stock' || (p.stock_quantity ?? 0) <= 0 ? 'out' : (p.stock_quantity < 10 ? 'low' : 'in'),
  dbStatus: p.status,
  desc: p.description || '',
  spec_body: p.spec_body || '',
  spec_top: p.spec_top || '',
  spec_neck: p.spec_neck || ''
})) || [];

const totalItems = items.length;
const lowStock = items.filter(i => i.status === 'low').length;
const inStock = items.filter(i => i.status === 'in').length;
const outOfStock = items.filter(i => i.status === 'out').length;
---

<AdminLayout
  title="Quản lý Kho hàng"
  subtitle="Theo dõi và cập nhật số lượng tồn kho theo thời gian thực"
  activeNav="inventory"
>
  <!-- ── HEADER ACTIONS ── -->
  <div class="inv-actions">
    <div class="search-box">
      <span class="material-symbols-outlined search-icon">search</span>
      <input type="text" placeholder="Tìm kiếm sản phẩm..." class="search-input" />
    </div>
    <div class="header-btns-group">
      <input type="file" id="excel-import-input" accept=".xlsx, .xls, .csv" style="display: none;" />
      <button class="btn-ghost" onclick="document.getElementById('excel-import-input').click()">
        <span class="material-symbols-outlined">upload_file</span>
        Nhập Excel
      </button>
      <button class="btn-ghost" id="btn-export-excel">
        <span class="material-symbols-outlined">download</span>
        Xuất Excel
      </button>
      <a href="/admin/products" class="btn-add-inv" style="text-decoration: none;">
        <span class="material-symbols-outlined">add_circle</span>
        Thêm sản phẩm mới
      </a>
    </div>
  </div>

  <!-- ── STAT CARDS ── -->
  <div class="inv-stats">

    <div class="inv-card">
      <div class="inv-card-top">
        <span class="inv-card-label">Tổng sản phẩm</span>
        <div class="inv-icon blue-icon">
          <span class="material-symbols-outlined">inventory</span>
        </div>
      </div>
      <div class="inv-card-val-row">
        <span class="inv-card-val">{totalItems}</span>
      </div>
    </div>

    <div class="inv-card">
      <div class="inv-card-top">
        <span class="inv-card-label">Sắp hết hàng</span>
        <div class="inv-icon orange-icon">
          <span class="material-symbols-outlined">warning</span>
        </div>
      </div>
      <div class="inv-card-val-row">
        <span class="inv-card-val orange-val">{lowStock}</span>
        <span class="inv-tag muted">Cần nhập sớm</span>
      </div>
    </div>

    <div class="inv-card">
      <div class="inv-card-top">
        <span class="inv-card-label">Sẵn có</span>
        <div class="inv-icon green-icon">
          <span class="material-symbols-outlined">check_circle</span>
        </div>
      </div>
      <div class="inv-card-val-row">
        <span class="inv-card-val">{inStock}</span>
      </div>
    </div>

    <div class="inv-card">
      <div class="inv-card-top">
        <span class="inv-card-label">Hết hàng</span>
        <div class="inv-icon red-icon">
          <span class="material-symbols-outlined">dangerous</span>
        </div>
      </div>
      <div class="inv-card-val-row">
        <span class="inv-card-val red-val">{outOfStock}</span>
      </div>
    </div>

  </div>

  <!-- ── TABLE CARD ── -->
  <div class="inv-table-card">
    <!-- Filter Tabs -->
    <div class="inv-tabs">
      <button class="inv-tab inv-tab-active">Tất cả</button>
      <button class="inv-tab">Đàn Guitar</button>
      <button class="inv-tab">Phụ kiện</button>
      <button class="inv-tab">Gỗ &amp; Vật liệu</button>
      <button class="inv-tab">Khác</button>
    </div>

    <!-- Table -->
    <div style="overflow-x:auto;">
      <table class="inv-table">
        <thead>
          <tr>
            <th>Mã SKU</th>
            <th>Tên sản phẩm</th>
            <th>Danh mục</th>
            <th style="text-align:right;">Giá bán</th>
            <th>Tồn kho</th>
            <th>Trạng thái</th>
            <th style="text-align:center;">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          {items.map(item => (
            <tr class={`inv-row ${item.status === 'out' || item.dbStatus === 'draft' ? 'row-faded' : ''}`} data-category={item.cat}>
              <td class="sku-col">
                {item.sku}
                {item.dbStatus === 'draft' && (
                  <>
                    <br/><span class="cat-chip" style="margin-top:4px;font-size:9px;">BẢN NHÁP</span>
                  </>
                )}
              </td>
              <td>
                <div class="prod-cell">
                  <div class="prod-img">
                    <img src={item.img} alt={item.name} loading="lazy" decoding="async" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1541689592655-f5f52825a3b8?auto=format&fit=crop&w=200&q=70';" />
                  </div>
                  <span class="prod-name">{item.name}</span>
                </div>
              </td>
              <td>
                <span class="cat-chip">{item.cat}</span>
              </td>
              <td class="price-col">{item.price}</td>
              <td>
                <div class="stock-cell">
                  <div class="stock-bar">
                    <div
                      class={`stock-fill ${item.status === 'in' ? 'fill-green' : item.status === 'low' ? 'fill-orange' : 'fill-red'}`}
                      style={`width:${item.pct}%`}
                    ></div>
                  </div>
                  <span class={`stock-num ${item.status === 'low' ? 'orange-txt' : item.status === 'out' ? 'red-txt' : ''}`}>
                    {item.qty}
                  </span>
                </div>
              </td>
              <td>
                {item.status === 'in' && (
                  <span class="status-dot green-status">
                    <span class="dot dot-green pulse"></span>Còn hàng
                  </span>
                )}
                {item.status === 'low' && (
                  <span class="status-dot orange-status">
                    <span class="dot dot-orange"></span>Sắp hết
                  </span>
                )}
                {item.status === 'out' && (
                  <span class="status-dot red-status">
                    <span class="dot dot-red"></span>Hết hàng
                  </span>
                )}
              </td>
              <td class="actions-center">
                <div class="act-row">
                  <a href={`/admin/products?id=${item.id}`} class="act-ico" title="Sửa">
                    <span class="material-symbols-outlined">edit</span>
                  </a>
                  <button class="act-ico text-red-400 hover:text-red-500 hover:bg-red-500/10" title="Xóa" onclick={`deleteProduct('${item.id}')`}>
                    <span class="material-symbols-outlined">delete</span>
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="inv-pagination">
      <span class="page-info">Hiển thị {totalItems > 0 ? 1 : 0}-{Math.min(10, totalItems)} trên {totalItems} sản phẩm</span>
      <div class="page-btns">
        <button class="page-nav"><span class="material-symbols-outlined">chevron_left</span></button>
        <button class="pnum pnum-active">1</button>
        <button class="page-nav"><span class="material-symbols-outlined">chevron_right</span></button>
      </div>
    </div>
  </div>

</AdminLayout>

<script>
  const fileInput = document.getElementById('excel-import-input') as HTMLInputElement;
  if(fileInput) {
    fileInput.addEventListener('change', async () => {
      const file = fileInput.files?.[0];
      if(!file) return;

      alert('Đang xử lý dữ liệu Excel, vui lòng đợi...');

      const formData = new FormData();
      formData.append('file', file);

      try {
        const res = await fetch('/api/products/import', {
          method: 'POST',
          body: formData
        });
        const data = await res.json();
        if(data.success) {
          alert(`Nhập thành công ${data.count} sản phẩm!`);
          window.location.reload();
        } else {
          alert('Lỗi nhập dữ liệu: ' + data.error);
        }
      } catch (err) {
        alert('Lỗi kết nối máy chủ khi nhập Excel.');
      }
      fileInput.value = ''; // Reset input
    });
  }

  const btnExport = document.getElementById('btn-export-excel');
  if(btnExport) {
    btnExport.addEventListener('click', () => {
      window.location.href = '/api/products/export';
    });
  }

  // --- Filter Tabs Logic ---
  const tabs = document.querySelectorAll('.inv-tab');
  const rows = document.querySelectorAll('.inv-row');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Update active tab styling
      tabs.forEach(t => t.classList.remove('inv-tab-active'));
      tab.classList.add('inv-tab-active');

      const selectedCat = tab.textContent?.trim();

      // Show/hide rows
      rows.forEach(row => {
        const rowCat = (row as HTMLElement).dataset.category;
        
        // Flexible matching
        let match = false;
        if (selectedCat === 'Tất cả') {
          match = true;
        } else if (selectedCat === 'Đàn Guitar') {
          // match Đàn Guitar Điện, Đàn Guitar Acoustic
          match = rowCat?.includes('Guitar') || false;
        } else {
          match = rowCat?.includes(selectedCat) || false;
        }

        if (match) {
          (row as HTMLElement).style.display = '';
        } else {
          (row as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  // Delete product function
  (window as any).deleteProduct = async (id: any) => {
    if(confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')) {
      try {
        const res = await fetch('/api/products/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id })
        });
        const data = await res.json();
        if(data.success) {
          window.location.reload();
        } else {
          alert('Lỗi: ' + data.error);
        }
      } catch(err) {
        alert('Lỗi khi xóa!');
      }
    }
  };

</script>

<style>
  .inv-actions {
    display: flex; gap: 12px; align-items: center;
    justify-content: flex-end;
    margin-bottom: 24px;
  }
  .search-box {
    position: relative;
    display: flex; align-items: center;
  }
  .search-icon {
    position: absolute; left: 12px;
    font-size: 20px; color: rgba(244,140,37,.4);
    pointer-events: none;
  }
  .search-input {
    padding: 9px 16px 9px 40px;
    width: 260px;
    background: rgba(244,140,37,.05);
    border: 1px solid rgba(244,140,37,.2);
    border-radius: 8px;
    font-size: 13px; color: #f1f5f9;
    font-family: 'Manrope', sans-serif;
    outline: none; transition: border .2s;
  }
  .search-input::placeholder { color: rgba(244,140,37,.35); }
  .search-input:focus { border-color: #f48c25; }
  .header-btns-group { display: flex; gap: 8px; align-items: center; }
  .btn-ghost {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: 8px;
    border: 1px solid rgba(244,140,37,.3); background: rgba(244,140,37,.05); color: #f48c25;
    font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Manrope', sans-serif;
    transition: all .15s;
  }
  .btn-ghost:hover { background: rgba(244,140,37,.15); }
  .btn-ghost .material-symbols-outlined { font-size: 18px; }

  .btn-add-inv {
    display: flex; align-items: center; gap: 8px;
    padding: 9px 18px; border-radius: 8px;
    background: #f48c25; color: #221910;
    font-size: 13px; font-weight: 700;
    border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    transition: filter .15s;
  }
  .btn-add-inv:hover { filter: brightness(1.1); }
  .btn-add-inv .material-symbols-outlined { font-size: 18px; }

  /* ── STATS ── */
  .inv-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }
  .inv-card {
    background: rgba(244,140,37,.05);
    border: 1px solid rgba(244,140,37,.1);
    border-radius: 12px;
    padding: 20px;
    display: flex; flex-direction: column; gap: 12px;
    transition: border-color .2s;
  }
  .inv-card:hover { border-color: rgba(244,140,37,.25); }
  .inv-card-top {
    display: flex; justify-content: space-between; align-items: center;
  }
  .inv-card-label {
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .12em;
    color: rgba(244,140,37,.65);
  }
  .inv-icon {
    width: 36px; height: 36px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .inv-icon .material-symbols-outlined { font-size: 20px; }
  .blue-icon   { background: rgba(59,130,246,.1);  color: #60a5fa; }
  .orange-icon { background: rgba(249,115,22,.1);   color: #fb923c; }
  .green-icon  { background: rgba(16,185,129,.1);   color: #34d399; }
  .red-icon    { background: rgba(239,68,68,.1);    color: #f87171; }

  .inv-card-val-row { display: flex; align-items: flex-end; gap: 10px; }
  .inv-card-val  { font-size: 30px; font-weight: 900; color: #f9fafb; line-height: 1; }
  .orange-val    { color: #fb923c; }
  .red-val       { color: #f87171; }
  .inv-tag {
    font-size: 11px; font-weight: 700;
    margin-bottom: 4px;
    display: flex; align-items: center; gap: 2px;
  }
  .inv-tag.green { color: #34d399; }
  .inv-tag.red   { color: #f87171; }
  .inv-tag.muted { color: rgba(244,140,37,.5); font-style: italic; font-weight: 500; }

  /* ── TABLE CARD ── */
  .inv-table-card {
    background: rgba(244,140,37,.05);
    border: 1px solid rgba(244,140,37,.1);
    border-radius: 16px;
    overflow: hidden;
  }

  /* ── TABS ── */
  .inv-tabs {
    display: flex;
    border-bottom: 1px solid rgba(244,140,37,.1);
    padding: 0 8px;
    overflow-x: auto;
  }
  .inv-tabs::-webkit-scrollbar { display: none; }
  .inv-tab {
    padding: 14px 18px;
    font-size: 13px; font-weight: 600;
    background: none; border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    color: rgba(244,140,37,.55);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    white-space: nowrap;
    transition: all .15s;
  }
  .inv-tab:hover { color: #f48c25; }
  .inv-tab-active { color: #f48c25; border-bottom-color: #f48c25; font-weight: 700; }

  /* ── TABLE ── */
  .inv-table {
    width: 100%; border-collapse: collapse; text-align: left;
  }
  .inv-table thead tr {
    background: rgba(244,140,37,.08);
    border-bottom: 1px solid rgba(244,140,37,.1);
  }
  .inv-table th {
    padding: 14px 24px;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .1em;
    color: rgba(244,140,37,.6);
    white-space: nowrap;
  }
  .inv-table tbody tr {
    border-bottom: 1px solid rgba(244,140,37,.05);
    transition: background .15s;
  }
  .inv-table tbody tr:last-child { border-bottom: none; }
  .inv-table tbody tr:hover { background: rgba(244,140,37,.04); }
  .inv-table td { padding: 20px 24px; vertical-align: middle; }

  .row-faded td { opacity: 0.6; }
  .row-faded td:nth-child(5),
  .row-faded td:nth-child(6),
  .row-faded td:nth-child(7) { opacity: 1; }

  .sku-col { font-family: monospace; font-size: 13px; color: rgba(244,140,37,.5); white-space: nowrap; }

  .prod-cell { display: flex; align-items: center; gap: 12px; }
  .prod-img {
    width: 40px; height: 40px; border-radius: 8px;
    background: rgba(244,140,37,.1); flex-shrink: 0; overflow: hidden;
  }
  .prod-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prod-name { font-size: 13.5px; font-weight: 700; color: #f9fafb; }

  .cat-chip {
    display: inline-block;
    padding: 4px 12px; border-radius: 999px;
    background: rgba(244,140,37,.1);
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em;
    color: rgba(244,140,37,.8);
    white-space: nowrap;
  }

  .price-col { text-align: right; font-size: 13px; font-weight: 700; color: #f9fafb; white-space: nowrap; }

  .stock-cell { display: flex; align-items: center; gap: 12px; }
  .stock-bar {
    width: 96px; height: 6px;
    background: rgba(244,140,37,.1); border-radius: 999px; overflow: hidden; flex-shrink: 0;
  }
  .stock-fill { height: 100%; border-radius: 999px; transition: width .3s; }
  .fill-green  { background: #10b981; }
  .fill-orange { background: #f97316; }
  .fill-red    { background: #ef4444; }
  .stock-num { font-size: 13px; font-weight: 700; color: #f9fafb; }
  .orange-txt { color: #f97316; }
  .red-txt    { color: #ef4444; }

  .status-dot {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em;
  }
  .green-status  { color: #10b981; }
  .orange-status { color: #f97316; }
  .red-status    { color: #ef4444; }
  .dot {
    width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
  }
  .dot-green  { background: #10b981; }
  .dot-orange { background: #f97316; }
  .dot-red    { background: #ef4444; }
  @keyframes pulse-anim { 0%,100%{opacity:1}50%{opacity:.4} }
  .pulse { animation: pulse-anim 1.5s infinite; }

  .actions-center { text-align: center; }
  .act-row { display: flex; justify-content: center; gap: 4px; }
  .act-ico {
    width: 32px; height: 32px; border-radius: 6px;
    background: none; border: none; cursor: pointer;
    color: rgba(244,140,37,.4);
    display: flex; align-items: center; justify-content: center;
    transition: all .15s;
  }
  .act-ico:hover { background: rgba(244,140,37,.15); color: #f48c25; }
  .act-ico .material-symbols-outlined { font-size: 18px; }

  .btn-restock {
    padding: 6px 12px; border-radius: 8px;
    font-size: 11px; font-weight: 900; text-transform: uppercase;
    font-family: 'Manrope', sans-serif; cursor: pointer;
    background: rgba(244,140,37,.2); color: #f48c25;
    border: none; transition: all .15s;
  }
  .btn-restock:hover { background: #f48c25; color: #221910; }
  .btn-urgent {
    padding: 6px 12px; border-radius: 8px;
    font-size: 11px; font-weight: 900; text-transform: uppercase;
    font-family: 'Manrope', sans-serif; cursor: pointer;
    background: rgba(239,68,68,.2); color: #ef4444;
    border: none; transition: all .15s;
  }
  .btn-urgent:hover { background: #ef4444; color: #fff; }

  /* ── PAGINATION ── */
  .inv-pagination {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 24px;
    background: rgba(244,140,37,.04);
    border-top: 1px solid rgba(244,140,37,.1);
  }
  .page-info { font-size: 11px; color: rgba(244,140,37,.55); }
  .page-btns { display: flex; align-items: center; gap: 4px; }
  .page-nav {
    width: 32px; height: 32px; border-radius: 6px;
    background: none;
    border: 1px solid rgba(244,140,37,.2);
    color: #94a3b8; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .15s;
  }
  .page-nav:hover { background: rgba(244,140,37,.1); }
  .page-nav .material-symbols-outlined { font-size: 18px; }
  .pnum {
    width: 32px; height: 32px; border-radius: 6px;
    background: none;
    border: 1px solid rgba(244,140,37,.2);
    font-size: 12px; font-weight: 700; color: #94a3b8;
    font-family: 'Manrope', sans-serif; cursor: pointer;
    transition: background .15s;
  }
  .pnum:hover { background: rgba(244,140,37,.1); }
  .pnum-active { background: #f48c25 !important; color: #221910 !important; border-color: #f48c25 !important; }
  .pellipsis { color: #64748b; font-size: 13px; padding: 0 4px; }

  @media (max-width: 1100px) {
    .inv-stats { grid-template-columns: 1fr 1fr; }
  }
</style>
