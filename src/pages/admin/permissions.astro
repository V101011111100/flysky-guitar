---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { ADMIN_FEATURES } from '../../lib/admin-permissions';

const featureDefs = ADMIN_FEATURES;
---

<AdminLayout
  title="Quản lý Phân quyền"
  subtitle="Thiết lập vai trò và cấu hình quyền truy cập hệ thống chi tiết."
  activeNav="permissions"
>
  <div class="perm-page">
    <div class="perm-topbar">
      <div class="search-wrap">
        <span class="material-symbols-outlined">search</span>
        <input id="account-search" type="text" placeholder="Tìm kiếm vai trò..." />
      </div>
      <button id="btn-toggle-create" class="btn-add-role" type="button">
        <span class="material-symbols-outlined">add</span>
        Thêm vai trò mới
      </button>
    </div>

    <div id="create-user-box" class="create-user-box hidden">
      <h4>Tạo tài khoản nhân viên mới</h4>
      <p>Tài khoản được tạo trong hệ thống đăng nhập và tự gán quyền theo preset.</p>
      <div class="create-user-grid">
        <input id="create-user-email" type="email" placeholder="sale@flysky.com.vn" />
        <input id="create-user-password" type="password" placeholder="Mật khẩu tạm (>= 8 ký tự)" />
        <select id="create-user-preset">
          <option value="readonly">Read only</option>
          <option value="content">Content Writer</option>
          <option value="sales">Sales Manager</option>
          <option value="inventory">Inventory Manager</option>
          <option value="full">Admin full quyền</option>
        </select>
        <button id="create-user-btn" type="button">Tạo user</button>
      </div>
    </div>

    <div class="perm-grid">
      <aside class="roles-panel">
        <div class="roles-label">Danh sách vai trò</div>

        <div class="quick-add-row">
          <input id="new-account-email" type="email" placeholder="Thêm email có sẵn..." />
          <button id="add-account-btn" type="button">Thêm</button>
        </div>

        <div id="accounts-list" class="roles-list"></div>
      </aside>

      <section class="editor-panel">
        <div class="editor-header">
          <div>
            <h3>
              Cấu hình Quyền hạn:
              <span id="selected-account" class="editor-account">Chưa chọn</span>
            </h3>
            <p id="selected-account-sub">Chỉnh sửa chi tiết quyền cho tài khoản này.</p>
          </div>
          <div class="header-actions">
            <button id="reset-btn" type="button" class="btn-ghost">Hủy bỏ</button>
            <button id="save-btn" type="button" class="btn-primary">Lưu thay đổi</button>
          </div>
        </div>

        <div class="table-wrap">
          <table class="perm-table">
            <thead>
              <tr>
                <th>Module hệ thống</th>
                <th>Xem</th>
                <th>Thêm</th>
                <th>Sửa</th>
                <th>Xóa</th>
              </tr>
            </thead>
            <tbody>
              {featureDefs.map((feature) => (
                <tr>
                  <td>
                    <div class="module-cell">
                      <span class="material-symbols-outlined">tune</span>
                      <span>{feature.label}</span>
                    </div>
                  </td>
                  <td><input class="perm-checkbox" type="checkbox" data-feature={feature.key} data-col="view" /></td>
                  <td><input class="perm-checkbox" type="checkbox" data-feature={feature.key} data-col="add" /></td>
                  <td><input class="perm-checkbox" type="checkbox" data-feature={feature.key} data-col="edit" /></td>
                  <td><input class="perm-checkbox" type="checkbox" data-feature={feature.key} data-col="delete" /></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="table-footer">
          <p>Thay đổi sẽ áp dụng ngay cho tài khoản được chọn sau khi lưu.</p>
          <div class="footer-actions">
            <button id="apply-preset-btn" type="button" class="link-btn">Áp preset</button>
            <select id="preset-select" class="preset-select">
              <option value="full">Admin full quyền</option>
              <option value="content">Content Writer</option>
              <option value="sales">Sales Manager</option>
              <option value="inventory">Inventory Manager</option>
              <option value="readonly">Read only</option>
            </select>
            <button id="select-all-btn" type="button" class="link-btn">Chọn tất cả</button>
            <button id="clear-all-btn" type="button" class="link-btn">Bỏ chọn tất cả</button>
          </div>
        </div>

        <div class="advanced-card">
          <h4>
            <span class="material-symbols-outlined">security</span>
            Quyền bảo mật nâng cao
          </h4>
          <div class="advanced-row">
            <label class="toggle-item">
              <span class="toggle-copy">
                <strong>Yêu cầu xác thực 2FA</strong>
                <small>Bắt buộc đăng nhập 2 bước cho vai trò này.</small>
              </span>
              <span class="switch-wrap">
                <input type="checkbox" checked />
                <span class="switch-slider"></span>
              </span>
            </label>
            <label class="toggle-item">
              <span class="toggle-copy">
                <strong>Truy cập API</strong>
                <small>Cho phép gọi API từ các ứng dụng bên thứ 3.</small>
              </span>
              <span class="switch-wrap">
                <input type="checkbox" />
                <span class="switch-slider"></span>
              </span>
            </label>
          </div>
        </div>

        <p id="perm-message" class="perm-message"></p>
      </section>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ featureDefs }}>
  const accountListEl = document.getElementById('accounts-list');
  const accountSearchInput = document.getElementById('account-search');
  const addEmailInput = document.getElementById('new-account-email');
  const addAccountBtn = document.getElementById('add-account-btn');
  const selectedAccountEl = document.getElementById('selected-account');
  const selectedAccountSubEl = document.getElementById('selected-account-sub');
  const saveBtn = document.getElementById('save-btn');
  const resetBtn = document.getElementById('reset-btn');
  const selectAllBtn = document.getElementById('select-all-btn');
  const clearAllBtn = document.getElementById('clear-all-btn');
  const presetSelect = document.getElementById('preset-select');
  const applyPresetBtn = document.getElementById('apply-preset-btn');
  const messageEl = document.getElementById('perm-message');

  const toggleCreateBtn = document.getElementById('btn-toggle-create');
  const createBox = document.getElementById('create-user-box');
  const createUserEmailInput = document.getElementById('create-user-email');
  const createUserPasswordInput = document.getElementById('create-user-password');
  const createUserPreset = document.getElementById('create-user-preset');
  const createUserBtn = document.getElementById('create-user-btn');

  const allFeatureKeys = featureDefs.map((item) => item.key);
  const allCheckboxes = Array.from(document.querySelectorAll('.perm-checkbox'));

  let permissionMap = {};
  let permissionMapSnapshot = {};
  let accounts = [];
  let rootAdmins = [];
  let selectedAccount = '';

  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const presets = {
    full: [...allFeatureKeys],
    content: ['dashboard', 'blog', 'brand', 'media', 'newsletter', 'settings'],
    sales: ['dashboard', 'pos', 'orders', 'shipping', 'consultations', 'reports', 'products', 'settings'],
    inventory: ['dashboard', 'inventory', 'products', 'media', 'reports', 'settings'],
    readonly: ['dashboard', 'settings'],
  };

  const presetRoleNames = {
    full: 'Quản trị viên (Admin)',
    content: 'Content Writer',
    sales: 'Sales Manager',
    inventory: 'Inventory Manager',
    readonly: 'Read only',
  };

  function normalizeEmail(value) {
    return value.trim().toLowerCase();
  }

  function isValidEmail(value) {
    return emailRegex.test(value);
  }

  function clonePermissionMap(input) {
    return JSON.parse(JSON.stringify(input || {}));
  }

  function setMessage(text, type = 'info') {
    if (!messageEl) return;
    messageEl.textContent = text;
    messageEl.dataset.type = type;
  }

  function getPresetFeatures(presetKey) {
    return Array.isArray(presets[presetKey])
      ? presets[presetKey].filter((key) => allFeatureKeys.includes(key))
      : [...allFeatureKeys];
  }

  function normalizeFeatureList(features) {
    if (!Array.isArray(features)) return [];
    return Array.from(new Set(features.filter((key) => allFeatureKeys.includes(key)))).sort();
  }

  function isSameFeatureSet(left, right) {
    if (left.length !== right.length) return false;
    return left.every((item, idx) => item === right[idx]);
  }

  function detectRoleInfo(email) {
    if (rootAdmins.includes(email)) {
      return {
        name: presetRoleNames.full,
        badge: 'Mặc định',
      };
    }

    const currentFeatures = normalizeFeatureList(permissionMap[email] || allFeatureKeys);
    const orderedPresetKeys = ['full', 'content', 'sales', 'inventory', 'readonly'];

    for (const presetKey of orderedPresetKeys) {
      const presetFeatures = normalizeFeatureList(getPresetFeatures(presetKey));
      if (isSameFeatureSet(currentFeatures, presetFeatures)) {
        return {
          name: presetRoleNames[presetKey],
          badge: presetKey === 'full' ? 'Toàn quyền' : 'Preset',
        };
      }
    }

    return {
      name: 'Custom Role',
      badge: 'Tùy chỉnh',
    };
  }

  function getFeatureCheckboxes(featureKey) {
    return allCheckboxes.filter((box) => box.dataset.feature === featureKey);
  }

  function setFeatureChecked(featureKey, checked) {
    for (const box of getFeatureCheckboxes(featureKey)) {
      box.checked = checked;
    }
  }

  function getFeaturesForSelected() {
    if (!selectedAccount) return new Set();
    const explicitFeatures = permissionMap[selectedAccount];
    if (!Array.isArray(explicitFeatures)) {
      return new Set(allFeatureKeys);
    }
    return new Set(explicitFeatures);
  }

  function applySelectedAccountToUI() {
    if (!selectedAccountEl || !selectedAccountSubEl) return;

    if (!selectedAccount) {
      selectedAccountEl.textContent = 'Chưa chọn';
      selectedAccountSubEl.textContent = 'Chọn tài khoản bên trái để bật/tắt quyền.';
      for (const box of allCheckboxes) box.checked = false;
      return;
    }

    selectedAccountEl.textContent = selectedAccount;
    selectedAccountSubEl.textContent = 'Chỉnh sửa chi tiết quyền cho tài khoản này.';

    const featureSet = getFeaturesForSelected();
    for (const featureKey of allFeatureKeys) {
      setFeatureChecked(featureKey, featureSet.has(featureKey));
    }
  }

  function getVisibleAccounts() {
    const keyword = (accountSearchInput?.value || '').trim().toLowerCase();
    if (!keyword) return accounts;
    return accounts.filter((email) => email.includes(keyword));
  }

  function renderAccounts() {
    if (!accountListEl) return;
    accountListEl.innerHTML = '';

    const visibleAccounts = getVisibleAccounts();
    if (visibleAccounts.length === 0) {
      const empty = document.createElement('p');
      empty.className = 'roles-empty';
      empty.textContent = 'Không tìm thấy tài khoản phù hợp.';
      accountListEl.appendChild(empty);
      return;
    }

    for (const email of visibleAccounts) {
      const enabledCount = Array.isArray(permissionMap[email])
        ? permissionMap[email].length
        : allFeatureKeys.length;
      const isActive = email === selectedAccount;

      const card = document.createElement('button');
      card.type = 'button';
      card.className = `role-card ${isActive ? 'active' : ''}`;

      const roleInfo = detectRoleInfo(email);

      card.innerHTML = `
        <div class="role-card-top">
          <span class="material-symbols-outlined role-card-icon">admin_panel_settings</span>
          <span class="role-badge">${roleInfo.badge}</span>
        </div>
        <h4 class="role-name">${roleInfo.name}</h4>
        <p class="role-email">${email}</p>
        <p class="role-desc">Đang bật ${enabledCount}/${allFeatureKeys.length} module hệ thống.</p>
        <div class="role-footer">
          <span class="dot"></span>
          <span>${enabledCount} quyền đang áp dụng</span>
        </div>
      `;

      card.addEventListener('click', () => {
        selectedAccount = email;
        renderAccounts();
        applySelectedAccountToUI();
      });

      accountListEl.appendChild(card);
    }
  }

  function syncCheckboxesToState() {
    if (!selectedAccount) return;
    const selectedFeatures = [];

    for (const featureKey of allFeatureKeys) {
      const boxes = getFeatureCheckboxes(featureKey);
      const checked = boxes.some((box) => box.checked);
      if (checked) selectedFeatures.push(featureKey);
      setFeatureChecked(featureKey, checked);
    }

    permissionMap[selectedAccount] = selectedFeatures;
    renderAccounts();
  }

  async function loadPermissions() {
    setMessage('Đang tải dữ liệu phân quyền...', 'info');
    const response = await fetch('/api/admin/permissions', { method: 'GET' });
    const payload = await response.json().catch(() => null);

    if (!response.ok || !payload?.success) {
      setMessage(payload?.error || 'Không thể tải dữ liệu quyền.', 'error');
      return;
    }

    permissionMap = payload.permissions || {};
    permissionMapSnapshot = clonePermissionMap(permissionMap);
    rootAdmins = Array.isArray(payload.rootAdmins)
      ? payload.rootAdmins.map((item) => normalizeEmail(item)).filter((item) => isValidEmail(item))
      : [];
    accounts = Array.isArray(payload.accounts)
      ? payload.accounts.map((item) => normalizeEmail(item)).filter((item) => isValidEmail(item))
      : [];
    accounts = Array.from(new Set(accounts)).sort((a, b) => a.localeCompare(b));

    selectedAccount = accounts[0] || '';
    renderAccounts();
    applySelectedAccountToUI();
    setMessage('Đã tải danh sách phân quyền.', 'ok');
  }

  async function savePermissions() {
    syncCheckboxesToState();
    setMessage('Đang lưu thay đổi...', 'info');

    const response = await fetch('/api/admin/permissions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ permissions: permissionMap }),
    });

    const payload = await response.json().catch(() => null);
    if (!response.ok || !payload?.success) {
      setMessage(payload?.error || 'Lưu thất bại.', 'error');
      return;
    }

    permissionMapSnapshot = clonePermissionMap(permissionMap);
    setMessage('Đã lưu phân quyền thành công.', 'ok');
  }

  async function createUserInSystem() {
    const email = normalizeEmail(createUserEmailInput?.value || '');
    const password = (createUserPasswordInput?.value || '').trim();
    const presetKey = createUserPreset?.value || 'readonly';

    if (!isValidEmail(email)) {
      setMessage('Email tạo user không hợp lệ.', 'error');
      return;
    }
    if (password.length < 8) {
      setMessage('Mật khẩu tạm phải từ 8 ký tự trở lên.', 'error');
      return;
    }

    const permissions = getPresetFeatures(presetKey);
    createUserBtn?.setAttribute('disabled', 'true');
    setMessage('Đang tạo user mới...', 'info');

    const response = await fetch('/api/admin/users', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password, permissions }),
    });

    createUserBtn?.removeAttribute('disabled');
    const payload = await response.json().catch(() => null);

    if (!response.ok || !payload?.success) {
      setMessage(payload?.error || 'Không thể tạo user mới.', 'error');
      return;
    }

    if (!accounts.includes(email)) {
      accounts.push(email);
      accounts.sort((a, b) => a.localeCompare(b));
    }

    permissionMap[email] = Array.isArray(payload.permissions) ? payload.permissions : permissions;
    permissionMapSnapshot = clonePermissionMap(permissionMap);
    selectedAccount = email;

    if (createUserEmailInput) createUserEmailInput.value = '';
    if (createUserPasswordInput) createUserPasswordInput.value = '';

    renderAccounts();
    applySelectedAccountToUI();
    setMessage('Đã tạo user mới thành công.', 'ok');
  }

  toggleCreateBtn?.addEventListener('click', () => {
    createBox?.classList.toggle('hidden');
  });

  addAccountBtn?.addEventListener('click', () => {
    const raw = addEmailInput?.value || '';
    const email = normalizeEmail(raw);

    if (!isValidEmail(email)) {
      setMessage('Email không hợp lệ.', 'error');
      return;
    }

    if (!accounts.includes(email)) {
      accounts.push(email);
      accounts.sort((a, b) => a.localeCompare(b));
    }

    if (!permissionMap[email]) {
      permissionMap[email] = [...allFeatureKeys];
    }

    selectedAccount = email;
    if (addEmailInput) addEmailInput.value = '';
    renderAccounts();
    applySelectedAccountToUI();
    setMessage('Đã thêm tài khoản. Nhấn lưu để áp dụng.', 'info');
  });

  addEmailInput?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') {
      event.preventDefault();
      addAccountBtn?.click();
    }
  });

  accountSearchInput?.addEventListener('input', () => {
    renderAccounts();
  });

  createUserBtn?.addEventListener('click', () => {
    void createUserInSystem();
  });

  createUserPasswordInput?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') {
      event.preventDefault();
      createUserBtn?.click();
    }
  });

  for (const checkbox of allCheckboxes) {
    checkbox.addEventListener('change', (event) => {
      const target = event.target;
      const featureKey = target?.dataset?.feature || '';
      if (!featureKey) return;

      setFeatureChecked(featureKey, Boolean(target.checked));
      syncCheckboxesToState();
      setMessage('Bạn có thay đổi chưa lưu.', 'info');
    });
  }

  selectAllBtn?.addEventListener('click', () => {
    for (const key of allFeatureKeys) setFeatureChecked(key, true);
    syncCheckboxesToState();
    setMessage('Đã chọn tất cả quyền cho tài khoản hiện tại.', 'info');
  });

  clearAllBtn?.addEventListener('click', () => {
    for (const key of allFeatureKeys) setFeatureChecked(key, false);
    syncCheckboxesToState();
    setMessage('Đã bỏ tất cả quyền cho tài khoản hiện tại.', 'info');
  });

  applyPresetBtn?.addEventListener('click', () => {
    if (!selectedAccount) {
      setMessage('Hãy chọn tài khoản trước khi áp preset.', 'error');
      return;
    }

    const presetKey = presetSelect?.value || 'full';
    const presetFeatures = getPresetFeatures(presetKey);

    permissionMap[selectedAccount] = [...presetFeatures];
    applySelectedAccountToUI();
    renderAccounts();
    setMessage(`Đã áp preset ${presetKey}. Nhấn Lưu thay đổi để áp dụng.`, 'info');
  });

  resetBtn?.addEventListener('click', () => {
    permissionMap = clonePermissionMap(permissionMapSnapshot);
    applySelectedAccountToUI();
    renderAccounts();
    setMessage('Đã khôi phục thay đổi chưa lưu.', 'info');
  });

  saveBtn?.addEventListener('click', () => {
    void savePermissions();
  });

  void loadPermissions();
</script>

<style>
  .perm-page {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .perm-topbar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 12px;
  }

  .search-wrap {
    position: relative;
    width: min(320px, 100%);
  }

  .search-wrap .material-symbols-outlined {
    position: absolute;
    left: 10px;
    top: 9px;
    font-size: 19px;
    color: #6b7280;
  }

  .search-wrap input {
    width: 100%;
    height: 38px;
    border: 1px solid rgba(244, 140, 37, 0.22);
    border-radius: 8px;
    background: rgba(32, 24, 16, 0.72);
    color: #f8fafc;
    padding: 0 10px 0 36px;
    font-family: inherit;
    outline: none;
    transition: border-color .16s, box-shadow .16s;
  }

  .search-wrap input:focus {
    border-color: rgba(244, 140, 37, 0.62);
    box-shadow: 0 0 0 2px rgba(244, 140, 37, 0.18);
  }

  .btn-add-role {
    height: 38px;
    border: 0;
    border-radius: 8px;
    padding: 0 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #f48c25;
    color: #21170f;
    font-weight: 800;
    cursor: pointer;
    transition: filter .16s ease;
  }

  .btn-add-role:hover {
    filter: brightness(1.08);
  }

  .create-user-box {
    border: 1px solid rgba(244, 140, 37, 0.22);
    background: rgba(32, 24, 16, 0.68);
    border-radius: 12px;
    padding: 14px;
  }

  .create-user-box.hidden {
    display: none;
  }

  .create-user-box h4 {
    color: #f8fafc;
    font-size: 15px;
    font-weight: 800;
  }

  .create-user-box p {
    margin-top: 4px;
    color: #9ca3af;
    font-size: 12px;
  }

  .create-user-grid {
    margin-top: 10px;
    display: grid;
    grid-template-columns: 1.1fr 1fr 0.8fr auto;
    gap: 8px;
  }

  .create-user-grid input,
  .create-user-grid select {
    height: 36px;
    border: 1px solid rgba(244, 140, 37, 0.22);
    border-radius: 8px;
    background: #2b2018;
    color: #f8fafc;
    padding: 0 10px;
    font-family: inherit;
    transition: border-color .16s, box-shadow .16s;
  }

  .create-user-grid input:focus,
  .create-user-grid select:focus {
    border-color: rgba(244, 140, 37, 0.65);
    box-shadow: 0 0 0 2px rgba(244, 140, 37, 0.16);
    outline: none;
  }

  .create-user-grid button {
    height: 36px;
    border: 0;
    border-radius: 8px;
    background: #f48c25;
    color: #21170f;
    font-weight: 800;
    padding: 0 12px;
    cursor: pointer;
    transition: filter .16s ease;
  }

  .create-user-grid button:hover {
    filter: brightness(1.08);
  }

  .create-user-grid button:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .perm-grid {
    display: grid;
    grid-template-columns: minmax(280px, 320px) minmax(0, 1fr);
    gap: 16px;
    align-items: start;
  }

  .roles-panel,
  .editor-panel {
    border: 1px solid rgba(244, 140, 37, 0.16);
    background: rgba(32, 24, 16, 0.6);
    border-radius: 14px;
  }

  .roles-panel {
    padding: 14px;
  }

  .roles-label {
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font-size: 10px;
    color: #f59e0b;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .quick-add-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px;
    margin-bottom: 10px;
  }

  .quick-add-row input {
    min-width: 0;
    height: 36px;
    border: 1px solid rgba(244, 140, 37, 0.22);
    border-radius: 8px;
    background: #2b2018;
    color: #f8fafc;
    padding: 0 10px;
    font-family: inherit;
    transition: border-color .16s, box-shadow .16s;
  }

  .quick-add-row input:focus {
    border-color: rgba(244, 140, 37, 0.65);
    box-shadow: 0 0 0 2px rgba(244, 140, 37, 0.16);
    outline: none;
  }

  .quick-add-row button {
    height: 36px;
    border: 0;
    border-radius: 8px;
    background: #f48c25;
    color: #21170f;
    font-weight: 800;
    padding: 0 12px;
    cursor: pointer;
