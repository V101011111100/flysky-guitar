    email: 'daopm@email.com',
    product: 'Phụ kiện dây đàn Ernie Ball',
    img: 'https://lh3.googleusercontent.com/aida-public/AB6AXuAnIv42ti-JOB-wy6_C6SIih3X6KwCjl9g3FwJp9UpbD5QwuM7BYPcsuoHEWkBDK8jVoPra_sb26Bq77lU1GaQjleEs4ZljnSU9E9Co4AffhMEqxBIq7uJpYaimr5j5stjeyJU62c-iVKGll_D5EAI0N04WQvy3W45skoEE9pqYuFnjgLHi7-uFa1nhziGM63Yq_sTz8S87fqVluZWZ0M8KWw5qe3YCTbrEH0ZatGJwa4Gu1c8LUpsRPdJEi77m-DXZYACNxDO2qIs8',
    total: '250.000₫', status: 'done', date: '09/10/2023',
