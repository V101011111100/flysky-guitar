---

<AdminLayout
  title="Quản lý đơn hàng"
  subtitle="Theo dõi, cập nhật và xuất dữ liệu đơn hàng nhạc cụ."
  activeNav="orders"
>
  <!-- ── HEADER ACTIONS ── -->
  <div class="orders-header">
    <div class="orders-header-actions">
      <button class="btn-export">
        <span class="material-symbols-outlined">download</span>
        Xuất file Excel
      </button>
      <button class="btn-create">
        <span class="material-symbols-outlined">add</span>
        Tạo đơn mới
      </button>
    </div>
  </div>

  <!-- ── FILTER TABS ── -->
  <div class="filter-tabs">
    <button class="tab-btn tab-active">Tất cả</button>
    <button class="tab-btn">Chờ xử lý</button>
    <button class="tab-btn">Đang giao</button>
    <button class="tab-btn">Hoàn thành</button>
    <button class="tab-btn">Đã hủy</button>
  </div>

  <!-- ── TABLE ── -->
  <div class="table-wrap">
    <div style="overflow-x:auto;">
      <table class="orders-table">
        <thead>
          <tr>
            <th>Mã đơn</th>
            <th>Khách hàng</th>
            <th>Sản phẩm</th>
            <th style="text-align:right;">Tổng tiền</th>
            <th style="text-align:center;">Trạng thái</th>
            <th>Ngày đặt</th>
            <th style="text-align:right;">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          {orders.map(o => (
            <tr>
              <td class="order-id">{o.id}</td>
              <td>
                <div class="cus-name">{o.customer}</div>
                <div class="cus-email">{o.email}</div>
              </td>
              <td>
                <div class="prod-cell">
                  <div class="prod-thumb" style={`background-image:url('${o.img}')`}></div>
                  <span class="prod-name">{o.product}</span>
                </div>
              </td>
              <td class="total-col">{o.total}</td>
              <td class="status-col">
                {o.status === 'pending'  && <span class="badge badge-amber">Chờ xử lý</span>}
                {o.status === 'shipping' && <span class="badge badge-blue">Đang giao</span>}
                {o.status === 'done'     && <span class="badge badge-green">Hoàn thành</span>}
                {o.status === 'cancelled'&& <span class="badge badge-red">Đã hủy</span>}
              </td>
              <td class="date-col">{o.date}</td>
              <td class="action-col">
                <button class="act-btn" title="Xem chi tiết">
                  <span class="material-symbols-outlined">visibility</span>
                </button>
                <button class="act-btn" title="Chỉnh sửa">
                  <span class="material-symbols-outlined">edit</span>
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="pagination">
      <span class="page-info">Hiển thị 1 đến 4 trong số 102 đơn hàng</span>
      <div class="page-btns">
        <button class="page-nav"><span class="material-symbols-outlined">chevron_left</span></button>
        <button class="page-num page-active">1</button>
        <button class="page-num">2</button>
        <button class="page-num">3</button>
        <span class="page-ellipsis">...</span>
        <button class="page-num">26</button>
        <button class="page-nav"><span class="material-symbols-outlined">chevron_right</span></button>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="orders-footer">
    <span class="footer-version">FlySky Guitar Admin System v2.4.0</span>
    <div class="footer-links">
      <a href="#">Hỗ trợ</a>
      <a href="#">Chính sách bảo mật</a>
    </div>
  </footer>

</AdminLayout>

<style>
  /* ── HEADER ── */
  .orders-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 28px;
  }
  .orders-header-actions { display: flex; gap: 12px; align-items: center; }

  .btn-export {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 12px;
    font-size: 13px; font-weight: 600;
    background: #2d2218; border: 1px solid #4a3a2a;
    color: #f1f5f9; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    transition: background .15s;
  }
  .btn-export:hover { background: #4a3a2a; }
  .btn-export .material-symbols-outlined { font-size: 18px; }

  .btn-create {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 12px;
    font-size: 13px; font-weight: 700;
    background: #f48c25; color: #221910;
    border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    box-shadow: 0 4px 16px rgba(244,140,37,.2);
    transition: filter .15s;
  }
  .btn-create:hover { filter: brightness(1.1); }
  .btn-create .material-symbols-outlined { font-size: 18px; }

  /* ── FILTER TABS ── */
  .filter-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid rgba(74,58,42,.5);
    margin-bottom: 20px;
  }
  .tab-btn {
    padding: 12px 20px;
    font-size: 13px; font-weight: 600;
    background: none; border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    color: #64748b;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all .15s;
  }
  .tab-btn:hover { color: #cbd5e1; }
  .tab-active {
    color: #f48c25;
    border-bottom-color: #f48c25;
    font-weight: 700;
  }

  /* ── TABLE ── */
  .table-wrap {
    background: rgba(45,34,24,.4);
    border: 1px solid #4a3a2a;
    border-radius: 16px;
    overflow: hidden;
  }

  .orders-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }
  .orders-table thead tr {
    background: rgba(45,34,24,.7);
  }
  .orders-table th {
    padding: 16px 24px;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .1em;
    color: #94a3b8;
    white-space: nowrap;
  }
  .orders-table tbody tr {
    border-top: 1px solid #4a3a2a;
    transition: background .15s;
  }
  .orders-table tbody tr:hover { background: rgba(74,58,42,.25); }
  .orders-table td {
    padding: 20px 24px;
    vertical-align: middle;
  }

  .order-id {
    font-family: 'Courier New', monospace;
    font-size: 13px; font-weight: 700;
    color: #f48c25;
    white-space: nowrap;
  }

  .cus-name  { font-size: 13.5px; font-weight: 700; color: #f9fafb; }
  .cus-email { font-size: 11px; color: #64748b; margin-top: 2px; }

  .prod-cell {
    display: flex; align-items: center; gap: 12px;
  }
  .prod-thumb {
    width: 32px; height: 32px;
    border-radius: 6px;
    background: #4a3a2a center/cover no-repeat;
    flex-shrink: 0;
  }
  .prod-name { font-size: 13px; color: #e2e8f0; }

  .total-col { text-align: right; font-size: 13px; font-weight: 600; color: #f9fafb; white-space: nowrap; }
  .status-col { text-align: center; }
  .date-col  { font-size: 13px; color: #94a3b8; white-space: nowrap; }
  .action-col { text-align: right; }

  /* Badges */
  .badge {
    display: inline-block;
    padding: 4px 12px; border-radius: 999px;
    font-size: 11px; font-weight: 700;
    border: 1px solid;
    white-space: nowrap;
  }
  .badge-amber { background: rgba(245,158,11,.15); color: #f59e0b; border-color: rgba(245,158,11,.3); }
  .badge-blue  { background: rgba(59,130,246,.15);  color: #60a5fa; border-color: rgba(59,130,246,.3); }
  .badge-green { background: rgba(16,185,129,.15);  color: #34d399; border-color: rgba(16,185,129,.3); }
  .badge-red   { background: rgba(239,68,68,.15);   color: #f87171; border-color: rgba(239,68,68,.3); }

  /* Action buttons */
  .act-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: 8px;
    background: none; border: none; cursor: pointer;
    color: #64748b; transition: all .15s;
  }
  .act-btn:hover { background: rgba(244,140,37,.2); color: #f48c25; }
  .act-btn .material-symbols-outlined { font-size: 18px; }

  /* ── PAGINATION ── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
    background: rgba(45,34,24,.4);
    border-top: 1px solid #4a3a2a;
  }
  .page-info { font-size: 11px; color: #64748b; }
  .page-btns { display: flex; align-items: center; gap: 4px; }
  .page-nav {
    width: 30px; height: 30px; border-radius: 8px;
    background: none; border: none; cursor: pointer;
    color: #94a3b8; display: flex; align-items: center; justify-content: center;
    transition: background .15s;
  }
  .page-nav:hover { background: #4a3a2a; }
  .page-nav .material-symbols-outlined { font-size: 18px; }
  .page-num {
    width: 30px; height: 30px; border-radius: 8px;
    background: none; border: none; cursor: pointer;
    font-size: 12px; font-weight: 700;
    color: #94a3b8; font-family: 'Manrope', sans-serif;
    transition: background .15s;
  }
  .page-num:hover { background: #4a3a2a; }
  .page-active { background: #f48c25 !important; color: #221910 !important; }
  .page-ellipsis { color: #64748b; font-size: 13px; padding: 0 4px; }

  /* ── FOOTER ── */
  .orders-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid rgba(74,58,42,.4);
  }
  .footer-version {
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .12em;
    color: #374151;
  }
  .footer-links { display: flex; align-items: center; gap: 20px; }
  .footer-links a {
    font-size: 12px; color: #64748b; text-decoration: none;
    transition: color .15s;
  }
  .footer-links a:hover { color: #f48c25; }
</style>
