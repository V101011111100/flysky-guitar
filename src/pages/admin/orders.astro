---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// Lấy filter từ URL param
const statusFilter = Astro.url.searchParams.get('status') || 'all';
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const PAGE_SIZE = 15;

// Build query
let query = supabase
  .from('orders')
  .select('*', { count: 'exact' })
  .order('created_at', { ascending: false })
  .range((page - 1) * PAGE_SIZE, page * PAGE_SIZE - 1);

if (statusFilter !== 'all') {
  query = query.eq('status', statusFilter);
}

const { data: ordersData, count, error } = await query;

// Nếu bảng orders chưa tồn tại, error sẽ xuất hiện → hiện empty state
const orders = ordersData || [];
const totalOrders = count || 0;
const totalPages = Math.ceil(totalOrders / PAGE_SIZE);

const statusMap: Record<string, { label: string; cls: string }> = {
  pending:    { label: 'Chờ xử lý',   cls: 'badge-amber' },
  processing: { label: 'Đang xử lý',  cls: 'badge-blue'  },
  completed:  { label: 'Hoàn thành',  cls: 'badge-green' },
  cancelled:  { label: 'Đã hủy',      cls: 'badge-red'   },
};

function fmt(n: number) {
  return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(n);
}
function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}
---

<AdminLayout
  title="Quản lý đơn hàng"
  subtitle="Theo dõi, cập nhật và xuất dữ liệu đơn hàng nhạc cụ."
  activeNav="orders"
>
  <!-- ── HEADER ACTIONS ── -->
  <div class="orders-header">
    <div class="orders-header-actions">
      <button class="btn-export" id="btn-export">
        <span class="material-symbols-outlined">download</span>
        Xuất Excel
      </button>
    </div>
  </div>

  <!-- ── FILTER TABS ── -->
  <div class="filter-tabs">
    {[
      { val: 'all',        label: 'Tất cả' },
      { val: 'pending',    label: 'Chờ xử lý' },
      { val: 'processing', label: 'Đang xử lý' },
      { val: 'completed',  label: 'Hoàn thành' },
      { val: 'cancelled',  label: 'Đã hủy' },
    ].map(tab => (
      <a
        href={`/admin/orders?status=${tab.val}`}
        class={`tab-btn ${statusFilter === tab.val ? 'tab-active' : ''}`}
      >
        {tab.label}
      </a>
    ))}
  </div>

  <!-- ── TABLE ── -->
  <div class="table-wrap">
    <div style="overflow-x:auto;">
      <table class="orders-table">
        <thead>
          <tr>
            <th>Mã đơn</th>
            <th>Khách hàng</th>
            <th>Sản phẩm</th>
            <th style="text-align:right;">Tổng tiền</th>
            <th style="text-align:center;">Trạng thái</th>
            <th>Ngày đặt</th>
            <th style="text-align:center;">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          {orders.length === 0 && (
            <tr>
              <td colspan="7" class="empty-row">
                <span class="material-symbols-outlined" style="font-size:36px; opacity:0.3;">inbox</span>
                <p style="margin-top:8px; color:#64748b;">
                  {error ? 'Bảng orders chưa được tạo. Hãy đặt đơn hàng đầu tiên từ trang cửa hàng!' : 'Chưa có đơn hàng nào.'}
                </p>
              </td>
            </tr>
          )}
          {orders.map(o => {
            const items: any[] = o.items || [];
            const firstItem = items[0];
            const moreCount = items.length - 1;
            const statusInfo = statusMap[o.status] || { label: o.status, cls: 'badge-amber' };
            return (
              <tr data-order-id={o.id}>
                <td class="order-id">{o.order_number}</td>
                <td>
                  <div class="cus-name">{o.customer_name}</div>
                  <div class="cus-email">{o.customer_phone}</div>
                  {o.customer_email && <div class="cus-email">{o.customer_email}</div>}
                  {o.shipping_address && <div class="cus-email" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;">{o.shipping_address}</div>}
                </td>
                <td>
                  {firstItem ? (
                    <div class="prod-cell">
                      <div class="prod-thumb" style={firstItem.image ? `background-image:url('${firstItem.image}')` : ''}></div>
                      <div>
                        <span class="prod-name">{firstItem.name}</span>
                        {moreCount > 0 && <div class="prod-more">+{moreCount} sản phẩm khác</div>}
                      </div>
                    </div>
                  ) : (
                    <span class="prod-name" style="color:#64748b;">—</span>
                  )}
                </td>
                <td class="total-col">{fmt(o.total_amount || 0)}</td>
                <td class="status-col">
                  <select
                    class={`status-select status-${o.status}`}
                    data-order-id={o.id}
                    data-current={o.status}
                  >
                    <option value="pending"    selected={o.status === 'pending'}>Chờ xử lý</option>
                    <option value="processing" selected={o.status === 'processing'}>Đang xử lý</option>
                    <option value="completed"  selected={o.status === 'completed'}>Hoàn thành</option>
                    <option value="cancelled"  selected={o.status === 'cancelled'}>Đã hủy</option>
                  </select>
                </td>
                <td class="date-col">{fmtDate(o.created_at)}</td>
                <td class="action-col">
                  <button class="act-btn btn-detail" data-order-id={o.id} title="Xem chi tiết">
                    <span class="material-symbols-outlined">visibility</span>
                  </button>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="pagination">
      <span class="page-info">
        Tổng {totalOrders} đơn hàng
        {totalOrders > 0 && ` — Trang ${page}/${totalPages}`}
      </span>
      {totalPages > 1 && (
        <div class="page-btns">
          {page > 1 && (
            <a href={`/admin/orders?status=${statusFilter}&page=${page - 1}`} class="page-nav">
              <span class="material-symbols-outlined">chevron_left</span>
            </a>
          )}
          {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
            <a
              href={`/admin/orders?status=${statusFilter}&page=${p}`}
              class={`page-num ${p === page ? 'page-active' : ''}`}
            >{p}</a>
          ))}
          {page < totalPages && (
            <a href={`/admin/orders?status=${statusFilter}&page=${page + 1}`} class="page-nav">
              <span class="material-symbols-outlined">chevron_right</span>
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- ── ORDER DETAIL MODAL ── -->
  <div id="order-modal" class="modal-backdrop hidden">
    <div class="modal-box">
      <div class="modal-header">
        <h3 class="modal-title">Chi tiết đơn hàng</h3>
        <button id="modal-close" class="modal-close-btn">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div id="modal-body" class="modal-body"></div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast-wrap" style="position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;"></div>

</AdminLayout>

<script>
  // ── Toast helper ──
  function showToast(msg: string, type: 'success' | 'error' = 'success') {
    const wrap = document.getElementById('toast-wrap')!;
    const t = document.createElement('div');
    t.className = `ord-toast ord-toast-${type}`;
    t.innerHTML = `<span class="material-symbols-outlined">${type === 'success' ? 'check_circle' : 'error'}</span>${msg}`;
    wrap.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 3000);
  }

  // ── Status dropdown change ──
  document.querySelectorAll<HTMLSelectElement>('.status-select').forEach(sel => {
    sel.addEventListener('change', async () => {
      const orderId = sel.dataset.orderId!;
      const newStatus = sel.value;
      const prev = sel.dataset.current!;

      sel.disabled = true;

      try {
        const res = await fetch('/api/orders/update-status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: orderId, status: newStatus }),
        });
        const data = await res.json();

        if (data.success) {
          sel.dataset.current = newStatus;
          // Reset class hoàn toàn để tránh regex match sai status-select
          sel.className = `status-select status-${newStatus}`;
          showToast('Cập nhật trạng thái thành công!');
        } else {
          throw new Error(data.error);
        }
      } catch (e: any) {
        sel.value = prev; // revert
        showToast('Lỗi: ' + (e.message || 'Không thể cập nhật'), 'error');
      } finally {
        sel.disabled = false;
      }
    });
  });

  // ── Order detail modal ──
  const modal = document.getElementById('order-modal')!;
  const modalBody = document.getElementById('modal-body')!;

  function openModal(orderId: string) {
    // Find row data from DOM
    const row = document.querySelector<HTMLElement>(`tr[data-order-id="${orderId}"]`);
    if (!row) return;
    
    const orderNum = row.querySelector('.order-id')?.textContent || '';
    const name = row.querySelector('.cus-name')?.textContent || '';
    const phone = row.querySelectorAll('.cus-email')[0]?.textContent || '';
    const email = row.querySelectorAll('.cus-email')[1]?.textContent || '';
    const total = row.querySelector('.total-col')?.textContent || '';
    const date = row.querySelector('.date-col')?.textContent || '';
    const status = row.querySelector<HTMLSelectElement>('.status-select')?.value || '';

    const statusLabels: Record<string, string> = {
      pending: 'Chờ xử lý', confirmed: 'Đã xác nhận',
      shipping: 'Đang giao', done: 'Hoàn thành', cancelled: 'Đã hủy'
    };

    modalBody.innerHTML = `
      <div class="detail-grid">
        <div class="detail-section">
          <h4 class="detail-section-title">Thông tin đơn hàng</h4>
          <div class="detail-row"><span>Mã đơn</span><strong>${orderNum}</strong></div>
          <div class="detail-row"><span>Ngày đặt</span><strong>${date}</strong></div>
          <div class="detail-row"><span>Tổng tiền</span><strong style="color:#f48c25;">${total}</strong></div>
          <div class="detail-row"><span>Trạng thái</span><strong>${statusLabels[status] || status}</strong></div>
        </div>
        <div class="detail-section">
          <h4 class="detail-section-title">Thông tin khách hàng</h4>
          <div class="detail-row"><span>Họ tên</span><strong>${name}</strong></div>
          <div class="detail-row"><span>Điện thoại</span><strong>${phone}</strong></div>
          ${email ? `<div class="detail-row"><span>Email</span><strong>${email}</strong></div>` : ''}
        </div>
      </div>
    `;

    modal.classList.remove('hidden');
  }

  document.querySelectorAll<HTMLButtonElement>('.btn-detail').forEach(btn => {
    btn.addEventListener('click', () => openModal(btn.dataset.orderId!));
  });

  document.getElementById('modal-close')?.addEventListener('click', () => modal.classList.add('hidden'));
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.add('hidden'); });

  // ── Export Excel ──
  document.getElementById('btn-export')?.addEventListener('click', () => {
    window.location.href = '/api/orders/export';
  });
</script>

<style>
  /* ── HEADER ── */
  .orders-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 28px;
  }
  .orders-header-actions { display: flex; gap: 12px; align-items: center; }

  .btn-export {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 12px;
    font-size: 13px; font-weight: 600;
    background: #2d2218; border: 1px solid #4a3a2a;
    color: #f1f5f9; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    transition: background .15s;
  }
  .btn-export:hover { background: #4a3a2a; }
  .btn-export .material-symbols-outlined { font-size: 18px; }

  /* ── FILTER TABS ── */
  .filter-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid rgba(74,58,42,.5);
    margin-bottom: 20px;
    overflow-x: auto;
  }
  .tab-btn {
    padding: 12px 20px;
    font-size: 13px; font-weight: 600;
    background: none; border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    color: #64748b;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all .15s;
    text-decoration: none;
    white-space: nowrap;
  }
  .tab-btn:hover { color: #cbd5e1; }
  .tab-active { color: #f48c25; border-bottom-color: #f48c25; font-weight: 700; }

  /* ── TABLE ── */
  .table-wrap {
    background: rgba(45,34,24,.4);
    border: 1px solid #4a3a2a;
    border-radius: 16px;
    overflow: hidden;
  }
  .orders-table { width: 100%; border-collapse: collapse; text-align: left; }
  .orders-table thead tr { background: rgba(45,34,24,.7); }
  .orders-table th {
    padding: 16px 24px;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .1em;
    color: #94a3b8; white-space: nowrap;
  }
  .orders-table tbody tr {
    border-top: 1px solid #4a3a2a;
    transition: background .15s;
  }
  .orders-table tbody tr:hover { background: rgba(74,58,42,.25); }
  .orders-table td { padding: 18px 24px; vertical-align: middle; }

  .empty-row { text-align: center; padding: 60px 24px; color: #64748b; }

  .order-id {
    font-family: 'Courier New', monospace;
    font-size: 13px; font-weight: 700;
    color: #f48c25; white-space: nowrap;
  }

  .cus-name  { font-size: 13.5px; font-weight: 700; color: #f9fafb; }
  .cus-email { font-size: 11px; color: #64748b; margin-top: 2px; }

  .prod-cell { display: flex; align-items: center; gap: 12px; }
  .prod-thumb {
    width: 36px; height: 36px; border-radius: 6px;
    background: #4a3a2a center/cover no-repeat; flex-shrink: 0;
  }
  .prod-name { font-size: 13px; color: #e2e8f0; }
  .prod-more { font-size: 11px; color: #64748b; margin-top: 2px; }

  .total-col { text-align: right; font-size: 13px; font-weight: 700; color: #f9fafb; white-space: nowrap; }
  .status-col { text-align: center; }
  .date-col  { font-size: 12px; color: #94a3b8; white-space: nowrap; }
  .action-col { text-align: center; }

  /* Status dropdown */
  .status-select {
    padding: 5px 10px;
    border-radius: 8px;
    font-size: 11px; font-weight: 700;
    font-family: 'Manrope', sans-serif;
    cursor: pointer;
    border: 1px solid;
    outline: none;
    transition: all .15s;
  }
  .status-select:disabled { opacity: 0.5; cursor: wait; }
  .status-pending    { background: rgba(245,158,11,.15);  color: #f59e0b; border-color: rgba(245,158,11,.3); }
  .status-processing { background: rgba(59,130,246,.15);  color: #60a5fa; border-color: rgba(59,130,246,.3); }
  .status-completed  { background: rgba(16,185,129,.15);  color: #34d399; border-color: rgba(16,185,129,.3); }
  .status-cancelled  { background: rgba(239,68,68,.15);   color: #f87171; border-color: rgba(239,68,68,.3); }
  .status-select option { background: #2d2218; color: #f1f5f9; }

  /* Action buttons */
  .act-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: 8px;
    background: none; border: none; cursor: pointer;
    color: #64748b; transition: all .15s;
  }
  .act-btn:hover { background: rgba(244,140,37,.2); color: #f48c25; }
  .act-btn .material-symbols-outlined { font-size: 18px; }

  /* ── PAGINATION ── */
  .pagination {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 24px;
    background: rgba(45,34,24,.4);
    border-top: 1px solid #4a3a2a;
  }
  .page-info { font-size: 11px; color: #64748b; }
  .page-btns { display: flex; align-items: center; gap: 4px; }
  .page-nav {
    width: 30px; height: 30px; border-radius: 8px;
    background: none; border: none; cursor: pointer;
    color: #94a3b8; display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    transition: background .15s;
  }
  .page-nav:hover { background: #4a3a2a; }
  .page-nav .material-symbols-outlined { font-size: 18px; }
  .page-num {
    width: 30px; height: 30px; border-radius: 8px;
    background: none; border: none; cursor: pointer;
    font-size: 12px; font-weight: 700;
    color: #94a3b8; font-family: 'Manrope', sans-serif;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    transition: background .15s;
  }
  .page-num:hover { background: #4a3a2a; }
  .page-active { background: #f48c25 !important; color: #221910 !important; border-radius: 8px; }

  /* ── MODAL ── */
  .modal-backdrop {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
    z-index: 900; display: flex; align-items: center; justify-content: center;
  }
  .modal-backdrop.hidden { display: none; }
  .modal-box {
    background: #2d2218; border: 1px solid #4a3a2a;
    border-radius: 16px; width: 100%; max-width: 560px;
    max-height: 80vh; overflow-y: auto;
    box-shadow: 0 24px 48px rgba(0,0,0,.5);
  }
  .modal-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px; border-bottom: 1px solid #4a3a2a;
  }
  .modal-title { font-size: 16px; font-weight: 700; color: #f9fafb; }
  .modal-close-btn {
    width: 32px; height: 32px; border-radius: 8px;
    background: none; border: none; cursor: pointer;
    color: #64748b; display: flex; align-items: center; justify-content: center;
    transition: all .15s;
  }
  .modal-close-btn:hover { background: rgba(244,140,37,.1); color: #f48c25; }
  .modal-body { padding: 24px; }

  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 480px) { .detail-grid { grid-template-columns: 1fr; } }
  .detail-section-title {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .1em; color: rgba(244,140,37,.6); margin-bottom: 12px;
  }
  .detail-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 0; border-bottom: 1px solid rgba(74,58,42,.4);
    font-size: 13px;
  }
  .detail-row span { color: #64748b; }
  .detail-row strong { color: #f1f5f9; font-weight: 600; }

  /* ── TOAST ── */
  .ord-toast {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 16px; border-radius: 10px;
    font-size: 13px; font-weight: 600; color: #fff;
    background: #2d2218; border: 1px solid #4a3a2a;
    box-shadow: 0 4px 16px rgba(0,0,0,.4);
    transition: opacity .3s;
    font-family: 'Manrope', sans-serif;
  }
  .ord-toast-success { border-left: 4px solid #10b981; }
  .ord-toast-success .material-symbols-outlined { color: #10b981; }
  .ord-toast-error { border-left: 4px solid #ef4444; }
  .ord-toast-error .material-symbols-outlined { color: #ef4444; }
</style>
