---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// Lấy filter từ URL param
const statusFilter = Astro.url.searchParams.get('status') || 'all';
const qRaw = Astro.url.searchParams.get('q') || '';
const q = qRaw.trim();
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const PAGE_SIZE = 15;

// Build query
let query = supabase
  .from('orders')
  .select('*, items:order_items(*, product:products(name, gallery_images))', { count: 'exact' })
  .order('created_at', { ascending: false })
  .range((page - 1) * PAGE_SIZE, page * PAGE_SIZE - 1);

if (statusFilter !== 'all') {
  query = query.eq('status', statusFilter);
}

if (q) {
  // Tránh ký tự có thể phá cú pháp .or() (PostgREST dùng dấu phẩy để phân tách)
  const safe = q.replaceAll(',', ' ');
  query = query.or(
    `order_number.ilike.%${safe}%,customer_name.ilike.%${safe}%,customer_phone.ilike.%${safe}%,customer_email.ilike.%${safe}%`
  );
}

const { data: ordersData, count, error } = await query;

// Nếu bảng orders chưa tồn tại, error sẽ xuất hiện → hiện empty state
const orders = (ordersData || []).map((o: any) => ({
  ...o,
  items: (o.items || []).map((it: any) => {
    let img = '/images/default-guitar.webp';
    try {
      if (it.product && it.product.gallery_images && it.product.gallery_images.length > 0) {
        img = typeof it.product.gallery_images === 'string' 
          ? JSON.parse(it.product.gallery_images)[0] 
          : it.product.gallery_images[0];
      }
    } catch(e) {}
    
    return {
      product_id: it.product_id,
      price: it.price_at_time || 0,
      quantity: it.quantity || 1,
      name: it.product?.name || 'Sản phẩm không xác định',
      image: img
    };
  })
}));
const totalOrders = count || 0;
const totalPages = Math.ceil(totalOrders / PAGE_SIZE);

// Thống kê nhanh theo trạng thái (trên trang hiện tại)
const pendingCount = orders.filter(o => o.status === 'pending').length;
const processingCount = orders.filter(o => o.status === 'processing').length;
const completedCount = orders.filter(o => o.status === 'completed').length;
const cancelledCount = orders.filter(o => o.status === 'cancelled').length;

const statusMap: Record<string, { label: string; cls: string }> = {
  pending:    { label: 'Chờ xử lý',   cls: 'badge-amber' },
  processing: { label: 'Đang xử lý',  cls: 'badge-blue'  },
  completed:  { label: 'Hoàn thành',  cls: 'badge-green' },
  cancelled:  { label: 'Đã hủy',      cls: 'badge-red'   },
};

function fmt(n: number) {
  return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(n);
}
function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}
---

<AdminLayout
  title="Quản lý đơn hàng"
  subtitle="Theo dõi, cập nhật và xuất dữ liệu đơn hàng nhạc cụ."
  activeNav="orders"
>
  <!-- ── OVERVIEW & ACTIONS (giao diện mới) ── -->
  <section class="orders-top">
    <div class="orders-top-text">
      <h2 class="orders-title">Quản lý Đơn hàng &amp; Yêu cầu</h2>
      <p class="orders-subtitle">
        Theo dõi và quản lý tập trung các yêu cầu và đơn hàng từ khách hàng.
      </p>
    </div>

    <div class="orders-stat-grid">
      <div class="stat-card">
        <p class="stat-label">Tổng cộng</p>
        <div class="stat-main">
          <span class="stat-value">{totalOrders}</span>
        </div>
      </div>
      <div class="stat-card stat-hot">
        <p class="stat-label">Chờ xử lý</p>
        <div class="stat-main">
          <span class="stat-value">{pendingCount}</span>
          <span class="stat-pill stat-pill-hot">HOT</span>
        </div>
      </div>
      <div class="stat-card">
        <p class="stat-label">Đang xử lý</p>
        <div class="stat-main">
          <span class="stat-value">{processingCount}</span>
        </div>
      </div>
      <div class="stat-card stat-success">
        <p class="stat-label">Hoàn thành</p>
        <div class="stat-main">
          <span class="stat-value">{completedCount}</span>
        </div>
      </div>
    </div>

  </section>

  <!-- ── FILTER TABS ── -->
  <div class="tabs-bar">
    <div class="filter-tabs no-scrollbar">
      {[
        { val: 'all',        label: 'Tất cả' },
        { val: 'pending',    label: 'Chờ xử lý' },
        { val: 'processing', label: 'Đang xử lý' },
        { val: 'completed',  label: 'Hoàn thành' },
        { val: 'cancelled',  label: 'Đã hủy' },
      ].map(tab => (
        <a
          href={`/admin/orders?status=${tab.val}${q ? `&q=${encodeURIComponent(q)}` : ''}`}
          class={`tab-btn ${statusFilter === tab.val ? 'tab-active' : ''}`}
        >
          {tab.label}
        </a>
      ))}
    </div>

    <div class="tabs-actions">
      <form class="search-wrap" method="GET" action="/admin/orders">
        <input type="hidden" name="status" value={statusFilter} />
        <div class="search-input">
          <span class="material-symbols-outlined search-ico">search</span>
          <input
            name="q"
            value={qRaw}
            placeholder="Tìm tên, SĐT hoặc ID..."
            autocomplete="off"
          />
        </div>
        <button class="btn-filter" type="submit">
          <span class="material-symbols-outlined">filter_alt</span>
          Lọc
        </button>
      </form>

      <button class="btn-export" id="btn-export" type="button">
        <span class="material-symbols-outlined">download</span>
        Xuất Excel
      </button>
    </div>
  </div>

  <!-- ── TABLE ── -->
  <div class="table-wrap">
    <div class="orders-table-scroller">
      <table class="orders-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Khách hàng</th>
            <th>Sản phẩm</th>
            <th style="text-align:right;">Giá trị</th>
            <th style="text-align:center;">Trạng thái</th>
            <th>Ngày tạo</th>
            <th style="text-align:right;">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          {orders.length === 0 && (
            <tr class="row-shell">
              <td colspan="7" class="empty-row">
                <span class="material-symbols-outlined empty-icon">inbox</span>
                <p>
                  {error
                    ? 'Bảng orders chưa được tạo. Hãy đặt đơn hàng đầu tiên từ trang cửa hàng!'
                    : 'Chưa có đơn hàng nào.'}
                </p>
              </td>
            </tr>
          )}

          {orders.map(o => {
            const items: any[] = o.items || [];
            const firstItem = items[0];
            const moreCount = items.length - 1;
            const statusInfo = statusMap[o.status] || { label: o.status, cls: 'badge-amber' };
            const initials =
              (o.customer_name || '')
                .split(' ')
                .filter(Boolean)
                .slice(-2)
                .map(p => p[0])
                .join('')
                .toUpperCase() || 'KH';

            return (
              <tr class="row-shell" data-order-id={o.id}>
                <td class="cell-id">
                  <span class="order-id">#{o.order_number}</span>
                </td>
                <td class="cell-customer">
                  <div class="customer-chip">
                    <div class="avatar-circle">
                      <span>{initials}</span>
                    </div>
                    <div class="customer-meta">
                      <p class="cus-name">{o.customer_name || 'Khách lẻ'}</p>
                      {o.customer_phone && <p class="cus-email">{o.customer_phone}</p>}
                      {o.customer_email && <p class="cus-email">{o.customer_email}</p>}
                    </div>
                  </div>
                </td>
                <td class="cell-product">
                  {firstItem ? (
                    <div class="prod-cell">
                      <div
                        class="prod-thumb"
                        style={firstItem.image ? `background-image:url('${firstItem.image}')` : ''}
                      ></div>
                      <div>
                        <span class="prod-name">{firstItem.name}</span>
                        {moreCount > 0 && (
                          <div class="prod-more">+{moreCount} sản phẩm khác</div>
                        )}
                      </div>
                    </div>
                  ) : (
                    <span class="prod-name prod-name-empty">—</span>
                  )}
                </td>
                <td class="total-col">
                  <span>{fmt(o.total_amount || 0)}</span>
                </td>
                <td class="status-col">
                  <select
                    class={`status-select status-${o.status}`}
                    data-order-id={o.id}
                    data-current={o.status}
                  >
                    <option value="pending"    selected={o.status === 'pending'}>Chờ xử lý</option>
                    <option value="processing" selected={o.status === 'processing'}>Đang xử lý</option>
                    <option value="completed"  selected={o.status === 'completed'}>Hoàn thành</option>
                    <option value="cancelled"  selected={o.status === 'cancelled'}>Đã hủy</option>
                  </select>
                </td>
                <td class="date-col">{fmtDate(o.created_at)}</td>
                <td class="action-col">
                  <div class="hidden cus-note" style="display:none;">{o.note || ''}</div>
                  <div class="hidden cus-pm" style="display:none;">{o.payment_method || ''}</div>
                  <div class="hidden cus-items" style="display:none;">{JSON.stringify(o.items || [])}</div>
                  <button
                    class="act-btn btn-detail"
                    data-order-id={o.id}
                    title="Xem chi tiết"
                  >
                    <span class="material-symbols-outlined">chevron_right</span>
                  </button>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="pagination">
      <span class="page-info">
        Hiển thị {orders.length} trong tổng {totalOrders} đơn hàng
        {totalOrders > 0 && ` — Trang ${page}/${totalPages}`}
      </span>
      {totalPages > 1 && (
        <div class="page-btns">
          {page > 1 && (
            <a href={`/admin/orders?status=${statusFilter}&page=${page - 1}${q ? `&q=${encodeURIComponent(q)}` : ''}`} class="page-nav">
              <span class="material-symbols-outlined">chevron_left</span>
            </a>
          )}
          {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
            <a
              href={`/admin/orders?status=${statusFilter}&page=${p}${q ? `&q=${encodeURIComponent(q)}` : ''}`}
              class={`page-num ${p === page ? 'page-active' : ''}`}
            >
              {p}
            </a>
          ))}
          {page < totalPages && (
            <a href={`/admin/orders?status=${statusFilter}&page=${page + 1}${q ? `&q=${encodeURIComponent(q)}` : ''}`} class="page-nav">
              <span class="material-symbols-outlined">chevron_right</span>
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- ── ORDER DETAIL DRAWER ── -->
  <aside id="order-drawer" class="drawer drawer-closed">
    <div class="drawer-header">
      <h3 class="drawer-title">
        Chi tiết đơn hàng <span id="drawer-order-code" class="drawer-title-code"></span>
      </h3>
      <button id="drawer-close" class="drawer-close-btn">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>
    <div id="drawer-body" class="drawer-body"></div>
    <div class="drawer-footer">
      <div class="drawer-actions-main">
        <button class="drawer-btn-primary" id="drawer-contact-btn">
          Liên hệ ngay
        </button>
      </div>
      <button class="drawer-btn-secondary" id="drawer-update-btn">
        Cập nhật trạng thái
      </button>
    </div>
  </aside>

  <!-- Toast -->
  <div id="toast-wrap" style="position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;"></div>

</AdminLayout>

<script>
  // ── Toast helper ──
  function showToast(msg: string, type: 'success' | 'error' = 'success') {
    const wrap = document.getElementById('toast-wrap')!;
    const t = document.createElement('div');
    t.className = `ord-toast ord-toast-${type}`;
    t.innerHTML = `<span class="material-symbols-outlined">${type === 'success' ? 'check_circle' : 'error'}</span>${msg}`;
    wrap.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 3000);
  }

  // ── Status dropdown change ──
  document.querySelectorAll<HTMLSelectElement>('.status-select').forEach(sel => {
    sel.addEventListener('change', async () => {
      const orderId = sel.dataset.orderId!;
      const newStatus = sel.value;
      const prev = sel.dataset.current!;

      sel.disabled = true;

      try {
        const res = await fetch('/api/orders/update-status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: orderId, status: newStatus }),
        });
        const data = await res.json();

        if (data.success) {
          sel.dataset.current = newStatus;
          // Reset class hoàn toàn để tránh regex match sai status-select
          sel.className = `status-select status-${newStatus}`;
          showToast('Cập nhật trạng thái thành công!');
        } else {
          throw new Error(data.error);
        }
      } catch (e: any) {
        sel.value = prev; // revert
        showToast('Lỗi: ' + (e.message || 'Không thể cập nhật'), 'error');
      } finally {
        sel.disabled = false;
      }
    });
  });

  // ── Order detail drawer ──
  const drawer = document.getElementById('order-drawer')!;
  const drawerBody = document.getElementById('drawer-body')!;
  const drawerOrderCode = document.getElementById('drawer-order-code')!;

  function openDrawer(orderId: string) {
    // Find row data from DOM
    const row = document.querySelector<HTMLElement>(`tr[data-order-id="${orderId}"]`);
    if (!row) return;
    
    const orderNum = row.querySelector('.order-id')?.textContent || '';
    const name = row.querySelector('.cus-name')?.textContent || '';
    const phone = row.querySelectorAll('.cus-email')[0]?.textContent || '';
    const email = row.querySelectorAll('.cus-email')[1]?.textContent || '';
    const total = row.querySelector('.total-col')?.textContent || '';
    const date = row.querySelector('.date-col')?.textContent || '';
    const status = row.querySelector<HTMLSelectElement>('.status-select')?.value || '';
    const note = row.querySelector('.cus-note')?.textContent || '';
    const pm = row.querySelector('.cus-pm')?.textContent || '';
    const itemsRaw = row.querySelector('.cus-items')?.textContent || '[]';
    let items = [];
    try { items = JSON.parse(itemsRaw); } catch(e){}

    const statusLabels: Record<string, string> = {
      pending: 'Chờ xử lý', processing: 'Đang xử lý',
      completed: 'Hoàn thành', cancelled: 'Đã hủy'
    };

    const pmLabels: Record<string, string> = {
      bank: 'Chuyển khoản / VietQR',
      cash: 'Tiền mặt khi nhận hàng',
      installment: 'Trả góp 0%'
    };

    drawerOrderCode.textContent = orderNum;
    drawerBody.innerHTML = `
      <section class="drawer-section">
        <h4 class="detail-section-title">Thông tin khách hàng</h4>
        <div class="detail-card">
          <div class="detail-row"><span>Họ tên</span><strong>${name}</strong></div>
          <div class="detail-row"><span>Điện thoại</span><strong>${phone}</strong></div>
          ${email ? `<div class="detail-row"><span>Email</span><strong>${email}</strong></div>` : ''}
        </div>
      </section>
      <section class="drawer-section">
        <h4 class="detail-section-title">Thông tin đơn hàng</h4>
        <div class="detail-card">
          <div class="detail-row"><span>Mã đơn</span><strong>${orderNum}</strong></div>
          <div class="detail-row"><span>Ngày tạo</span><strong>${date}</strong></div>
          <div class="detail-row"><span>Hình thức TT</span><strong>${pmLabels[pm] || pm}</strong></div>
          <div class="detail-row"><span>Giá trị</span><strong style="color:#f48c25;">${total}</strong></div>
          <div class="detail-row"><span>Trạng thái</span><strong>${statusLabels[status] || status}</strong></div>
          ${note ? `<div class="detail-row" style="flex-direction: column; align-items: flex-start; gap: 4px;"><span>Ghi chú</span><strong style="line-height: 1.4; white-space: pre-wrap;">${note}</strong></div>` : ''}
        </div>
      </section>
      <section class="drawer-section">
        <h4 class="detail-section-title">Sản phẩm đã mua</h4>
        <div class="detail-card" style="display:flex; flex-direction:column; gap:12px;">
          ${items.map((it: any) => `
             <div style="display:flex; gap:12px; align-items:center;">
                <img src="${it.image || '/images/default-guitar.webp'}" style="width:40px;height:40px;border-radius:6px;object-fit:cover; background:#221910;" />
                <div style="flex:1;">
                   <div style="font-size:13.5px; font-weight:700; color:#f9fafb; line-height:1.2; margin-bottom:4px;">${it.name}</div>
                   <div style="font-size:11px; font-weight:600; color:#f48c25;">
                     SL: ${it.quantity || 1} <span style="color:#64748b; margin:0 4px;">x</span> ${new Intl.NumberFormat('vi-VN', {style:'currency',currency:'VND'}).format(it.price || 0)}
                   </div>
                </div>
             </div>
          `).join('<div style="height:1px; background:rgba(74,58,42,.5); margin:4px 0;"></div>')}
        </div>
      </section>
    `;

    drawer.classList.remove('drawer-closed');
    drawer.classList.add('drawer-open');
    const _sy = window.scrollY;
    drawer.dataset.scrollY = String(_sy);
    document.body.style.position = 'fixed';
    document.body.style.top = `-${_sy}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer.classList.remove('drawer-open');
    drawer.classList.add('drawer-closed');
    const sy = Number(drawer.dataset.scrollY || 0);
    document.body.style.removeProperty('position');
    document.body.style.removeProperty('top');
    document.body.style.removeProperty('left');
    document.body.style.removeProperty('right');
    document.body.style.removeProperty('overflow');
    window.scrollTo({ top: sy, behavior: 'instant' });
  }

  document.querySelectorAll<HTMLButtonElement>('.btn-detail').forEach(btn => {
    btn.addEventListener('click', () => openDrawer(btn.dataset.orderId!));
  });

  document.getElementById('drawer-close')?.addEventListener('click', closeDrawer);

  // ── Export Excel ──
  document.getElementById('btn-export')?.addEventListener('click', () => {
    const params = new URLSearchParams(window.location.search);
    const qs = params.toString();
    window.location.href = qs ? `/api/orders/export?${qs}` : '/api/orders/export';
  });
</script>

<style>
  /* ── TOP SECTION (title + stats + actions) ── */
  .orders-top {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 24px;
  }
  .orders-top-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .orders-title {
    font-size: 24px;
    font-weight: 700;
    color: #f9fafb;
  }
  .orders-subtitle {
    font-size: 13px;
    color: #9ca3af;
  }

  .orders-stat-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }
  .stat-card {
    background: rgba(45,34,24,.4);
    border-radius: 14px;
    border: 1px solid #4a3a2a;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .stat-label {
    font-size: 11px;
    color: #9ca3af;
  }
  .stat-main {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 8px;
  }
  .stat-value {
    font-size: 20px;
    font-weight: 700;
    color: #f9fafb;
  }
  .stat-pill {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 999px;
    text-transform: uppercase;
  }
  .stat-pill-hot {
    background: rgba(248,113,113,.12);
    color: #f97316;
  }
  .stat-hot .stat-value {
    color: #f97316;
  }
  .stat-success .stat-value {
    color: #22c55e;
  }

  .orders-header-actions {
    display: flex;
    justify-content: flex-end;
  }

  .btn-export {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 12px;
    font-size: 13px; font-weight: 600;
    background: #2d2218; border: 1px solid #4a3a2a;
    color: #f1f5f9; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    transition: background .15s;
  }
  .btn-export:hover { background: #4a3a2a; }
  .btn-export .material-symbols-outlined { font-size: 18px; }

  /* ── FILTER TABS ── */
  .tabs-bar{
    display:flex;
    align-items:flex-end;
    justify-content:space-between;
    gap:16px;
    border-bottom: 1px solid rgba(74,58,42,.5);
    margin-bottom: 20px;
    padding-bottom: 2px;
  }
  .filter-tabs {
    display: flex;
    gap: 0;
    overflow-x: auto;
  }
  .no-scrollbar::-webkit-scrollbar { display:none; }
  .no-scrollbar { -ms-overflow-style:none; scrollbar-width:none; }
  .tab-btn {
    padding: 12px 20px;
    font-size: 13px; font-weight: 600;
    background: none; border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    color: #64748b;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all .15s;
    text-decoration: none;
    white-space: nowrap;
  }
  .tab-btn:hover { color: #cbd5e1; }
  .tab-active { color: #f48c25; border-bottom-color: #f48c25; font-weight: 700; }

  .tabs-actions{
    display:flex;
    align-items:center;
    gap:12px;
    flex-shrink:0;
    padding-bottom: 8px;
  }
  .search-wrap{
    display:flex;
    align-items:center;
    gap:10px;
  }
  .search-input{
    position:relative;
    width: 420px;
    max-width: 46vw;
  }
