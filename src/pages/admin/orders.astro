    total: '12.000.000₫', status: 'shipping', date: '11/10/2023',
  },
  {
    id: '#FS-1026',
    customer: 'Lê Hoàng Nam',
    email: 'namle@email.com',
    product: 'Acoustic Wood W-2',
    img: 'https://lh3.googleusercontent.com/aida-public/AB6AXuD-5SP_EitEAGNjsO1vCP13_Trp0_I_pTty7Fvr_9YuBlYikDdypk7RxzXpQRCW6jRR-PWgNBMsZhAkp0w3OEWH7rqPih6dqXOiXNin8G2RAHTLaIa9DWIdIp1rX3oMivzKPUIaIsdBnLWEEsd7KwiQ97DWzEGNbKDUqbrZ6Hfbzmpr_t1Lo9OUl-ixhBX2nxHR3bBiEL89kxwDiHWKqNuxBfSxulLFsi4x4sz-k8iTb1waPCPfQZqsKf6EFCel0PbvIS1bdeO5R2_l',
    total: '7.200.000₫', status: 'done', date: '10/10/2023',
