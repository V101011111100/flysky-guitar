---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// Lấy tất cả đơn hàng, tổng hợp theo khách hàng (phone)
const { data: ordersRaw, error } = await supabase
  .from('orders')
  .select('id, customer_name, customer_phone, customer_email, shipping_address, status, total_amount, created_at')
  .order('created_at', { ascending: false });

const orders = ordersRaw || [];

// Lấy tên chính thức admin đã đặt (từ bảng customers)
const { data: overridesRaw } = await supabase
  .from('customers')
  .select('phone, display_name, note');
const overrideMap = new Map<string, { display_name: string | null; note: string | null }>(
  (overridesRaw || []).map(c => [c.phone, { display_name: c.display_name, note: c.note }])
);

// Nhóm theo số điện thoại → tạo danh sách khách hàng
type CustomerRecord = {
  name: string;          // Tên từ đơn mới nhất
  displayName: string | null; // Tên chính thức do admin đặt
  note: string | null;
  phone: string;
  email: string;
  address: string;
  orderCount: number;
  totalSpent: number;
  lastOrderDate: string;
  lastStatus: string;
  allNames: string[];    // Tất cả tên đã từng dùng
  hasConflict: boolean;  // Có nhiều tên khác nhau?
  orders: typeof orders;
};

const customerMap = new Map<string, CustomerRecord>();

for (const o of orders) {
  const key = o.customer_phone || o.customer_email || o.id;
  const override = overrideMap.get(key);
  if (!customerMap.has(key)) {
    customerMap.set(key, {
      name: o.customer_name,
      displayName: override?.display_name ?? null,
      note: override?.note ?? null,
      phone: o.customer_phone,
      email: o.customer_email || '',
      address: o.shipping_address || '',
      orderCount: 0,
      totalSpent: 0,
      lastOrderDate: o.created_at,
      lastStatus: o.status,
      allNames: [],
      hasConflict: false,
      orders: [],
    });
  }
  const c = customerMap.get(key)!;
  c.orderCount++;
  c.totalSpent += o.total_amount || 0;
  c.orders.push(o);
  // Tích lũy tên để phát hiện xung đột
  if (o.customer_name && !c.allNames.includes(o.customer_name)) {
    c.allNames.push(o.customer_name);
  }
  // Lấy đơn mới nhất
  if (new Date(o.created_at) > new Date(c.lastOrderDate)) {
    c.lastOrderDate = o.created_at;
    c.lastStatus = o.status;
    c.name = o.customer_name;
    c.address = o.shipping_address || '';
  }
}

// Đánh dấu conflict sau khi tổng hợp xong
for (const c of customerMap.values()) {
  c.hasConflict = c.allNames.length > 1;
}

const customers = Array.from(customerMap.values()).sort(
  (a, b) => new Date(b.lastOrderDate).getTime() - new Date(a.lastOrderDate).getTime()
);

// Thống kê tổng quan
const totalCustomers = customers.length;
const newThisMonth = customers.filter(c => {
  const d = new Date(c.lastOrderDate);
  const now = new Date();
  return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
}).length;
const repeatCustomers = customers.filter(c => c.orderCount > 1).length;
const totalRevenue = customers.reduce((s, c) => s + c.totalSpent, 0);

function fmt(n: number) {
  return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(n);
}
function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

const statusLabel: Record<string, string> = {
  pending:    'Chờ xử lý',
  processing: 'Đang xử lý',
  completed:  'Hoàn thành',
  cancelled:  'Đã hủy',
};
---

<AdminLayout
  title="Khách hàng"
  subtitle="Tổng hợp và theo dõi khách hàng từ dữ liệu đơn hàng thực tế."
  activeNav="consultations"
>

  <!-- ── STAT CARDS ── -->
  <div class="cus-stats">
    {[
      { label: 'Tổng khách hàng', val: totalCustomers, icon: 'group', color: '#f48c25' },
      { label: 'Khách mới tháng này', val: newThisMonth, icon: 'person_add', color: '#60a5fa' },
      { label: 'Khách quay lại', val: repeatCustomers, icon: 'loyalty', color: '#34d399' },
      { label: 'Tổng doanh thu', val: fmt(totalRevenue), icon: 'payments', color: '#fbbf24', wide: true },
    ].map(s => (
      <div class="stat-card">
        <div class="stat-top">
          <span class="stat-label">{s.label}</span>
          <div class="stat-icon" style={`background: ${s.color}20; color: ${s.color};`}>
            <span class="material-symbols-outlined">{s.icon}</span>
          </div>
        </div>
        <div class="stat-val">{s.val}</div>
      </div>
    ))}
  </div>

  <!-- ── SEARCH ── -->
  <div class="toolbar">
    <div class="search-wrap">
      <span class="material-symbols-outlined s-icon">search</span>
      <input type="text" id="search-input" placeholder="Tìm theo tên, SĐT, email..." class="search-in" />
    </div>
    <span class="total-label" id="total-label">{customers.length} khách hàng</span>
  </div>

  <!-- ── TABLE ── -->
  <div class="table-wrap">
    <div style="overflow-x: auto;">
      <table class="cus-table" id="cus-table">
        <thead>
          <tr>
            <th>Khách hàng</th>
            <th>Liên hệ</th>
            <th style="text-align:center;">Số đơn</th>
            <th style="text-align:right;">Tổng chi tiêu</th>
            <th style="text-align:center;">Đơn gần nhất</th>
            <th>Trạng thái</th>
            <th style="text-align:center;">Lần mua cuối</th>
            <th style="text-align:center;">Chi tiết</th>
          </tr>
        </thead>
        <tbody>
          {customers.length === 0 && (
            <tr>
              <td colspan="8" class="empty-row">
                <span class="material-symbols-outlined" style="font-size:40px;opacity:0.3;">group_off</span>
                <p style="margin-top:8px;color:#64748b;">
                  {error ? 'Chưa có đơn hàng nào. Hãy kiểm tra kết nối database.' : 'Chưa có khách hàng nào. Đơn hàng đầu tiên sẽ xuất hiện ở đây.'}
                </p>
              </td>
            </tr>
          )}
          {customers.map((c, i) => (
            <tr class="cus-row" data-search={`${c.displayName || ''} ${c.name} ${c.phone} ${c.email}`.toLowerCase()}>
              <td>
                <div class="cus-cell">
                  <div class="cus-avatar" style={`background: hsl(${(i * 47) % 360}, 60%, 25%); color: hsl(${(i * 47) % 360}, 80%, 75%);`}>
                    {(c.displayName || c.name).charAt(0).toUpperCase()}
                  </div>
                  <div style="min-width:0;">
                    {/* Tên chính thức (admin đặt) */}
                    {c.displayName ? (
                      <div class="cus-name official-name" title="Tên chính thức do admin đặt">
                        <span class="material-symbols-outlined" style="font-size:13px;color:#f48c25;vertical-align:middle;">verified</span>
                        {' '}{c.displayName}
                      </div>
                    ) : (
                      <div class="cus-name">{c.name}</div>
                    )}
                    {/* Tên gốc từ đơn (khi đã có override) */}
                    {c.displayName && (
                      <div style="font-size:11px;color:#64748b;margin-top:1px;">
                        Đặt hàng với tên: {c.name}
                      </div>
                    )}
                    {/* Cảnh báo nhiều tên */}
                    {c.hasConflict && !c.displayName && (
                      <div class="conflict-badge" title={`Các tên đã dùng: ${c.allNames.join(', ')}`}>
                        <span class="material-symbols-outlined">warning</span>
                        {c.allNames.length} tên khác nhau
                      </div>
                    )}
                    <div class="name-badges-row">
                      {c.orderCount > 1 && <span class="badge-repeat">⭐ Khách quen</span>}
                      <button
                        class="btn-edit-name"
                        data-phone={c.phone}
                        data-display-name={c.displayName || ''}
                        data-note={c.note || ''}
                        data-all-names={c.allNames.join('|')}
                        title="Đặt tên chính thức"
                      >
                        <span class="material-symbols-outlined">edit</span>
                      </button>
                    </div>
                  </div>
                </div>
              </td>
              <td>
                <div class="contact-cell">
                  <span class="material-symbols-outlined" style="font-size:14px;color:#64748b;">phone</span>
                  <span class="contact-val">{c.phone}</span>
                </div>
                {c.email && (
                  <div class="contact-cell" style="margin-top:3px;">
                    <span class="material-symbols-outlined" style="font-size:14px;color:#64748b;">mail</span>
                    <span class="contact-val">{c.email}</span>
                  </div>
                )}
              </td>
              <td style="text-align:center;">
                <span class="order-count">{c.orderCount}</span>
              </td>
              <td style="text-align:right;">
                <span class="spent-val">{fmt(c.totalSpent)}</span>
              </td>
              <td style="text-align:center;">
                <span class={`status-badge status-${c.lastStatus}`}>
                  {statusLabel[c.lastStatus] || c.lastStatus}
                </span>
              </td>
              <td>
                <div class="address-cell" title={c.address}>{c.address || '—'}</div>
              </td>
              <td style="text-align:center;">
                <span class="date-val">{fmtDate(c.lastOrderDate)}</span>
              </td>
              <td style="text-align:center;">
                <button class="btn-detail" data-phone={c.phone} data-name={c.name} title="Xem lịch sử đơn hàng">
                  <span class="material-symbols-outlined">receipt_long</span>
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="table-footer">
      <span class="page-info" id="page-info">{customers.length} khách hàng</span>
    </div>
  </div>

  <!-- ── EDIT NAME MODAL ── -->
  <div id="edit-modal" class="modal-backdrop hidden">
    <div class="modal-box" style="max-width:420px;">
      <div class="modal-header">
        <div>
          <h3 class="modal-title">Đặt tên chính thức</h3>
          <p class="modal-sub" id="edit-modal-phone"></p>
        </div>
        <button id="edit-modal-close" class="modal-close-btn">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div class="modal-body" style="padding:20px 24px;">
        <!-- Danh sách tên đã dùng -->
        <div id="edit-all-names" class="all-names-box"></div>

        <label class="edit-label">Tên chính thức (admin đặt)</label>
        <input
          type="text"
          id="edit-display-name"
          class="edit-input"
          placeholder="Nhập tên chính thức..."
        />

        <label class="edit-label" style="margin-top:12px;">Ghi chú nội bộ</label>
        <textarea
          id="edit-note"
          class="edit-input"
          rows="2"
          placeholder="VD: Khách hay đổi địa chỉ, ưu tiên gọi sáng..."
          style="resize:vertical;"
        ></textarea>

        <div style="display:flex;gap:8px;margin-top:16px;">
          <button id="edit-save-btn" class="btn-save-name">
            <span class="material-symbols-outlined">save</span>
            Lưu
          </button>
          <button id="edit-clear-btn" class="btn-clear-name" title="Xóa tên chính thức đã đặt">
            <span class="material-symbols-outlined">delete</span>
            Xóa override
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ── ORDER HISTORY MODAL ── -->
  <div id="history-modal" class="modal-backdrop hidden">
    <div class="modal-box">
      <div class="modal-header">
        <div>
          <h3 class="modal-title" id="modal-cus-name">Lịch sử đơn hàng</h3>
          <p class="modal-sub" id="modal-cus-phone"></p>
        </div>
        <button id="modal-close" class="modal-close-btn">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div id="modal-body" class="modal-body">
        <!-- filled by JS -->
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast-wrap" style="position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;"></div>

</AdminLayout>

<script>
  // ── Search ──
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const rows = document.querySelectorAll<HTMLElement>('.cus-row');
  const totalLabel = document.getElementById('total-label')!;

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    let visible = 0;
    rows.forEach(row => {
      const match = !q || (row.dataset.search || '').includes(q);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    totalLabel.textContent = `${visible} khách hàng`;
  });

  // ── Toast helper ──
  function showToast(msg: string, type: 'success' | 'error' = 'success') {
    const wrap = document.getElementById('toast-wrap')!;
    const t = document.createElement('div');
    t.className = `ord-toast ord-toast-${type}`;
    t.innerHTML = `<span class="material-symbols-outlined">${type === 'success' ? 'check_circle' : 'error'}</span>${msg}`;
    wrap.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 3000);
  }

  // ── Edit Name Modal ──
  const editModal = document.getElementById('edit-modal')!;
  const editPhone = document.getElementById('edit-modal-phone')!;
  const editInput = document.getElementById('edit-display-name') as HTMLInputElement;
  const editNote  = document.getElementById('edit-note') as HTMLTextAreaElement;
  const editAllNames = document.getElementById('edit-all-names')!;

  let currentEditPhone = '';

  document.querySelectorAll<HTMLButtonElement>('.btn-edit-name').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      currentEditPhone = btn.dataset.phone!;
      editPhone.textContent = currentEditPhone;
      editInput.value = btn.dataset.displayName || '';
      editNote.value = btn.dataset.note || '';

      // Show all known names
      const allNames = (btn.dataset.allNames || '').split('|').filter(Boolean);
      if (allNames.length > 1) {
        editAllNames.innerHTML = `
          <div class="names-header">Các tên đã đặt hàng:</div>
          <div class="names-chips">
            ${allNames.map(n => `<span class="name-chip" onclick="document.getElementById('edit-display-name').value='${n.replace(/'/g, "\\'")}';">${n}</span>`).join('')}
          </div>
        `;
      } else if (allNames.length === 1) {
        editAllNames.innerHTML = '';
        if (!editInput.value) editInput.value = allNames[0];
      } else {
        editAllNames.innerHTML = '';
      }

      editModal.classList.remove('hidden');
      editInput.focus();
    });
  });

  document.getElementById('edit-modal-close')?.addEventListener('click', () => editModal.classList.add('hidden'));
  editModal.addEventListener('click', e => { if (e.target === editModal) editModal.classList.add('hidden'); });

  async function saveCustomerName(displayName: string | null) {
    const btn = document.getElementById('edit-save-btn') as HTMLButtonElement;
    btn.disabled = true;
    try {
      const res = await fetch('/api/customers/upsert', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          phone: currentEditPhone,
          display_name: displayName,
          note: editNote.value,
        }),
      });
      const data = await res.json();
      if (data.success) {
        showToast(displayName ? 'Đã lưu tên chính thức!' : 'Đã xóa tên chính thức!');
        editModal.classList.add('hidden');
        setTimeout(() => location.reload(), 800);
      } else {
        throw new Error(data.error);
      }
    } catch (e: any) {
      showToast('Lỗi: ' + e.message, 'error');
    } finally {
      btn.disabled = false;
    }
  }

  document.getElementById('edit-save-btn')?.addEventListener('click', () => saveCustomerName(editInput.value.trim() || null));
  document.getElementById('edit-clear-btn')?.addEventListener('click', () => {
    if (confirm('Xóa tên chính thức? Sẽ hiển thị lại tên từ đơn hàng.')) saveCustomerName(null);
  });

  // ── Order History Modal ──
  const modal = document.getElementById('history-modal')!;
  const modalBody = document.getElementById('modal-body')!;
  const modalName = document.getElementById('modal-cus-name')!;
  const modalPhone = document.getElementById('modal-cus-phone')!;

  // Collect order data from inline data attributes (passed via row)
  document.querySelectorAll<HTMLButtonElement>('.btn-detail').forEach(btn => {
    btn.addEventListener('click', async () => {
      const phone = btn.dataset.phone!;
      const name = btn.dataset.name!;
      modalName.textContent = name;
      modalPhone.textContent = phone;
      modalBody.innerHTML = '<div style="text-align:center;padding:32px;color:#64748b;"><span class="material-symbols-outlined" style="animation:spin 1s linear infinite;font-size:32px;">autorenew</span></div>';
      modal.classList.remove('hidden');

      // Fetch orders for this customer
      const res = await fetch(`/api/orders/by-phone?phone=${encodeURIComponent(phone)}`);
      const data = await res.json();
      const orders = data.orders || [];

      if (orders.length === 0) {
        modalBody.innerHTML = '<p style="color:#64748b;padding:24px;text-align:center;">Không có đơn hàng nào.</p>';
        return;
      }

      const statusLabel: Record<string, string> = {
        pending: 'Chờ xử lý', processing: 'Đang xử lý',
        completed: 'Hoàn thành', cancelled: 'Đã hủy'
      };
      const statusCls: Record<string, string> = {
        pending: 'status-pending', processing: 'status-processing',
        completed: 'status-completed', cancelled: 'status-cancelled'
      };

      modalBody.innerHTML = orders.map((o: any) => `
        <div class="order-history-item">
          <div class="oh-top">
            <div>
              <span class="oh-num">${o.order_number}</span>
              <span class="oh-date">${new Date(o.created_at).toLocaleDateString('vi-VN')}</span>
            </div>
            <span class="oh-status ${statusCls[o.status] || ''}">${statusLabel[o.status] || o.status}</span>
          </div>
          <div class="oh-bottom">
            <span style="color:#94a3b8;font-size:12px;">${o.shipping_address || ''}</span>
            <strong class="oh-total">${new Intl.NumberFormat('vi-VN',{style:'currency',currency:'VND'}).format(o.total_amount||0)}</strong>
          </div>
        </div>
      `).join('');
    });
  });

  document.getElementById('modal-close')?.addEventListener('click', () => modal.classList.add('hidden'));
  modal.addEventListener('click', e => { if (e.target === modal) modal.classList.add('hidden'); });
</script>

<style>
  /* ── STATS ── */
  .cus-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (max-width: 1200px) { .cus-stats { grid-template-columns: 1fr 1fr; } }

  .stat-card {
    background: #2d2218;
    border: 1px solid #4a3a2a;
    border-radius: 14px;
    padding: 20px 24px;
    transition: border-color .2s;
  }
  .stat-card:hover { border-color: rgba(244,140,37,.4); }
  .stat-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .stat-label { font-size: 13px; color: #94a3b8; font-weight: 500; }
  .stat-icon {
    width: 36px; height: 36px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .stat-icon .material-symbols-outlined { font-size: 20px; }
  .stat-val { font-size: 26px; font-weight: 900; color: #f9fafb; }

  /* ── TOOLBAR ── */
  .toolbar {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; margin-bottom: 16px;
  }
  .search-wrap { position: relative; flex: 1; max-width: 400px; }
  .s-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); font-size: 20px; color: #64748b; }
  .search-in {
    width: 100%; padding: 10px 16px 10px 40px;
    background: #2d2218; border: 1px solid #4a3a2a;
    border-radius: 10px; font-size: 13px; color: #f1f5f9;
    font-family: 'Manrope', sans-serif; outline: none; transition: border .2s;
  }
  .search-in::placeholder { color: #64748b; }
  .search-in:focus { border-color: #f48c25; }
  .total-label { font-size: 12px; color: #64748b; white-space: nowrap; }

  /* ── TABLE ── */
  .table-wrap {
    background: rgba(45,34,24,.4);
    border: 1px solid #4a3a2a;
    border-radius: 16px; overflow: hidden;
  }
  .cus-table { width: 100%; border-collapse: collapse; text-align: left; }
  .cus-table thead tr { background: rgba(45,34,24,.7); }
  .cus-table th {
    padding: 14px 20px; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .1em;
    color: #94a3b8; white-space: nowrap;
  }
  .cus-table tbody tr { border-top: 1px solid #4a3a2a; transition: background .15s; }
  .cus-table tbody tr:hover { background: rgba(74,58,42,.2); }
  .cus-table td { padding: 16px 20px; vertical-align: middle; }

  .empty-row { text-align: center; padding: 60px; color: #64748b; }

  /* Customer cell */
  .cus-cell { display: flex; align-items: center; gap: 12px; }
  .cus-avatar {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; font-weight: 800; flex-shrink: 0;
  }
  .cus-name { font-size: 13.5px; font-weight: 700; color: #f9fafb; }
  .official-name { color: #fde68a; }
  .conflict-badge {
    display: inline-flex; align-items: center; gap: 3px; margin-top: 4px;
    font-size: 10px; font-weight: 700; color: #fbbf24;
    background: rgba(251,191,36,.1); border: 1px solid rgba(251,191,36,.25);
    border-radius: 4px; padding: 2px 6px; cursor: default;
  }
  .conflict-badge .material-symbols-outlined { font-size: 12px; }
  .name-badges-row { display: flex; align-items: center; gap: 4px; margin-top: 4px; flex-wrap: wrap; }
  .badge-repeat {
    display: inline-block;
    font-size: 10px; font-weight: 700;
    background: rgba(251,191,36,.1); color: #fbbf24;
    border: 1px solid rgba(251,191,36,.2); border-radius: 4px;
    padding: 1px 6px;
