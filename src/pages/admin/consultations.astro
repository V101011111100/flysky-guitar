---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Tư vấn khách hàng" activeNav="consultations">
  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;">
    {[
      { label: 'Tổng yêu cầu', value: '1,248', color: '#fff' },
      { label: 'Chờ xử lý', value: '42', color: '#f59e0b' },
      { label: 'Đã liên hệ', value: '856', color: '#3b82f6' },
      { label: 'Đã chốt đơn', value: '350', color: '#10b981' },
    ].map(s => (
      <div class="stat-card" style="text-align:center;">
        <p class="stat-label">{s.label}</p>
        <p class="stat-value" style={`color:${s.color};font-size:30px;`}>{s.value}</p>
      </div>
    ))}
  </div>

  <div style="display:grid;grid-template-columns:1fr 380px;gap:20px;">
    <!-- Main table -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Danh sách yêu cầu tư vấn</span>
        <div style="display:flex;gap:8px;">
          <select class="admin-select" id="status-filter" style="font-size:12px;padding:5px 10px;">
            <option value="all">Tất cả</option>
            <option value="pending">Chờ xử lý</option>
            <option value="contacted">Đã liên hệ</option>
            <option value="closed">Đã chốt</option>
          </select>
          <input class="admin-input" placeholder="Tìm kiếm..." style="width:160px;font-size:12px;padding:5px 10px;" id="search-input" />
        </div>
      </div>
      <div style="overflow-x:auto;">
        <table class="admin-table" id="consult-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Khách hàng</th>
              <th>Số điện thoại</th>
              <th>Nội dung</th>
              <th>Trạng thái</th>
              <th>Thời gian</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {[
              { id: 'REQ-1023', name: 'Trần Thị Bích', phone: '0901 234 567', msg: 'Muốn tư vấn guitar acoustic Cordoba C5', status: 'pending', time: '5 phút' },
              { id: 'REQ-1022', name: 'Nguyễn Văn An', phone: '0912 345 678', msg: 'Cần tư vấn dòng Electric cho nhạc Rock', status: 'contacted', time: '30 phút' },
              { id: 'REQ-1021', name: 'Lê Minh Cường', phone: '0933 456 789', msg: 'Khóa đàn số 3 bị kẹt, cần bảo hành', status: 'closed', time: '1 giờ' },
              { id: 'REQ-1020', name: 'Phạm Thu Hà', phone: '0944 567 890', msg: 'Tư vấn guitar bass FlySky Thunder', status: 'pending', time: '2 giờ' },
              { id: 'REQ-1019', name: 'Vũ Đình Hùng', phone: '0955 678 901', msg: 'Hỏi giá Piano Grand Concert', status: 'contacted', time: '3 giờ' },
              { id: 'REQ-1018', name: 'Đỗ Thị Lan', phone: '0966 789 012', msg: 'Cần đàn acoustic tầm 15 triệu', status: 'closed', time: '5 giờ' },
            ].map((r, i) => (
              <tr data-status={r.status} class="consult-row">
                <td style="font-size:11px;color:#6b5a46;">{r.id}</td>
                <td style="font-weight:600;color:#fff;">{r.name}</td>
                <td style="color:#f48c25;">{r.phone}</td>
                <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{r.msg}</td>
                <td>
                  <span class={`badge badge-${r.status}`}>
                    {r.status === 'pending' ? '⏳ Chờ xử lý' : r.status === 'contacted' ? '📞 Đã liên hệ' : '✅ Đã chốt'}
                  </span>
                </td>
                <td style="color:#6b5a46;font-size:12px;">{r.time} trước</td>
                <td>
                  <button class="btn-icon" onclick={`openDetail(${i})`} title="Xem chi tiết">
                    <span class="material-symbols-outlined" style="font-size:16px;">open_in_new</span>
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Detail panel -->
    <div class="card" id="detail-panel">
      <div class="card-header">
        <span class="card-title" style="color:#f48c25;">#REQ-1023 — Trần Thị Bích</span>
        <span class="badge badge-pending">⏳ Chờ xử lý</span>
      </div>
      <div class="card-body" style="display:flex;flex-direction:column;gap:16px;">
        <!-- Customer info -->
        <div style="background:#0e0a06;border-radius:10px;padding:14px;display:flex;flex-direction:column;gap:8px;">
          <div style="display:flex;gap:8px;font-size:12px;"><span style="color:#6b5a46;width:70px;flex-shrink:0;">Tên:</span><span style="color:#fff;font-weight:600;">Trần Thị Bích</span></div>
          <div style="display:flex;gap:8px;font-size:12px;"><span style="color:#6b5a46;width:70px;flex-shrink:0;">SĐT:</span><span style="color:#f48c25;font-weight:700;">0901 234 567</span></div>
          <div style="display:flex;gap:8px;font-size:12px;"><span style="color:#6b5a46;width:70px;flex-shrink:0;">Nội dung:</span><span style="color:#ccc;">Muốn tư vấn guitar acoustic Cordoba C5</span></div>
        </div>

        <!-- Chat history -->
        <div>
          <p style="font-size:11px;font-weight:700;color:#6b5a46;text-transform:uppercase;margin-bottom:10px;">Lịch sử trao đổi</p>
          <div style="display:flex;flex-direction:column;gap:10px;max-height:180px;overflow-y:auto;">
            <div style="background:rgba(244,140,37,0.1);border-radius:8px;padding:10px;font-size:12px;">
              <p style="color:#f48c25;font-weight:700;margin-bottom:4px;">Admin</p>
              <p style="color:#ccc;">Chào chị Bích, em là admin FlySky. Chị cần tư vấn thêm về mẫu acoustic không ạ?</p>
            </div>
            <div style="background:#0e0a06;border-radius:8px;padding:10px;font-size:12px;margin-left:16px;">
              <p style="color:#3b82f6;font-weight:700;margin-bottom:4px;">Khách hàng</p>
              <p style="color:#ccc;">Dạ, mình đang phân vân giá cả chút xíu. Shop có ưu đãi gì không?</p>
            </div>
          </div>
        </div>

        <!-- Quick reply -->
        <div>
          <p style="font-size:11px;font-weight:700;color:#6b5a46;text-transform:uppercase;margin-bottom:8px;">Mẫu trả lời nhanh</p>
          <div style="display:flex;flex-direction:column;gap:6px;">
            {['Chào hỏi & Giới thiệu', 'Tư vấn sản phẩm', 'Thông tin bảo hành', 'Mời ghé showroom'].map(t => (
              <button class="btn-secondary" style="font-size:11px;justify-content:flex-start;text-align:left;padding:6px 10px;" onclick={`insertTemplate('${t}')`}>{t}</button>
            ))}
          </div>
        </div>

        <!-- Reply box -->
        <div>
          <textarea id="reply-box" class="admin-input" rows="3" placeholder="Nhập nội dung trả lời..." style="resize:none;"></textarea>
          <div style="display:flex;gap:8px;margin-top:8px;">
            <button class="btn-primary" style="flex:1;justify-content:center;">
              <span class="material-symbols-outlined" style="font-size:16px;">send</span>
              Gửi trả lời
            </button>
            <button class="btn-secondary" style="font-size:12px;padding:8px 12px;" onclick="markContacted()">
              <span class="material-symbols-outlined" style="font-size:15px;">phone_in_talk</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const statusFilter = document.getElementById('status-filter') as HTMLSelectElement;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;

  function filterTable() {
    const status = statusFilter.value;
    const q = searchInput.value.toLowerCase();
    document.querySelectorAll('.consult-row').forEach((row: any) => {
      const rowStatus = row.dataset.status;
      const text = row.textContent.toLowerCase();
      const matchStatus = status === 'all' || rowStatus === status;
      const matchSearch = !q || text.includes(q);
      row.style.display = matchStatus && matchSearch ? '' : 'none';
    });
  }

  statusFilter.addEventListener('change', filterTable);
  searchInput.addEventListener('input', filterTable);

  const templates: Record<string, string> = {
    'Chào hỏi & Giới thiệu': 'Chào bạn, cảm ơn bạn đã quan tâm đến FlySky Guitar. Mình có thể giúp gì cho bạn ạ?',
    'Tư vấn sản phẩm': 'Dạ, sản phẩm này hiện đang có giá ưu đãi. Bên em đang có chương trình tặng kèm bao đàn và phụ kiện ạ.',
    'Thông tin bảo hành': 'Sản phẩm được bảo hành chính hãng 12 tháng, bảo trì trọn đời tại showroom FlySky ạ.',
    'Mời ghé showroom': 'Mời bạn ghé showroom để trải nghiệm trực tiếp âm thanh nhé. Shop mở cửa từ 8h-21h hàng ngày ạ.',
  };

  function insertTemplate(name: string) {
    const box = document.getElementById('reply-box') as HTMLTextAreaElement;
    box.value = templates[name] || '';
    box.focus();
  }

  function markContacted() {
    alert('Đã đánh dấu trạng thái: Đã liên hệ');
  }

  function openDetail(i: number) {
    // Future: open modal or navigate
  }

  (window as any).insertTemplate = insertTemplate;
  (window as any).markContacted = markContacted;
  (window as any).openDetail = openDetail;
</script>
