---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Quản lý mã giảm giá"
  subtitle="Tạo, cập nhật và theo dõi hiệu suất các chương trình khuyến mãi."
  activeNav="discounts"
>

  <div class="dc-container" x-data="discountManager()" x-init="init()">
    <!-- Page Header & Stats -->
    <div class="dc-header">
      <h1 class="dc-title">Quản lý mã giảm giá</h1>
      <div class="dc-header-right">
        <p class="dc-sub">Tạo, cập nhật và theo dõi hiệu suất các chương trình khuyến mãi.</p>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="dc-stats-grid">
      <div class="dc-stat-card">
        <div class="dc-stat-head">
          <span class="material-symbols-outlined dc-icon-bg text-primary bg-primary-10">confirmation_number</span>
        </div>
        <p class="dc-stat-label">Mã đang chạy</p>
        <p class="dc-stat-val" x-text="activeDiscountsCount"></p>
      </div>
      <div class="dc-stat-card">
        <div class="dc-stat-head">
          <span class="material-symbols-outlined dc-icon-bg text-blue bg-blue-10">group</span>
        </div>
        <p class="dc-stat-label">Tổng lượt dùng</p>
        <p class="dc-stat-val" x-text="totalUsedCount"></p>
      </div>
      <div class="dc-stat-card">
        <div class="dc-stat-head">
          <span class="material-symbols-outlined dc-icon-bg text-amber bg-amber-10">payments</span>
        </div>
        <p class="dc-stat-label">Tổng mã đã tạo</p>
        <p class="dc-stat-val" x-text="discounts.length"></p>
      </div>
    </div>

    <!-- Main Content Layout -->
    <div class="dc-main-layout">
      
      <!-- Form Section -->
      <div class="dc-col-side">
        <div class="card dc-form-card">
          <div class="dc-form-head">
            <span class="material-symbols-outlined text-primary">edit_note</span>
            <h3 class="dc-form-title" x-text="form.id ? 'Cập nhật mã giảm giá' : 'Tạo mã mới'"></h3>
          </div>
          
          <form class="dc-form" @submit.prevent="saveDiscount">
            <div class="form-group">
              <label class="form-label">Tên mã (Code) *</label>
              <input type="text" x-model="form.code" required class="form-input text-uppercase fw-bold tracking-wide" placeholder="VD: FLYSKY2026" />
            </div>
            
            <div class="form-group">
              <label class="form-label">Mô tả ngắn</label>
              <input type="text" x-model="form.description" class="form-input" placeholder="Khuyến mãi mùa hè..." />
            </div>

            <div class="form-row-2">
              <div class="form-group">
                <label class="form-label">Loại giảm giá</label>
                <select x-model="form.discount_type" class="form-select">
                  <option value="percent">Phần trăm (%)</option>
                  <option value="fixed">Số tiền cố định</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Giá trị *</label>
                <div class="input-with-suffix">
                  <input type="number" x-model.number="form.discount_value" required min="1" class="form-input" />
                  <span class="input-suffix" x-text="form.discount_type === 'percent' ? '%' : 'VNĐ'"></span>
                </div>
              </div>
            </div>

            <div class="form-row-2">
              <div class="form-group">
                <label class="form-label">Trạng thái</label>
                <select x-model="form.status" class="form-select">
                  <option value="Đang hoạt động">Đang hoạt động</option>
                  <option value="Bản nháp">Bản nháp</option>
                  <option value="Đã hết hạn">Đã hết hạn</option>
                </select>
              </div>
            </div>

            <div class="form-row-2">
              <div class="form-group">
                <label class="form-label">Ngày bắt đầu</label>
                <input type="date" x-model="form.start_date" class="form-input" />
              </div>
              <div class="form-group">
                <label class="form-label">Ngày kết thúc</label>
                <input type="date" x-model="form.end_date" class="form-input" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Giá trị đơn hàng tối thiểu (đ)</label>
              <input type="number" x-model.number="form.min_order_value" class="form-input" placeholder="Ví dụ: 500000" />
            </div>

            <div class="form-row-2">
              <div class="form-group">
                <label class="form-label">Giới hạn số lần (0=Ko hạn chế)</label>
                <input type="number" x-model.number="form.usage_limit" class="form-input" />
              </div>
              <div class="form-group">
                <label class="form-label">Mỗi khách hàng</label>
                <input type="number" x-model.number="form.per_user_limit" class="form-input" />
              </div>
            </div>

            <div class="dc-form-actions flex-wrap">
              <button type="submit" class="btn-primary btn-full" :disabled="isSaving" style="flex: 1 1 100%;">
                 <span x-text="isSaving ? 'Đang lưu...' : (form.id ? 'Lưu thay đổi' : 'Tạo mới')">Lưu</span>
              </button>
              <div class="flex w-full gap-3 mt-2">
                <button type="button" @click="resetForm()" class="btn-outline flex-1">Hủy thiết lập</button>
                <button type="button" x-show="form.id" @click="deleteDiscount(form.id)" class="btn-outline flex-1" style="color: #fb7185; border-color: rgba(251,113,133,0.3);">
                  <span class="material-symbols-outlined text-[18px] mr-1 align-middle">delete</span> Xóa mã
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <!-- List Section -->
      <div class="dc-col-main">
        <div class="card dc-list-card">
          
          <!-- Table Toolbar -->
          <div class="dc-toolbar">
            <div class="dc-tabs">
              <button class="dc-tab" :class="currentTab === 'Đang hoạt động' ? 'active' : ''" @click="currentTab = 'Đang hoạt động'">Đang hoạt động</button>
              <button class="dc-tab" :class="currentTab === 'Đã hết hạn' ? 'active' : ''" @click="currentTab = 'Đã hết hạn'">Đã hết hạn</button>
              <button class="dc-tab" :class="currentTab === 'Bản nháp' ? 'active' : ''" @click="currentTab = 'Bản nháp'">Bản nháp</button>
              <button class="dc-tab" :class="currentTab === 'all' ? 'active' : ''" @click="currentTab = 'all'">Tất cả</button>
            </div>
          </div>

          <!-- Table -->
          <div class="table-responsive custom-scroll h-[600px] overflow-y-auto">
            <table class="dc-table">
              <thead class="sticky top-0 z-10">
                <tr>
                  <th>Thông tin mã</th>
                  <th>Giá trị</th>
                  <th>Hiệu suất</th>
                  <th>Thời gian</th>
                  <th class="text-right">Thao tác</th>
                </tr>
              </thead>
              <tbody>
                <template x-for="item in filteredDiscounts" :key="item.id">
                  <tr @click="editDiscount(item)" class="cursor-pointer" title="Nhấn để chỉnh sửa">
                    <td>
                      <div class="dc-code-info">
                        <span class="dc-code-name" x-text="item.code"></span>
                        <span class="dc-code-desc" x-text="item.description || 'Không có mô tả'"></span>
                      </div>
                    </td>
                    <td>
                      <span class="badge" :class="item.discount_type === 'percent' ? 'badge-emerald' : 'badge-primary'" 
                            x-text="item.discount_type === 'percent' ? '-' + item.discount_value + '%' : '-' + new Intl.NumberFormat('vi-VN').format(item.discount_value) + 'đ'">
                      </span>
                    </td>
                    <td>
                      <div class="progress-wrap">
                        <div class="progress-info">
                          <span x-text="item.used_count + (item.usage_limit > 0 ? '/' + item.usage_limit : ' lượt')"></span>
                          <span class="text-light" x-show="item.usage_limit > 0" x-text="(item.used_count / item.usage_limit * 100).toFixed(0) + '%'"></span>
                        </div>
                        <div class="progress-track" x-show="item.usage_limit > 0">
                          <div class="progress-fill" :style="'width: ' + Math.min((item.used_count / item.usage_limit * 100), 100) + '%'"></div>
                        </div>
                      </div>
                    </td>
                    <td>
                      <div class="dc-dates">
                        <span class="text-light" x-text="'BĐ: ' + (item.start_date ? new Date(item.start_date).toLocaleDateString('vi-VN') : 'Ko giới hạn')"></span>
                        <span class="text-muted" x-text="'KT: ' + (item.end_date ? new Date(item.end_date).toLocaleDateString('vi-VN') : 'Ko giới hạn')"></span>
                      </div>
                    </td>
                    <td class="text-right">
                      <div class="action-buttons">
                        <button @click="editDiscount(item)" class="btn-act btn-act-edit" title="Sửa"><span class="material-symbols-outlined">edit</span></button>
                        <button @click="deleteDiscount(item.id)" class="btn-act btn-act-del" title="Xóa"><span class="material-symbols-outlined">delete</span></button>
                      </div>
                    </td>
                  </tr>
                </template>
                <template x-if="filteredDiscounts.length === 0">
                  <tr>
                    <td colspan="5" class="text-center text-muted py-8">Không có mã giảm giá nào.</td>
                  </tr>
                </template>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
    </div>
  </div>

</AdminLayout>

<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script is:inline>
  document.addEventListener('alpine:init', () => {
    Alpine.data('discountManager', () => ({
      discounts: [],
      currentTab: 'Đang hoạt động',
      isSaving: false,
      
      form: {
        id: null,
        code: '',
        description: '',
        discount_type: 'percent',
        discount_value: '',
        status: 'Đang hoạt động',
        start_date: '',
        end_date: '',
        min_order_value: 0,
        usage_limit: 0,
        per_user_limit: 1
      },

      async init() {
        await this.fetchDiscounts();
      },

      async fetchDiscounts() {
        try {
          const res = await fetch('/api/discounts');
          const data = await res.json();
          if (data.success) {
            this.discounts = data.discounts;
          }
        } catch (error) {
          console.error('Failed to fetch discounts', error);
        }
      },

      get filteredDiscounts() {
        if (this.currentTab === 'all') return this.discounts;
        return this.discounts.filter(d => d.status === this.currentTab);
      },

      get activeDiscountsCount() {
        return this.discounts.filter(d => d.status === 'Đang hoạt động').length;
      },

      get totalUsedCount() {
        return this.discounts.reduce((sum, d) => sum + (d.used_count || 0), 0);
      },

      resetForm() {
        this.form = {
          id: null,
          code: '',
          description: '',
          discount_type: 'percent',
          discount_value: '',
          status: 'Đang hoạt động',
          start_date: '',
          end_date: '',
          min_order_value: 0,
          usage_limit: 0,
          per_user_limit: 1
        };
      },

      editDiscount(item) {
        this.form = {
          id: item.id,
          code: item.code,
          description: item.description || '',
          discount_type: item.discount_type || 'percent',
          discount_value: item.discount_value,
          status: item.status || 'Đang hoạt động',
          start_date: item.start_date ? item.start_date.split('T')[0] : '',
          end_date: item.end_date ? item.end_date.split('T')[0] : '',
          min_order_value: item.min_order_value || 0,
          usage_limit: item.usage_limit || 0,
          per_user_limit: item.per_user_limit || 1
        };
        window.scrollTo({ top: 0, behavior: 'smooth' });
      },

      async saveDiscount() {
        this.isSaving = true;
        try {
          const method = this.form.id ? 'PUT' : 'POST';
          const res = await fetch('/api/discounts', {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(this.form)
          });
          const data = await res.json();
          if (res.ok) {
            alert(this.form.id ? 'Cập nhật thành công!' : 'Tạo mới thành công!');
            this.resetForm();
            await this.fetchDiscounts();
          } else {
            alert('Lỗi: ' + (data.error || 'Không thể lưu mã giảm giá'));
          }
        } catch (error) {
          alert('Lỗi kết nối tới máy chủ');
        } finally {
          this.isSaving = false;
        }
      },

      async deleteDiscount(id) {
        if (!confirm('Bạn có chắc muốn xóa mã giảm giá này?')) return;
        try {
          const res = await fetch('/api/discounts', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id })
          });
          if (res.ok) {
            this.discounts = this.discounts.filter(d => d.id !== id);
          } else {
            const data = await res.json();
            alert('Lỗi xóa: ' + (data.error || 'Trục trặc máy chủ'));
          }
        } catch (error) {
          alert('Lỗi kết nối tới máy chủ');
        }
      }
    }));
  });
</script>

<style>
  /* ── UTILITIES ── */
  .text-primary { color: #f48c25; }
  .bg-primary-10 { background: rgba(244,140,37,.1); }
  
  .text-emerald { color: #34d399; }
  .bg-emerald-10 { background: rgba(52,211,153,.1); }
  
  .text-blue { color: #60a5fa; }
  .bg-blue-10 { background: rgba(96,165,250,.1); }
  
  .text-amber { color: #fbbf24; }
  .bg-amber-10 { background: rgba(251,191,36,.1); }
  
  .text-rose { color: #fb7185; }
  
  .text-purple { color: #c084fc; }
  .bg-purple-10 { background: rgba(192,132,252,.1); }

  .text-uppercase { text-transform: uppercase; }
  .fw-bold { font-weight: 700; }
  .tracking-wide { letter-spacing: 0.1em; }
  .text-right { text-align: right; }
  .text-light { color: #cbd5e1; }
  .text-muted { color: #64748b; }

  /* ── SHARED BTN/CARD ── */
  .btn-primary {
    background: #f48c25; color: #fff;
    font-weight: 700; font-size: 14px;
    padding: 12px 24px; border-radius: 12px;
    border: none; cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    box-shadow: 0 8px 24px rgba(244,140,37,.2); transition: all .15s;
  }
  .btn-primary:hover:not(:disabled) { background: rgba(244,140,37,.9); }
  .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
  .btn-primary .material-symbols-outlined { font-size: 20px; }
  .btn-full { width: 100%; flex: 1; min-height: 48px; }

  .btn-outline {
    background: transparent; border: 1px solid rgba(244,140,37,.1);
    color: #94a3b8; font-weight: 700; font-size: 14px;
    padding: 12px 20px; border-radius: 12px; cursor: pointer;
    transition: all .15s;
  }
  .btn-outline:hover { background: rgba(244,140,37,.05); color: #f1f5f9; }

  .card {
    background: rgba(244,140,37,.05);
    border: 1px solid rgba(244,140,37,.1);
    border-radius: 16px;
  }

  /* ── LAYOUT ── */
  .dc-container { display: flex; flex-direction: column; gap: 24px; }
  
  .dc-header {
    display: flex; flex-direction: column; gap: 8px; align-items: flex-start; margin-bottom: 8px;
  }
  .dc-title { font-size: 24px; font-weight: 800; color: #f9fafb; }
  .dc-header-right { width: 100%; display: flex; flex-direction: column; gap: 16px; }
  @media (min-width: 768px) {
    .dc-header-right { flex-direction: row; align-items: center; justify-content: space-between; gap: 24px; }
  }
  .dc-sub { font-size: 13.5px; color: #94a3b8; }

  /* ── STATS CARDS ── */
  .dc-stats-grid { display: grid; grid-template-columns: 1fr; gap: 16px; margin-bottom: 8px; }
  @media (min-width: 640px) { .dc-stats-grid { grid-template-columns: 1fr 1fr 1fr; } }
  @media (min-width: 1024px) { .dc-stats-grid { grid-template-columns: repeat(3, 1fr); } }

  .dc-stat-card {
    background: rgba(244,140,37,.05); border: 1px solid rgba(244,140,37,.1);
    border-radius: 16px; padding: 24px;
  }
  .dc-stat-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .dc-icon-bg { padding: 8px; border-radius: 8px; font-size: 20px; }
  .dc-stat-label { font-size: 14px; font-weight: 600; color: #94a3b8; margin-bottom: 4px; }
  .dc-stat-val { font-size: 24px; font-weight: 700; color: #fff; }

  /* ── MAIN GRID ── */
  .dc-main-layout { display: grid; grid-template-columns: 1fr; gap: 32px; }
  @media (min-width: 1100px) {
    .dc-main-layout { grid-template-columns: 4fr 8fr; }
  }

  /* ── FORM CARD ── */
  .dc-form-card { padding: 24px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
  .dc-form-head { display: flex; align-items: center; gap: 8px; margin-bottom: 24px; }
  .dc-form-head .material-symbols-outlined { font-size: 24px; }
  .dc-form-title { font-size: 18px; font-weight: 700; color: #f1f5f9; }

  .dc-form { display: flex; flex-direction: column; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 8px; }
  .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  
  .form-label { font-size: 14px; font-weight: 600; color: #cbd5e1; }
  .form-input, .form-select {
    width: 100%; background: rgba(244,140,37,.08); border: 1px solid rgba(244,140,37,.1);
    border-radius: 8px; padding: 10px 16px;
    font-size: 14px; color: #fff;
    outline: none; transition: border .2s, box-shadow .2s; box-sizing: border-box;
  }
  .form-input:focus, .form-select:focus { border-color: #f48c25; box-shadow: 0 0 0 1px #f48c25; }
  .form-input::placeholder { color: #64748b; }
  
  .input-with-suffix { position: relative; }
  .input-suffix {
    position: absolute; right: 16px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; font-size: 14px; pointer-events: none;
  }

  .dc-form-actions { display: flex; gap: 12px; padding-top: 16px; }

  /* ── LIST CARD ── */
  .dc-list-card { overflow: hidden; box-shadow: 0 1px 2px rgba(0,0,0,0.05); height: 100%; display: flex; flex-direction: column; }
  
  .dc-toolbar {
    display: flex; flex-direction: column; gap: 16px;
    padding: 24px; border-bottom: 1px solid rgba(244,140,37,.1);
  }
  @media (min-width: 640px) {
    .dc-toolbar { flex-direction: row; align-items: center; justify-content: space-between; }
  }
  
  .dc-tabs { display: flex; align-items: center; gap: 24px; overflow-x: auto; }
  .dc-tab {
    background: none; border: none; border-bottom: 2px solid transparent; padding-bottom: 4px;
    font-size: 14px; font-weight: 600; color: #94a3b8; cursor: pointer; transition: color .15s; font-family: inherit; white-space: nowrap;
  }
  .dc-tab:hover { color: #e2e8f0; }
  .dc-tab.active { color: #f48c25; border-bottom-color: #f48c25; font-weight: 700; }

  /* Table */
  .table-responsive { overflow-x: auto; flex: 1; }
  .custom-scroll::-webkit-scrollbar { height: 6px; width: 6px; }
  .custom-scroll::-webkit-scrollbar-track { background: rgba(244,140,37,.08); }
  .custom-scroll::-webkit-scrollbar-thumb { background: rgba(244,140,37,.1); border-radius: 10px; }

  .dc-table { width: 100%; border-collapse: collapse; min-width: 700px; text-align: left; }
  .dc-table th {
    padding: 16px 24px; font-size: 12px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8;
    background: #2a1f16;
  }
  .dc-table td {
    padding: 16px 24px; border-top: 1px solid rgba(244,140,37,.2);
    transition: background .15s;
  }
  .dc-table tbody tr:hover td { background: rgba(34,25,16,.3); }

  .dc-code-name { display: block; font-size: 14px; font-weight: 700; color: #fff; letter-spacing: 0.05em; margin-bottom: 4px; transition: color .15s; }
  .dc-table tbody tr:hover .dc-code-name { color: #f48c25; }
  .dc-code-desc { font-size: 12px; color: #64748b; }

  .badge {
    display: inline-block; padding: 4px 8px; border-radius: 6px;
    font-size: 14px; font-weight: 700;
  }
  .badge-emerald { background: rgba(52,211,153,.1); color: #34d399; }
  .badge-primary { background: rgba(244,140,37,.1); color: #f48c25; }

  .progress-wrap { display: flex; flex-direction: column; gap: 4px; margin-bottom: 4px; }
  .progress-info { display: flex; justify-content: space-between; font-size: 12px; color: #94a3b8; }
  .progress-track { width: 128px; height: 6px; background: rgba(244,140,37,.08); border-radius: 99px; overflow: hidden; }
  .progress-fill { height: 100%; background: #f48c25; border-radius: 99px; }

  .dc-dates { display: flex; flex-direction: column; gap: 4px; font-size: 12px; }

  .action-buttons { display: flex; justify-content: flex-end; gap: 8px; }
  .btn-act {
    width: 36px; height: 36px; border-radius: 8px; background: none; border: none;
    color: #94a3b8; display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all .15s;
  }
  .btn-act-edit:hover { background: rgba(244,140,37,.2); color: #f48c25; }
  .btn-act-del:hover { background: rgba(251,113,133,.2); color: #fb7185; }
  .btn-act .material-symbols-outlined { font-size: 18px; }
</style>
