---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Cài đặt hệ thống"
  subtitle="Quản lý cấu hình cửa hàng, giao diện và bảo mật tài khoản."
  activeNav="settings"
>

  <!-- ── BREADCRUMBS ── -->
  <nav class="breadcrumbs">
    <a href="/admin" class="bc-link">Trang chủ</a>
    <span class="material-symbols-outlined bc-arrow">chevron_right</span>
    <span class="bc-current">Cài đặt hệ thống</span>
  </nav>

  <!-- ── TABS ── -->
  <div class="stg-tabs">
    <button class="stg-tab stg-tab-active">Cài đặt chung</button>
    <button class="stg-tab">Giao diện</button>
    <button class="stg-tab">Thông báo</button>
    <button class="stg-tab">Bảo mật &amp; Tài khoản</button>
  </div>

  <!-- ── SETTINGS CONTENT ── -->
  <div class="stg-content">

    <!-- Store Info -->
    <section class="stg-section">
      <div class="section-head">
        <div>
          <h3 class="section-title">Thông tin cửa hàng</h3>
          <p class="section-desc">Thông tin cơ bản hiển thị trên website và hóa đơn.</p>
        </div>
        <button class="btn-save">
          <span class="material-symbols-outlined">save</span>
          Lưu thay đổi
        </button>
      </div>
      <div class="form-grid">
        <div class="form-group">
          <label class="form-label">Tên cửa hàng</label>
          <input type="text" class="form-input" value="FlySky Guitar Studio" />
        </div>
        <div class="form-group">
          <label class="form-label">Email liên hệ</label>
          <input type="email" class="form-input" value="contact@flysky.vn" />
        </div>
        <div class="form-group form-full">
          <label class="form-label">Địa chỉ cửa hàng</label>
          <input type="text" class="form-input" value="123 Đường Nhạc Cụ, Phường Hòa Âm, Quận Giai Điệu, TP. HCM" />
        </div>
      </div>
    </section>

    <hr class="stg-divider" />

    <!-- Logo & Brand -->
    <section class="stg-section stg-two-col">
      <div class="stg-two-col-left">
        <h3 class="section-title">Logo &amp; Thương hiệu</h3>
        <p class="section-desc">Logo hiển thị tại header và footer của website.</p>
      </div>
      <div class="stg-two-col-right">
        <div class="logo-area">
          <div class="logo-preview">
            <span class="material-symbols-outlined logo-icon">image</span>
            <div class="logo-label">Logo Hiện Tại</div>
            <div class="logo-hover-overlay">
              <span class="material-symbols-outlined">upload</span>
            </div>
          </div>
          <div class="logo-info">
            <p class="form-label" style="margin-bottom:8px;">Thay đổi Logo</p>
            <p class="section-desc" style="margin-bottom:16px;">Khuyên dùng định dạng PNG hoặc SVG. Kích thước tối ưu 512x512px.</p>
            <button class="btn-upload">Tải lên ảnh mới</button>
          </div>
        </div>
      </div>
    </section>

    <hr class="stg-divider" />

    <!-- Contact & Social -->
    <section class="stg-section stg-two-col">
      <div class="stg-two-col-left">
        <h3 class="section-title">Liên hệ &amp; Mạng xã hội</h3>
        <p class="section-desc">Liên kết với các nền tảng mạng xã hội của studio.</p>
      </div>
      <div class="stg-two-col-right">
        <div class="icon-input-wrap">
          <span class="material-symbols-outlined inp-icon">call</span>
          <input type="text" class="form-input inp-with-icon" value="090 123 4567" />
        </div>
        <div class="icon-input-wrap" style="margin-top:12px;">
          <span class="material-symbols-outlined inp-icon">public</span>
          <input type="text" class="form-input inp-with-icon" value="https://facebook.com/flyskyguitar" />
        </div>
      </div>
    </section>

    <hr class="stg-divider" />

    <!-- Danger Zone -->
    <section class="danger-zone">
      <div class="danger-content">
        <div>
          <h3 class="danger-title">Bảo trì hệ thống</h3>
          <p class="section-desc">Tạm thời đóng cửa hàng để nâng cấp hoặc bảo trì kỹ thuật.</p>
        </div>
        <button class="btn-danger">Bật chế độ bảo trì</button>
      </div>
    </section>

  </div>

  <!-- ── BOTTOM ACTIONS ── -->
  <div class="bottom-actions">
    <button class="btn-cancel">Hủy bỏ</button>
    <button class="btn-update">Cập nhật tất cả</button>
  </div>

</AdminLayout>

<style>
  /* ── BREADCRUMBS ── */
  .breadcrumbs {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: #94a3b8;
    margin-bottom: 24px;
  }
  .bc-link { color: #94a3b8; text-decoration: none; transition: color .15s; }
  .bc-link:hover { color: #f48c25; }
  .bc-arrow { font-size: 14px; color: #64748b; }
  .bc-current { color: #f9fafb; font-weight: 600; }

  /* ── TABS ── */
  .stg-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid rgba(74,58,42,.5);
    margin-bottom: 32px;
    overflow-x: auto;
  }
  .stg-tabs::-webkit-scrollbar { display: none; }
  .stg-tab {
    padding: 14px 24px;
    font-size: 13px; font-weight: 600;
    background: none; border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    color: #64748b;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    white-space: nowrap;
    transition: all .15s;
  }
  .stg-tab:hover { color: #f48c25; }
  .stg-tab-active { color: #f48c25; border-bottom-color: #f48c25; font-weight: 700; }

  /* ── CONTENT ── */
  .stg-content { display: flex; flex-direction: column; gap: 0; max-width: 860px; }

  /* ── SECTION ── */
  .stg-section { padding: 32px 0; }
  .section-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 24px;
  }
  .section-title { font-size: 16px; font-weight: 800; color: #f9fafb; }
  .section-desc  { font-size: 13px; color: #94a3b8; margin-top: 4px; }

  .btn-save {
    display: flex; align-items: center; gap: 6px;
    padding: 9px 20px; border-radius: 10px;
    background: #f48c25; color: #221910;
    font-size: 13px; font-weight: 700;
    border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    box-shadow: 0 4px 16px rgba(244,140,37,.2);
    transition: filter .15s; white-space: nowrap;
  }
  .btn-save:hover { filter: brightness(1.1); }
  .btn-save .material-symbols-outlined { font-size: 16px; }

  /* Form */
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .form-group { display: flex; flex-direction: column; gap: 8px; }
  .form-full  { grid-column: 1 / -1; }
  .form-label { font-size: 13px; font-weight: 600; color: #cbd5e1; }
  .form-input {
    width: 100%;
    background: #2d2218;
    border: 1px solid #4a3a2a;
    border-radius: 10px;
    padding: 10px 16px;
    font-size: 13px; color: #f1f5f9;
    font-family: 'Manrope', sans-serif;
    outline: none; transition: border .2s;
    box-sizing: border-box;
  }
  .form-input:focus { border-color: #f48c25; }

  /* Two-col layout */
  .stg-two-col { display: grid; grid-template-columns: 1fr 2fr; gap: 40px; align-items: start; }
  .stg-two-col-left {}
  .stg-two-col-right {}

  /* Logo */
  .logo-area { display: flex; align-items: center; gap: 32px; }
  .logo-preview {
    width: 128px; height: 128px; flex-shrink: 0;
    border-radius: 16px;
    background: #2d2218;
    border: 2px dashed #4a3a2a;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    position: relative; overflow: hidden; cursor: pointer;
    transition: border-color .2s;
  }
  .logo-preview:hover { border-color: #f48c25; }
  .logo-preview:hover .logo-hover-overlay { opacity: 1; }
  .logo-preview:hover .logo-icon { display: none; }
  .logo-icon { font-size: 32px; color: #64748b; }
  .logo-label {
    position: absolute; bottom: 8px;
    background: rgba(244,140,37,.1);
    color: #f48c25; font-size: 9px; font-weight: 700;
    padding: 2px 6px; border-radius: 4px;
  }
  .logo-hover-overlay {
    position: absolute; inset: 0;
    background: rgba(244,140,37,.15);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity .2s;
  }
  .logo-hover-overlay .material-symbols-outlined { color: #f48c25; font-size: 28px; }
  .btn-upload {
    padding: 8px 16px; border-radius: 8px;
    background: none; border: 1px solid #4a3a2a;
    color: #f1f5f9; font-size: 13px; font-weight: 600;
    font-family: 'Manrope', sans-serif; cursor: pointer;
    transition: background .15s;
  }
  .btn-upload:hover { background: #4a3a2a; }

  /* Icon-input */
  .icon-input-wrap { position: relative; display: flex; align-items: center; }
  .inp-icon {
    position: absolute; left: 14px;
    font-size: 18px; color: #94a3b8;
    pointer-events: none;
  }
  .inp-with-icon { padding-left: 44px; }

  /* Divider */
  .stg-divider { border: none; border-top: 1px solid rgba(74,58,42,.5); margin: 0; }

  /* ── DANGER ZONE ── */
  .danger-zone {
    padding: 24px;
    background: rgba(239,68,68,.06);
    border: 1px solid rgba(239,68,68,.2);
    border-radius: 16px;
    margin-top: 32px;
  }
  .danger-content { display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .danger-title { font-size: 16px; font-weight: 800; color: #f87171; }
  .btn-danger {
    padding: 10px 24px; border-radius: 10px;
    background: #dc2626; color: #fff;
    font-size: 13px; font-weight: 700;
    border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    white-space: nowrap;
    transition: background .15s;
  }
  .btn-danger:hover { background: #b91c1c; }

  /* ── BOTTOM ACTIONS ── */
  .bottom-actions {
    display: flex; align-items: center; justify-content: flex-end;
    gap: 16px;
    padding: 28px 0 8px;
    max-width: 860px;
  }
  .btn-cancel {
    padding: 10px 24px; border-radius: 10px;
    background: none; border: none; cursor: pointer;
    font-size: 13px; font-weight: 700; color: #94a3b8;
    font-family: 'Manrope', sans-serif;
    transition: color .15s;
  }
  .btn-cancel:hover { color: #f9fafb; }
  .btn-update {
    padding: 10px 28px; border-radius: 10px;
    background: #f48c25; color: #221910;
    font-size: 13px; font-weight: 700;
    border: none; cursor: pointer;
    font-family: 'Manrope', sans-serif;
    box-shadow: 0 4px 16px rgba(244,140,37,.2);
    transition: filter .15s;
  }
  .btn-update:hover { filter: brightness(1.1); }

  @media (max-width: 900px) {
    .stg-two-col { grid-template-columns: 1fr; gap: 20px; }
    .form-grid   { grid-template-columns: 1fr; }
    .form-full   { grid-column: 1; }
  }
</style>
