<script is:inline define:vars={{ reportEmailsInit, autoLogoutTimeout, canManageSystemSettings }}>
  window._reportEmails = reportEmailsInit;
  window._autoLogoutTimeout = parseInt(autoLogoutTimeout) || 120;
  window._canManageSystemSettings = !!canManageSystemSettings;
</script>

<script>
  function switchTab(tabId: string, btn: HTMLElement) {
    if (!(window as any)._canManageSystemSettings && tabId !== 'security') {
      return;
    }
    document.querySelectorAll('.tab-pane').forEach((p: Element) => (p as HTMLElement).style.display = 'none');
    document.querySelectorAll('.stg-tab').forEach(b => b.classList.remove('stg-tab-active'));
    const pane = document.getElementById('tab-' + tabId);
    if (pane) pane.style.display = 'block';
    btn.classList.add('stg-tab-active');
  }
  (window as any).switchTab = switchTab;

  // ── MAINTENANCE MODE ──
  async function toggleMaintenanceMode() {
    const btn = document.getElementById('btn-maintenance') as HTMLButtonElement;
    const isCurrentlyOn = btn.classList.contains('btn-success');
    const newValue = isCurrentlyOn ? 'false' : 'true';
    btn.disabled = true;
    btn.textContent = 'Đang lưu...';
    try {
      const res = await fetch('/api/settings/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ settings: [{ key: 'flysky_maintenanceMode', value: newValue }] }),
      });
      const data = await res.json();
      if (data.success) {
        location.reload();
      } else {
        alert('Lỗi: ' + data.error);
        btn.disabled = false;
        btn.textContent = isCurrentlyOn ? '✅ Tắt chế độ bảo trì' : '🔧 Bật chế độ bảo trì';
      }
    } catch (e: any) {
      alert('Lỗi kết nối: ' + e.message);
      btn.disabled = false;
    }
  }
  (window as any).toggleMaintenanceMode = toggleMaintenanceMode;

  // ── CANCEL BUTTONS ── reload page to discard unsaved changes
  document.querySelectorAll('.btn-cancel').forEach(btn => {
    btn.addEventListener('click', () => {
      if (confirm('Bỏ các thay đổi chưa lưu?')) location.reload();
    });
  });

  // ── COLOR SWATCHES ──
  (function () {
    const hexInput = document.getElementById('stg-brand-color') as HTMLInputElement;
    if (!hexInput) return;

    // Helper: apply color live to CSS var
    function applyColor(hex: string) {
      const valid = /^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/.test(hex);
      if (!valid) return;
      document.documentElement.style.setProperty('--color-primary', hex);
    }

    // Set active swatch based on current hex value
    function syncActiveSwatches(hex: string) {
      const normalised = hex.toLowerCase();
      document.querySelectorAll('.swatch:not(.swatch-add)').forEach((s: Element) => {
        const btn = s as HTMLButtonElement;
        const swatchColor = (btn.dataset.color || '').toLowerCase();
        if (swatchColor === normalised) {
          btn.classList.add('swatch-active');
          if (!btn.querySelector('.swatch-check')) {
            const icon = document.createElement('span');
            icon.className = 'material-symbols-outlined swatch-check';
            icon.textContent = 'check';
            btn.appendChild(icon);
          }
        } else {
          btn.classList.remove('swatch-active');
          btn.querySelector('.swatch-check')?.remove();
        }
      });
    }

    // Init active state
    applyColor(hexInput.value);
    syncActiveSwatches(hexInput.value);

    // Swatch click
    document.querySelectorAll('.swatch:not(.swatch-add)').forEach((s: Element) => {
      (s as HTMLButtonElement).addEventListener('click', function () {
        const color = this.dataset.color || '';
        if (!color) return;
        hexInput.value = color;
        applyColor(color);
        syncActiveSwatches(color);
      });
    });

    // "+" swatch — open native color picker
    const addSwatch = document.querySelector('.swatch-add') as HTMLButtonElement;
    if (addSwatch) {
      const picker = document.createElement('input');
      picker.type = 'color';
      picker.style.cssText = 'position:absolute;opacity:0;width:0;height:0;pointer-events:none;';
      picker.value = hexInput.value || '#f48c25';
      addSwatch.style.position = 'relative';
      addSwatch.appendChild(picker);
      addSwatch.addEventListener('click', () => picker.click());
      picker.addEventListener('input', () => {
        hexInput.value = picker.value;
        applyColor(picker.value);
        syncActiveSwatches(picker.value);
      });
    }

    // Live update on hex input change
    hexInput.addEventListener('input', () => {
      applyColor(hexInput.value);
      syncActiveSwatches(hexInput.value);
    });
  })();

  // Header Logo Upload Handlers
  // Save Settings Function (general settings — no payment fields)
  async function saveSettings() {
    const fields = [
      { id: 'stg-store-name', key: 'flysky_storeName' },
      { id: 'stg-contact-email', key: 'flysky_contactEmail' },
      { id: 'stg-store-address', key: 'flysky_storeAddress' },
      { id: 'stg-contact-phone', key: 'flysky_contactPhone' },
      { id: 'stg-zalo-url', key: 'flysky_zaloUrl' },
      { id: 'stg-facebook-url', key: 'flysky_facebookUrl' },
      { id: 'stg-whatsapp-url', key: 'flysky_whatsappUrl' },
      { id: 'stg-instagram-url', key: 'flysky_instagramUrl' },
      { id: 'stg-support-warranty-url', key: 'flysky_supportWarrantyUrl' },
      { id: 'stg-support-shipping-return-url', key: 'flysky_supportShippingReturnUrl' },
      { id: 'stg-support-care-guide-url', key: 'flysky_supportCareGuideUrl' },
      { id: 'stg-brand-color', key: 'flysky_brandColor' },
      { id: 'stg-hero-h1', key: 'flysky_heroH1' },
      { id: 'stg-hero-sub', key: 'flysky_heroSub' },
      { id: 'stg-hero-images', key: 'flysky_heroImages' },
      { id: 'stg-hero-effect', key: 'flysky_heroEffect' },
      { id: 'stg-hero-interval', key: 'flysky_heroIntervalSec' },
      { id: 'stg-smtp-host', key: 'flysky_smtpHost' },
      { id: 'stg-smtp-port', key: 'flysky_smtpPort' },
      { id: 'stg-smtp-user', key: 'flysky_smtpUser' },
      { id: 'stg-smtp-pass', key: 'flysky_smtpPass' },
      { id: 'stg-smtp-from-name', key: 'flysky_smtpFromName' }
    ];

    const settingsToSave: any[] = [];
    fields.forEach(field => {
      const el = document.getElementById(field.id) as HTMLInputElement;
      if (el) settingsToSave.push({ key: field.key, value: el.value });
    });

    // Notification toggle settings (checkboxes)
    const checkboxFields = [
      { id: 'ntf-new-order',    key: 'flysky_notif_new_order' },
      { id: 'ntf-consult',      key: 'flysky_notif_consult' },
      { id: 'ntf-report-chart', key: 'flysky_notif_report_chart' },
    ];
    checkboxFields.forEach(f => {
      const el = document.getElementById(f.id) as HTMLInputElement;
      if (el) settingsToSave.push({ key: f.key, value: el.checked ? 'true' : 'false' });
    });

    // Daily report email list
    const reportEmails = (window as any)._reportEmails as string[] | undefined;
    if (reportEmails) {
      settingsToSave.push({ key: 'flysky_report_emails', value: reportEmails.join(',') });
    }

    try {
      const res = await fetch('/api/settings/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ settings: settingsToSave })
      });
      const data = await res.json();
      if (data.success) {
        alert('Đã lưu dữ liệu cài đặt thành công! Tải lại trang chủ để xem kết quả.');
      } else {
        alert('Lỗi lưu cấu hình: ' + data.error);
      }
    } catch (e) {
      alert('Lỗi kết nối máy chủ');
    }
  }
  (window as any).saveSettings = saveSettings;

  // ── PAYMENT SETTINGS FUNCTIONS ──

  async function savePaymentProvider(provider: string, enabled: boolean, config: Record<string, string>) {
    const res = await fetch('/api/payment-settings/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ provider, enabled, config }),
    });
    return res.json();
  }

  async function savePaymentBank() {
    const btn = document.getElementById('btn-save-bank') as HTMLButtonElement;
    btn.disabled = true;
    btn.innerHTML = '<span class="material-symbols-outlined animate-spin">autorenew</span> Đang lưu...';

    const enabled = (document.getElementById('pay-bank-enabled') as HTMLInputElement).checked;
    const config = {
      bank_name: (document.getElementById('stg-bank-name') as HTMLInputElement).value.trim(),
      account_name: (document.getElementById('stg-bank-acc-name') as HTMLInputElement).value.trim(),
      account_number: (document.getElementById('stg-bank-acc-num') as HTMLInputElement).value.trim(),
    };

    try {
      const data = await savePaymentProvider('bank_transfer', enabled, config);
      if (data.success) {
        btn.innerHTML = '<span class="material-symbols-outlined">check</span> Đã lưu';
        setTimeout(() => {
          btn.disabled = false;
          btn.innerHTML = '<span class="material-symbols-outlined">save</span> Lưu';
        }, 2000);
      } else {
        alert('Lỗi lưu cài đặt ngân hàng: ' + data.error);
        btn.disabled = false;
        btn.innerHTML = '<span class="material-symbols-outlined">save</span> Lưu';
      }
    } catch (e: any) {
      alert('Lỗi kết nối: ' + e.message);
      btn.disabled = false;
      btn.innerHTML = '<span class="material-symbols-outlined">save</span> Lưu';
    }
  }
  (window as any).savePaymentBank = savePaymentBank;

  async function savePaymentMomo() {
    const btn = document.getElementById('btn-save-momo') as HTMLButtonElement;
    btn.disabled = true;
    btn.innerHTML = '<span class="material-symbols-outlined animate-spin">autorenew</span> Đang lưu...';

    const enabled = (document.getElementById('pay-momo-enabled') as HTMLInputElement).checked;
