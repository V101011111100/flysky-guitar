    await savePaymentMomo();
  }
  (window as any).saveAllPayment = saveAllPayment;

  // ── PAYMENT TOGGLE HANDLERS (enable/disable section opacity) ──
  (function () {
    const bankToggle = document.getElementById('pay-bank-enabled') as HTMLInputElement;
    const bankFields = document.getElementById('bank-fields');
    if (bankToggle && bankFields) {
      bankToggle.addEventListener('change', () => {
        bankFields.style.opacity = bankToggle.checked ? '1' : '0.5';
        bankFields.style.pointerEvents = bankToggle.checked ? '' : 'none';
      });
    }

    const momoToggle = document.getElementById('pay-momo-enabled') as HTMLInputElement;
    const momoFields = document.getElementById('momo-fields');
    if (momoToggle && momoFields) {
      momoToggle.addEventListener('change', () => {
        momoFields.style.opacity = momoToggle.checked ? '1' : '0.5';
        momoFields.style.pointerEvents = momoToggle.checked ? '' : 'none';
      });
    }
  })();

  // ── VIETQR LIVE PREVIEW ──
  (function () {
    const bankNameInput = document.getElementById('stg-bank-name') as HTMLInputElement;
    const accNameInput = document.getElementById('stg-bank-acc-name') as HTMLInputElement;
    const accNumInput = document.getElementById('stg-bank-acc-num') as HTMLInputElement;
    const qrImg = document.getElementById('preview-qr-img') as HTMLImageElement;
    const bankLabel = document.getElementById('preview-bank-label');
    const accNameLabel = document.getElementById('preview-accname-label');
    const accNumLabel = document.getElementById('preview-accnum-label');

    if (!bankNameInput || !qrImg) return;

    let debounceTimer: ReturnType<typeof setTimeout>;
    function updateQR() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        const bank = bankNameInput.value.trim() || 'BIDV';
        const accNum = accNumInput.value.trim() || '0';
        const accName = accNameInput.value.trim() || '';
        const url = `https://img.vietqr.io/image/${bank}-${accNum}-compact2.jpg?amount=500000&addInfo=XEM+THU&accountName=${encodeURIComponent(accName)}`;
        qrImg.src = url;
        if (bankLabel) bankLabel.textContent = bank;
        if (accNameLabel) accNameLabel.textContent = accName;
        if (accNumLabel) accNumLabel.textContent = accNum;
      }, 600);
    }

    bankNameInput.addEventListener('input', updateQR);
    accNameInput.addEventListener('input', updateQR);
    accNumInput.addEventListener('input', updateQR);
  })();

  // Test Email Connection
  async function testEmailConnection() {
    const testEmailInput = document.getElementById('test-email-input') as HTMLInputElement;
    const resultEl = document.getElementById('test-email-result');
    
    if (!testEmailInput || !resultEl) return;
    
    const testEmail = testEmailInput.value.trim();
