---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';
import { getAdminMfaState } from '../../lib/security';

// Fetch settings from Database
const { data: settingsData } = await supabase
  .from('site_settings')
  .select('*');

// Helper to get value
const getSetting = (key: string, _default: string) => {
  const item = settingsData?.find((s: any) => s.key === key);
  return item ? item.value : _default;
};

// Fetch payment settings from dedicated payment_settings table
const { data: paymentSettingsData } = await supabase
  .from('payment_settings')
  .select('*');

const getPaymentProvider = (provider: string) => {
  return paymentSettingsData?.find((p: any) => p.provider === provider);
};

const storeName = getSetting('flysky_storeName', 'FlySky Guitar');
const contactEmail = getSetting('flysky_contactEmail', 'hello@flyskyguitar.com');
const storeAddress = getSetting('flysky_storeAddress', '37 Lê Thiện Trị, Phường Ngũ Hành Sơn, Thành phố Đà Nẵng');
const contactPhone = getSetting('flysky_contactPhone', '0987 654 321');
const socialUrl = getSetting('flysky_socialUrl', 'https://facebook.com/flyskyguitar');

// Social Media Links
const zaloUrl = getSetting('flysky_zaloUrl', 'https://zalo.me/0987654321');
const facebookUrl = getSetting('flysky_facebookUrl', 'https://facebook.com/flyskyguitar');
const whatsappUrl = getSetting('flysky_whatsappUrl', 'https://wa.me/84987654321');
const instagramUrl = getSetting('flysky_instagramUrl', 'https://instagram.com/flyskyguitar');
const supportWarrantyUrl = getSetting('flysky_supportWarrantyUrl', '/blog');
const supportShippingReturnUrl = getSetting('flysky_supportShippingReturnUrl', '/payment');
const supportCareGuideUrl = getSetting('flysky_supportCareGuideUrl', '/blog');

const brandColor = getSetting('flysky_brandColor', '#F48C25');
const heroH1 = getSetting('flysky_heroH1', 'Đánh Thức Đam Mê Âm Nhạc Của Bạn');
const heroSub = getSetting('flysky_heroSub', 'Khám phá bộ sưu tập nhạc cụ cao cấp, được tinh chỉnh hoàn hảo để mang lại cảm hứng sáng tạo bất tận cho mọi nghệ sĩ.');
const heroImages = getSetting('flysky_heroImages', '');
const heroEffect = getSetting('flysky_heroEffect', 'fade');
const heroIntervalSec = getSetting('flysky_heroIntervalSec', '4');

// Payment Settings — read from payment_settings table
const bankTransferProvider = getPaymentProvider('bank_transfer');
const bankEnabled: boolean = bankTransferProvider?.enabled ?? true;
const bankName: string = bankTransferProvider?.config?.bank_name ?? 'BIDV';
const bankAccountName: string = bankTransferProvider?.config?.account_name ?? 'CÔNG TY TNHH FLYSKY GUITAR';
const bankAccountNumber: string = bankTransferProvider?.config?.account_number ?? '1234567890';

const momoProvider = getPaymentProvider('momo');
const momoEnabled: boolean = momoProvider?.enabled ?? false;
const momoPartnerCode: string = momoProvider?.config?.partner_code ?? '';
const momoAccessKey: string = momoProvider?.config?.access_key ?? '';
const momoSecretKey: string = momoProvider?.config?.secret_key ?? '';

// Email SMTP Settings
const smtpHost = getSetting('flysky_smtpHost', 'smtp.gmail.com');
const smtpPort = getSetting('flysky_smtpPort', '587');
const smtpUser = getSetting('flysky_smtpUser', '');
const smtpPass = getSetting('flysky_smtpPass', '');
const smtpFromName = getSetting('flysky_smtpFromName', 'FlySky Guitar');
const logoUrl = getSetting('flysky_logoUrl', '/logo.svg');
const heroImageUrl = getSetting('flysky_heroImageUrl', '/images/hero-guitar.jpg');

// Maintenance mode
const maintenanceMode = getSetting('flysky_maintenanceMode', 'false') === 'true';

// Notification toggle settings
const notifNewOrder   = getSetting('flysky_notif_new_order',   'true') !== 'false';
const notifConsult    = getSetting('flysky_notif_consult',     'true') !== 'false';
const notifReportChart = getSetting('flysky_notif_report_chart', 'true') !== 'false';
const reportEmailsRaw = getSetting('flysky_report_emails', '');
const reportEmailsInit = reportEmailsRaw
  ? reportEmailsRaw.split(',').map((e: string) => e.trim()).filter(Boolean)
  : ['admin@flyskyguitar.com'];

// Auto-logout timeout
const autoLogoutTimeout = getSetting('flysky_autoLogoutTimeout', '120');

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
const authState = await getAdminMfaState(accessToken, refreshToken);
const currentAdminEmail = String(authState.user?.email || '').trim().toLowerCase();
const ownerAdminEmails = String(import.meta.env.ADMIN_EMAILS || '')
  .split(',')
  .map((item) => item.trim().toLowerCase())
  .filter(Boolean);
if (ownerAdminEmails.length === 0) ownerAdminEmails.push('admin@flyskyguitar.com');
const canManageSystemSettings = ownerAdminEmails.includes(currentAdminEmail);
const settingsSubtitle = canManageSystemSettings
  ? 'Quản lý cấu hình cửa hàng, giao diện và bảo mật tài khoản.'
  : 'Quản lý bảo mật tài khoản và phiên đăng nhập.';
---

<AdminLayout
  title="Cài đặt hệ thống"
  subtitle={settingsSubtitle}
  activeNav="settings"
>

  <!-- ── BREADCRUMBS ── -->
  <nav class="breadcrumbs">
    <a href="/admin" class="bc-link">Trang chủ</a>
    <span class="material-symbols-outlined bc-arrow">chevron_right</span>
    <span class="bc-current">Cài đặt hệ thống</span>
  </nav>

  <!-- ── TABS ── -->
  <div class="stg-tabs">
    <button class="stg-tab" data-requires-owner="true" onclick="switchTab('general', this)">Cài đặt chung</button>
    <button class="stg-tab" data-requires-owner="true" onclick="switchTab('appearance', this)">Giao diện</button>
    <button class="stg-tab" data-requires-owner="true" onclick="switchTab('payment', this)">Thanh toán</button>
    <button class="stg-tab" data-requires-owner="true" onclick="switchTab('email-notifications', this)">Email &amp; Thông báo</button>
    <button class="stg-tab stg-tab-active" onclick="switchTab('security', this)">Bảo mật &amp; Tài khoản</button>
  </div>

  <!-- ── TAB: CÀI ĐẶT CHUNG ── -->
  <div id="tab-general" class="tab-pane" data-requires-owner="true" style="display:none;">
    <div class="stg-content">
      <section class="stg-section">
        <div class="section-head">
          <div>
            <h3 class="section-title">Thông tin cửa hàng</h3>
            <p class="section-desc">Thông tin cơ bản hiển thị trên website và hóa đơn.</p>
          </div>
        </div>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Tên cửa hàng</label>
            <input type="text" id="stg-store-name" class="form-input" value={storeName} />
          </div>
          <div class="form-group">
            <label class="form-label">Email liên hệ</label>
            <input type="email" id="stg-contact-email" class="form-input" value={contactEmail} />
          </div>
          <div class="form-group form-full">
            <label class="form-label">Địa chỉ cửa hàng</label>
            <input type="text" id="stg-store-address" class="form-input" value={storeAddress} />
          </div>
        </div>
      </section>

      <hr class="stg-divider" />

      <section class="stg-section stg-two-col">
        <div class="stg-two-col-left">
          <h3 class="section-title">Logo &amp; Thương hiệu</h3>
          <p class="section-desc">Logo hiển thị tại header và footer của website.</p>
        </div>
        <div class="stg-two-col-right">
          <div class="logo-area">
            <input type="file" id="logo-upload-input" accept="image/png, image/svg+xml, image/jpeg" style="display: none;" />
            <div class="logo-preview" id="logo-preview-box" onclick="document.getElementById('logo-upload-input').click()">
              <img src={logoUrl} alt="Preview" id="logo-preview-img" style="width:100%; height:100%; object-fit:contain; padding:10px;" class="flysky-global-logo" />
              <div class="logo-label">Logo Hiện Tại</div>
              <div class="logo-hover-overlay">
                <span class="material-symbols-outlined">upload</span>
              </div>
            </div>
            <div class="logo-info">
              <p class="form-label" style="margin-bottom:8px;">Thay đổi Logo</p>
              <p class="section-desc" style="margin-bottom:16px;">Khuyên dùng định dạng PNG hoặc SVG. Kích thước tối ưu 512x512px.</p>
              <button class="btn-upload" onclick="document.getElementById('logo-upload-input').click()">Tải lên ảnh mới</button>
            </div>
          </div>
        </div>
      </section>

      <hr class="stg-divider" />

      <section class="stg-section stg-two-col">
        <div class="stg-two-col-left">
          <h3 class="section-title">Ảnh Hero trang chủ</h3>
          <p class="section-desc">Ảnh nền lớn hiển thị ở khu vực đầu trang chủ. Khuyên dùng tỷ lệ 3:4. Lưu trên Supabase Storage.</p>
        </div>
        <div class="stg-two-col-right">
          <div class="logo-area">
            <input type="file" id="hero-upload-input" accept="image/png,image/jpeg,image/jpg,image/webp" style="display: none;" />
            <input type="file" id="hero-upload-multi-input" accept="image/png,image/jpeg,image/jpg,image/webp" multiple style="display: none;" />
            <div class="logo-preview" id="hero-preview-box" onclick="document.getElementById('hero-upload-input').click()" style="aspect-ratio:3/4;max-height:180px;">
              <img src={heroImageUrl} alt="Hero preview" id="hero-preview-img" style="width:100%;height:100%;object-fit:cover;border-radius:8px;" />
              <div class="logo-hover-overlay">
                <span class="material-symbols-outlined">upload</span>
              </div>
            </div>
            <div class="logo-info">
              <p class="form-label" style="margin-bottom:8px;" id="hero-upload-label">Thay đổi ảnh Hero</p>
              <p class="section-desc" style="margin-bottom:16px;">PNG, JPG hoặc WebP, tối đa 5MB.</p>
              <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <button class="btn-upload" id="hero-upload-btn" onclick="document.getElementById('hero-upload-input').click()">Tải lên ảnh mới</button>
                <button class="btn-upload" id="hero-upload-multi-btn" onclick="document.getElementById('hero-upload-multi-input').click()" style="background:transparent;border:1px solid rgba(244,140,37,.55);color:#f48c25;">Tải nhiều ảnh</button>
              </div>
              <p class="section-desc" style="margin-top:10px;">Khi tải nhiều ảnh, hệ thống tự thêm URL vào danh sách slideshow trong mục Banner.</p>
            </div>
          </div>
        </div>
      </section>

      <hr class="stg-divider" />

      <section class="stg-section stg-two-col">
        <div class="stg-two-col-left">
          <h3 class="section-title">Liên hệ &amp; Mạng xã hội</h3>
          <p class="section-desc">Liên kết với các nền tảng mạng xã hội của studio.</p>
        </div>
        <div class="stg-two-col-right">
          <div class="icon-input-wrap">
            <span class="material-symbols-outlined inp-icon">call</span>
            <input type="text" id="stg-contact-phone" class="form-input inp-with-icon" value={contactPhone} />
          </div>
          <div class="icon-input-wrap" style="margin-top:12px;">
            <span class="material-symbols-outlined inp-icon">chat</span>
            <input type="text" id="stg-zalo-url" class="form-input inp-with-icon" placeholder="https://zalo.me/..." value={zaloUrl} />
          </div>
          <div class="icon-input-wrap" style="margin-top:12px;">
            <span class="material-symbols-outlined inp-icon">groups</span>
            <input type="text" id="stg-facebook-url" class="form-input inp-with-icon" placeholder="https://facebook.com/..." value={facebookUrl} />
          </div>
          <div class="icon-input-wrap" style="margin-top:12px;">
            <span class="material-symbols-outlined inp-icon">send</span>
            <input type="text" id="stg-whatsapp-url" class="form-input inp-with-icon" placeholder="https://wa.me/..." value={whatsappUrl} />
          </div>
          <div class="icon-input-wrap" style="margin-top:12px;">
            <span class="material-symbols-outlined inp-icon">photo_camera</span>
            <input type="text" id="stg-instagram-url" class="form-input inp-with-icon" placeholder="https://instagram.com/..." value={instagramUrl} />
          </div>
          <div class="icon-input-wrap" style="margin-top:12px;">
            <span class="material-symbols-outlined inp-icon">article</span>
            <input type="text" id="stg-support-warranty-url" class="form-input inp-with-icon" placeholder="Link bài viết chính sách bảo hành" value={supportWarrantyUrl} />
          </div>
          <div class="icon-input-wrap" style="margin-top:12px;">
            <span class="material-symbols-outlined inp-icon">local_shipping</span>
            <input type="text" id="stg-support-shipping-return-url" class="form-input inp-with-icon" placeholder="Link bài viết giao hàng & trả hàng" value={supportShippingReturnUrl} />
          </div>
          <div class="icon-input-wrap" style="margin-top:12px;">
            <span class="material-symbols-outlined inp-icon">menu_book</span>
            <input type="text" id="stg-support-care-guide-url" class="form-input inp-with-icon" placeholder="Link bài viết hướng dẫn bảo quản" value={supportCareGuideUrl} />
          </div>
        </div>
      </section>

      <hr class="stg-divider" />

      <section class={maintenanceMode ? 'danger-zone maintenance-active' : 'danger-zone'}>
        <div class="danger-content">
          <div>
            <h3 class={maintenanceMode ? 'danger-title success-title' : 'danger-title'}>Bảo trì hệ thống</h3>
            <p class="section-desc">
              {maintenanceMode
                ? '⚠️ Website đang ở chế độ bảo trì. Khách hàng sẽ thấy trang thông báo bảo trì.'
                : 'Tạm thời đóng cửa hàng để nâng cấp hoặc bảo trì kỹ thuật.'}
            </p>
          </div>
          <button
            id="btn-maintenance"
            class={maintenanceMode ? 'btn-success' : 'btn-danger'}
            onclick="toggleMaintenanceMode()"
          >
            {maintenanceMode ? '✅ Tắt chế độ bảo trì' : '🔧 Bật chế độ bảo trì'}
          </button>
        </div>
      </section>

      <div class="bottom-actions">
        <button class="btn-cancel">Hủy bỏ</button>
        <button class="btn-update" onclick="saveSettings()">Cập nhật tất cả</button>
      </div>
    </div>
  </div>

  <!-- ── TAB: GIAO DIỆN ── -->
  <div id="tab-appearance" class="tab-pane" data-requires-owner="true" style="display:none;">
    <div class="app-content">

      <!-- Color Section -->
      <section class="app-section">
        <div class="app-sec-head">
          <span class="material-symbols-outlined app-sec-icon">colorize</span>
          <h2 class="app-sec-title">Tông màu chủ đạo (Accent Color)</h2>
        </div>
        <div class="color-card">
          <p class="color-desc">Màu sắc này sẽ được áp dụng cho các nút bấm, icon và các thành phần nổi bật trên website.</p>
          <div class="color-swatches">
            <button class="swatch" data-color="#f48c25" style="background:#f48c25;" title="Cam FlySky"></button>
            <button class="swatch" data-color="#3b82f6" style="background:#3b82f6;" title="Xanh dương"></button>
            <button class="swatch" data-color="#10b981" style="background:#10b981;" title="Xanh lá"></button>
            <button class="swatch" data-color="#8b5cf6" style="background:#8b5cf6;" title="Tím"></button>
            <button class="swatch" data-color="#f43f5e" style="background:#f43f5e;" title="Đỏ hồng"></button>
            <button class="swatch swatch-add" title="Thêm màu tùy chỉnh">
              <span class="material-symbols-outlined">add</span>
            </button>
          </div>
          <div class="hex-row">
            <div class="hex-wrap">
              <label class="hex-label">Mã màu Hex</label>
              <input type="text" id="stg-brand-color" class="hex-input" value={brandColor} />
            </div>
          </div>
        </div>
      </section>

      <!-- Banner Section -->
      <section class="app-section">
        <div class="app-sec-head">
          <span class="material-symbols-outlined app-sec-icon">view_carousel</span>
          <h2 class="app-sec-title">Cấu hình Banner Trang chủ</h2>
        </div>
        <div class="banner-card">
          <div class="banner-preview">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuA0RLO_GkP1fRoMq2dQAvkkSAoh92EvcaRoYm7v88XMkBwXklSgVUDfvRw7JybfkZieQJyaXd9fFflea7cRNVwiKU3-3SmPM4OmdO0KOfXowVPV1KGF6Yz-Wq2OpTSYFLBCNSRvvVgTK8ctQUTdPix0rAq-rdtWYojAKwee__2MBkSEiouRqBY_btC12ZwORO4u3s2mYAvAWTqd4dTMXHViImhVoSCfbY3Ks3UdNq0CZkLr4HkPdiuvZYHHNF_jz4AKml8fmbIxigi5"
              alt="Banner preview"
              class="banner-img"
            />
            <div class="banner-gradient"></div>
            <div class="banner-overlay">
              <div>
                <span class="banner-badge">Xem trước banner</span>
                <h3 class="banner-tagline">Âm nhạc là hơi thở của cuộc sống</h3>
                <p class="banner-sub">Phong cách Studio &amp; Wood cổ điển</p>
              </div>
            </div>
          </div>
          <div class="banner-fields">
            <div class="form-group">
              <label class="form-label">Tiêu đề chính (H1)</label>
              <input type="text" id="stg-hero-h1" class="form-input" placeholder="Nhập tiêu đề banner..." value={heroH1} />
            </div>
            <div class="form-group">
              <label class="form-label">Lời kêu gọi hành động (CTA)</label>
              <input type="text" id="stg-hero-sub" class="form-input" placeholder="Ví dụ: Đàn guitar thủ công..." value={heroSub} />
            </div>
            <div class="form-group form-full">
              <label class="form-label">Danh sách ảnh Hero (nhiều ảnh)</label>
              <textarea
                id="stg-hero-images"
                class="form-input"
                rows="4"
                placeholder="Mỗi dòng là 1 URL ảnh, ví dụ:\nhttps://.../hero-1.jpg\nhttps://.../hero-2.jpg"
                style="resize:vertical;min-height:96px;"
              >{heroImages}</textarea>
              <p class="section-desc" style="margin-top:8px;">Để trống nếu chỉ dùng 1 ảnh mặc định (mục Ảnh Hero trang chủ bên trên).</p>
            </div>
            <div class="form-group">
              <label class="form-label">Hiệu ứng chuyển ảnh</label>
              <select id="stg-hero-effect" class="form-input">
                <option value="fade" selected={heroEffect === 'fade'}>Fade (mờ dần)</option>
                <option value="zoom" selected={heroEffect === 'zoom'}>Zoom nhẹ</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Thời gian chuyển (giây)</label>
              <input type="number" id="stg-hero-interval" class="form-input" min="2" max="15" step="1" value={heroIntervalSec} />
            </div>
          </div>
        </div>
      </section>

      <!-- Font Section — info only -->
      <section class="app-section">
        <div class="app-sec-head">
          <span class="material-symbols-outlined app-sec-icon">text_fields</span>
          <h2 class="app-sec-title">Font chữ</h2>
        </div>
        <div class="font-card" style="display:block;padding:20px 24px;">
          <div style="display:flex;align-items:flex-start;gap:14px;">
            <span class="material-symbols-outlined" style="color:#f48c25;font-size:22px;flex-shrink:0;margin-top:2px;">info</span>
            <div>
              <p style="font-size:14px;font-weight:700;color:#f1f5f9;margin-bottom:6px;">Font Manrope đang được sử dụng toàn bộ website</p>
              <p style="font-size:13px;color:#94a3b8;line-height:1.6;">Để thay đổi font chữ, chỉnh sửa file <code style="background:rgba(244,140,37,.15);color:#f48c25;padding:2px 6px;border-radius:4px;">src/layouts/Layout.astro</code> và <code style="background:rgba(244,140,37,.15);color:#f48c25;padding:2px 6px;border-radius:4px;">global.css</code> — font chữ cần được tích hợp trong quá trình build.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Save Actions -->
      <div class="app-actions">
        <button class="btn-cancel">Hủy thay đổi</button>
        <button class="btn-save" onclick="saveSettings()">
          <span class="material-symbols-outlined">save</span>
          Lưu cấu hình
        </button>
      </div>
    </div>
  </div>

  <!-- ── TAB: THANH TOÁN ── -->
  <div id="tab-payment" class="tab-pane" data-requires-owner="true" style="display:none;">
    <div class="stg-content">

      <!-- ── BANK TRANSFER ── -->
      <section class="stg-section">
        <div class="section-head">
          <div>
            <h3 class="section-title">Chuyển khoản Ngân hàng</h3>
            <p class="section-desc">Thông tin tài khoản nhận tiền — phục vụ tạo mã VietQR tự động trên trang thanh toán.</p>
          </div>
          <div style="display:flex;align-items:center;gap:14px;">
            <label class="toggle-label-wrap" title="Bật/tắt phương thức chuyển khoản ngân hàng">
              <input type="checkbox" class="toggle-chk" id="pay-bank-enabled" checked={bankEnabled} />
              <div class="toggle-track"><div class="toggle-thumb"></div></div>
            </label>
            <button class="btn-save" id="btn-save-bank" onclick="savePaymentBank()">
              <span class="material-symbols-outlined">save</span>
              Lưu
            </button>
          </div>
        </div>

        <div id="bank-fields" style={bankEnabled ? '' : 'opacity:0.5;pointer-events:none;'}>
          <div class="form-grid">
            <div class="form-group form-full">
              <label class="form-label">Tên Ngân hàng <span style="color:#94a3b8;font-weight:400;">(viết tắt, VD: BIDV, VCB, TCB)</span></label>
              <input type="text" id="stg-bank-name" class="form-input" value={bankName} placeholder="BIDV" />
            </div>
            <div class="form-group">
              <label class="form-label">Tên chủ tài khoản</label>
              <input type="text" id="stg-bank-acc-name" class="form-input" value={bankAccountName} />
            </div>
            <div class="form-group">
              <label class="form-label">Số tài khoản</label>
