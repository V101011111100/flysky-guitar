---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// Fetch settings from Database
const { data: settingsData } = await supabase
  .from('site_settings')
  .select('*');

// Helper to get value
const getSetting = (key: string, _default: string) => {
  const item = settingsData?.find((s: any) => s.key === key);
  return item ? item.value : _default;
};

const storeName = getSetting('flysky_storeName', 'FlySky Guitar');
const contactEmail = getSetting('flysky_contactEmail', 'hello@flyskyguitar.com');
const storeAddress = getSetting('flysky_storeAddress', '37 Lê Thiện Trị, Phường Ngũ Hành Sơn, Thành phố Đà Nẵng');
const contactPhone = getSetting('flysky_contactPhone', '0987 654 321');
const socialUrl = getSetting('flysky_socialUrl', 'https://facebook.com/flyskyguitar');
const brandColor = getSetting('flysky_brandColor', '#F48C25');
const heroH1 = getSetting('flysky_heroH1', 'Đánh Thức Đam Mê Âm Nhạc Của Bạn');
const heroSub = getSetting('flysky_heroSub', 'Khám phá bộ sưu tập nhạc cụ cao cấp, được tinh chỉnh hoàn hảo để mang lại cảm hứng sáng tạo bất tận cho mọi nghệ sĩ.');
---

<AdminLayout
  title="Cài đặt hệ thống"
  subtitle="Quản lý cấu hình cửa hàng, giao diện và bảo mật tài khoản."
  activeNav="settings"
>

  <!-- ── BREADCRUMBS ── -->
  <nav class="breadcrumbs">
    <a href="/admin" class="bc-link">Trang chủ</a>
    <span class="material-symbols-outlined bc-arrow">chevron_right</span>
    <span class="bc-current">Cài đặt hệ thống</span>
  </nav>

  <!-- ── TABS ── -->
  <div class="stg-tabs">
    <button class="stg-tab" onclick="switchTab('general', this)">Cài đặt chung</button>
    <button class="stg-tab" onclick="switchTab('appearance', this)">Giao diện</button>
    <button class="stg-tab" onclick="switchTab('notifications', this)">Thông báo</button>
    <button class="stg-tab stg-tab-active" onclick="switchTab('security', this)">Bảo mật &amp; Tài khoản</button>
  </div>

  <!-- ── TAB: CÀI ĐẶT CHUNG ── -->
  <div id="tab-general" class="tab-pane" style="display:none;">
    <div class="stg-content">
      <section class="stg-section">
        <div class="section-head">
          <div>
            <h3 class="section-title">Thông tin cửa hàng</h3>
            <p class="section-desc">Thông tin cơ bản hiển thị trên website và hóa đơn.</p>
          </div>
          <button class="btn-save" onclick="saveSettings()">
            <span class="material-symbols-outlined">save</span>
            Lưu thay đổi
          </button>
        </div>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Tên cửa hàng</label>
            <input type="text" id="stg-store-name" class="form-input" value={storeName} />
          </div>
          <div class="form-group">
            <label class="form-label">Email liên hệ</label>
            <input type="email" id="stg-contact-email" class="form-input" value={contactEmail} />
          </div>
          <div class="form-group form-full">
            <label class="form-label">Địa chỉ cửa hàng</label>
            <input type="text" id="stg-store-address" class="form-input" value={storeAddress} />
          </div>
        </div>
      </section>

      <hr class="stg-divider" />

      <section class="stg-section stg-two-col">
        <div class="stg-two-col-left">
          <h3 class="section-title">Logo &amp; Thương hiệu</h3>
          <p class="section-desc">Logo hiển thị tại header và footer của website.</p>
        </div>
        <div class="stg-two-col-right">
          <div class="logo-area">
            <input type="file" id="logo-upload-input" accept="image/png, image/svg+xml, image/jpeg" style="display: none;" />
            <div class="logo-preview" id="logo-preview-box" onclick="document.getElementById('logo-upload-input').click()">
              <img src="/logo.svg" alt="Preview" id="logo-preview-img" style="width:100%; height:100%; object-fit:contain; padding:10px;" class="flysky-global-logo" />
              <div class="logo-label">Logo Hiện Tại</div>
              <div class="logo-hover-overlay">
                <span class="material-symbols-outlined">upload</span>
              </div>
            </div>
            <div class="logo-info">
              <p class="form-label" style="margin-bottom:8px;">Thay đổi Logo</p>
              <p class="section-desc" style="margin-bottom:16px;">Khuyên dùng định dạng PNG hoặc SVG. Kích thước tối ưu 512x512px.</p>
              <button class="btn-upload" onclick="document.getElementById('logo-upload-input').click()">Tải lên ảnh mới</button>
            </div>
          </div>
        </div>
      </section>

      <hr class="stg-divider" />

      <section class="stg-section stg-two-col">
        <div class="stg-two-col-left">
          <h3 class="section-title">Liên hệ &amp; Mạng xã hội</h3>
          <p class="section-desc">Liên kết với các nền tảng mạng xã hội của studio.</p>
        </div>
        <div class="stg-two-col-right">
          <div class="icon-input-wrap">
            <span class="material-symbols-outlined inp-icon">call</span>
            <input type="text" id="stg-contact-phone" class="form-input inp-with-icon" value={contactPhone} />
          </div>
          <div class="icon-input-wrap" style="margin-top:12px;">
            <span class="material-symbols-outlined inp-icon">public</span>
            <input type="text" id="stg-social-url" class="form-input inp-with-icon" value={socialUrl} />
          </div>
        </div>
      </section>

      <hr class="stg-divider" />

      <section class="danger-zone">
        <div class="danger-content">
          <div>
            <h3 class="danger-title">Bảo trì hệ thống</h3>
            <p class="section-desc">Tạm thời đóng cửa hàng để nâng cấp hoặc bảo trì kỹ thuật.</p>
          </div>
          <button class="btn-danger">Bật chế độ bảo trì</button>
        </div>
      </section>

      <div class="bottom-actions">
        <button class="btn-cancel">Hủy bỏ</button>
        <button class="btn-update" onclick="saveSettings()">Cập nhật tất cả</button>
      </div>
    </div>
  </div>

  <!-- ── TAB: GIAO DIỆN ── -->
  <div id="tab-appearance" class="tab-pane" style="display:none;">
    <div class="app-content">

      <!-- Color Section -->
      <section class="app-section">
        <div class="app-sec-head">
          <span class="material-symbols-outlined app-sec-icon">colorize</span>
          <h2 class="app-sec-title">Tông màu chủ đạo (Accent Color)</h2>
        </div>
        <div class="color-card">
          <p class="color-desc">Màu sắc này sẽ được áp dụng cho các nút bấm, icon và các thành phần nổi bật trên website.</p>
          <div class="color-swatches">
            <button class="swatch swatch-active" style="background:#f48c25;" title="Cam FlySky">
              <span class="material-symbols-outlined swatch-check">check</span>
            </button>
            <button class="swatch" style="background:#3b82f6;" title="Xanh dương"></button>
            <button class="swatch" style="background:#10b981;" title="Xanh lá"></button>
            <button class="swatch" style="background:#8b5cf6;" title="Tím"></button>
            <button class="swatch" style="background:#f43f5e;" title="Đỏ hồng"></button>
            <button class="swatch swatch-add" title="Thêm màu">
              <span class="material-symbols-outlined">add</span>
            </button>
          </div>
          <div class="hex-row">
            <div class="hex-wrap">
              <label class="hex-label">Mã màu Hex</label>
              <input type="text" id="stg-brand-color" class="hex-input" value={brandColor} />
            </div>
          </div>
        </div>
      </section>

      <!-- Banner Section -->
      <section class="app-section">
        <div class="app-sec-head">
          <span class="material-symbols-outlined app-sec-icon">view_carousel</span>
          <h2 class="app-sec-title">Cấu hình Banner Trang chủ</h2>
        </div>
        <div class="banner-card">
          <div class="banner-preview">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuA0RLO_GkP1fRoMq2dQAvkkSAoh92EvcaRoYm7v88XMkBwXklSgVUDfvRw7JybfkZieQJyaXd9fFflea7cRNVwiKU3-3SmPM4OmdO0KOfXowVPV1KGF6Yz-Wq2OpTSYFLBCNSRvvVgTK8ctQUTdPix0rAq-rdtWYojAKwee__2MBkSEiouRqBY_btC12ZwORO4u3s2mYAvAWTqd4dTMXHViImhVoSCfbY3Ks3UdNq0CZkLr4HkPdiuvZYHHNF_jz4AKml8fmbIxigi5"
              alt="Banner preview"
              class="banner-img"
            />
            <div class="banner-gradient"></div>
            <div class="banner-overlay">
              <div>
                <span class="banner-badge">Xem trước banner</span>
                <h3 class="banner-tagline">Âm nhạc là hơi thở của cuộc sống</h3>
                <p class="banner-sub">Phong cách Studio &amp; Wood cổ điển</p>
              </div>
              <button class="banner-change-btn">
                <span class="material-symbols-outlined">edit</span> Thay đổi ảnh
              </button>
            </div>
          </div>
          <div class="banner-fields">
            <div class="form-group">
              <label class="form-label">Tiêu đề chính (H1)</label>
              <input type="text" id="stg-hero-h1" class="form-input" placeholder="Nhập tiêu đề banner..." value={heroH1} />
            </div>
            <div class="form-group">
              <label class="form-label">Lời kêu gọi hành động (CTA)</label>
              <input type="text" id="stg-hero-sub" class="form-input" placeholder="Ví dụ: Đàn guitar thủ công..." value={heroSub} />
            </div>
          </div>
        </div>
      </section>

      <!-- Font Section -->
      <section class="app-section">
        <div class="app-sec-head">
          <span class="material-symbols-outlined app-sec-icon">text_fields</span>
          <h2 class="app-sec-title">Cấu hình Font chữ</h2>
        </div>
        <div class="font-card">
          <div class="font-col">
            <label class="font-col-label">Font Tiêu đề</label>
            <select class="form-input">
              <option>Manrope (Mặc định)</option>
              <option>Montserrat</option>
              <option>Playfair Display</option>
              <option>Oswald</option>
            </select>
            <div class="font-preview-box">
              <h4 class="font-preview-h">ABCDEFGHI</h4>
              <p class="font-preview-sub">Xem trước font tiêu đề</p>
            </div>
          </div>
          <div class="font-col">
            <label class="font-col-label">Font Nội dung</label>
            <select class="form-input">
              <option>Manrope (Mặc định)</option>
              <option>Inter</option>
              <option>Roboto</option>
              <option>Open Sans</option>
            </select>
            <div class="font-preview-box">
              <p class="font-preview-body">Âm nhạc kết nối tâm hồn mọi người.</p>
              <p class="font-preview-sub">Xem trước font nội dung</p>
            </div>
          </div>
          <div class="font-tip-col">
            <div class="font-tip">
              <p class="font-tip-text">"Sử dụng font chữ serif như Playfair Display sẽ mang lại cảm giác cổ điển (Vintage) phù hợp với guitar acoustic."</p>
              <div class="font-tip-footer">
                <span class="material-symbols-outlined font-tip-icon">info</span>
                <span class="font-tip-label">Gợi ý từ Studio</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Save Actions -->
      <div class="app-actions">
        <button class="btn-cancel">Hủy thay đổi</button>
        <button class="btn-save" onclick="saveSettings()">
          <span class="material-symbols-outlined">save</span>
          Lưu cấu hình
        </button>
      </div>
    </div>
  </div>

  <!-- ── TAB: THÔNG BÁO ── -->
  <div id="tab-notifications" class="tab-pane" style="display:none;">
    <div class="ntf-content">

      <div class="ntf-header">
        <h2 class="ntf-title">Cấu hình thông báo</h2>
        <p class="ntf-desc">Quản lý cách thức FlySky Guitar gửi thông báo đơn hàng và báo cáo đến bạn.</p>
      </div>

      <!-- Email Notifications -->
      <section class="ntf-section">
        <div class="ntf-sec-head">
          <span class="material-symbols-outlined ntf-sec-icon">mail</span>
          <h3 class="ntf-sec-title">Thông báo qua Email</h3>
        </div>
        <div class="ntf-list">
          <div class="ntf-row">
            <div class="ntf-row-text">
              <span class="ntf-row-name">Đơn hàng mới</span>
              <span class="ntf-row-sub">Nhận email ngay khi khách hàng hoàn tất đặt hàng</span>
            </div>
            <label class="toggle-label-wrap">
              <input type="checkbox" class="toggle-chk" checked />
              <div class="toggle-track"><div class="toggle-thumb"></div></div>
            </label>
          </div>
          <div class="ntf-row">
            <div class="ntf-row-text">
              <span class="ntf-row-name">Yêu cầu tư vấn mới</span>
              <span class="ntf-row-sub">Thông báo khi có khách hàng để lại thông tin cần hỗ trợ gỗ &amp; studio</span>
            </div>
            <label class="toggle-label-wrap">
              <input type="checkbox" class="toggle-chk" checked />
              <div class="toggle-track"><div class="toggle-thumb"></div></div>
            </label>
          </div>
        </div>
      </section>

      <!-- Push Notifications -->
      <section class="ntf-section">
        <div class="ntf-sec-head">
          <span class="material-symbols-outlined ntf-sec-icon">notifications_active</span>
          <h3 class="ntf-sec-title">Thông báo đẩy (Push)</h3>
        </div>
        <div class="ntf-card">
          <div class="ntf-row" style="padding:0 0 16px;">
            <div class="ntf-row-text">
              <span class="ntf-row-name">Thông báo trình duyệt cho Admin</span>
              <span class="ntf-row-sub">Hiển thị thông báo tức thì trên máy tính khi đang làm việc</span>
            </div>
            <label class="toggle-label-wrap">
              <input type="checkbox" class="toggle-chk" />
              <div class="toggle-track"><div class="toggle-thumb"></div></div>
            </label>
          </div>
          <div class="ntf-info-note">
            <span class="material-symbols-outlined ntf-info-icon">info</span>
            <p class="ntf-info-text">Bạn cần cho phép trình duyệt hiển thị thông báo để tính năng này hoạt động.</p>
          </div>
        </div>
      </section>

      <!-- Daily Reports -->
      <section class="ntf-section">
        <div class="ntf-sec-head">
          <span class="material-symbols-outlined ntf-sec-icon">assessment</span>
          <h3 class="ntf-sec-title">Báo cáo hàng ngày</h3>
        </div>
        <div class="ntf-card">
          <div class="ntf-report-block">
            <label class="form-label">Danh sách Email nhận báo cáo</label>
            <p class="ntf-row-sub" style="margin-bottom:14px;">Các email này sẽ nhận được bản tóm tắt doanh thu và hoạt động vào 8:00 sáng mỗi ngày.</p>
            <div class="ntf-tags">
              <span class="ntf-tag">
                admin@flyskyguitar.com
                <button class="ntf-tag-del material-symbols-outlined">close</button>
              </span>
              <span class="ntf-tag">
                manager@flyskyguitar.com
                <button class="ntf-tag-del material-symbols-outlined">close</button>
              </span>
            </div>
            <div class="ntf-add-row">
              <input type="email" class="ntf-email-input" placeholder="Thêm email mới..." />
              <button class="ntf-add-btn">
                <span class="material-symbols-outlined">add</span>
                Thêm
              </button>
            </div>
          </div>
          <div class="ntf-row ntf-chart-row">
            <div class="ntf-row-text">
              <span class="ntf-row-name">Bao gồm biểu đồ tăng trưởng</span>
              <span class="ntf-row-sub">Đính kèm hình ảnh biểu đồ trong nội dung email báo cáo</span>
            </div>
            <label class="toggle-label-wrap">
              <input type="checkbox" class="toggle-chk" checked />
              <div class="toggle-track"><div class="toggle-thumb"></div></div>
            </label>
          </div>
        </div>
      </section>

      <!-- Actions -->
      <div class="ntf-actions">
        <button class="btn-cancel">Hủy thay đổi</button>
        <button class="btn-save">
          <span class="material-symbols-outlined">save</span>
          Lưu cấu hình
        </button>
      </div>

    </div>
  </div>

  <!-- ── TAB: BẢO MẬT & TÀI KHOẢN ── -->
  <div id="tab-security" class="tab-pane">

    <div class="sec-content">

      <!-- ═══ PHẦN 1: THÔNG TIN TÀI KHOẢN ═══ -->
      <div class="sec-card">
        <div class="sec-card-header">
          <h2 class="sec-section-title">Thông tin tài khoản</h2>
          <p class="section-desc">Quản lý thông tin cá nhân và thiết lập hiển thị của bạn.</p>
        </div>

        <!-- Avatar row -->
        <div class="avatar-row">
          <div class="avatar-wrap">
            <div class="avatar-circle">
              <img
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuB8Q0jdsxpNU2XIDWvdQq6YnyDJbLyaBSgTHqFfXBjafk3RFy_MvxxI7h2_6jR9ZxzJAaN2cKrkjpAx9_KLkwa1ngAU3dzewG-XEn3YWq_o-O5acJD_oktbLOe27bGy9q6zwOZ47Gam_8v4Uzd1maWjcdE2TAa-gjYY6yzCscoAaCfLYmWq7NqnvrFSqyHYTDZZ49ytfclkVsD0AN_20erWVJirXpeonu7wUcBKrkudIO4j9RyQbAO_iy7q6ABOtYQzXwWxrt2Zxrnn"
                alt="Avatar"
              />
            </div>
            <button class="avatar-cam-btn">
              <span class="material-symbols-outlined">photo_camera</span>
            </button>
          </div>
          <div class="avatar-info">
            <h3 class="sec-label">Ảnh đại diện</h3>
            <p class="section-desc">Định dạng JPG, GIF hoặc PNG. Kích thước tối đa 2MB.</p>
            <div class="avatar-btns">
              <button class="btn-upload-img">Tải ảnh mới</button>
              <button class="btn-delete-img">Xóa ảnh</button>
            </div>
          </div>
        </div>

        <hr class="stg-divider" style="margin:0;" />

        <!-- Profile Form -->
        <div class="form-grid profile-form">
          <div class="form-group">
            <label class="form-label">Họ và tên</label>
            <div class="icon-input-wrap">
              <span class="material-symbols-outlined inp-icon">person</span>
              <input type="text" class="form-input inp-with-icon" value="Nguyễn Văn A" />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Chức vụ</label>
            <div class="icon-input-wrap">
              <span class="material-symbols-outlined inp-icon">badge</span>
              <select class="form-input inp-with-icon">
                <option selected>Quản trị viên (Admin)</option>
                <option>Biên tập viên (Editor)</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Email cá nhân</label>
            <div class="icon-input-wrap">
              <span class="material-symbols-outlined inp-icon">mail</span>
              <input type="email" class="form-input inp-with-icon" value="vana.nguyen@studiowood.com" />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Số điện thoại liên hệ</label>
            <div class="icon-input-wrap">
              <span class="material-symbols-outlined inp-icon">call</span>
              <input type="tel" class="form-input inp-with-icon" value="+84 988 123 456" />
            </div>
          </div>
        </div>

        <div class="profile-actions">
          <button class="btn-cancel">Chỉnh sửa</button>
          <button class="btn-save">
            <span class="material-symbols-outlined">save</span>
            Lưu thay đổi
          </button>
        </div>

        <!-- Account Security Tip -->
        <div class="tip-card amber-tip">
          <span class="material-symbols-outlined tip-icon">info</span>
          <div>
            <h4 class="tip-title amber-title">Bảo mật tài khoản</h4>
            <p class="tip-text">Chúng tôi khuyên bạn nên cập nhật mật khẩu ít nhất 3 tháng một lần để đảm bảo an toàn cho quyền quản trị.</p>
          </div>
        </div>
      </div>

      <!-- ═══ PHẦN 2: MẬT KHẨU & XÁC THỰC ═══ -->
      <div class="sec-card">
        <h2 class="sec-section-title" style="padding:24px 24px 16px;">Mật khẩu &amp; Xác thực</h2>
        <div class="auth-list">
          <!-- Change Password -->
          <div class="auth-item auth-item-hover">
            <div class="auth-icon orange-bg">
              <span class="material-symbols-outlined">key</span>
            </div>
            <div class="auth-texts">
              <p class="auth-name">Đổi mật khẩu Admin</p>
              <p class="auth-desc">Cập nhật mật khẩu định kỳ để bảo vệ hệ thống FlySky</p>
            </div>
            <span class="material-symbols-outlined auth-arrow">chevron_right</span>
          </div>
          <!-- 2FA -->
          <div class="auth-item">
            <div class="auth-icon orange-bg">
              <span class="material-symbols-outlined">verified_user</span>
            </div>
            <div class="auth-texts">
