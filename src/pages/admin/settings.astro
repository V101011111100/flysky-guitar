  (window as any).testEmailConnection = testEmailConnection;

  // Session Management Functions
  async function loadActiveSessions() {
    try {
      const response = await fetch('/api/admin/sessions');
      const data = await response.json();
      if (data.success) {
        renderSessions(data.sessions);
      }
    } catch (error) {
      console.error('Error loading sessions:', error);
    }
  }

  function renderSessions(sessions: any[]) {
    const sessionList = document.querySelector('.session-list');
    if (!sessionList) return;
    
    if (!sessions || sessions.length === 0) {
      sessionList.innerHTML = '<div class="session-empty"><span class="material-symbols-outlined" style="font-size:32px;display:block;margin-bottom:8px;">devices</span>Không có phiên đăng nhập nào</div>';
      return;
    }
    
    sessionList.innerHTML = sessions.map((session: any) => `
      <div class="session-item ${session.isCurrent ? 'current-session' : ''}">
        <div class="session-icon ${session.deviceType === 'desktop' ? 'green-bg' : session.deviceType === 'mobile' ? 'blue-bg' : 'grey-bg'}">
          <span class="material-symbols-outlined">
            ${session.deviceType === 'desktop' ? 'laptop_mac' : session.deviceType === 'mobile' ? 'smartphone' : 'devices'}
          </span>
        </div>
        <div class="session-info">
          <p class="session-name">${session.deviceName} - ${session.browser}</p>
          <div class="session-meta">
            <span>IP: ${session.ipAddress}</span>
            <span class="session-meta-dot"></span>
            <span>${session.location}</span>
          </div>
          <p class="session-last">Hoạt động lần cuối: ${formatLastActivity(session.lastActivity)}</p>
          <span class="session-badge" style="margin-top:8px;background:${session.sessionKind === 'temporary' ? 'rgba(59,130,246,.12)' : 'rgba(34,197,94,.12)'};color:${session.sessionKind === 'temporary' ? '#93c5fd' : '#86efac'};border-color:${session.sessionKind === 'temporary' ? 'rgba(59,130,246,.28)' : 'rgba(34,197,94,.28)'};">${session.sessionKind === 'temporary' ? 'Phiên tạm thời' : 'Ghi nhớ đăng nhập'}</span>
          ${session.isCurrent ? '<span class="session-badge current-badge"><span class="badge-dot"></span> Phiên hiện tại</span>' : ''}
          ${!session.isCurrent && !session.isActive ? '<span class="session-badge" style="margin-top:8px;background:rgba(148,163,184,.15);color:#cbd5e1;border-color:rgba(148,163,184,.35);">Đã kết thúc</span>' : ''}
        </div>
        ${!session.isCurrent ? `<button class="session-del-btn" onclick="terminateSession('${session.sessionId}')">
          <span class="material-symbols-outlined">delete_outline</span>
          ${session.isActive ? 'Kết thúc phiên' : 'Xóa khỏi danh sách'}
        </button>` : ''}
      </div>
    `).join('');
  }

  function formatLastActivity(timestamp: string) {
    const date = new Date(timestamp);
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffMins = Math.floor(diffMs / (1000 * 60));
    const diffHours = Math.floor(diffMins / 60);
    const diffDays = Math.floor(diffHours / 24);

    if (diffMins < 1) {
      return 'Vừa xong';
    } else if (diffMins < 60) {
      return `${diffMins} phút trước`;
    } else if (diffHours < 24) {
      return `${diffHours} giờ ${diffMins % 60} phút trước`;
    } else {
      return `${diffDays} ngày ${diffHours % 24} giờ trước`;
    }
  }

  async function terminateSession(sessionId: string) {
    if (!confirm('Bạn có chắc chắn muốn kết thúc phiên này?')) return;
    
    try {
      const response = await fetch('/api/admin/sessions/terminate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId })
      });
      
      const data = await response.json();
      if (data.success) {
        if (data.forceLogout) {
          alert('Phiên hiện tại đã bị kết thúc. Hệ thống sẽ đăng xuất ngay.');
          const form = document.getElementById('logout-form') as HTMLFormElement | null;
          if (form) {
            form.submit();
          } else {
            window.location.href = '/api/auth/signout';
          }
          return;
        }

        if (data.action === 'deleted') {
          alert('Đã xóa phiên khỏi danh sách!');
        } else {
          alert('Đã kết thúc phiên thành công!');
        }
        loadActiveSessions(); // Reload sessions
      } else {
        alert('Lỗi khi kết thúc phiên: ' + data.error);
      }
    } catch (error: any) {
      alert('Lỗi kết nối: ' + error.message);
    }
  }

  async function logoutAllSessions() {
    if (!confirm('Bạn có chắc chắn muốn đăng xuất khỏi TẤT CẢ thiết bị (bao gồm phiên hiện tại)?\n\nBạn sẽ bị chuyển về trang đăng nhập.')) return;
    
    try {
      const response = await fetch('/api/admin/sessions/logout-all', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      
      const data = await response.json();
      if (data.success) {
        // Sign out current session: submit the signout form to clear cookies
        const form = document.getElementById('logout-form') as HTMLFormElement;
        if (form) {
          form.submit();
        } else {
          window.location.href = '/api/auth/signout';
        }
      } else {
        alert('Lỗi khi đăng xuất: ' + data.error);
      }
    } catch (error: any) {
      alert('Lỗi kết nối: ' + error.message);
    }
  }

  // Auto-logout timeout functionality
  async function updateAutoLogoutTimeout() {
    const timeoutSelect = document.querySelector('.timeout-select') as HTMLSelectElement | null;
    const saveBtn = document.querySelector('.btn-save-sm-orange') as HTMLButtonElement | null;
    
    if (!timeoutSelect || !saveBtn) return;
    
    try {
      const response = await fetch('/api/settings/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          settings: [{ key: 'flysky_autoLogoutTimeout', value: timeoutSelect?.value || '' }]
        })
      });
      
      const data = await response.json();
      if (data.success) {
        const nextTimeout = parseInt(timeoutSelect?.value || '120', 10);
        (window as any)._autoLogoutMinutes = Number.isFinite(nextTimeout) ? nextTimeout : 120;
        window.dispatchEvent(new CustomEvent('admin:auto-logout-timeout-updated', {
          detail: { minutes: (window as any)._autoLogoutMinutes }
        }));
        alert('Đã cập nhật thời gian tự động đăng xuất thành công!');
      } else {
        alert('Lỗi cập nhật: ' + data.error);
      }
    } catch (error: any) {
      alert('Lỗi kết nối: ' + error.message);
    }
  }

  // Initialize session management on page load
  document.addEventListener('DOMContentLoaded', () => {
    if (!(window as any)._canManageSystemSettings) {
      document.querySelectorAll('[data-requires-owner="true"]').forEach((el) => {
        (el as HTMLElement).style.display = 'none';
      });
      const securityTabBtn = Array.from(document.querySelectorAll('.stg-tab')).find((el) =>
        (el as HTMLElement).textContent?.includes('Bảo mật')
      ) as HTMLElement | undefined;
      if (securityTabBtn) {
        switchTab('security', securityTabBtn);
      }
    }

    loadActiveSessions();
    
    // Expose functions to window for onclick handlers
    (window as any).logoutAllSessions = logoutAllSessions;
    (window as any).terminateSession = terminateSession;
    
    // Add event listener for auto-logout timeout
    const timeoutSelect = document.querySelector('.timeout-select') as HTMLSelectElement | null;
    const saveBtn = document.querySelector('.btn-save-sm-orange') as HTMLButtonElement | null;
    if (timeoutSelect && saveBtn) {
      timeoutSelect.addEventListener('change', updateAutoLogoutTimeout);
      saveBtn.addEventListener('click', updateAutoLogoutTimeout);
    }

    // ── Change Password Modal ──
    const pwModal = document.getElementById('modal-change-pw') as HTMLElement;
    const btnOpenPw = document.getElementById('btn-change-password');
    const btnClosePw = document.getElementById('close-pw-modal');
    const btnCancelPw = document.getElementById('cancel-pw-modal');
    const btnSavePw = document.getElementById('btn-save-pw') as HTMLButtonElement;
    const pwCurrent = document.getElementById('pw-current') as HTMLInputElement;
    const pwNew = document.getElementById('pw-new') as HTMLInputElement;
    const pwConfirm = document.getElementById('pw-confirm') as HTMLInputElement;
    const strengthFill = document.querySelector('.pw-strength-fill') as HTMLElement;
    const strengthText = document.getElementById('pw-strength-text') as HTMLElement;
    const matchText = document.getElementById('pw-match-text') as HTMLElement;

    let _pwScrollY = 0;
    function openPwModal() {
      if (!pwModal) return;
      _pwScrollY = window.scrollY;
      pwModal.style.display = 'flex';
      document.body.style.position = 'fixed';
      document.body.style.top = `-${_pwScrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.overflow = 'hidden';
    }
    function closePwModal() {
      if (pwModal) pwModal.style.display = 'none';
      document.body.style.removeProperty('position');
      document.body.style.removeProperty('top');
      document.body.style.removeProperty('left');
      document.body.style.removeProperty('right');
      document.body.style.removeProperty('overflow');
      window.scrollTo({ top: _pwScrollY, behavior: 'instant' });
      if (pwCurrent) pwCurrent.value = '';
      if (pwNew) pwNew.value = '';
      if (pwConfirm) pwConfirm.value = '';
      if (strengthFill) { strengthFill.style.width = '0%'; strengthFill.style.background = ''; }
      if (strengthText) strengthText.textContent = '';
      if (matchText) matchText.textContent = '';
      if (btnSavePw) btnSavePw.disabled = true;
    }

    btnOpenPw?.addEventListener('click', openPwModal);
    btnClosePw?.addEventListener('click', closePwModal);
    btnCancelPw?.addEventListener('click', closePwModal);
    pwModal?.addEventListener('click', (e: Event) => { if (e.target === pwModal) closePwModal(); });

    // Password strength checker
    function checkPasswordStrength(pw: string): { score: number; label: string; color: string } {
      let score = 0;
      if (pw.length >= 8) score++;
      if (pw.length >= 12) score++;
      if (/[a-z]/.test(pw) && /[A-Z]/.test(pw)) score++;
      if (/\d/.test(pw)) score++;
      if (/[^a-zA-Z0-9]/.test(pw)) score++;

      if (score <= 1) return { score, label: 'Yếu', color: '#ef4444' };
      if (score <= 2) return { score, label: 'Trung bình', color: '#f59e0b' };
      if (score <= 3) return { score, label: 'Khá', color: '#3b82f6' };
      return { score, label: 'Mạnh', color: '#10b981' };
    }

    function validatePwForm() {
      const current = pwCurrent?.value || '';
      const newPw = pwNew?.value || '';
      const confirm = pwConfirm?.value || '';
      const strength = checkPasswordStrength(newPw);

      // Update strength bar
      if (strengthFill && strengthText) {
        if (newPw.length > 0) {
          strengthFill.style.width = `${(strength.score / 5) * 100}%`;
          strengthFill.style.background = strength.color;
          strengthText.textContent = `Độ mạnh: ${strength.label}`;
          strengthText.style.color = strength.color;
        } else {
          strengthFill.style.width = '0%';
          strengthText.textContent = '';
        }
      }

      // Check match
      if (matchText) {
        if (confirm.length > 0 && newPw !== confirm) {
          matchText.textContent = 'Mật khẩu xác nhận không khớp';
          matchText.style.color = '#ef4444';
        } else if (confirm.length > 0 && newPw === confirm) {
          matchText.textContent = 'Mật khẩu khớp ✓';
          matchText.style.color = '#10b981';
        } else {
          matchText.textContent = '';
        }
      }

      // Enable save button
      if (btnSavePw) {
        btnSavePw.disabled = !(current.length > 0 && newPw.length >= 8 && newPw === confirm);
      }
    }

    pwCurrent?.addEventListener('input', validatePwForm);
    pwNew?.addEventListener('input', validatePwForm);
    pwConfirm?.addEventListener('input', validatePwForm);

    // Toggle password visibility
    document.querySelectorAll('.pw-eye').forEach(btn => {
      btn.addEventListener('click', () => {
        const wrap = btn.closest('.pw-input-wrap');
        const input = wrap?.querySelector('input') as HTMLInputElement;
        const icon = btn.querySelector('.material-symbols-outlined') as HTMLElement;
        if (input && icon) {
          const isPassword = input.type === 'password';
          input.type = isPassword ? 'text' : 'password';
          icon.textContent = isPassword ? 'visibility' : 'visibility_off';
        }
      });
    });

    // Save password
    btnSavePw?.addEventListener('click', async () => {
      const currentPw = pwCurrent?.value || '';
      const newPw = pwNew?.value || '';
      
      btnSavePw.disabled = true;
      btnSavePw.textContent = 'Đang cập nhật...';

      try {
        const response = await fetch('/api/admin/change-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ currentPassword: currentPw, newPassword: newPw })
        });
        
        const data = await response.json();
        if (data.success) {
          alert('Đã cập nhật mật khẩu thành công!');
          closePwModal();
        } else {
          alert(data.error || 'Lỗi cập nhật mật khẩu');
        }
      } catch (err: any) {
        alert('Lỗi kết nối: ' + (err?.message || 'Không xác định'));
      } finally {
        btnSavePw.disabled = false;
        btnSavePw.innerHTML = '<span class="material-symbols-outlined">save</span> Cập nhật mật khẩu';
      }
    });

    // ── 2FA Toggle ──
    const toggle2fa = document.getElementById('toggle-2fa') as HTMLInputElement;
    const modal2fa = document.getElementById('modal-2fa-setup') as HTMLElement;
    const close2faBtn = document.getElementById('close-2fa-modal');
    const cancel2faBtn = document.getElementById('cancel-2fa-modal');
    const verify2faBtn = document.getElementById('btn-verify-2fa') as HTMLButtonElement;
    const qrCodeImg = document.getElementById('qr-code-img') as HTMLImageElement;
    const totpSecret = document.getElementById('totp-secret') as HTMLElement;
    const totpInput = document.getElementById('totp-verify-code') as HTMLInputElement;
    let currentFactorId = '';

    let _2faScrollY = 0;
    function open2faModal() {
      if (!modal2fa) return;
      _2faScrollY = window.scrollY;
      modal2fa.style.display = 'flex';
      document.body.style.position = 'fixed';
      document.body.style.top = `-${_2faScrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.overflow = 'hidden';
    }
    function close2faModal() {
      if (modal2fa) modal2fa.style.display = 'none';
      document.body.style.removeProperty('position');
      document.body.style.removeProperty('top');
      document.body.style.removeProperty('left');
      document.body.style.removeProperty('right');
      document.body.style.removeProperty('overflow');
      window.scrollTo({ top: _2faScrollY, behavior: 'instant' });
      if (totpInput) totpInput.value = '';
      currentFactorId = '';
    }

    close2faBtn?.addEventListener('click', () => { close2faModal(); toggle2fa.checked = false; });
    cancel2faBtn?.addEventListener('click', () => { close2faModal(); toggle2fa.checked = false; });
    modal2fa?.addEventListener('click', (e: Event) => {
      if (e.target === modal2fa) { close2faModal(); toggle2fa.checked = false; }
    });

    // Check current 2FA status via API
    (async () => {
      try {
        const res = await fetch('/api/admin/mfa/status');
        const data = await res.json();
        if (data.success && data.enabled && toggle2fa) {
          toggle2fa.checked = true;
        }
      } catch (e) { /* MFA not available */ }
    })();

    toggle2fa?.addEventListener('change', async () => {
      if (toggle2fa.checked) {
        // Enroll MFA via API
        try {
          const enrollRes = await fetch('/api/admin/mfa/enroll', { method: 'POST' });
          const enrollData = await enrollRes.json();
          
          if (!enrollData.success) {
            alert('Lỗi kích hoạt 2FA: ' + enrollData.error);
            toggle2fa.checked = false;
            return;
          }
          
          if (enrollData.qrCode) {
            // Show QR code and secret in inline modal
            currentFactorId = enrollData.factorId;
            if (qrCodeImg) qrCodeImg.src = enrollData.qrCode;
            if (totpSecret) totpSecret.textContent = enrollData.secret;
            if (totpInput) totpInput.value = '';
            open2faModal();
          } else {
            alert('Không nhận được mã QR từ server.');
            toggle2fa.checked = false;
          }
        } catch (err: any) {
          alert('Lỗi: ' + (err?.message || 'Không hỗ trợ 2FA'));
          toggle2fa.checked = false;
        }
      } else {
        // Unenroll MFA via API
        if (!confirm('Bạn có chắc chắn muốn tắt xác thực 2 lớp?')) {
          toggle2fa.checked = true;
          return;
        }
        try {
          const res = await fetch('/api/admin/mfa/unenroll', { method: 'POST' });
          const data = await res.json();
          if (data.success) {
            alert('Đã tắt xác thực 2 lớp.');
          } else {
            alert('Lỗi: ' + data.error);
            toggle2fa.checked = true;
          }
        } catch (err: any) {
          alert('Lỗi: ' + (err?.message || 'Không xác định'));
          toggle2fa.checked = true;
        }
      }
    });

    // Verify 2FA code button
    verify2faBtn?.addEventListener('click', async () => {
      const code = totpInput?.value?.trim() || '';
      if (code.length !== 6 || !/^\d{6}$/.test(code)) {
        alert('Vui lòng nhập đúng mã 6 chữ số.');
        return;
      }
      
      verify2faBtn.disabled = true;
      verify2faBtn.textContent = 'Đang xác nhận...';

      try {
        const verifyRes = await fetch('/api/admin/mfa/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ factorId: currentFactorId, code })
        });
        const verifyData = await verifyRes.json();
        
        if (verifyData.success) {
          alert('Đã kích hoạt xác thực 2 lớp thành công!');
          close2faModal();
        } else {
          alert(verifyData.error || 'Mã xác thực không đúng.');
          toggle2fa.checked = false;
        }
      } catch (err: any) {
        alert('Lỗi kết nối: ' + (err?.message || 'Không xác định'));
        toggle2fa.checked = false;
      } finally {
        verify2faBtn.disabled = false;
        verify2faBtn.innerHTML = '<span class="material-symbols-outlined">check_circle</span> Xác nhận kích hoạt';
      }
    });
  });

  const logoInput = document.getElementById('logo-upload-input');
  const previewImg = document.getElementById('logo-preview-img');
  
  if (logoInput && previewImg) {
    logoInput.addEventListener('change', async (e: Event) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;

      try {
        // Hiển thị trạng thái đang upload
        const originalText = document.querySelector('.logo-info .form-label')?.textContent;
        const submitBtn = document.querySelector('.logo-info .btn-upload') as HTMLButtonElement;
        
        if (submitBtn) submitBtn.textContent = 'Đang tải lên...';
        if (submitBtn) submitBtn.disabled = true;

        const formData = new FormData();
        formData.append('file', file);

        // Gọi API upload (Supabase Storage — site media)
        const response = await fetch('/api/site-media/upload', {
          method: 'POST',
          body: formData,
        });

        const result = await response.json();

        if (response.ok && result.success) {
          const publicUrl = result.url;

          // Update preview & all logos immediately
          (previewImg as HTMLImageElement).src = publicUrl;
          document.querySelectorAll('.flysky-global-logo').forEach((img) => {
            (img as HTMLImageElement).src = publicUrl;
          });
          localStorage.setItem('flysky_custom_logo', publicUrl);

          // Persist URL to DB so it survives localStorage clears
          await fetch('/api/settings/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ settings: [{ key: 'flysky_logoUrl', value: publicUrl }] }),
          });

          alert('Upload logo thành công! Logo đã được lưu vĩnh viễn.');
        } else {
          throw new Error(result.error || 'Upload thất bại');
        }
      } catch (error: any) {
        console.error('Lỗi upload:', error);
        alert('Có lỗi xảy ra khi upload: ' + error.message);
      } finally {
        const submitBtn = document.querySelector('.logo-info .btn-upload') as HTMLButtonElement;
        if (submitBtn) submitBtn.textContent = 'Tải lên ảnh mới';
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }

  // ── HERO IMAGE UPLOAD ──
  const heroInput  = document.getElementById('hero-upload-input') as HTMLInputElement;
  const heroMultiInput = document.getElementById('hero-upload-multi-input') as HTMLInputElement;
  const heroPreview = document.getElementById('hero-preview-img') as HTMLImageElement;
  const heroBtn    = document.getElementById('hero-upload-btn') as HTMLButtonElement;
  const heroMultiBtn = document.getElementById('hero-upload-multi-btn') as HTMLButtonElement;
  const heroImagesTextarea = document.getElementById('stg-hero-images') as HTMLTextAreaElement;

  const uploadSiteMedia = async (file: File): Promise<string> => {
    const formData = new FormData();
    formData.append('file', file);
    const res = await fetch('/api/site-media/upload', { method: 'POST', body: formData });
    const result = await res.json();
    if (!res.ok || !result.success) {
      throw new Error(result.error || 'Upload thất bại');
    }
    return result.url as string;
  };

  if (heroInput && heroPreview) {
    heroInput.addEventListener('change', async (e: Event) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;
      heroBtn.textContent = 'Đang tải lên...';
      heroBtn.disabled = true;
      try {
        const url = await uploadSiteMedia(file);
        heroPreview.src = url;
        if (heroImagesTextarea) {
          heroImagesTextarea.value = '';
        }
        await fetch('/api/settings/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            settings: [
              { key: 'flysky_heroImageUrl', value: url },
              { key: 'flysky_heroImages', value: '' }
            ]
          }),
        });

        alert('Upload ảnh Hero thành công! Ảnh đã được lưu vĩnh viễn.');
      } catch (err: any) {
        alert('Lỗi upload ảnh Hero: ' + err.message);
      } finally {
        heroBtn.textContent = 'Tải lên ảnh mới';
        heroBtn.disabled = false;
        heroInput.value = '';
      }
    });
  }

  if (heroMultiInput && heroMultiBtn && heroImagesTextarea && heroPreview) {
    heroMultiInput.addEventListener('change', async (e: Event) => {
      const files = Array.from((e.target as HTMLInputElement).files || []);
      if (!files.length) return;

      heroMultiBtn.textContent = `Đang tải ${files.length} ảnh...`;
      heroMultiBtn.disabled = true;
      heroBtn.disabled = true;

      try {
        const uploadedUrls: string[] = [];
        for (const file of files) {
          const url = await uploadSiteMedia(file);
          uploadedUrls.push(url);
        }

        const currentUrls = heroImagesTextarea.value
          .split(/\r?\n/)
          .map(x => x.trim())
          .filter(Boolean);

        const merged = [...new Set([...currentUrls, ...uploadedUrls])];
        heroImagesTextarea.value = merged.join('\n');
        heroPreview.src = uploadedUrls[0];

        await fetch('/api/settings/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            settings: [
              { key: 'flysky_heroImageUrl', value: uploadedUrls[0] },
              { key: 'flysky_heroImages', value: merged.join('\n') }
            ]
          }),
        });

        alert(`Đã upload ${uploadedUrls.length} ảnh Hero và cập nhật slideshow.`);
      } catch (err: any) {
        alert('Lỗi upload nhiều ảnh Hero: ' + err.message);
      } finally {
        heroMultiBtn.textContent = 'Tải nhiều ảnh';
        heroMultiBtn.disabled = false;
        heroBtn.disabled = false;
        heroMultiInput.value = '';
      }
    });
  }

  // ── PUSH NOTIFICATION LOGIC ──
  if ('serviceWorker' in navigator && 'PushManager' in window) {
    // Register service worker
    navigator.serviceWorker.register('/sw.js')
      .then(registration => {
        console.log('Service Worker registered:', registration);
      })
      .catch(error => {
        console.error('Service Worker registration failed:', error);
      });

    // Handle push notification toggle
    const pushToggle = document.getElementById('push-notification-toggle') as HTMLInputElement;
    
    if (pushToggle) {
      // Check current notification permission and subscription status
      (async () => {
        try {
          const registration = await navigator.serviceWorker.ready;
          const subscription = await registration.pushManager.getSubscription();
          
          if (subscription && Notification.permission === 'granted') {
            pushToggle.checked = true;
          } else {
            pushToggle.checked = false;
          }
        } catch (error) {
          console.error('Error checking push subscription:', error);
        }
      })();

      pushToggle.addEventListener('change', async () => {
        if (pushToggle.checked) {
          // Enable push notifications
          try {
            const permission = await Notification.requestPermission();
            
            if (permission !== 'granted') {
              alert('Bạn cần cho phép thông báo để sử dụng tính năng này.');
              pushToggle.checked = false;
              return;
            }

            // Get VAPID public key
            const keyResponse = await fetch('/api/notifications/vapid-key');
            const keyData = await keyResponse.json();
            
            if (!keyData.publicKey) {
              alert('Không thể lấy VAPID key. Vui lòng liên hệ quản trị viên.');
              pushToggle.checked = false;
              return;
            }

            // Subscribe to push notifications
            const registration = await navigator.serviceWorker.ready;
            const subscription = await registration.pushManager.subscribe({
              userVisibleOnly: true,
              applicationServerKey: urlBase64ToUint8Array(keyData.publicKey) as unknown as Uint8Array<ArrayBuffer>
            });

            // Send subscription to server
            const response = await fetch('/api/notifications/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ subscription: subscription.toJSON() })
            });

            const data = await response.json();
            
            if (data.success) {
              alert('Đã bật thông báo đẩy thành công!');
            } else {
              throw new Error(data.error || 'Không thể lưu subscription');
            }
          } catch (error: any) {
            console.error('Error enabling push notifications:', error);
            alert('Lỗi khi bật thông báo: ' + error.message);
            pushToggle.checked = false;
          }
        } else {
          // Disable push notifications
          try {
            const registration = await navigator.serviceWorker.ready;
            const subscription = await registration.pushManager.getSubscription();
            
            if (subscription) {
              await subscription.unsubscribe();
              
              // Remove subscription from server
              await fetch('/api/notifications/unsubscribe', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ endpoint: subscription.endpoint })
              });
            }
            
            alert('Đã tắt thông báo đẩy.');
          } catch (error: any) {
            console.error('Error disabling push notifications:', error);
            alert('Lỗi khi tắt thông báo: ' + error.message);
          }
        }
      });
    }
  }

  // Daily report email management — initialized from server-side DB values (set by inline script below)
  (window as any)._reportEmails = (window as any)._reportEmails || ['admin@flyskyguitar.com'];

  function renderReportEmailTags() {
    const container = document.getElementById('report-email-tags');
    if (!container) return;
    const emails: string[] = (window as any)._reportEmails || [];
    container.innerHTML = emails.map((email: string) => `
      <span class="ntf-tag" data-email="${email}">
        ${email}
        <button class="ntf-tag-del material-symbols-outlined" onclick="removeReportEmail('${email}')">close</button>
      </span>
    `).join('');
  }

  function addReportEmail() {
    const input = document.getElementById('ntf-add-email-input') as HTMLInputElement;
    if (!input) return;
    const email = input.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      alert('Vui lòng nhập địa chỉ email hợp lệ.');
      return;
    }
    const emails: string[] = (window as any)._reportEmails || [];
    if (emails.includes(email)) {
      alert('Email này đã có trong danh sách.');
      return;
    }
    emails.push(email);
    (window as any)._reportEmails = emails;
    input.value = '';
    renderReportEmailTags();
  }

  function removeReportEmail(email: string) {
    const emails: string[] = (window as any)._reportEmails || [];
    (window as any)._reportEmails = emails.filter((e: string) => e !== email);
    renderReportEmailTags();
  }

  (window as any).addReportEmail = addReportEmail;
  (window as any).removeReportEmail = removeReportEmail;

  // Init email tags on load
  document.addEventListener('DOMContentLoaded', () => {
    renderReportEmailTags();

    // Test push button
    const btnTestPush = document.getElementById('btn-test-push') as HTMLButtonElement;
    btnTestPush?.addEventListener('click', async () => {
      btnTestPush.disabled = true;
      btnTestPush.textContent = 'Đang gửi...';
      try {
        const res = await fetch('/api/notifications/test', { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          alert('✅ Đã gửi push notification test thành công!');
        } else {
          alert('❌ Lỗi: ' + (data.error || 'Không gửi được. Hãy đảm bảo đã bật thông báo đẩy bên trên.'));
        }
      } catch (e: any) {
        alert('❌ Lỗi kết nối: ' + e.message);
      } finally {
        btnTestPush.disabled = false;
        btnTestPush.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">send</span> Gửi test push';
      }
    });
  });

  // Helper function to convert VAPID key
  function urlBase64ToUint8Array(base64String: string): Uint8Array {
    const padding = '='.repeat((4 - base64String.length % 4) % 4);
    const base64 = (base64String + padding)
      .replace(/\-/g, '+')
      .replace(/_/g, '/');

    const rawData = window.atob(base64);
    const outputArray = new Uint8Array(rawData.length);

    for (let i = 0; i < rawData.length; ++i) {
      outputArray[i] = rawData.charCodeAt(i);
    }
    return outputArray;
  }
</script>

