    try {
      const data = await savePaymentProvider('momo', enabled, config);
      if (data.success) {
        btn.innerHTML = '<span class="material-symbols-outlined">check</span> Đã lưu';
        setTimeout(() => {
          btn.disabled = false;
          btn.innerHTML = '<span class="material-symbols-outlined">save</span> Lưu';
        }, 2000);
      } else {
        alert('Lỗi lưu cài đặt MoMo: ' + data.error);
        btn.disabled = false;
        btn.innerHTML = '<span class="material-symbols-outlined">save</span> Lưu';
      }
    } catch (e: any) {
      alert('Lỗi kết nối: ' + e.message);
