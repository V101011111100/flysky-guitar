---
import { supabase } from '../../lib/supabase';
import { SessionManager } from '../../lib/session-manager';
import { getClientIp } from '../../lib/logger';
import { ADMIN_SESSION_COOKIE, getAdminMfaState, isAdminUser, PENDING_MFA_REMEMBER_COOKIE } from '../../lib/security';

const isProduction = import.meta.env.PROD || import.meta.env.NODE_ENV === 'production';
const useSecureCookies = isProduction ? true : Astro.url.protocol === 'https:';
const persistentMaxAge = 30 * 24 * 60 * 60;

const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");
const pendingMfaRememberCookie = Astro.cookies.get(PENDING_MFA_REMEMBER_COOKIE);

let errorMessage = "";
let needsMfa = false;
let mfaRememberMe = false;

function clearAuthCookies() {
  Astro.cookies.delete("sb-access-token", { path: "/" });
  Astro.cookies.delete("sb-refresh-token", { path: "/" });
  Astro.cookies.delete("sb-session-type", { path: "/" });
  Astro.cookies.delete(ADMIN_SESSION_COOKIE, { path: "/" });
  Astro.cookies.delete(PENDING_MFA_REMEMBER_COOKIE, { path: "/" });
}

function setAuthCookies(accessTokenValue: string, refreshTokenValue: string, sessionType: 'persistent' | 'temporary', maxAge?: number) {
  Astro.cookies.set("sb-access-token", accessTokenValue, {
    path: "/",
    httpOnly: true,
    secure: useSecureCookies,
    sameSite: 'lax',
    maxAge,
  });
  Astro.cookies.set("sb-refresh-token", refreshTokenValue, {
    path: "/",
    httpOnly: true,
    secure: useSecureCookies,
    sameSite: 'lax',
    maxAge,
  });
  Astro.cookies.set("sb-session-type", sessionType, {
    path: "/",
    httpOnly: false,
    secure: useSecureCookies,
    sameSite: 'lax',
    maxAge,
  });
}

if (accessToken && refreshToken) {
  const authState = await getAdminMfaState(accessToken.value, refreshToken.value);

  if (authState.authenticated && authState.isAdmin) {
    if (authState.requiresMfa) {
      needsMfa = true;
      mfaRememberMe = pendingMfaRememberCookie?.value === '1';
    } else {
      return Astro.redirect("/admin");
    }
  } else {
    clearAuthCookies();
    if (authState.authenticated && !authState.isAdmin) {
      errorMessage = 'Tài khoản này không có quyền quản trị.';
    }
  }
}

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const email = data.get("email")?.toString();
    const password = data.get("password")?.toString();
    const rememberMe = data.get("remember")?.toString() === "on";

    if (email && password) {
      const { data: authData, error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        errorMessage = error.message;
      } else if (authData.session && authData.user) {
        if (!isAdminUser(authData.user)) {
          clearAuthCookies();
          await supabase.auth.signOut();
          errorMessage = 'Tài khoản này không có quyền quản trị.';
        } else {
          try {
            const { data: mfaData, error: mfaListError } = await supabase.auth.mfa.listFactors();
            if (mfaListError) throw mfaListError;

            const verifiedFactors = mfaData?.totp?.filter((f: any) => f.status === 'verified') || [];
            if (verifiedFactors.length > 0) {
              needsMfa = true;
              mfaRememberMe = rememberMe;

              setAuthCookies(authData.session.access_token, authData.session.refresh_token, 'temporary');
              Astro.cookies.delete(ADMIN_SESSION_COOKIE, { path: "/" });
              Astro.cookies.set(PENDING_MFA_REMEMBER_COOKIE, rememberMe ? '1' : '0', {
                path: "/",
                httpOnly: true,
                secure: useSecureCookies,
                sameSite: 'lax',
              });
            } else {
              setAuthCookies(
                authData.session.access_token,
                authData.session.refresh_token,
                rememberMe ? 'persistent' : 'temporary',
                rememberMe ? persistentMaxAge : undefined,
              );
              Astro.cookies.delete(PENDING_MFA_REMEMBER_COOKIE, { path: "/" });

              if (rememberMe) {
                const userAgent = Astro.request.headers.get("user-agent") || '';
                const clientIP = await getClientIp(Astro.request);
                const deviceInfo = SessionManager.parseUserAgent(userAgent);
                const savedSession = await SessionManager.createSession(authData.user.id, {
                  device_name: deviceInfo.deviceName,
                  device_type: deviceInfo.deviceType,
                  browser: deviceInfo.browser,
                  ip_address: clientIP,
                  location: 'TP. Hồ Chí Minh, VN',
                  user_agent: userAgent,
                  expires_at: new Date(Date.now() + (persistentMaxAge * 1000)).toISOString(),
                });

                if (savedSession?.session_token) {
                  Astro.cookies.set(ADMIN_SESSION_COOKIE, savedSession.session_token, {
                    path: "/",
                    httpOnly: true,
                    secure: useSecureCookies,
                    sameSite: 'lax',
                    maxAge: persistentMaxAge,
                  });
                } else {
                  Astro.cookies.delete(ADMIN_SESSION_COOKIE, { path: "/" });
                }
              } else {
                Astro.cookies.delete(ADMIN_SESSION_COOKIE, { path: "/" });
              }

              return Astro.redirect("/admin");
            }
          } catch (mfaErr) {
            clearAuthCookies();
            await supabase.auth.signOut();
            errorMessage = 'Không thể xác minh trạng thái 2FA. Vui lòng thử lại.';
          }
        }
      } else {
        errorMessage = "Vui lòng nhập Email và Mật khẩu.";
      }
    } else {
      errorMessage = "Vui lòng nhập Email và Mật khẩu.";
    }
  } catch (err) {
    if (err instanceof Error) errorMessage = err.message;
  }
}
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Đăng nhập Quản trị viên | FlySky Guitar</title>
  <link rel="icon" href="/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; font-family: 'Manrope', sans-serif; }

    .login-page {
      min-height: 100vh;
      background: #0c0a07;
      display: grid;
      grid-template-rows: 56px 1fr;
      position: relative;
      overflow: hidden;
    }

    /* Background guitar glow */
    .login-page::before {
      content: '';
      position: absolute;
      left: -200px;
      top: 50%;
      transform: translateY(-50%);
      width: 700px;
      height: 700px;
      background: radial-gradient(ellipse at center, rgba(244,140,37,0.08) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    /* Guitar silhouette bg */
    .guitar-bg {
      position: absolute;
      left: 80px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 380px;
      color: rgba(244,140,37,0.04);
      line-height: 1;
      pointer-events: none;
      z-index: 0;
      user-select: none;
    }

    /* ── Top bar ── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 32px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      position: relative;
      z-index: 10;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }
    .brand img { height: 30px; width: auto; }
    .brand-name { font-size: 16px; font-weight: 800; color: #fff; }
    .topbar-tag {
      font-size: 11px;
      font-weight: 700;
      color: #a08060;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .topbar-tag span { color: #f48c25; }

    /* ── Main area ── */
    .main {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 24px;
      position: relative;
      z-index: 1;
    }

    /* Left branding text — show on large screens */
    .brand-text-area {
      position: absolute;
      left: 60px;
      bottom: 60px;
      max-width: 320px;
      z-index: 2;
    }
    .brand-headline {
      font-size: 38px;
      font-weight: 800;
      line-height: 1.2;
      color: #fff;
      margin-bottom: 16px;
    }
    .brand-headline em { color: #f48c25; font-style: normal; }
    .brand-desc { font-size: 13px; color: #6b5a46; line-height: 1.7; }

    /* ── Form card ── */
    .form-card {
      background: #14100c;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 20px;
      padding: 44px 48px;
      width: 100%;
      max-width: 460px;
      box-shadow: 0 24px 80px rgba(0,0,0,0.5);
      position: relative;
    }

    .form-title {
      font-size: 24px;
      font-weight: 800;
      color: #fff;
      margin-bottom: 6px;
      text-align: center;
    }
    .form-sub {
      font-size: 13px;
      color: #6b5a46;
      text-align: center;
      margin-bottom: 36px;
    }

    /* Fields */
    .field { margin-bottom: 18px; }
    .field-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
    }
    .field-label {
      font-size: 11px;
      font-weight: 700;
      color: #a08060;
      text-transform: uppercase;
      letter-spacing: 0.07em;
    }
    .forgot-link {
      font-size: 12px;
      font-weight: 600;
      color: #f48c25;
      text-decoration: none;
      transition: opacity 0.15s;
    }
    .forgot-link:hover { opacity: 0.8; }

    .input-wrap {
      position: relative;
    }
    .input-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: #6b5a46;
      font-size: 19px;
      pointer-events: none;
    }
    .form-input {
      width: 100%;
      background: #0c0a07;
      border: 1px solid #2a2015;
      border-radius: 10px;
      padding: 13px 16px 13px 44px;
      color: #fff;
      font-size: 14px;
      font-family: 'Manrope', sans-serif;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-input:focus {
      border-color: #f48c25;
      box-shadow: 0 0 0 3px rgba(244,140,37,0.1);
    }
    .form-input::placeholder { color: #4a3a2a; }
    .input-eye {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: #6b5a46;
      font-size: 19px;
      cursor: pointer;
      transition: color 0.15s;
    }
    .input-eye:hover { color: #f48c25; }

    /* Remember me */
    .remember-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 24px;
    }
    .remember-checkbox {
      appearance: none;
      width: 16px;
      height: 16px;
      border: 1px solid #2a2015;
      border-radius: 4px;
      background: #0c0a07;
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
      transition: border-color 0.15s, background 0.15s;
    }
    .remember-checkbox:checked {
      background: #f48c25;
      border-color: #f48c25;
    }
    .remember-checkbox:checked::after {
      content: '';
      position: absolute;
      top: 2px; left: 5px;
      width: 5px; height: 9px;
      border: 2px solid #0c0a07;
      border-top: none; border-left: none;
      transform: rotate(45deg);
    }
    .remember-label {
      font-size: 13px;
      color: #a08060;
      cursor: pointer;
      user-select: none;
    }

    /* Login button */
    .login-btn {
      width: 100%;
      background: #f48c25;
      color: #0c0a07;
      font-weight: 800;
      font-size: 15px;
      padding: 14px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      font-family: 'Manrope', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    }
    .login-btn:hover {
      background: #e07b10;
      box-shadow: 0 0 28px rgba(244,140,37,0.4);
      transform: translateY(-1px);
    }
    .login-btn:active { transform: translateY(0); }
    .login-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    /* Error box */
    .error-box {
      display: none;
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.25);
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 13px;
      color: #f87171;
      text-align: center;
      margin-top: 16px;
    }

    /* Divider */
    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 28px 0 20px;
      color: #2a2015;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #4a3a2a;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #2a2015;
    }

    /* Footer */
    .form-footer {
      margin-top: 32px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
    }
    .social-links {
      display: flex;
      gap: 16px;
    }
    .social-link {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid #2a2015;
      background: #0c0a07;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      transition: all 0.2s;
    }
    .social-link:hover {
      border-color: #f48c25;
      background: rgba(244,140,37,0.1);
    }
    .social-link svg { width: 16px; height: 16px; fill: #a08060; }
    .social-link:hover svg { fill: #f48c25; }
    .copyright { font-size: 11px; color: #4a3a2a; text-align: center; }

    /* Shake animation */
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      20% { transform: translateX(-6px); }
      40% { transform: translateX(6px); }
      60% { transform: translateX(-4px); }
      80% { transform: translateX(4px); }
    }
    .shake { animation: shake 0.4s ease; }

    /* Success state */
    @keyframes spin { to { transform: rotate(360deg); } }
    .btn-spinner { animation: spin 0.7s linear infinite; display: inline-block; }

    @media (max-width: 768px) {
      .brand-text-area { display: none; }
      .form-card { padding: 32px 24px; }
      .brand-headline { font-size: 26px; }
      .guitar-bg { display: none; }
    }
  </style>
</head>
<body>
  <div class="login-page">
    <!-- Background guitar silhouette -->
    <div class="guitar-bg">
      <span class="material-symbols-outlined">acoustic_guitar</span>
    </div>

    <!-- Top navigation bar -->
    <nav class="topbar">
      <a class="brand" href="/">
        <img src="/logo.svg" alt="FlySky Guitar" class="flysky-global-logo" />
        <span class="brand-name">FlySky Guitar</span>
      </a>
      <div class="topbar-tag">
        <span class="material-symbols-outlined" style="font-size:16px;color:#f48c25;">admin_panel_settings</span>
        Hệ thống quản trị
      </div>
    </nav>

    <!-- Main content -->
    <div class="main">
      <!-- Left branding (desktop only) -->
      <div class="brand-text-area">
        <h1 class="brand-headline">Âm thanh tuyệt đỉnh,<br/><em>Quản lý thông minh.</em></h1>
        <p class="brand-desc">Chào mừng quay trở lại với trang quản trị FlySky Guitar. Hãy đăng nhập để bắt đầu phiên làm việc của bạn.</p>
      </div>

      <!-- Login form -->
      <div class="form-card" id="login-card" style={needsMfa ? 'display:none;' : ''}>
        <h2 class="form-title">Đăng nhập Quản trị viên</h2>
        <p class="form-sub">Vui lòng nhập thông tin để truy cập hệ thống.</p>

        <form method="POST" id="login-form">
          <!-- Username (Email) -->
          <div class="field">
            <div class="field-header">
              <label class="field-label" for="email">Tên đăng nhập hoặc Email</label>
            </div>
            <div class="input-wrap">
              <span class="material-symbols-outlined input-icon">person</span>
              <input
                id="email"
                name="email"
                class="form-input"
                type="email"
                placeholder="Nhập tên đăng nhập hoặc email"
                autocomplete="username"
                required
              />
            </div>
          </div>

          <!-- Password -->
          <div class="field">
            <div class="field-header">
              <label class="field-label" for="password">Mật khẩu</label>
              <a href="#" class="forgot-link" onclick="return false;">Quên mật khẩu?</a>
            </div>
            <div class="input-wrap">
              <span class="material-symbols-outlined input-icon">lock</span>
              <input
                id="password"
                name="password"
                class="form-input"
                type="password"
                placeholder="Nhập mật khẩu"
                autocomplete="current-password"
                required
              />
              <span class="material-symbols-outlined input-eye" id="pw-eye" onclick="togglePw()">visibility</span>
            </div>
          </div>

          <!-- Remember me -->
          <div class="remember-wrap">
            <input type="checkbox" id="remember" name="remember" value="on" class="remember-checkbox" />
            <label for="remember" class="remember-label">Ghi nhớ đăng nhập</label>
          </div>

          <!-- Submit -->
          <button class="login-btn" type="submit" id="login-btn">
            <span class="material-symbols-outlined" style="font-size:20px;">login</span>
            Đăng nhập Quản trị viên
          </button>

          {errorMessage && (
            <div class="error-box" style="display: block; animation: shake 0.4s ease;">
              ❌ {errorMessage === 'Invalid login credentials' ? 'Tên đăng nhập hoặc mật khẩu không đúng' : errorMessage}
            </div>
          )}
        </form>

        <!-- Footer -->
        <div class="form-footer">
          <div class="divider">Theo dõi FlySky Guitar</div>
          <div class="social-links">
            <!-- Facebook -->
            <a href="https://facebook.com" target="_blank" class="social-link" title="Facebook">
              <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <!-- Instagram -->
            <a href="https://instagram.com" target="_blank" class="social-link" title="Instagram">
              <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" style="fill:none;stroke:#a08060;stroke-width:2"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" style="stroke:#a08060;stroke-width:2;stroke-linecap:round"/></svg>
            </a>
            <!-- YouTube -->
            <a href="https://youtube.com" target="_blank" class="social-link" title="YouTube">
              <svg viewBox="0 0 24 24"><path d="M22.54 6.42A2.78 2.78 0 0 0 20.58 4.4C18.88 4 12 4 12 4s-6.88 0-8.58.46a2.78 2.78 0 0 0-1.95 2 29 29 0 0 0-.47 5.25 29 29 0 0 0 .47 5.25A2.78 2.78 0 0 0 3.42 19.6C5.12 20 12 20 12 20s6.88 0 8.58-.46a2.78 2.78 0 0 0 1.95-2 29 29 0 0 0 .47-5.25 29 29 0 0 0-.46-5.83z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" style="fill:#a08060"/></svg>
            </a>
          </div>
          <p class="copyright">© 2024 FlySky Guitar Admin Portal. All Rights Reserved.</p>
        </div>
      </div>

      <!-- 2FA Verification form (shown after password auth when MFA is enabled) -->
      <div class="form-card" id="mfa-card" data-remember={mfaRememberMe ? 'true' : 'false'} style={needsMfa ? '' : 'display:none;'}>
        <div style="text-align:center;margin-bottom:24px;">
          <div style="width:64px;height:64px;border-radius:16px;background:rgba(244,140,37,.1);display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;">
            <span class="material-symbols-outlined" style="font-size:32px;color:#f48c25;">verified_user</span>
          </div>
          <h2 class="form-title">Xác thực 2 lớp</h2>
          <p class="form-sub">Nhập mã 6 số từ ứng dụng Authenticator để tiếp tục</p>
        </div>

        <div class="field">
          <div class="field-header">
            <label class="field-label" for="totp-code">Mã xác thực (OTP)</label>
          </div>
          <div class="input-wrap">
            <span class="material-symbols-outlined input-icon">pin</span>
            <input
              id="totp-code"
              class="form-input"
              type="text"
              placeholder="000000"
              maxlength="6"
              autocomplete="one-time-code"
              inputmode="numeric"
              style="letter-spacing:8px;font-size:22px;font-weight:800;text-align:center;padding-left:16px;"
              autofocus
            />
          </div>
        </div>

        <button class="login-btn" type="button" id="verify-mfa-btn" style="margin-top:8px;">
          <span class="material-symbols-outlined" style="font-size:20px;">check_circle</span>
          Xác nhận đăng nhập
        </button>

        <div class="error-box" id="mfa-error" style="display:none;"></div>

        <div style="text-align:center;margin-top:20px;">
          <a href="/admin/login" style="font-size:13px;color:#6b5a46;text-decoration:none;transition:color .15s;" onmouseover="this.style.color='#f48c25'" onmouseout="this.style.color='#6b5a46'">
            <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">arrow_back</span>
            Quay lại đăng nhập
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('login-form')?.addEventListener('submit', function() {
      const btn = document.getElementById('login-btn') as HTMLButtonElement | null;
      if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="material-symbols-outlined btn-spinner" style="font-size:20px;">autorenew</span> Đang xác thực...';
      }
    });
    
    // Custom logo check
    const savedLogo = localStorage.getItem('flysky_custom_logo');
    if (savedLogo) {
      document.querySelectorAll('.flysky-global-logo').forEach((img) => {
        (img as HTMLImageElement).src = savedLogo;
      });
    }



    function togglePw() {
      const pw = document.getElementById('password') as HTMLInputElement | null;
      const eye = document.getElementById('pw-eye');
      if (pw && eye) {
        if (pw.type === 'password') {
          pw.type = 'text';
          eye.textContent = 'visibility_off';
        } else {
          pw.type = 'password';
          eye.textContent = 'visibility';
        }
      }
    }

    (window as any).togglePw = togglePw;

    // ── 2FA Verification on Login ──
    const mfaCard = document.getElementById('mfa-card');
    const totpCodeInput = document.getElementById('totp-code') as HTMLInputElement | null;
    const verifyMfaBtn = document.getElementById('verify-mfa-btn') as HTMLButtonElement | null;
    const mfaError = document.getElementById('mfa-error') as HTMLElement | null;

    // Auto-focus TOTP input if MFA card is visible
    if (mfaCard && mfaCard.style.display !== 'none' && totpCodeInput) {
      setTimeout(() => totpCodeInput.focus(), 100);
    }

    // Only allow digits in TOTP input
    totpCodeInput?.addEventListener('input', () => {
      totpCodeInput.value = totpCodeInput.value.replace(/\D/g, '').slice(0, 6);
    });

    // Submit on Enter key
    totpCodeInput?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        verifyMfaBtn?.click();
      }
    });

    verifyMfaBtn?.addEventListener('click', async () => {
      const code = totpCodeInput?.value?.trim() || '';
      
      if (code.length !== 6 || !/^\d{6}$/.test(code)) {
        if (mfaError) {
          mfaError.textContent = 'Vui lòng nhập đúng mã 6 chữ số.';
          mfaError.style.display = 'block';
        }
        return;
      }

      if (mfaError) mfaError.style.display = 'none';
      verifyMfaBtn.disabled = true;
      verifyMfaBtn.innerHTML = '<span class="material-symbols-outlined btn-spinner" style="font-size:20px;">autorenew</span> Đang xác thực...';

      try {
        // First get MFA factors to find the factorId
        const statusRes = await fetch('/api/admin/mfa/status');
        const statusData = await statusRes.json();
        
        if (!statusData.success || !statusData.factors || statusData.factors.length === 0) {
          // No factors found, just redirect
          window.location.href = '/admin';
          return;
        }

        const factorId = statusData.factors[0].id;

        // Verify the TOTP code
        const verifyRes = await fetch('/api/admin/mfa/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ factorId, code })
        });
        const verifyData = await verifyRes.json();

        if (verifyData.success) {
          verifyMfaBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:20px;">check_circle</span> Thành công! Đang chuyển hướng...';
          window.location.href = '/admin';
        } else {
          if (mfaError) {
            mfaError.textContent = verifyData.error || 'Mã xác thực không đúng. Vui lòng thử lại.';
            mfaError.style.display = 'block';
            mfaError.style.animation = 'shake 0.4s ease';
          }
          if (totpCodeInput) {
            totpCodeInput.value = '';
            totpCodeInput.focus();
          }
          verifyMfaBtn.disabled = false;
          verifyMfaBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:20px;">check_circle</span> Xác nhận đăng nhập';
        }
      } catch (err: any) {
        if (mfaError) {
          mfaError.textContent = 'Lỗi kết nối: ' + (err?.message || 'Không xác định');
          mfaError.style.display = 'block';
        }
        verifyMfaBtn.disabled = false;
        verifyMfaBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:20px;">check_circle</span> Xác nhận đăng nhập';
      }
    });
  </script>
</body>
</html>
