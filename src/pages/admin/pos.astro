---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// Lấy sản phẩm
const { data: products } = await supabase
  .from('products')
  .select('id, name, sku, price, stock_quantity, gallery_images')
  .eq('status', 'active')
  .order('created_at', { ascending: false });

// Lấy danh sách đơn hàng POS (Hóa đơn)
const { data: orders } = await supabase
  .from('orders')
  .select('id, order_number, customer_name, total_amount, created_at, source, status, order_items(quantity, price_at_time, products(name, sku))')
  .eq('source', 'pos')
  .order('created_at', { ascending: false })
  .limit(50);

---

<AdminLayout title="POS" subtitle="Bán hàng tại quầy" activeNav="pos">
  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
      .font-pos-sans { font-family: 'Inter', sans-serif; }
      .font-pos-serif { font-family: 'Playfair Display', serif; }
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--color-border-dark, #4a3a2a); border-radius: 10px; }
      .btn-orange-gradient { background: linear-gradient(135deg, var(--color-accent-orange, #e67e22) 0%, #d35400 100%); }
    </style>
  </Fragment>

  <style is:global>
    .content-scroll:has(.pos-shell) { padding: 0 !important; overflow: hidden !important; }
  </style>

  <!-- Pass data to client -->
  <script define:vars={{ products, orders }}>
    window.posProducts = products || [];
    window.posOrders = orders || [];
  </script>

  <script is:inline>
    document.addEventListener('alpine:init', () => {
      Alpine.data('posApp', () => ({
        activeTab: new URLSearchParams(window.location.search).get('tab') || 'sales',
        reportPeriod: 'today',
        startDate: '',
        endDate: '',
        tabs: [
          { id: 'sales', label: 'Bán hàng', icon: 'storefront' },
          { id: 'invoices', label: 'Hóa đơn', icon: 'receipt_long' },
          { id: 'reports', label: 'Báo cáo', icon: 'bar_chart' }
        ],
        search: '',
        products: window.posProducts,
        orders: window.posOrders,
        orderSearch: '',
        cart: [],
        discountCode: '',
        discountId: null,
        discountAmount: 0,
        shippingFee: 0,
        customerName: '',
        customerPhone: '',
        // In ấn: lưu trữ + modal
        printType: localStorage.getItem('pos_print_type') || 'invoice_a4', // 'invoice_a4' | 'invoice_thermal'
        showPrintModal: false,
        pendingPrintOrderId: null,

        get filteredOrders() {
          if (!this.orderSearch.trim()) return this.orders;
          const q = this.orderSearch.trim().toLowerCase();
          return this.orders.filter(o =>
            (o.order_number || '').toLowerCase().includes(q) ||
            (o.customer_name || '').toLowerCase().includes(q) ||
            (o.customer_phone || '').toLowerCase().includes(q)
          );
        },

        get periodOrders() {
          const now = new Date();
          let startDate = new Date();
          let endDate = new Date();
          
          switch (this.reportPeriod) {
            case 'today':
              startDate.setHours(0, 0, 0, 0);
              endDate = now;
              break;
            case 'week':
              startDate.setDate(now.getDate() - 7);
              endDate = now;
              break;
            case 'month':
              startDate.setMonth(now.getMonth());
              endDate = now;
              break;
            case 'quarter':
              startDate.setMonth(Math.floor(now.getMonth() / 3) * 3);
              endDate = now;
              break;
            case 'year':
              startDate.setMonth(0);
              endDate = now;
              break;
            case 'custom':
              startDate = this.startDate ? new Date(this.startDate) : new Date();
              endDate = this.endDate ? new Date(this.endDate) : new Date();
              break;
            default:
              startDate.setHours(0, 0, 0, 0);
              endDate = now;
              break;
          }
          
          return this.orders.filter(o => {
            const orderDate = new Date(o.created_at);
            return orderDate >= startDate && orderDate <= endDate;
          });
        },

        get periodRevenue() {
          return this.periodOrders.reduce((sum, o) => sum + (o.total_amount || 0), 0);
        },

        get periodOrderCount() {
          return this.periodOrders.length;
        },

        get periodProductsSold() {
          const productMap = {};
          this.periodOrders.forEach(order => {
            if (order.order_items) {
              order.order_items.forEach(item => {
                const productId = item.products?.id || 'unknown';
                productMap[productId] = (productMap[productId] || 0) + (item.quantity || 0);
              });
            }
          });
          return Object.values(productMap).reduce((sum, qty) => sum + qty, 0);
        },

        get periodUniqueProducts() {
          const products = new Set();
          this.periodOrders.forEach(order => {
            if (order.order_items) {
              order.order_items.forEach(item => {
                if (item.products?.id) {
                  products.add(item.products.id);
                }
              });
            }
          });
          return products.size;
        },

        get todayOrders() {
          const today = new Date().toDateString();
          return this.orders.filter(o => new Date(o.created_at).toDateString() === today);
        },

        get todayRevenue() {
          return this.todayOrders.reduce((sum, o) => sum + (o.total_amount || 0), 0);
        },

        get todayCustomersCount() {
          const names = this.todayOrders.map(o => o.customer_name).filter(Boolean);
          return new Set(names).size || this.todayOrders.length; 
        },

        get topProducts() {
          let productMap = {};
          this.periodOrders.forEach(order => {
            if (order.order_items) {
              order.order_items.forEach(item => {
                const productId = item.products?.id || 'unknown';
                const productName = item.products?.name || 'Unknown Product';
                const quantity = item.quantity || 0;
                const revenue = (item.price_at_time || 0) * quantity;
                
                if (!productMap[productId]) {
                  productMap[productId] = {
                    id: productId,
                    name: productName,
                    quantity: 0,
                    revenue: 0,
                    image: null
                  };
                }
                
                productMap[productId].quantity += quantity;
                productMap[productId].revenue += revenue;
              });
            }
          });
          
          // Get product images from the products data
          const productsData = window.posProducts || [];
          productMap = Object.fromEntries(
            Object.entries(productMap).map(([id, data]) => [
              id,
              {
                ...data,
                image: productsData.find(p => p.id === id)?.gallery_images?.[0] || null
              }
            ])
          );
          
          return Object.values(productMap)
            .sort((a, b) => b.revenue - a.revenue)
            .slice(0, 10);
        },

        get hourlySales() {
          const hourlyData = [];
          for (let i = 0; i < 24; i++) {
            const hourOrders = this.periodOrders.filter(order => {
              const orderHour = new Date(order.created_at).getHours();
              return orderHour === i;
            });
            
            const hourRevenue = hourOrders.reduce((sum, order) => sum + (order.total_amount || 0), 0);
            const maxRevenue = Math.max(...this.periodOrders.map(o => o.total_amount || 0));
            
            hourlyData.push({
              hour: i,
              revenue: hourRevenue,
              percentage: maxRevenue > 0 ? (hourRevenue / maxRevenue) * 100 : 0
            });
          }
          return hourlyData;
        },

        get paymentMethods() {
          const methods = {
            'cash': { type: 'cash', label: 'Tiền mặt', count: 0, color: 'text-green-400' },
            'bank': { type: 'bank', label: 'Chuyển khoản', count: 0, color: 'text-blue-400' },
            'card': { type: 'card', label: 'Thẻ tín dụng', count: 0, color: 'text-purple-400' }
          };
          
          this.periodOrders.forEach(order => {
            if (methods[order.payment_method]) {
              methods[order.payment_method].count++;
            }
          });
          
          return Object.values(methods);
        },

        get periodNewCustomers() {
          const customers = new Set();
          this.periodOrders.forEach(order => {
            if (order.customer_name) {
              customers.add(order.customer_name);
            }
          });
          return customers.size;
        },

        get periodReturningCustomers() {
          const customerOrders = {};
          this.periodOrders.forEach(order => {
            if (order.customer_name) {
              if (!customerOrders[order.customer_name]) {
                customerOrders[order.customer_name] = 0;
              }
              customerOrders[order.customer_name]++;
            }
          });
          
          return Object.values(customerOrders).filter(count => count > 1).length;
        },

        get filteredProducts() {
          if (!this.search) return this.products;
          const q = this.search.toLowerCase();
          return this.products.filter(p => (p.name && p.name.toLowerCase().includes(q)) || (p.sku && p.sku.toLowerCase().includes(q)));
        },

        get subtotal() {
          return this.cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
        },

        get total() {
          return Math.max(0, this.subtotal - this.discountAmount + this.shippingFee);
        },

        addToCart(product) {
          if (product.stock_quantity <= 0) return alert('Sản phẩm đã hết hàng!');
          const existing = this.cart.find(i => i.id === product.id);
          if (existing) {
            if (existing.qty < product.stock_quantity) existing.qty++;
            else alert('Vượt quá số lượng trong kho!');
          } else {
            const imgUrl = product.gallery_images && product.gallery_images.length > 0 ? product.gallery_images[0] : null;
            this.cart.push({ ...product, qty: 1, imgUrl });
          }
        },

        updateQty(id, delta) {
          const item = this.cart.find(i => i.id === id);
          if (item) {
            const newQty = item.qty + delta;
            if (newQty <= 0) {
              this.cart = this.cart.filter(i => i.id !== id);
            } else if (newQty > item.stock_quantity) {
              alert('Vượt số lượng tồn kho!');
            } else {
              item.qty = newQty;
            }
          }
        },

        formatCurrency(val) {
          return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(val || 0);
        },

        async applyDiscount() {
          if (!this.discountCode) {
            this.discountAmount = 0;
            this.discountId = null;
            return;
          }
          try {
            const res = await fetch('/api/pos/check-discount', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                code: this.discountCode,
                subtotal: this.subtotal
              })
            });
            const data = await res.json();
            if (res.ok) {
              this.discountId = data.discountId;
              this.discountCode = data.discountCode; // Chuẩn hóa chữ hoa
              this.discountAmount = data.discountAmount;
              alert(data.message);
            } else {
              this.discountAmount = 0;
              this.discountId = null;
              alert('Lỗi: ' + data.error);
            }
          } catch (e) {
            alert('Lỗi khi kiểm tra mã giảm giá!');
            this.discountAmount = 0;
            this.discountId = null;
          }
        },

        async saveDraft() {
          if (this.cart.length === 0) return alert('Giỏ hàng trống!');
          try {
            const res = await fetch('/api/pos/checkout', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                items: this.cart,
                customerName: this.customerName || '', 
                customerPhone: this.customerPhone || '',
                subtotal: this.subtotal,
                discountCode: this.discountAmount > 0 ? this.discountCode : '',
                discountId: this.discountAmount > 0 ? this.discountId : null,
                discountAmount: this.discountAmount,
                shippingFee: this.shippingFee,
                total: this.total,
                status: 'pending'
              })
            });
            const data = await res.json();
            if (res.ok) {
              alert('Đã lưu nháp thành công!');
              this.cart = [];
              this.discountCode = '';
              this.discountId = null;
              this.discountAmount = 0;
              setTimeout(() => {
                window.location.href = '/admin/pos?tab=invoices';
              }, 500);
            } else {
              alert('Lỗi: ' + data.error);
            }
          } catch (err) {
            alert('Lỗi kết nối tới máy chủ!');
          }
        },

        async payDraft(orderId) {
          if (!confirm('Xác nhận thanh toán đơn nháp này?')) return;
          try {
            const res = await fetch('/api/orders/update-status', {
               method: 'POST',
               headers: {'Content-Type': 'application/json'},
               body: JSON.stringify({id: orderId, status: 'completed'})
            });
            if (res.ok) {
               this.pendingPrintOrderId = orderId;
               this.showPrintModal = true;
               // Reload xảy ra sau khi user nhấn In / Bỏ qua trong confirmPrint()
            } else alert('Lỗi thanh toán');
          } catch (e) { alert('Lỗi kết nối') }
        },

        async cancelDraft(orderId) {
          if (!confirm('Bạn chắc chắn muốn hủy hóa đơn nháp này?')) return;
          try {
            const res = await fetch('/api/orders/update-status', {
               method: 'POST',
               headers: {'Content-Type': 'application/json'},
               body: JSON.stringify({id: orderId, status: 'cancelled'})
            });
            if (res.ok) {
               alert('Hủy thành công!');
               location.reload();
            } else alert('Lỗi hủy đơn');
          } catch (e) { alert('Lỗi kết nối') }
        },

        async checkout() {
          if (this.cart.length === 0) return alert('Giỏ hàng trống!');
          try {
            const res = await fetch('/api/pos/checkout', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                items: this.cart,
                customerName: this.customerName || '', 
                customerPhone: this.customerPhone || '',
                subtotal: this.subtotal,
                discountCode: this.discountAmount > 0 ? this.discountCode : '',
                discountId: this.discountAmount > 0 ? this.discountId : null,
                discountAmount: this.discountAmount,
                shippingFee: this.shippingFee,
                total: this.total
              })
            });
            const data = await res.json();
            if (res.ok) {
              this.pendingPrintOrderId = data.orderId;
              this.cart = [];
              this.discountCode = '';
              this.discountId = null;
              this.discountAmount = 0;
              this.customerName = '';
              this.customerPhone = '';
              this.showPrintModal = true;
            } else {
              alert('Lỗi: ' + data.error);
            }
          } catch (err) {
            alert('Lỗi kết nối tới máy chủ!');
          }
        },

        openPrintWindow(orderId, type) {
          const url = type === 'invoice_thermal'
            ? `/admin/pos/thermal?id=${orderId}`
            : `/admin/pos/invoice?id=${orderId}`;
          window.open(url, '_blank');
        },

        confirmPrint() {
          this.openPrintWindow(this.pendingPrintOrderId, this.printType);
          this.showPrintModal = false;
          this.pendingPrintOrderId = null;
          setTimeout(() => location.reload(), 800);
        },

        savePrintDefault(type) {
          this.printType = type;
          localStorage.setItem('pos_print_type', type);
        },

        exportReport(format) {
          try {
            let data, filename, mimeType;
            
            if (format === 'excel') {
              // Excel export data
              data = this.generateExcelData();
              filename = `pos-report-${this.reportPeriod}-${new Date().toISOString().split('T')[0]}.xlsx`;
              mimeType = 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet';
            } else if (format === 'pdf') {
              // PDF export data
              data = this.generatePdfData();
              filename = `pos-report-${this.reportPeriod}-${new Date().toISOString().split('T')[0]}.pdf`;
              mimeType = 'application/pdf';
            } else {
              alert('Định dạng xuất không hợp lệ!');
              return;
            }
            
            // Create blob and download
            const blob = new Blob([data], { type: mimeType });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            
            alert(`Đã xuất báo cáo ${format.toUpperCase()} thành công!`);
          } catch (error) {
            console.error('Export error:', error);
            alert('Lỗi khi xuất báo cáo. Vui lòng thử lại!');
          }
        },

        generateExcelData() {
          const headers = ['STT', 'Mã đơn', 'Khách hàng', 'Sản phẩm', 'Số lượng', 'Thành tiền', 'Phương thức', 'Thời gian'];
          const rows = this.periodOrders.map((order, index) => [
            index + 1,
            order.order_number || '',
            order.customer_name || '',
            order.order_items?.map(item => item.products?.name).join(', ') || '',
            order.order_items?.reduce((sum, item) => sum + (item.quantity || 0), 0) || 0,
            this.formatCurrency(order.total_amount) || '',
            order.payment_method || '',
            new Date(order.created_at).toLocaleString('vi-VN')
          ]);
          
          return [headers, ...rows];
        },

        generatePdfData() {
          // Simple PDF generation (would need a PDF library for production)
          const title = `BÁO CÁO POS - ${this.reportPeriod.toUpperCase()}`;
          const content = `
            BÁO CÁO HỆ THỐNG POS
            Kỳ báo cáo: ${this.reportPeriod}
            Ngày xuất: ${new Date().toLocaleString('vi-VN')}
            
            TỔNG DOANH THU: ${this.formatCurrency(this.periodRevenue)}
            SỐ ĐƠN HÀNG: ${this.periodOrderCount}
            
            CHI TIẾT THEO PHƯƠNG THÁNH TOÁN:
            ${this.paymentMethods().map(m => `- ${m.label}: ${m.count} đơn`).join('\n')}
          `;
          
          // For demo purposes, return as text. In production, use jsPDF or similar
          return content;
        },
      }));
    });
  </script>

  <div class="pos-shell bg-[#221910] text-[#f1f5f9] h-full overflow-hidden font-pos-sans" x-data="posApp()">

    <!-- PRINT TYPE MODAL -->
    <div x-show="showPrintModal" x-transition.opacity class="fixed inset-0 z-[9999] flex items-center justify-center" style="background:rgba(0,0,0,0.7); display:none;">
      <div class="bg-[#2d241e] border border-[#4a3a2a] rounded-2xl p-8 w-[380px] shadow-2xl">
        <h3 class="text-lg font-bold text-white mb-2 flex items-center gap-2">
          <span class="material-symbols-outlined text-[#e67e22]">print</span>
          Chọn loại in hóa đơn
        </h3>
        <p class="text-slate-400 text-sm mb-5">Thanh toán thành công! Chọn loại mẫu in cho đơn hàng này:</p>

        <div class="grid grid-cols-2 gap-3 mb-5">
          <button @click="printType='invoice_a4'"
            :class="printType==='invoice_a4' ? 'border-[#e67e22] bg-[#e67e22]/10 text-white' : 'border-[#3a2a1c] text-slate-400 hover:border-[#e67e22]/50'"
            class="border-2 rounded-xl p-4 flex flex-col items-center gap-2 transition-all">
            <span class="material-symbols-outlined text-3xl" :class="printType==='invoice_a4' ? 'text-[#e67e22]' : ''">receipt_long</span>
            <span class="font-bold text-sm">Hóa đơn A4</span>
            <span class="text-[10px] text-slate-500">Khổ A4 • Phóng to</span>
          </button>
          <button @click="printType='invoice_thermal'"
            :class="printType==='invoice_thermal' ? 'border-[#e67e22] bg-[#e67e22]/10 text-white' : 'border-[#3a2a1c] text-slate-400 hover:border-[#e67e22]/50'"
            class="border-2 rounded-xl p-4 flex flex-col items-center gap-2 transition-all">
            <span class="material-symbols-outlined text-3xl" :class="printType==='invoice_thermal' ? 'text-[#e67e22]' : ''">receipt</span>
            <span class="font-bold text-sm">Phíu nhiệt</span>
            <span class="text-[10px] text-slate-500">Khổ 80mm • Máy in nhiệt</span>
          </button>
        </div>

        <label class="flex items-center gap-2 text-sm text-slate-400 mb-5 cursor-pointer select-none">
          <input type="checkbox" class="accent-[#e67e22] w-4 h-4" @change="savePrintDefault(printType)">
          <span>Ghi nhớ lựa chọn này làm mặc định</span>
        </label>

        <div class="flex gap-3">
          <button @click="confirmPrint()" class="flex-1 bg-gradient-to-r from-[#e67e22] to-[#d35400] text-white font-bold py-3 rounded-lg text-sm flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[18px]">print</span>
            In ngay
          </button>
          <button @click="showPrintModal=false" class="px-4 bg-[#1a1412] border border-[#3a2a1c] text-slate-400 font-semibold py-3 rounded-lg text-sm hover:text-white">
            Bỏ qua
          </button>
        </div>
      </div>
    </div>

    <main class="flex h-full w-full relative flex-col">
      <!-- Top Bar with Tabs -->
      <div class="flex-shrink-0 bg-wood-medium/50 border-b border-stone-800 px-4 py-3 flex items-center justify-between gap-4">
        <!-- Left: Logo & Tabs -->
        <div class="flex items-center gap-6">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-accent-orange flex items-center justify-center text-wood-dark font-bold">
              <span class="material-symbols-outlined text-xl">point_of_sale</span>
            </div>
            <div class="hidden sm:block">
              <div class="text-sm font-bold tracking-widest uppercase text-white">FlySky POS</div>
              <div class="text-[10px] text-gray-400 uppercase">Hệ thống bán hàng</div>
            </div>
          </div>
          
          <!-- Desktop Tabs -->
          <div class="hidden md:flex gap-2">
            <template x-for="tab in tabs" :key="tab.id">
              <button @click="activeTab = tab.id; window.history.replaceState(null, '', '?tab=' + tab.id)"
                :class="activeTab === tab.id ? 'bg-accent-orange text-white shadow-lg' : 'text-gray-400 hover:bg-wood-medium/60 hover:text-white'"
                class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold transition-colors">
                <span class="material-symbols-outlined text-lg" x-text="tab.icon"></span>
                <span x-text="tab.label"></span>
              </button>
            </template>
          </div>
        </div>

        <!-- Right: Back button -->
        <a href="/admin" class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-wood-medium/40 transition-colors text-sm font-semibold">
          <span class="material-symbols-outlined text-lg">arrow_back</span>
          <span class="hidden sm:inline">Quay về</span>
        </a>
      </div>

      <!-- Mobile Tab Dropdown -->
      <div class="md:hidden p-3 bg-wood-medium/30 border-b border-stone-800" x-data="{dropdownOpen: false}">
        <div class="relative">
          <button @click="dropdownOpen = !dropdownOpen"
