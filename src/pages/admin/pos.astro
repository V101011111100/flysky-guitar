                              </template>
                            </div>
                            <span class="text-white font-medium" x-text="product.name"></span>
                          </div>
                        </td>
                        <td class="p-2 text-right font-mono text-white" x-text="product.quantity"></td>
                        <td class="p-2 text-right font-mono text-accent-orange" x-text="formatCurrency(product.revenue)"></td>
                      </tr>
                    </template>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Sales by Hour -->
            <div class="bg-wood-medium/40 p-6 rounded-xl border border-stone-800">
              <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-accent-orange">schedule</span>
                Doanh thu theo giờ
              </h3>
              <div class="space-y-2">
                <template x-for="hour in hourlySales" :key="hour.hour">
                  <div class="flex items-center justify-between p-2 rounded-lg bg-wood-medium/20">
                    <span class="text-sm text-gray-400" x-text="hour.hour + ':00'"></span>
                    <div class="flex items-center gap-2">
                      <div class="w-24 bg-stone-700 rounded-full h-2">
                        <div class="bg-accent-orange h-2 rounded-full transition-all duration-500" :style="`width: ${hour.percentage}%`"></div>
                      </div>
                      <span class="text-sm font-mono text-white" x-text="formatCurrency(hour.revenue)"></span>
                    </div>
                  </div>
                </template>
              </div>
            </div>
          </div>

          <!-- Payment Methods Breakdown -->
          <div class="bg-wood-medium/40 p-6 rounded-xl border border-stone-800 lg:col-span-2">
            <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-accent-orange">payments</span>
              Phương thức thanh toán
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <template x-for="method in paymentMethods" :key="method.type">
                <div class="bg-wood-medium/20 p-4 rounded-lg border border-stone-700 text-center">
                  <div class="text-2xl font-bold mb-2" :class="method.color" x-text="method.count"></div>
                  <div class="text-xs text-gray-400 uppercase tracking-wider" x-text="method.label"></div>
                </div>
              </template>
            </div>
          </div>
        </div>

        <!-- Export Options -->
        <div class="p-6 bg-wood-medium/50 border-t border-stone-800">
          <div class="flex justify-between items-center">
            <div class="flex items-center gap-4">
              <button @click="exportReport('excel')" class="flex items-center gap-2 bg-green-600/80 hover:bg-green-500 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors">
                <span class="material-symbols-outlined">table_chart</span>
                Xuất Excel
              </button>
              <button @click="exportReport('pdf')" class="flex items-center gap-2 bg-red-600/80 hover:bg-red-500 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors">
                <span class="material-symbols-outlined">picture_as_pdf</span>
                Xuất PDF
              </button>
            </div>
            <div class="text-xs text-gray-500">
              Cập nhật lần cuối: <span x-text="new Date().toLocaleString('vi-VN')"></span>
            </div>
          </div>
        </div>
      </section>
      
    </main>
  </div>
</AdminLayout>

