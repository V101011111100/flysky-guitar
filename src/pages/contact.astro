---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase';
import { getAdminMfaState } from '../lib/security';

let isAdmin = false;
const accessToken = Astro.cookies.get('sb-access-token');
const refreshToken = Astro.cookies.get('sb-refresh-token');

if (accessToken && refreshToken) {
  const authState = await getAdminMfaState(accessToken.value, refreshToken.value);
  isAdmin = authState.authenticated && authState.isAdmin && !authState.requiresMfa;
}

const { data: rows } = await supabase.from('site_settings').select('key, value');
const s: Record<string, string> = {};
(rows || []).forEach((r: any) => { s[r.key] = r.value ?? ''; });
const g = (k: string, d: string) => s[k] || d;

const contactTag = g('flysky_contact_page_tag', 'Hỗ trợ 24/7');
const contactTitle = g('flysky_contact_title', 'Kết nối với chúng tôi');
const contactDesc = g('flysky_contact_desc', 'Mọi thắc mắc về sản phẩm, dịch vụ bảo hành hay hợp tác, đừng ngần ngại gửi tin nhắn cho đội ngũ FlySky Guitar. Chúng tôi luôn sẵn sàng lắng nghe.');

const storeTitle = g('flysky_contact_store_title', 'Đến cửa hàng');
const storeDesc = g('flysky_contact_store_desc', 'Mở cửa từ 8:00 đến 21:00 hàng ngày. Trải nghiệm âm thanh thực tế trước khi mua.');
const storeAddress = g('flysky_contact_store_address', '37 Lê Thiện Trị, P. Ngũ Hành Sơn, TP. Đà Nẵng');
const storeMapUrl = g('flysky_contact_store_map_url', 'https://maps.google.com');
const storeCta = g('flysky_contact_store_cta', 'Chỉ đường');
const storeImage = g('flysky_contact_store_image', 'https://images.unsplash.com/photo-1510915361894-db8b60106cb1?auto=format&fit=crop&w=1200&q=80');

const phoneTitle = g('flysky_contact_phone_title', 'Gọi trực tiếp');
const phoneDesc = g('flysky_contact_phone_desc', 'Đội ngũ tư vấn online giải đáp và chốt đơn nhanh chóng.');
const phoneNumber = g('flysky_contact_phone_number', '0987 654 321');
const phoneCta = g('flysky_contact_phone_cta', 'Bấm gọi ngay');

const emailTitle = g('flysky_contact_email_title', 'Gửi Email');
const emailDesc = g('flysky_contact_email_desc', 'Dành cho đối tác cung cấp, sửa chữa số lượng hoặc yêu cầu hợp tác đại lý.');
const emailAddress = g('flysky_contact_email_address', 'hello@flyskyguitar.com');
const emailCta = g('flysky_contact_email_cta', 'Mở ứng dụng thư');

const formTitle = g('flysky_contact_form_title', 'Gửi lời nhắn');
const formDesc = g('flysky_contact_form_desc', 'Vui lòng điền thông tin bên dưới, FlySky sẽ phản hồi chậm nhất trong 2 giờ làm việc.');
const formButton = g('flysky_contact_form_button', 'Gửi tin nhắn');

const subject1 = g('flysky_contact_subject_1', 'Tư vấn mua nhạc cụ');
const subject2 = g('flysky_contact_subject_2', 'Sửa chữa & Bảo hành');
const subject3 = g('flysky_contact_subject_3', 'Hợp tác kinh doanh');
const subject4 = g('flysky_contact_subject_4', 'Vấn đề khác');

const successTitle = g('flysky_contact_success_title', 'Đã gửi tin nhắn!');
const successDesc = g('flysky_contact_success_desc', 'Cảm ơn bạn đã liên hệ. Đội ngũ FlySky Guitar đã nhận được thông tin và sẽ phản hồi qua điện thoại / email sớm nhất.');

const phoneHref = `tel:${phoneNumber.replace(/\D+/g, '') || '0987654321'}`;
const emailHref = `mailto:${emailAddress.trim() || 'hello@flyskyguitar.com'}`;
---

<Layout title="Liên hệ | FlySky Guitar" description="Gửi tin nhắn, đặt lịch hẹn hoặc tìm đường đến cửa hàng FlySky Guitar.">
  <Navbar />

  <!-- Breadcrumb -->
  <div class="bg-background-dark border-b border-border-dark/50">
    <div class="mx-auto max-w-7xl px-4 lg:px-10 py-3 flex items-center gap-2 text-sm text-text-muted">
      <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
      <span class="material-symbols-outlined text-[14px]">chevron_right</span>
      <span class="text-white/60">Liên hệ</span>
    </div>
  </div>

  <section class="py-12 lg:py-20 bg-background-dark min-h-screen">
    <div class="mx-auto max-w-7xl px-4 lg:px-10">
      
      <!-- Page Header -->
      <div class="mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold mb-4 tracking-wider uppercase">
          <span class="material-symbols-outlined text-[16px]">support_agent</span>
          <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_contact_page_tag' : undefined}>{contactTag}</span>
        </div>
        <h1 class={`text-white text-3xl font-extrabold mb-4 ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_title' : undefined}>{contactTitle}</h1>
        <p class={`text-text-muted text-sm max-w-xl ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_desc' : undefined}>{contactDesc}</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        <!-- Contact Info (Left) -->
        <div class="lg:col-span-1 flex flex-col gap-6">
          <div class="bg-card-dark border border-border-dark rounded-2xl p-6 group hover:border-primary/50 transition-colors">
            <div class={`mb-4 rounded-xl overflow-hidden border border-border-dark/70 relative ${isAdmin ? 'quick-image-editable' : ''}`} data-image-setting={isAdmin ? 'flysky_contact_store_image' : undefined}>
              <img src={storeImage} alt="Hình cửa hàng FlySky" class="w-full h-32 object-cover" />
              {isAdmin && (
                <div class="quick-image-overlay">
                  <span class="material-symbols-outlined text-[18px]">upload</span>
                  Kéo ảnh vào hoặc bấm để đổi
                </div>
              )}
            </div>
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4 text-primary">
              <span class="material-symbols-outlined">location_on</span>
            </div>
            <h3 class={`text-white font-bold text-lg mb-2 ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_store_title' : undefined}>{storeTitle}</h3>
            <p class="text-text-muted text-sm leading-relaxed mb-4">
              <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_contact_store_desc' : undefined}>{storeDesc}</span><br/><br/>
              <span class={`text-white/90 ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_store_address' : undefined}>{storeAddress}</span>
            </p>
            <a href={storeMapUrl} target="_blank" class="text-primary font-bold text-sm flex items-center gap-1 hover:underline">
              <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_contact_store_cta' : undefined}>{storeCta}</span> <span class="material-symbols-outlined text-sm">open_in_new</span>
            </a>
          </div>

          <div class="bg-card-dark border border-border-dark rounded-2xl p-6 group hover:border-primary/50 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4 text-primary">
              <span class="material-symbols-outlined">call</span>
            </div>
            <h3 class={`text-white font-bold text-lg mb-2 ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_phone_title' : undefined}>{phoneTitle}</h3>
            <p class="text-text-muted text-sm leading-relaxed mb-4">
              <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_contact_phone_desc' : undefined}>{phoneDesc}</span><br/><br/>
              Hotline: <strong class={`text-white ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_phone_number' : undefined}>{phoneNumber}</strong>
            </p>
            <a href={phoneHref} class="text-primary font-bold text-sm flex items-center gap-1 hover:underline">
              <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_contact_phone_cta' : undefined}>{phoneCta}</span> <span class="material-symbols-outlined text-sm">phone_forwarded</span>
            </a>
          </div>

          <div class="bg-card-dark border border-border-dark rounded-2xl p-6 group hover:border-primary/50 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4 text-primary">
              <span class="material-symbols-outlined">mail</span>
            </div>
            <h3 class={`text-white font-bold text-lg mb-2 ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_email_title' : undefined}>{emailTitle}</h3>
            <p class="text-text-muted text-sm leading-relaxed mb-4">
              <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_contact_email_desc' : undefined}>{emailDesc}</span><br/><br/>
              Email: <strong class={`text-white ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_email_address' : undefined}>{emailAddress}</strong>
            </p>
            <a href={emailHref} class="text-primary font-bold text-sm flex items-center gap-1 hover:underline">
              <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_contact_email_cta' : undefined}>{emailCta}</span> <span class="material-symbols-outlined text-sm">send</span>
            </a>
          </div>
        </div>

        <!-- Contact Form (Right) -->
        <div class="lg:col-span-2">
          <div class="bg-card-dark border border-border-dark rounded-3xl p-8 lg:p-10 relative overflow-hidden h-full">
            <div class="absolute -top-32 -right-32 w-64 h-64 bg-primary/10 blur-[80px] rounded-full pointer-events-none"></div>
            
            <h2 class={`text-white text-2xl font-bold mb-2 relative ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_form_title' : undefined}>{formTitle}</h2>
            <p class={`text-text-muted text-sm mb-8 relative ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_form_desc' : undefined}>{formDesc}</p>

            <form id="contact-form" class="flex flex-col gap-6 relative" novalidate>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-semibold text-white/80 mb-2" for="name">Họ và tên *</label>
                  <input
                    id="name"
                    name="name"
                    type="text"
                    required
                    placeholder="Nguyễn Văn A"
                    class="w-full bg-background-dark border border-border-dark rounded-xl px-4 py-3.5 text-white placeholder-text-muted text-sm focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-white/80 mb-2" for="phone">Số điện thoại *</label>
                  <input
                    id="phone"
                    name="phone"
                    type="tel"
                    required
                    placeholder="0901 234 567"
                    class="w-full bg-background-dark border border-border-dark rounded-xl px-4 py-3.5 text-white placeholder-text-muted text-sm focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-white/80 mb-2" for="email">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="email@example.com"
                  class="w-full bg-background-dark border border-border-dark rounded-xl px-4 py-3.5 text-white placeholder-text-muted text-sm focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold text-white/80 mb-2" for="subject">Chủ đề</label>
                <select 
                  id="subject" 
                  name="subject"
                  class="w-full bg-background-dark border border-border-dark rounded-xl px-4 py-3.5 text-white text-sm focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all appearance-none"
                >
                  <option value="tu-van">{subject1}</option>
                  <option value="bao-hanh">{subject2}</option>
                  <option value="hop-tac">{subject3}</option>
                  <option value="khac">{subject4}</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold text-white/80 mb-2" for="message">Nội dung chi tiết *</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  placeholder="Nhập nội dung bạn cần hỗ trợ ở đây..."
                  class="w-full bg-background-dark border border-border-dark rounded-xl px-4 py-3.5 text-white placeholder-text-muted text-sm focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all resize-none"
                ></textarea>
              </div>

              <div class="mt-2">
                <button
                  id="btn-send-message"
                  type="button"
                  class="bg-primary hover:bg-primary/90 text-background-dark font-extrabold py-4 px-8 rounded-xl transition-all duration-200 hover:shadow-[0_0_20px_rgba(244,140,37,0.4)] flex items-center justify-center gap-2 group w-full sm:w-auto"
                >
                  <span class={isAdmin ? 'quick-editable' : ''} data-setting-key={isAdmin ? 'flysky_contact_form_button' : undefined}>{formButton}</span>
                  <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">send</span>
                </button>
              </div>
            </form>
            
            <div id="contact-success" class="hidden absolute inset-0 bg-card-dark z-20 flex-col items-center justify-center text-center p-8">
              <div class="w-20 h-20 bg-green-500/10 rounded-full flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-green-500 text-5xl">check_circle</span>
              </div>
              <h2 class={`text-white text-2xl font-bold mb-3 ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_success_title' : undefined}>{successTitle}</h2>
              <p class={`text-text-muted text-sm mb-8 max-w-md ${isAdmin ? 'quick-editable' : ''}`} data-setting-key={isAdmin ? 'flysky_contact_success_desc' : undefined}>{successDesc}</p>
              <button onclick="window.location.reload()" class="bg-border-dark hover:bg-border-dark/80 text-white font-bold py-3 px-8 rounded-xl transition-all">Gửi thư khác</button>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />

  {isAdmin && (
    <>
      <div id="contact-quick-edit-toolbar" class="public-quick-toolbar">
        <button id="toggle-contact-edit" type="button" class="public-quick-btn">
          <span class="material-symbols-outlined">edit_square</span>
          <span id="contact-edit-label">Chỉnh sửa nhanh trang liên hệ</span>
        </button>
        <span id="contact-edit-status" class="public-quick-status hidden">Đã lưu</span>
      </div>

      <script is:inline>
        const contactToggleBtn = document.getElementById('toggle-contact-edit');
        const contactEditLabel = document.getElementById('contact-edit-label');
        const contactEditStatus = document.getElementById('contact-edit-status');
        let contactEditMode = false;

        function flashContactSaved(message = 'Đã lưu') {
          if (!contactEditStatus) return;
          contactEditStatus.textContent = message;
          contactEditStatus.classList.remove('hidden');
          setTimeout(() => contactEditStatus.classList.add('hidden'), 1800);
        }

        async function saveContactSetting(key, value) {
          let res = await fetch('/api/settings/quick-update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ key, value }),
          });

          if (res.status === 404) {
            res = await fetch('/api/settings/update', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
              body: JSON.stringify({ settings: [{ key, value }] }),
            });
          }

          const data = await res.json().catch(() => ({}));
          if (!res.ok || !data.success) {
            throw new Error(data.error || 'Không thể lưu thay đổi');
          }
        }

        async function uploadAndSaveContactImage(file, key, el) {
          const form = new FormData();
          form.append('file', file);

          const uploadRes = await fetch('/api/site-media/upload', {
            method: 'POST',
            body: form,
          });
          const uploadData = await uploadRes.json().catch(() => ({}));
          if (!uploadRes.ok || !uploadData.url) {
            throw new Error(uploadData.error || 'Upload thất bại');
          }

          await saveContactSetting(key, uploadData.url);
          const img = el.querySelector('img');
          if (img) img.src = uploadData.url;
          flashContactSaved('Đã cập nhật ảnh');
        }

        async function handleContactImageFile(file, el) {
          const key = el.dataset.imageSetting;
          if (!key || !file) return;
          el.classList.add('quick-saving');
          try {
            await uploadAndSaveContactImage(file, key, el);
          } catch (error) {
            alert(error.message || 'Không thể cập nhật ảnh');
          } finally {
            el.classList.remove('quick-saving');
          }
        }

        async function handleContactTextSave(event) {
          const el = event.target;
          const key = el.dataset.settingKey;
          const nextValue = (el.textContent || '').trim();
          const prevValue = el.dataset.originalValue || '';
          if (!key || !nextValue || nextValue === prevValue) return;

          el.classList.add('quick-saving');
          try {
            await saveContactSetting(key, nextValue);
            el.dataset.originalValue = nextValue;
            flashContactSaved();
          } catch (error) {
            el.textContent = prevValue;
            alert(error.message || 'Không thể lưu thay đổi');
          } finally {
            el.classList.remove('quick-saving');
          }
        }

        function enableContactTextEditing() {
          document.querySelectorAll('[data-setting-key]').forEach((node) => {
            const el = node;
            el.contentEditable = 'true';
            el.dataset.originalValue = el.textContent || '';
            el.classList.add('quick-edit-active');
            el.addEventListener('blur', handleContactTextSave);
          });
        }

        function disableContactTextEditing() {
          document.querySelectorAll('[data-setting-key]').forEach((node) => {
            const el = node;
            el.contentEditable = 'false';
            el.classList.remove('quick-edit-active');
            el.removeEventListener('blur', handleContactTextSave);
          });
        }

        function bindContactImageEditors() {
          document.querySelectorAll('[data-image-setting]').forEach((node) => {
            const el = node;
            const openPicker = () => {
              if (!contactEditMode) return;
              const input = document.createElement('input');
              input.type = 'file';
              input.accept = 'image/png,image/jpeg,image/jpg,image/webp,image/gif';
              input.addEventListener('change', () => {
                const file = input.files?.[0];
                if (file) handleContactImageFile(file, el);
              });
              input.click();
            };

            el.addEventListener('click', (ev) => {
              if (!contactEditMode) return;
              ev.preventDefault();
              ev.stopPropagation();
              openPicker();
            });

            el.addEventListener('dragover', (ev) => {
              if (!contactEditMode) return;
              ev.preventDefault();
              el.classList.add('quick-drag-over');
            });

            el.addEventListener('dragleave', () => el.classList.remove('quick-drag-over'));
            el.addEventListener('drop', (ev) => {
              if (!contactEditMode) return;
              ev.preventDefault();
              ev.stopPropagation();
              el.classList.remove('quick-drag-over');
              const file = ev.dataTransfer?.files?.[0];
              if (file) handleContactImageFile(file, el);
            });
          });
        }

        contactToggleBtn?.addEventListener('click', () => {
          contactEditMode = !contactEditMode;
          document.body.classList.toggle('public-edit-mode', contactEditMode);
          if (contactEditLabel) {
            contactEditLabel.textContent = contactEditMode ? 'Thoát chỉnh sửa nhanh' : 'Chỉnh sửa nhanh trang liên hệ';
          }
          if (contactEditMode) {
            enableContactTextEditing();
          } else {
            disableContactTextEditing();
          }
        });

        bindContactImageEditors();
      </script>

      <style>
        .public-quick-toolbar {
          position: fixed;
          right: 73px;
          bottom: 20px;
          z-index: 120;
          display: flex;
          align-items: center;
          gap: 10px;
        }
        .public-quick-btn {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          border: 1px solid rgba(244, 140, 37, 0.35);
          background: rgba(16, 13, 8, 0.92);
          color: #fff;
          border-radius: 999px;
          padding: 12px 16px;
          font: inherit;
          font-weight: 700;
          cursor: pointer;
          box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
        }
        .public-quick-status {
          border-radius: 999px;
          padding: 10px 12px;
          background: rgba(22, 101, 52, 0.92);
          color: #86efac;
          font-size: 12px;
          font-weight: 700;
        }
        .public-quick-status.hidden {
          display: none;
        }
        .quick-edit-active {
          outline: 2px dashed rgba(244, 140, 37, 0.95);
          outline-offset: 6px;
          border-radius: 8px;
          cursor: text;
        }
        .quick-image-editable {
          cursor: pointer;
        }
        .quick-image-overlay {
          position: absolute;
          inset: auto 8px 8px 8px;
          display: none;
          align-items: center;
          justify-content: center;
          gap: 8px;
          padding: 8px 10px;
          border-radius: 10px;
          background: rgba(12, 10, 7, 0.88);
          color: #fff;
          font-size: 12px;
          font-weight: 700;
          z-index: 3;
        }
        .public-edit-mode .quick-image-editable {
          outline: 2px dashed rgba(244, 140, 37, 0.95);
          outline-offset: 4px;
        }
        .public-edit-mode .quick-image-editable .quick-image-overlay {
          display: inline-flex;
        }
        .quick-drag-over {
          outline: 2px solid #f48c25 !important;
          box-shadow: 0 0 0 6px rgba(244, 140, 37, 0.15);
        }
        .quick-saving {
          opacity: 0.65;
          pointer-events: none;
        }
      </style>
    </>
  )}
</Layout>

<script>
  // Simple form validation and success message logic
  document.getElementById('btn-send-message')?.addEventListener('click', () => {
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('phone') as HTMLInputElement).value.trim();
    const msg = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

    if (!name || !phone || !msg) {
      [document.getElementById('name'), document.getElementById('phone'), document.getElementById('message')].forEach(el => {
        if (el && !(el as HTMLInputElement|HTMLTextAreaElement).value.trim()) {
           el.classList.add('ring-2', 'ring-red-500', 'border-red-500');
           setTimeout(() => el.classList.remove('ring-2', 'ring-red-500', 'border-red-500'), 2000);
        }
      });
      return;
    }

    // In a real app, send data to Supabase here
    // For now just show success UI
    const form = document.getElementById('contact-form');
    const success = document.getElementById('contact-success');
    
    if (form && success) {
      success.classList.remove('hidden');
      success.classList.add('flex');
    }
  });
</script>
