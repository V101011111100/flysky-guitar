---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import FeaturedCollections from '../components/FeaturedCollections.astro';
import BestSellers from '../components/BestSellers.astro';
import BrandStory from '../components/BrandStory.astro';
import Footer from '../components/Footer.astro';
import { getAdminMfaState } from '../lib/security';

let isAdmin = false;
const accessToken = Astro.cookies.get('sb-access-token');
const refreshToken = Astro.cookies.get('sb-refresh-token');

if (accessToken && refreshToken) {
  const authState = await getAdminMfaState(accessToken.value, refreshToken.value);
  isAdmin = authState.authenticated && authState.isAdmin && !authState.requiresMfa;
}
---

<Layout>
  <Navbar />
  <Hero isAdmin={isAdmin} />
  <FeaturedCollections isAdmin={isAdmin} />
  <BestSellers />
  <BrandStory isAdmin={isAdmin} />
  <Footer />

  {isAdmin && (
    <>
      <div id="public-quick-edit-toolbar" class="public-quick-toolbar">
        <button id="toggle-public-edit" type="button" class="public-quick-btn">
          <span class="material-symbols-outlined">edit_square</span>
          <span id="public-edit-label">Chỉnh sửa nhanh trang chủ</span>
        </button>
        <span id="public-edit-status" class="public-quick-status hidden">Đã lưu</span>
      </div>

      <script is:inline>
        const toggleBtn = document.getElementById('toggle-public-edit');
        const editLabel = document.getElementById('public-edit-label');
        const editStatus = document.getElementById('public-edit-status');
        let editMode = false;

        function flashSaved(message = 'Đã lưu') {
          if (!editStatus) return;
          editStatus.textContent = message;
          editStatus.classList.remove('hidden');
          setTimeout(() => editStatus.classList.add('hidden'), 1800);
        }

        async function saveSetting(key, value) {
          let res = await fetch('/api/settings/quick-update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ key, value }),
          });

          // Fallback for environments still running an older build without the quick-update route.
          if (res.status === 404) {
            res = await fetch('/api/settings/update', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
              body: JSON.stringify({ settings: [{ key, value }] }),
            });
          }

          const data = await res.json().catch(() => ({}));
          if (!res.ok || !data.success) {
            throw new Error(data.error || 'Không thể lưu thay đổi');
          }
          return data;
        }

        async function uploadAndSaveImage(file, key, el) {
          const form = new FormData();
          form.append('file', file);

          const uploadRes = await fetch('/api/site-media/upload', {
            method: 'POST',
            body: form,
          });
          const uploadData = await uploadRes.json().catch(() => ({}));
          if (!uploadRes.ok || !uploadData.url) {
            throw new Error(uploadData.error || 'Upload thất bại');
          }

          await saveSetting(key, uploadData.url);

          if (el.tagName === 'IMG') {
            el.src = uploadData.url;
          } else {
            el.style.backgroundImage = `url('${uploadData.url}')`;
          }
          flashSaved('Đã cập nhật ảnh');
        }

        async function handleImageFile(file, el) {
          const key = el.dataset.imageSetting;
          if (!key || !file) return;
          el.classList.add('quick-saving');
          try {
            await uploadAndSaveImage(file, key, el);
          } catch (error) {
            alert(error.message || 'Không thể cập nhật ảnh');
          } finally {
            el.classList.remove('quick-saving');
          }
        }

        function enableTextEditing() {
          document.querySelectorAll('[data-setting-key]').forEach((node) => {
            const el = node;
            el.contentEditable = 'true';
            el.dataset.originalValue = el.textContent || '';
            el.classList.add('quick-edit-active');
            el.addEventListener('blur', handleTextSave);
          });
        }

        function disableTextEditing() {
          document.querySelectorAll('[data-setting-key]').forEach((node) => {
            const el = node;
            el.contentEditable = 'false';
            el.classList.remove('quick-edit-active');
            el.removeEventListener('blur', handleTextSave);
          });
        }

        async function handleTextSave(event) {
          const el = event.target;
          const key = el.dataset.settingKey;
          const nextValue = (el.textContent || '').trim();
          const prevValue = el.dataset.originalValue || '';
          if (!key || !nextValue || nextValue === prevValue) return;

          el.classList.add('quick-saving');
          try {
            await saveSetting(key, nextValue);
            el.dataset.originalValue = nextValue;
            flashSaved();
          } catch (error) {
            el.textContent = prevValue;
            alert(error.message || 'Không thể lưu thay đổi');
          } finally {
            el.classList.remove('quick-saving');
          }
        }

        function bindImageEditors() {
          document.querySelectorAll('[data-image-setting]').forEach((node) => {
            const el = node;
            const openPicker = () => {
              if (!editMode) return;
              const input = document.createElement('input');
              input.type = 'file';
              input.accept = 'image/png,image/jpeg,image/jpg,image/webp,image/gif';
              input.addEventListener('change', () => {
                const file = input.files?.[0];
                if (file) handleImageFile(file, el);
              });
              input.click();
            };

            el.addEventListener('click', (ev) => {
              if (!editMode) return;
              ev.preventDefault();
              ev.stopPropagation();
              openPicker();
            });

            el.addEventListener('dragover', (ev) => {
              if (!editMode) return;
              ev.preventDefault();
              el.classList.add('quick-drag-over');
            });

            el.addEventListener('dragleave', () => el.classList.remove('quick-drag-over'));
            el.addEventListener('drop', (ev) => {
              if (!editMode) return;
              ev.preventDefault();
              ev.stopPropagation();
              el.classList.remove('quick-drag-over');
              const file = ev.dataTransfer?.files?.[0];
              if (file) handleImageFile(file, el);
            });
          });
        }

        toggleBtn?.addEventListener('click', () => {
          editMode = !editMode;
          document.body.classList.toggle('public-edit-mode', editMode);
          if (editLabel) {
            editLabel.textContent = editMode ? 'Thoát chỉnh sửa nhanh' : 'Chỉnh sửa nhanh trang chủ';
          }
          if (editMode) {
            enableTextEditing();
          } else {
            disableTextEditing();
          }
        });

        bindImageEditors();
      </script>

      <style>
        .public-quick-toolbar {
          position: fixed;
          right: 73px;
          bottom: 20px;
          z-index: 120;
          display: flex;
          align-items: center;
          gap: 10px;
        }
        @media (min-width: 768px) {
          .public-quick-toolbar {
            right: 73px;
          }
        }
        .public-quick-btn {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          border: 1px solid rgba(244, 140, 37, 0.35);
          background: rgba(16, 13, 8, 0.92);
          color: #fff;
          border-radius: 999px;
          padding: 12px 16px;
          font: inherit;
          font-weight: 700;
          cursor: pointer;
          box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
        }
        .public-quick-status {
          border-radius: 999px;
          padding: 10px 12px;
          background: rgba(22, 101, 52, 0.92);
          color: #86efac;
          font-size: 12px;
          font-weight: 700;
        }
        .public-quick-status.hidden {
          display: none;
        }
        .quick-edit-active {
          outline: 2px dashed rgba(244, 140, 37, 0.95);
          outline-offset: 6px;
          border-radius: 8px;
          cursor: text;
        }
        .quick-image-editable {
          cursor: pointer;
        }
        .quick-image-overlay {
          position: absolute;
          inset: auto 12px 12px 12px;
          display: none;
          align-items: center;
          justify-content: center;
          gap: 8px;
          padding: 10px 12px;
          border-radius: 12px;
          background: rgba(12, 10, 7, 0.88);
          color: #fff;
          font-size: 12px;
          font-weight: 700;
          z-index: 3;
        }
        .public-edit-mode .quick-image-editable {
          outline: 2px dashed rgba(244, 140, 37, 0.95);
          outline-offset: 4px;
        }
        .public-edit-mode .quick-image-editable .quick-image-overlay {
          display: inline-flex;
        }
        .quick-drag-over {
          outline: 2px solid #f48c25 !important;
          box-shadow: 0 0 0 6px rgba(244, 140, 37, 0.15);
        }
        .quick-saving {
          opacity: 0.6;
          transition: opacity 0.15s ease;
        }
      </style>
    </>
  )}
</Layout>
