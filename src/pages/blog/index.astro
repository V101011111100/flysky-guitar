---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

// Dummy blog posts for UI mockup. In a real app, fetch from Supabase.
const posts = [
  {
    id: 1,
    title: "Hướng dẫn chọn mua Guitar Acoustic cho người mới bắt đầu",
    excerpt: "Bạn đang băn khoăn không biết nên chọn dáng đàn D hay OM? Mặt gỗ Sitka hay tuyết tùng? Bài viết này sẽ giải đáp mọi thắc mắc của bạn.",
    category: "Kiến thức",
    date: "10/05/2026",
    image: "https://images.unsplash.com/photo-1510915228340-29c85a43dcfe?q=80&w=2070&auto=format&fit=crop"
  },
  {
    id: 2,
    title: "Vệ sinh và bảo dưỡng đàn Guitar điện: Bao lâu 1 lần?",
    excerpt: "Dây đàn gỉ sét, phím xỉn màu có thể làm hỏng cảm giác chơi của bạn. Hãy học cách tự bảo dưỡng đàn cơ bản tại nhà qua các bước sau.",
    category: "Bảo dưỡng",
    date: "08/05/2026",
    image: "https://images.unsplash.com/photo-1598514982205-f36b96d1e8d4?q=80&w=2070&auto=format&fit=crop"
  },
  {
    id: 3,
    title: "Khám phá bí mật gỗ Mahogany: Tại sao đây là tiêu chuẩn vàng?",
    excerpt: "Gỗ Mahogany (Gỗ gụ) luôn được các nghệ nhân làm đàn yêu thích nhờ dải âm trung dày và trầm ấm. Cùng tìm hiểu chi tiết về loại gỗ này.",
    category: "Review",
    date: "05/05/2026",
    image: "https://images.unsplash.com/photo-1555694851-419b674828b8?q=80&w=2070&auto=format&fit=crop"
  },
  {
    id: 4,
    title: "Top 5 phơ bàn (Multi-Effects) đáng mua nhất tầm giá 5 triệu",
    excerpt: "Chơi show nhỏ hay tập ở phòng trọ? Những cục phơ nhỏ gọn nhưng đầy đủ tính năng này sẽ không làm bạn thất vọng.",
    category: "Thiết bị",
    date: "01/05/2026",
    image: "https://images.unsplash.com/photo-1516057747705-d01732d8479e?q=80&w=2070&auto=format&fit=crop"
  }
];
---

<Layout title="Blog | FlySky Guitar" description="Chia sẻ kiến thức, hướng dẫn chọn đàn và các tin tức về âm nhạc từ chuyên gia.">
  <Navbar />

  <!-- Breadcrumb -->
  <div class="bg-background-dark border-b border-border-dark/50">
    <div class="mx-auto max-w-7xl px-4 lg:px-10 py-3 flex items-center gap-2 text-sm text-text-muted">
      <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
      <span class="material-symbols-outlined text-[14px]">chevron_right</span>
      <span class="text-white/60">Góc kiến thức</span>
    </div>
  </div>

  <section class="py-12 lg:py-20 bg-background-dark min-h-screen">
    <div class="mx-auto max-w-7xl px-4 lg:px-10">

      <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold mb-4 tracking-wider uppercase">
            <span class="material-symbols-outlined text-[16px]">menu_book</span>
            Góc Kiến Thức
          </div>
          <h1 class="text-white text-3xl font-extrabold mb-4">Blog & Chia sẻ</h1>
          <p class="text-text-muted text-sm max-w-xl">Nơi cập nhật tin tức mi nhất, bài viết đánh giá chuyên sâu và hướng dẫn bảo dưỡng nhạc cụ từ các chuyên gia tại FlySky Guitar.</p>
        </div>

        <div class="flex items-center gap-3 overflow-x-auto pb-2 -mx-4 px-4 md:mx-0 md:px-0 md:pb-0 scrollbar-hide">
          <button class="bg-primary text-background-dark text-xs font-bold px-4 py-2 rounded-lg whitespace-nowrap">Tất cả</button>
          <button class="bg-card-dark hover:bg-border-dark text-white border border-border-dark text-xs font-semibold px-4 py-2 rounded-lg transition-colors whitespace-nowrap">Kiến thức</button>
          <button class="bg-card-dark hover:bg-border-dark text-white border border-border-dark text-xs font-semibold px-4 py-2 rounded-lg transition-colors whitespace-nowrap">Bảo dưỡng</button>
          <button class="bg-card-dark hover:bg-border-dark text-white border border-border-dark text-xs font-semibold px-4 py-2 rounded-lg transition-colors whitespace-nowrap">Review</button>
        </div>
      </div>

      <!-- Featured / Latest Post (The first one) -->
      <div class="mb-12">
        <a href="#" class="group block relative rounded-3xl overflow-hidden border border-border-dark/60 aspect-[2/1] md:aspect-[3/1] bg-card-dark">
          <img src={posts[0].image} alt={posts[0].title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 opacity-60" />
          <div class="absolute inset-0 bg-gradient-to-t from-background-dark via-background-dark/80 to-transparent"></div>
          
          <div class="absolute bottom-0 left-0 p-6 md:p-10 w-full md:w-2/3">
             <div class="flex items-center gap-3 mb-4">
              <span class="bg-primary/20 text-primary text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider">{posts[0].category}</span>
              <span class="text-text-muted text-xs flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                {posts[0].date}
              </span>
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-3 group-hover:text-primary transition-colors">{posts[0].title}</h2>
            <p class="text-text-muted text-sm line-clamp-2 md:line-clamp-3 mb-6">{posts[0].excerpt}</p>
            <span class="inline-flex items-center gap-1 text-primary text-sm font-bold">
              Đọc tiếp <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </span>
          </div>
        </a>
      </div>

      <!-- Other Posts Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.slice(1).map(post => (
          <a href="#" class="group flex flex-col bg-card-dark rounded-2xl border border-border-dark overflow-hidden hover:border-primary/50 transition-colors h-full">
            <div class="aspect-[16/10] overflow-hidden relative">
              <img src={post.image} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute top-4 left-4 bg-background-dark/80 backdrop-blur-sm border border-border-dark text-white text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider">
                {post.category}
              </div>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <span class="text-text-muted text-[11px] mb-3 flex items-center gap-1">
                <span class="material-symbols-outlined text-[12px]">calendar_today</span>
                {post.date}
              </span>
              <h3 class="text-lg font-bold text-white mb-2 line-clamp-2 group-hover:text-primary transition-colors">{post.title}</h3>
              <p class="text-text-muted text-xs line-clamp-3 mb-4 flex-1">{post.excerpt}</p>
              <div class="mt-auto flex justify-end">
                 <span class="material-symbols-outlined text-border-dark group-hover:text-primary transition-colors">arrow_right_alt</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Pagination -->
      <div class="mt-16 flex justify-center">
        <div class="flex gap-2">
          <button class="w-10 h-10 rounded-xl bg-card-dark border border-border-dark text-text-muted flex items-center justify-center cursor-not-allowed opacity-50"><span class="material-symbols-outlined text-sm">chevron_left</span></button>
          <button class="w-10 h-10 rounded-xl bg-primary text-background-dark font-bold flex items-center justify-center">1</button>
          <button class="w-10 h-10 rounded-xl bg-card-dark hover:bg-border-dark border border-border-dark text-white transition-colors flex items-center justify-center">2</button>
          <button class="w-10 h-10 rounded-xl bg-card-dark hover:bg-border-dark border border-border-dark text-white transition-colors flex items-center justify-center">3</button>
          <button class="w-10 h-10 rounded-xl bg-card-dark hover:bg-border-dark border border-border-dark text-white transition-colors flex items-center justify-center"><span class="material-symbols-outlined text-sm">chevron_right</span></button>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
