# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ADMIN_EMAILS=admin@your-domain.com

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=your_public_url

# VAPID Keys for Push Notifications
# Generate these by running: node scripts/generate-vapid-keys.js
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@flyskyguitar.com

# Viettel Post API Configuration (for test-viettel-post.js)
# Required if you do NOT set VIETTEL_TOKEN directly:
VIETTEL_USERNAME=your_viettel_username
VIETTEL_PASSWORD=your_viettel_password

# Optional: if set, script will skip login and use this token directly
VIETTEL_TOKEN=your_viettel_token

# Recommended for create/update order tests
VIETTEL_CUSTOMER_ID=your_viettel_customer_id

# Optional: fallback order number for update/status tests when createOrder fails
VIETTEL_ORDER_NUMBER=

# Optional: UpdateOrder in Viettel partner UI updates order status, not the full order payload.
# Observed on this account: TYPE=1 approve, TYPE=4 cancel, TYPE=5 resend.
# Adjust TYPE to the status transition allowed by your account.
VIETTEL_UPDATE_ORDER_TYPE=1
VIETTEL_UPDATE_ORDER_NOTE=Ghi chu test tu script

# Optional: encryptLinkPrint uses a separate print token issued by Viettel.
VIETTEL_PRINT_TYPE=1
VIETTEL_PRINT_TOKEN=your_viettel_print_token

# Optional: ask Viettel to push the whole order journey back to your configured webhook.
VIETTEL_REGISTER_HOOK_MESSAGE=Re-sync order journey from test script

# Required for dedicated Viettel webhook endpoint at /api/webhooks/viettel-post
# Set this exact URL in Viettel Partner webhook configuration.
VIETTEL_WEBHOOK_URL=https://your-domain.com/api/webhooks/viettel-post
VIETTEL_WEBHOOK_SECRET=your_viettel_webhook_secret

# Optional: legacy endpoint. Keep false unless Viettel confirms getOrderStatus is enabled for your account.
VIETTEL_ENABLE_LEGACY_STATUS_TEST=false
